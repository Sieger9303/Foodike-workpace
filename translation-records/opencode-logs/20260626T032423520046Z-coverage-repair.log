    match (contentRepository.getRestaurantByName(restaurantName)) {\n38:                 case Some(restaurant) => return restaurant\n39:                 case None => return contentRepository.getRestaurants()[0]\n40:             }\n41:         }\n42:         return contentRepository.getRestaurants()[0]\n43:     }\n44: \n45:     public func recommendedItems(menuItems: ArrayList<DetailMenuItemData>): ArrayList<DetailMenuItemData> {\n46:         let recommended = ArrayList<DetailMenuItemData>([])\n47:         var index: Int64 = 0\n48:         for (item in menuItems) {\n49:             if (index < 5) {\n50:                 recommended.add(item)\n51:             }\n52:             index += 1\n53:         }\n54:         return recommended\n55:     }\n56: \n57:     public func nonVegItems(menuItems: ArrayList<DetailMenuItemData>): ArrayList<DetailMenuItemData> {\n58:         let filtered = ArrayList<DetailMenuItemData>([])\n59:         for (item in menuItems) {\n60:             if (!item.menuItem.isVegetarian) {\n61:                 filtered.add(item)\n62:             }\n63:         }\n64:         return filtered\n65:     }\n66: \n67:     public func vegItems(menuItems: ArrayList<DetailMenuItemData>): ArrayList<DetailMenuItemData> {\n68:         let filtered = ArrayList<DetailMenuItemData>([])\n69:         for (item in menuItems) {\n70:             if (item.menuItem.isVegetarian) {\n71:                 filtered.add(item)\n72:             }\n73:         }\n74:         return filtered\n75:     }\n76: \n77:     public func incrementQuantity(item: DetailMenuItemData): Unit {\n78:         item.quantity += 1\n79:     }\n80: \n81:     public func decrementQuantity(item: DetailMenuItemData): Unit {\n82:         if (item.quantity > 0) {\n83:             item.quantity -= 1\n84:         }\n85:     }\n86: \n87:     public func totalSelectedItems(menuItems: ArrayList<DetailMenuItemData>): Int64 {\n88:         var total: Int64 = 0\n89:         for (item in menuItems) {\n90:             total += item.quantity\n91:         }\n92:         return total\n93:     }\n94: \n95:     public func shouldShowCartAction(menuItems: ArrayList<DetailMenuItemData>): Bool {\n96:         return totalSelectedItems(menuItems) > 0\n97:     }\n98: \n99:     public func toggleLiked(restaurant: RestaurantData, currentValue: Bool): Bool {\n100:         let nextValue = !currentValue\n101:         sessionRepository.setRestaurantLiked(restaurant, nextValue)\n102:         return nextValue\n103:     }\n104: \n105:     public func formatPrice(price: Float64): String {\n106:         return \"$${price}\"\n107:     }\n108: \n109:     public func formatRatingCount(ratingCount: Int64): String {\n110:         return \"${ratingCount} ratings\"\n111:     }\n112: \n113:     public func formatRestaurantMeta(restaurant: RestaurantData): String {\n114:         return \"${restaurant.rating}(${customerCount(restaurant.ratingCount)}) · ${restaurant.etaMinutes} Min · $${restaurant.averagePrice}\"\n115:     }\n116: \n117:     public func customerCount(ratingCount: Int64): String {\n118:         if (ratingCount >= 1000) {\n119:             return \"1000+\"\n120:         }\n121:         if (ratingCount >= 100) {\n122:             return \"${ratingCount}+\"\n123:         }\n124:         return \"${ratingCount}\"\n125:     }\n126: \n127:     public func session(): SessionRepository {\n128:         return sessionRepository\n129:     }\n130: }\n\n(End of file - total 130 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\npublic let detailStore = DetailStore()\n\npublic class DetailStore {\n    private let contentRepository = HomeContentRepository()\n  