       \"archivedPhaseGate\",\n1066:           \"coverageGap\",\n1067:           \"currentPhaseGate\"\n1068:         ],\n1069:         \"phases\": [],\n1070:         \"sourcePaths\": [],\n1071:         \"targetEndpoints\": [],\n1072:         \"findingKinds\": [\n1073:           \"phase-gate-open-entry\",\n1074:           \"coverage-matrix-uncovered-entry\"\n1075:         ],\n1076:         \"featureIds\": [],\n1077:         \"capabilityIds\": [],\n1078:         \"groupCount\": 3,\n1079:         \"itemCount\": 3,\n1080:         \"groupIds\": [\n1081:           \"finding-archivedphasegate-phase-gate-open-entry\",\n1082:           \"finding-coveragegap-coverage-matrix-uncovered-entry\",\n1083:           \"finding-currentphasegate-phase-gate-open-entry\"\n1084:         ],\n1085:         \"evidence\": {\n1086:           \"byRepairMode\": {\n1087:             \"implement-or-evidence\": 3\n1088:           },\n1089:           \"byProblemType\": {\n1090:             \"report-finding\": 3\n1091:           },\n1092:           \"sampleGroups\": [\n1093:             \"phase-gate-open-entry (archivedPhaseGate)\",\n1094:             \"coverage-matrix-uncovered-entry (coverageGap)\",\n1095:             \"phase-gate-open-entry (currentPhaseGate)\"\n1096:           ]\n1097:         },\n1098:         \"suggestedHandling\": \"Treat this as the prompt-facing parent cluster. Sweep every child group listed in groupIds; use the child group items in translation-quality-summary.json for exact feature, capability, source path, endpoint, and evidence details.\",\n1099:         \"blockerPolicy\": \"If a child group is blocked by platform/product/tooling limits, record that blocker precisely and continue to the next child group instead of stopping the whole cluster.\"\n1100:       },\n1101:       {\n1102:         \"clusterId\": \"cluster-report-finding-whole-project-implement-or-structure\",\n1103:         \"title\": \"Whole-project findings: implement-or-structure\",\n1104:         \"clusterKind