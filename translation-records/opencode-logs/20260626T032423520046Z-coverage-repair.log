alEvidence\": [],\n240:         },\n241:         \"factsSource\": facts_source,\n242:     }\n243:     return copy.deepcopy(facts)\n244: \n245: \n246: def default_capability_facts(*, facts_source: str = \"template\") -> dict[str, Any]:\n247:     \"\"\"Return a fresh default platform capability fact object.\"\"\"\n248: \n249:     facts = {\n250:         \"schemaVersion\": FACTS_SCHEMA_VERSION,\n251:         \"resolutionKind\": \"open\",\n252:         \"activeFallback\": {\n253:             \"used\": False,\n254:             \"fallbackKind\": \"\",\n255:             \"reason\": \"\",\n256:             \"blocker\": \"\",\n257:         },\n258:         \"apiEvidence\": [],\n259:         \"discoveryOnlyEvidence\": [],\n260:         \"compileProbeEvidence\": [],\n261:         \"targetEndpoints\": [],\n262:         \"blocker\": {\n263:             \"used\": False,\n264:             \"kind\": \"\",\n265:             \"detail\": \"\",\n266:             \"futureCompletionPath\": \"\",\n267:         },\n268:         \"factsSource\": facts_source,\n269:     }\n270:     return copy.deepcopy(facts)\n271: \n272: \n273: def _text_items(value: Any) -> list[str]:\n274:     if isinstance(value, list):\n275:         return [str(item).strip() for item in value if str(item or \"\").strip()]\n276:     if value in (None, \"\"):\n277:         return []\n278:     text = str(value).strip()\n279:     return [text] if text else []\n280: \n281: \n282: def _first_text(*values: Any) -> str:\n283:     for value in values:\n284:         items = _text_items(value)\n285:         if items:\n286:             return items[0]\n287:     return \"\"\n288: \n289: \n290: def _normalized_text(*values: Any) -> str:\n291:     return \" \".join(item.lower() for value in values for item in _text_items(value))\n292: \n293: \n294: def _evidence_items(value: Any, *, kind: str) -> list[dict[str, str]]:\n295:     result: list[dict[str, str]] = []\n296:     for text in _text_items(value):\n297:         item: dict[str, st