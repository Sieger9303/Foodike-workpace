n58:     /**\n59:      * Compares this ButtonType with another for equality.\n60:      *\n61:      * @param { ButtonType } - The ButtonType to compare with.\n62:      * @returns { Bool } True if both modes are equal, false otherwise.\n63:      */\n64:     @!APILevel[\n65:         since: \"22\",\n66:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n67:     ]\n68:     public operator func ==(other: ButtonType): Bool\n69:     /**\n70:      * Compares this ButtonType with another for equality.\n71:      *\n72:      * @param { ButtonType } - The ButtonType to compare with.\n73:      * @returns { Bool } True if both modes are not equal, false otherwise.\n74:      */\n75:     @!APILevel[\n76:         since: \"22\",\n77:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n78:     ]\n79:     public operator func !=(other: ButtonType): Bool\n80: }\n81: \n82: /**\n83:  * Enum for button role.\n84:  */\n85: @!APILevel[\n86:     since: \"22\",\n87:     syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n88: ]\n89: public enum ButtonRole {\n90:     /**\n91:      * Normal button.\n92:      */\n93:     @!APILevel[\n94:         since: \"22\",\n95:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n96:     ]\n97:     Normal\n98:     | \n99:     /**\n100:      * Error button.\n101:      */\n102:     @!APILevel[\n103:         since: \"22\",\n104:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n105:     ]\n106:     Error\n107:     | ...\n108: }\n109: \n110: extend ButtonRole <: Equatable<ButtonRole> {\n111:     /**\n112:      * Compares this ButtonRole with another for equality.\n113:      *\n114:      * @param { ButtonRole } - The ButtonRole to compare with.\n115:      * @returns { Bool } True if both modes are equal, false otherwise.\n116:      */\n117:     @!APILevel[\n118:         since: \"22\",\n119:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n120:     ]\n121:     public operator func ==(other: ButtonRole): Bool\n122:     /**\n123:      * Compares this ButtonRole with another for equality.\n124:      *\n125:      * @param { ButtonRole } - The ButtonRole to compare with.\n126:      * @returns { Bool } True if both modes are not equal, false otherwise.\n127:      */\n128:     @!APILevel[\n129:         since: \"22\",\n130:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n131:     ]\n132:     public operator func !=(other: ButtonRole): Bool\n133: }\n134: \n135: /**\n136:  * Enum for button style type.\n137:  */\n138: @!APILevel[\n139:     since: \"22\",\n140:     syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n141: ]\n142: public enum ButtonStyleMode {\n143:     /**\n144:      * Normal button (with normal background color).\n145:      */\n146:     @!APILevel[\n147:         since: \"22\",\n148:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n149:     ]\n150:     Normal\n151:     | \n152:     /**\n153:      * Emphasized button (with emphasized background color).\n154:      */\n155:     @!APILevel[\n156:         since: \"22\",\n157:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n158:     ]\n159:     Emphasized\n160:     | \n161:     /**\n162:      * Textual button (with none background color).\n163:      */\n164:     @!APILevel[\n165:         since: \"22\",\n166:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n167:     ]\n168:     Textual\n169:     | ...\n170: }\n171: \n172: extend ButtonStyleMode <: Equatable<ButtonStyleMode> {\n173:     /**\n174:      * Compares this ButtonStyleMode with another for equality.\n175:      *\n176:      * @param { ButtonStyleMode } - The ButtonStyleMode to compare with.\n177:      * @returns { Bool } True if both modes are equal, false otherwise.\n178:      */\n179:     @!APILevel[\n180:         since: \"22\",\n181:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n182:     ]\n183:     public operator func ==(other: ButtonStyleMode): Bool\n184:     /**\n185:      * Compares this ButtonStyleMode with another for equality.\n186:      *\n187:      * @param { ButtonStyleMode } - The ButtonStyleMode to compare with.\n188:      * @returns { Bool } True if both modes are not equal, false otherwise.\n189:      */\n190:     @!APILevel[\n191:         since: \"22\",\n192:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n193:     ]\n194:     public operator func !=(other: ButtonStyleMode): Bool\n195: }\n196: \n197: /**\n198:  * Defines the button options.\n199:  */\n200: @!APILevel[\n201:     since: \"22\",\n202:     syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n203: ]\n204: public class ButtonOptions {\n205:     /**\n206:      * Describes the button style.\n207:      */\n208:     @!APILevel[\n209:         since: \"22\",\n210:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n211:     ]\n212:     public var shape: ?ButtonType\n213: \n214:     /**\n215:      * Indicates whether to enable the switchover effect when the button is pressed. When the status is set to false, the switchover effect is disabled.\n216:      * @default true\n217:      */\n218:     @!APILevel[\n219:         since: \"22\",\n220:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n\n(Showing lines 1-220 of 551. Use offset=221 to continue.)\n</content>","metadata":{"preview":"package ohos.arkui.component.button\n\nimport ohos.arkui.component.common.*\nimport ohos.arkui.component.native_struct.*\nimport ohos.arkui.component.util.*\nimport ohos.base.*\nimport ohos.labels.APILevel\nimport ohos.resource.*\nimport std.deriving.Derive\n\n/**\n * Provides a button component.\n */\n@!APILevel[\n    since: \"22\",\n    syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n]\npublic enum ButtonType {\n    /**\n     * Common button (no rounded corners by default).","truncated":true,"loaded":[]},"title":"C:\\Users\\Sieger\\.cangjie-sdk\\6.1\\cangjie\\api\\modules\\linux_ohos_aarch64_cjnative\\ohos\\ohos.arkui.component.button.cj.d","time":{"start":1782370587856,"end":1782370587862}},"id":"prt_efd90d48700aP2dk5h7WBOYKod","sessionID":"ses_102718fc5ffeKX5hudaWeJGgV5","mess