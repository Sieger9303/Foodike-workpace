{"type":"tool_use","timestamp":1782370587940,"sessionID":"ses_102718fc5ffeKX5hudaWeJGgV5","part":{"type":"tool","tool":"read","callID":"call_fo59Mp8Nt6MQagjKd2apFeMx","state":{"status":"completed","input":{"filePath":"C:\\Users\\Sieger\\.cangjie-sdk\\6.1\\cangjie\\api\\modules\\linux_ohos_aarch64_cjnative\\ohos\\ohos.arkui.component.text_input.cj.d","offset":1,"limit":260},"output":"<path>C:\\Users\\Sieger\\.cangjie-sdk\\6.1\\cangjie\\api\\modules\\linux_ohos_aarch64_cjnative\\ohos\\ohos.arkui.component.text_input.cj.d</path>\n<type>file</type>\n<content>\n1: package ohos.arkui.component.text_input\n2: \n3: import ohos.arkui.component.common.*\n4: import ohos.arkui.component.text_field.*\n5: import ohos.arkui.component.util.*\n6: import ohos.base.*\n7: import ohos.ffi.*\n8: import ohos.labels.APILevel\n9: import ohos.resource.*\n10: \n11: /**\n12:  * Provides the method of switching the cursor position.\n13:  */\n14: @!APILevel[\n15:     since: \"22\",\n16:     syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n17: ]\n18: public class TextInputController <: RemoteDataLite {\n19:     /**\n20:      * TextInputController constructor.\n21:      */\n22:     @!APILevel[\n23:         since: \"22\",\n24:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n25:     ]\n26:     public init()\n27: \n28:     /**\n29:      * Called when the position of the insertion cursor is set.\n30:      *\n31:      * NOTE:\n32:      * If the value is less than 0, the value 0 is used.\n33:      * If the value exceeds the text length, the caret is placed at the end of the text.\n34:      *\n35:      * @param { ?Int32 } value\n36:      */\n37:     @!APILevel[\n38:         since: \"22\",\n39:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n40:     ]\n41:     public func caretPosition(value: ?Int32): Unit\n42: \n43:     /**\n44:      * Text selection is achieved by specifying the start and end positions of the text.\n45:      *\n46:      * NOTE:\n47:      * If selectionStart or selectionEnd is set to None, the value 0 will be used.\n48:      * If selectionMenuHidden is set to true or a 2-in-1 device is used,\n49:      * calling setTextSelection does not display the context menu even when options is set to MenuPolicy.SHOW.\n50:      * If the selected text contains an emoji,\n51:      * the emoji is selected when its start position is within the text selection range.\n52:      *\n53:      * @param { ?Int32 } selectionStart - The start position of the selected text.The start position of text in the text box is 0.\n54:      * @param { ?Int32 } selectionEnd - The end position of the selected text.\n55:      * @param { ?MenuPolicy } [options] - Indicates the options of the text selection.Default value is MenuPolicy.DEFAULT.\n56:      */\n57:     @!APILevel[\n58:         since: \"22\",\n59:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n60:     ]\n61:     public func setTextSelection(selectionStart: ?Int32, selectionEnd: ?Int32, options!: ?MenuPolicy = None): Unit\n62: \n63:     /**\n64:      * Exit edit state.\n65:      */\n66:     @!APILevel[\n67:         since: \"22\",\n68:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n69:     ]\n70:     public func stopEditing(): Unit\n71: }\n72: \n73: /**\n74:  * Defines TextInput Component.\n75:  */\n76: @!APILevel[\n77:     since: \"22\",\n78:     syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n79: ]\n80: public class TextInput <: CommonMethodComponent<TextInput> & TextInputAttribute {\n81:     /**\n82:      * Called when writing a single line of text.\n83:      *\n84:      * @param { ?ResourceStr } [placeholder] - The place holder text string.\n85:      * @param { ?ResourceStr } [text] - Sets the current value of TextInput.\n86:      * @param { ?TextInputController } [controller] - Called when the position of the insertion cursor is set.\n87:      */\n88:     @!APILevel[\n89:         since: \"22\",\n90:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n91:     ]\n92:     public init(placeholder!: ?ResourceStr = None, text!: ?ResourceStr = None, controller!: ?TextInputController = None)\n93: \n94:     /**\n95:      * Called when the type of soft keyboard input button is set\n96:      *\n97:      * @param { ?EnterKeyType } value - Default value is EnterKeyType.Done.\n98:      * @returns { This } returns the instance of the TextInput.\n99:      */\n100:     @!APILevel[\n101:         since: \"22\",\n102:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n103:     ]\n104:     public func enterKeyType(value: ?EnterKeyType): This\n105: \n106:     /**\n107:      * Called when the text align is set. NOTE: Available options are TextAlign.Start, TextAlign.Center, and TextAlign.End. To set vertical alignment for the text, use the align attribute. The align attribute alone does not control the horizontal position of the text. In other words, Alignment.TopStart, Alignment.Top, and Alignment.TopEnd produce the same effect, top-aligning the text; Alignment.Start, Alignment.Center, and Alignment.End produce the same effect, centered-aligning the text vertically; Alignment.BottomStart, Alignment.Bottom, and Alignment.BottomEnd produce the same effect, bottom-aligning the text\n108:      *\n109:      * @param { ?TextAlign } value - Default value is TextAlign.Start.\n110:      * @returns { This } returns the instance of the TextInput.\n111:      */\n112:     @!APILevel[\n113:         since: \"22\",\n114:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n115:     ]\n116:     public func textAlign(value: ?TextAlign): This\n117: \n118:     /**\n119:      * Called when the color of the placeholder is set\n120:      *\n121:      * @param { ?ResourceColor } value - Default value follows the theme. The default value on wearable devices is 0x99ffffff.\n122:      * @returns { This } returns the instance of the TextInput.\n123:      */\n124:     @!APILevel[\n125:         since: \"22\",\n126:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n127:     ]\n128:     public func placeholderColor(value: ?ResourceColor): This\n129: \n130:     /**\n131:      * Called when the color of the insertion cursor is set.\n132:      *\n133:      * @param { ?ResourceColor } value - Default value is 0x007DFF.\n134:      * @returns { This } returns the instance of the TextInput.\n135:      */\n136:     @!APILevel[\n137:         since: \"22\",\n138:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n139:     ]\n140:     public func caretColor(value: ?ResourceColor): This\n141: \n142:     /**\n143:      * Called when the font property of the placeholder is set. The 'HarmonyOS Sans' font and registered custom fonts are supported\n144:      *\n145:      * @param { ?Length } size - The font size of the placeholder.\n146:      * @param { ?FontWeight } [weight] - The font weight of the placeholder.\n147:      * @param { ?String } [family] - The font family of the placeholder.\n148:      * @param { ?FontStyle } [style] - The font style of the placeholder.\n149:      * @returns { This } returns the instance of the TextInput.\n150:      */\n151:     @!APILevel[\n152:         since: \"22\",\n153:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n154:     ]\n155:     public func placeholderFont(size!: ?Length, weight!: ?FontWeight = None, family!: ?String = None,\n156:         style!: ?FontStyle = None): This\n157: \n158:     /**\n159:      * Called when the input of maximum text length is set. NOTE: If this attribute is not set or is set to an invalid value, the default value is used. If a decimal number is specified, the integer part is used\n160:      *\n161:      * @param { ?UInt32 } value - Default value is Infinity, indicating that there is no upper limit on the number of characters that can be entered.\n162:      * @returns { This } returns the instance of the TextInput.\n163:      */\n164:     @!APILevel[\n165:         since: \"22\",\n166:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n167:     ]\n168:     public func maxLength(value: ?UInt32): This\n169: \n170:     /**\n171:      * Called when the font size is set. NOTE: If fontSize is of the number type, the unit fp is used. The default font size is 16 fp. The value cannot be a percentage. The default value on wearable devices is 18fp\n172:      *\n173:      * @param { ?Length } value - The font size.\n174:      * @returns { This } returns the instance of the TextInput.\n175:      */\n176:     @!APILevel[\n177:         since: \"22\",\n178:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n179:     ]\n180:     public func fontSize(value: ?Length): This\n181: \n182:     /**\n183:      * Sets the font color\n184:      *\n185:      * @param { ?ResourceColor } value - Default value is 0xe6182431.The default value on wearable devices is 0xc5ffffff.\n186:      * @returns { This } returns the instance of the TextInput.\n187:      */\n188:     @!APILevel[\n189:         since: \"22\",\n190:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n191:     ]\n192:     public func fontColor(value: ?ResourceColor): This\n193: \n194:     /**\n195:      * Called when the font weight is set\n196:      *\n197:      * @param { ?FontWeight } value - The font weight.\n198:      * @returns { This } returns the instance of the TextInput.\n199:      */\n200:     @!APILevel[\n201:         since: \"22\",\n202:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n203:     ]\n204:     public func fontWeight(value: ?FontWeight): This\n205: \n206:     /**\n207:      * Sets the font style\n208:      *\n209:      * @param { ?FontStyle } value - Font style.Default value: FontStyle.Normal\n210:      * @returns { This } returns the instance of the TextInput.\n211:      */\n212:     @!APILevel[\n213:         since: \"22\",\n214:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n215:     ]\n216:     public func fontStyle(value: ?FontStyle): This\n217: \n218:     /**\n219:      * Called when the font list of text is set. NOTE: Default font: 'HarmonyOS Sans' The 'HarmonyOS Sans' font and registered custom fonts are supported for applications. Only the 'HarmonyOS Sans' font is supported for widgets\n220:      *\n221:      * @param { ?ResourceStr } value - The font family resource.\n222:      * @returns { This } returns the instance of the TextInput.\n223:      */\n224:     @!APILevel[\n225:         since: \"22\",\n226:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n227:     ]\n228:     public func fontFamily(value: ?ResourceStr): This\n229: \n230:     /**\n231:      * Called when the inputFilter of text is set.\n232:      * NOTE: Only inputs that comply with the regular expression can be displayed.\n233:      * Other inputs are filtered out.\n234:      * The specified regular expression can match single characters, but not strings.\n235:      * if inputFilter is set and the entered characters are not null, the filtering effect attached to the text box type (specified through the type attribute) does not take effect.\n236:      *\n237:      * @param { ?ResourceStr } value - The input filter pattern.\n238:      * @param { ?(String) -> Unit } [error] - Callback function when input error occurs.\n239:      * @returns { This } returns the instance of the TextInput.\n240:      */\n241:     @!APILevel[\n242:         since: \"22\",\n243:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n244:     ]\n245:     public func inputFilter(value: ?ResourceStr, error!: ?(String) -> Unit = None): This\n246: \n247:     /**\n248:      * Called when submitted.\n249:      *\n250:      * @param { ?(EnterKeyType) -> Unit } callback - If it is EnterKeyType.NewLine and the text box is in inline input style, onSubmit is not triggered.\n251:      * @returns { This } returns the instance of the TextInput.\n252:      */\n253:     @!APILevel[\n254:         since: \"22\",\n255:         syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n256:     ]\n257:     public func onSubmit(callback: ?(EnterKeyType) -> Unit): This\n258: \n259:     /**\n260:      * Called when using the Clipboard menu.\n\n(Showing lines 1-260 of 778. Use offset=261 to continue.)\n</content>","metadata":{"preview":"package ohos.arkui.component.text_input\n\nimport ohos.arkui.component.common.*\nimport ohos.arkui.component.text_field.*\nimport ohos.arkui.component.util.*\nimport ohos.base.*\nimport ohos.ffi.*\nimport ohos.labels.APILevel\nimport ohos.resource.*\n\n/**\n * Provides the method of switching the cursor position.\n */\n@!APILevel[\n    since: \"22\",\n    syscap: \"SystemCapability.ArkUI.ArkUI.Full\"\n]\npublic class TextInputController <: RemoteDataLite {\n    /**\n     * TextInputController constructor.","truncated":true,"loaded":[]},"title":"C:\\Users\\Sieger\\.cangjie-sdk\\6.1\\cangjie\\api\\modules\\linux_ohos_aarch64_cjnative\\ohos\\ohos.arkui.component.text_input.cj.d","time":{"start":1782370587935,"end":1782370587940}},"id":"prt_efd90d4d2001L21FUkeqOGHjGK","sessionID":"ses_102718fc5ffeKX5hudaWeJGgV5","messageID":"msg_efd90969a001CXVQTuGqcHlAEx"}}
