dx.lifecycle.viewModelScope\n33: import com.example.foodike.domain.repository.LoginRepository\n34: import dagger.hilt.android.lifecycle.HiltViewModel\n35: import kotlinx.coroutines.flow.MutableSharedFlow\n36: import kotlinx.coroutines.flow.asSharedFlow\n37: import kotlinx.coroutines.launch\n38: import javax.inject.Inject\n39: \n40: \n41: @HiltViewModel\n42: class LoginViewModel @Inject constructor(\n43:     private val repository: LoginRepository\n44: ) : ViewModel() {\n45: \n46:     private val _email = mutableStateOf(\n47:         FoodikeTextFieldState(\n48:             hint = \"Enter email or phone number\"\n49:         )\n50:     )\n51:     val email: State<FoodikeTextFieldState> = _email\n52: \n53:     private val _password = mutableStateOf(\n54:         FoodikeTextFieldState(\n55:             hint = \"Password\"\n56:         )\n57:     )\n58:     val password: State<FoodikeTextFieldState> = _password\n59: \n60:     private val _eventFlow = MutableSharedFlow<UiEvent>()\n61:     val eventFlow = _eventFlow.asSharedFlow()\n62: \n63: \n64:     fun onEvent(event: LoginEvent) {\n65:         when (event) {\n66:             is LoginEvent.EnteredEmail -> {\n67:                 _email.value = email.value.copy(\n68:                     text = event.value\n69:                 )\n70: \n71:             }\n72:             is LoginEvent.EnteredPassword -> {\n73:                 _password.value = password.value.copy(\n74:                     text = event.value\n75:                 )\n76:             }\n77:             is LoginEvent.PerformLogin -> {\n78:                 if (email.value.text == \"abcxyz@gmail.com\" && password.value.text == \"abcdef\"){\n79:                   viewModelScope.launch  {\n80:                         repository.toggleLoginState()\n81:                         event.onClick()\n82:                     }\n83:                 }\n84:                 else {\n85:                     viewModelScope.launch{\n86:                         _eventFlow.emit(\n87:                             UiEvent.ShowSnackbar(\n88:                                 message = \"Please enter correct email and password\"\n89:                             )\n90:                         )\n91:                     }\n92:                 }\n93:             }\n94:         }\n95:     }\n96: }\n\n(End of file - total 96 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER","truncated":false,"loaded":[]},"title":"..\\..\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\login\\LoginViewModel.kt","time":{"start":1782370459760,"end":1782370459768}},"id":"prt_efd8ee061001ZH4Iu3kDxSp12Q","sessionID":"ses_102718fc5ffeKX5hudaWeJGgV5","messageID":"msg_efd8ec0530012I85ulRgyEEWqn"}}
