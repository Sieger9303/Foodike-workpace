am): Unit {\n+        Hilog.info(0x0000, \"Foodike\", \"EntryAbility created for ${want.abilityName}\")\n+        match (launchParam.launchReason) {\n+            case LaunchReason.StartAbility => Hilog.info(0x0000, \"Foodike\", \"Launcher startup request received\")\n+            case _ => ()\n+        }\n+    }\n+\n+    public override func onWindowStageCreate(windowStage: WindowStage): Unit {\n+        Hilog.info(0x0000, \"Foodike\", \"Loading Foodike bootstrap content\")\n+        windowStage.loadContent(\"FoodikeBootstrap\")\n+    }\n+}\n\nIndex: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\ability_stage.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\ability_stage.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\ability_stage.cj\n@@ -0,0 +1,10 @@\n+package ohos_app_cangjie_entry\n+\n+import kit.AbilityKit.AbilityStage\n+import kit.PerformanceAnalysisKit.Hilog\n+\n+class FoodikeAbilityStage <: AbilityStage {\n+    public override func onCreate(): Unit {\n+        Hilog.info(0x0000, \"Foodike\", \"Foodike ability stage created\")\n+    }\n+}\n\nIndex: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj\n@@ -0,0 +1,22 @@\n+package ohos_app_cangjie_entry\n+\n+import kit.ArkUI.Column\n+import kit.ArkUI.Row\n+import kit.ArkUI.Text\n+import ohos.arkui.state_macro_manage.Component\n+import ohos.arkui.state_macro_manage.Entry\n+\n+@Entry\n+@Component\n+class FoodikeBootstrap