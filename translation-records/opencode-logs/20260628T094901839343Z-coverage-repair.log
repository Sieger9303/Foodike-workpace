{"type":"tool_use","timestamp":1782640173338,"sessionID":"ses_0f25e1410ffe4A3n5zSwX8chJf","part":{"type":"tool","tool":"read","callID":"call_7oRprez9ihvv7mWmULVCnisb","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_page.cj","limit":360,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home\n2: \n3: import kit.ArkUI.*\n4: import ohos.arkui.state_macro_manage.Builder\n5: import ohos.base.ResourceStr\n6: import ohos.resource.AppResource\n7: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaChineseBowl, mediaClock, mediaGroceries, mediaIcProfile, mediaRider, mediaUpi, stringAllAroundYou, stringFromCreator, stringLocation, stringLove, stringOrderFromFavourites, stringRecommendedForYou, stringWith}\n8: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.{renderRestaurantCard, restaurantMedia, renderSearchBar}\n9: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n10: import std.collection.ArrayList\n11: \n12: private func homeMedia(name: String): AppResource {\n13:     match (name) {\n14:         case \"chinese_bowl\" => mediaChineseBowl\n15:         case \"rider\" => mediaRider\n16:         case \"groceries\" => mediaGroceries\n17:         case \"upi\" => mediaUpi\n18:         case _ => mediaClock\n19:     }\n20: }\n21: \n22: @Builder\n23: func buildHomeTopSection(onProfileClick: () -> Unit) {\n24:     Row {\n25:         Image(mediaIcProfile)\n26:             .width(36)\n27:             .height(36)\n28:             .borderRadius(18)\n29:             .onClick({ _ =>\n30:                 onProfileClick()\n31:             })\n32:         Row(space: 4) {\n33:             Text(stringLocation)\n34:                 .fontSize(14)\n35:                 .fontColor(Color.Gray)\n36:             Text(\"Guwahati\")\n37:                 .fontSize(16)\n38:                 .fontWeight(FontWeight.Medium)\n39:         }\n40:     }\n41:     .width(100.percent)\n42:     .justifyContent(FlexAlign.SpaceBetween)\n43:     .alignItems(VerticalAlign.Center)\n44: }\n45: \n46: @Builder\n47: func buildHomeGreeting(hour: Int64) {\n48:     Column(space: 2) {\n49:         Text(homeStore.greetingForHour(hour))\n50:             .fontSize(28)\n51:             .fontWeight(FontWeight.Regular)\n52:         Text(\"Andrew\")\n53:             .fontSize(28)\n54:             .fontWeight(FontWeight.Regular)\n55:     }\n56:     .width(100.percent)\n57: }\n58: \n59: @Builder\n60: func buildHomeSectionTitle(title: ResourceStr) {\n61:     Text(title)\n62:         .fontSize(20)\n63:         .fontWeight(FontWeight.Regular)\n64:         .width(100.percent)\n65: }\n66: \n67: @Builder\n68: func buildHomeAdCards(advertisements: ArrayList<AdvertisementData>) {\n69:     Scroll(Scroller()) {\n70:         Row(space: 12) {\n71:             ForEach(advertisements, itemGeneratorFunc: { advertisement: AdvertisementData, _: Int64 =>\n72:                 Row(space: 12) {\n73:                     Column(space: 8) {\n74:                         Text(advertisement.title)\n75:                             .fontSize(22)\n76:                             .fontWeight(FontWeight.Bold)\n77:                         Text(advertisement.subtitle)\n78:                             .fontSize(13)\n79:                     }\n80:                     .layoutWeight(1)\n81:                     Image(homeMedia(advertisement.mediaName))\n82:                         .width(92)\n83:                         .height(92)\n84:                 }\n85:                 .width(260)\n86:                 .padding(top: 16, right: 16, bottom: 16, left: 16)\n87:                 .backgroundColor(0xFFF4F4F4)\n88:                 .borderRadius(20)\n89:             })\n90:         }\n91:     }\n92:     .scrollable(ScrollDirection.Horizontal)\n93:     .scrollBar(BarState.Off)\n94:     .width(100.percent)\n95:     .height(140)\n96: }\n97: \n98: @Builder\n99: func buildRecommendedCategories(categories: ArrayList<FoodCategoryData>) {\n100:     Scroll(Scroller()) {\n101:         Row(space: 16) {\n102:             ForEach(categories, itemGeneratorFunc: { category: FoodCategoryData, _: Int64 =>\n103:                 Column(space: 8) {\n104:                     Image(restaurantMedia(category.mediaName))\n105:                         .width(80)\n106:                         .height(80)\n107:                         .borderRadius(40)\n108:                     Text(category.name)\n109:                         .fontSize(14)\n110:                 }\n111:                 .alignItems(HorizontalAlign.Center)\n112:             })\n113:         }\n114:     }\n115:     .scrollable(ScrollDirection.Horizontal)\n116:     .scrollBar(BarState.Off)\n117:     .width(100.percent)\n118:     .height(120)\n119: }\n120: \n121: @Builder\n122: func buildFavouriteStrip(favourites: ArrayList<RestaurantData>, onSelectRestaurant: (RestaurantData) -> Unit) {\n123:     if (favourites.size > 0) {\n124:         Column(space: 10) {\n125:             buildHomeSectionTitle(stringOrderFromFavourites)\n126:             Scroll(Scroller()) {\n127:                 Row(space: 12) {\n128:                     ForEach(favourites, itemGeneratorFunc: { restaurant: RestaurantData, _: Int64 =>\n129:                         Column(space: 8) {\n130:                             Image(restaurantMedia(restaurant.mediaName))\n131:                                 .width(98)\n132:                                 .height(128)\n133:                                 .borderRadius(12)\n134:                             Text(restaurant.name)\n135:                                 .fontSize(14)\n136:                         }\n137:                         .width(110)\n138:                         .alignItems(HorizontalAlign.Center)\n139:                         .onClick({ _ =>\n140:                             onSelectRestaurant(restaurant)\n141:                         })\n142:                     })\n143:                 }\n144:             }\n145:             .scrollable(ScrollDirection.Horizontal)\n146:             .scrollBar(BarState.Off)\n147:             .width(100.percent)\n148:             .height(170)\n149:         }\n150:     }\n151: }\n152: \n153: @Builder\n154: func buildFilterRow(selectedFilter: String, onToggleFilter: (String) -> Unit) {\n155:     Scroll(Scroller()) {\n156:         Row(space: 8) {\n157:             ForEach(homeStore.filtersList(), itemGeneratorFunc: { filterName: String, _: Int64 =>\n158:                 Text(filterName)\n159:                     .fontSize(14)\n160:                     .fontColor(if (selectedFilter == filterName) { Color.White } else { Color.Black })\n161:                     .padding(top: 8, right: 12, bottom: 8, left: 12)\n162:                     .backgroundColor(if (selectedFilter == filterName) { 0xFF228D39 } else { Color.White })\n163:                     .borderRadius(16)\n164:                     .border(width: 1.px, color: 0x55000000)\n165:                     .onClick({ _ =>\n166:                         onToggleFilter(filterName)\n167:                     })\n168:             })\n169:         }\n170:     }\n171:     .scrollable(ScrollDirection.Horizontal)\n172:     .scrollBar(BarState.Off)\n173:     .width(100.percent)\n174:     .height(48)\n175: }\n176: \n177: @Builder\n178: func buildRestaurantList(restaurants: ArrayList<RestaurantData>, onSelectRestaurant: (RestaurantData) -> Unit) {\n179:     Column(space: 10) {\n180:         ForEach(restaurants, itemGeneratorFunc: { restaurant: RestaurantData, _: Int64 =>\n181:             renderRestaurantCard(restaurant, { =>\n182:                 onSelectRestaurant(restaurant)\n183:             })\n184:         })\n185:     }\n186:     .width(100.percent)\n187: }\n188: \n189: @Builder\n190: func buildHomeFooter() {\n191:     Row(space: 6) {\n192:         Text(stringWith)\n193:             .fontSize(24)\n194:             .fontColor(Color.Gray)\n195:         Text(stringLove)\n196:             .fontSize(24)\n197:             .fontColor(Color.Red)\n198:         Text(stringFromCreator)\n199:             .fontSize(24)\n200:             .fontColor(Color.Gray)\n201:     }\n202:     .width(100.percent)\n203:     .justifyContent(FlexAlign.Center)\n204: }\n205: \n206: @Builder\n207: public func renderHomeRoute(\n208:     state: HomePageState,\n209:     hour: Int64,\n210:     query: String,\n211:     selectedFilter: String,\n212:     onQueryChange: (String) -> Unit,\n213:     onToggleFilter: (String) -> Unit,\n214:     onProfileClick: () -> Unit,\n215:     onSelectRestaurant: (RestaurantData) -> Unit\n216: ) {\n217:     Scroll(Scroller()) {\n218:         Column(space: 18) {\n219:             buildHomeTopSection(onProfileClick)\n220:             buildHomeGreeting(hour)\n221:             renderSearchBar(query, onQueryChange)\n222:             buildHomeAdCards(state.advertisements)\n223:             buildHomeSectionTitle(stringRecommendedForYou)\n224:             buildRecommendedCategories(state.categories)\n225:             buildFavouriteStrip(state.favourites, onSelectRestaurant)\n226:             buildFilterRow(selectedFilter, onToggleFilter)\n227:             buildHomeSectionTitle(stringAllAroundYou)\n228:             buildRestaurantList(state.restaurants, onSelectRestaurant)\n229:             buildHomeFooter()\n230:         }\n231:         .width(100.percent)\n232:         .padding(top: 12, right: 16, bottom: 24, left: 16)\n233:     }\n234:     .scrollable(ScrollDirection.Vertical)\n235:     .scrollBar(BarState.Off)\n236:     .width(100.percent)\n237:     .height(100.percent)\n238:     .backgroundColor(Color.White)\n239: }\n\n(End of file - total 239 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos.base.ResourceStr\nimport ohos.resource.AppResource\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaChineseBowl, mediaClock, mediaGroceries, mediaIcProfile, mediaRider, mediaUpi, stringAllAroundYou, stringFromCreator, stringLocation, stringLove, stringOrderFromFavourites, stringRecommendedForYou, stringWith}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.{renderRestaurantCard, restaurantMedia, renderSearchBar}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\nprivate func homeMedia(name: String): AppResource {\n    match (name) {\n        case \"chinese_bowl\" => mediaChineseBowl\n        case \"rider\" => mediaRider\n        case \"groceries\" => mediaGroceries\n        case \"upi\" => mediaUpi\n        case _ => mediaClock\n    }\n}","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_page.cj","time":{"start":1782640173300,"end":1782640173337}},"id":"prt_f0da260f00017sAKziUmWtzhHf","sessionID":"ses_0f25e1410ffe4A3n5zSwX8chJf","messageID":"msg_f0da224ac001ckGq4oZ3BJEI23"}}
{"type":"tool_use","timestamp":1782640173340,"sessionID":"ses_0f25e1410ffe4A3n5zSwX8chJf","part":{"type":"tool","tool":"read","callID":"call_mddGLnEekIxL4Yj2itHnzH47","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_store.cj","limit":360,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_store.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home\n2: \n3: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.homeContentRepository\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n6: import std.collection.ArrayList\n7: import std.unicode.*\n8: \n9: public let homeStore = HomeStore()\n10: \n11: public class HomeStore {\n12:     private let contentRepository = homeContentRepository\n13:     private let sessionRepository = sessionRepository\n14:     private let filters = ArrayList<String>([\n15:         \"Fast Delivery\",\n16:         \"50% Discount\",\n17:         \"Great deals\",\n18:         \"Non-Veg\"\n19:     ])\n20: \n21:     public init() {}\n22: \n23:     public func loadAdvertisements(): ArrayList<AdvertisementData> {\n24:         return contentRepository.getAds()\n25:     }\n26: \n27:     public func loadRecommendedCategories(): ArrayList<FoodCategoryData> {\n28:         return contentRepository.getFoodItems()\n29:     }\n30: \n31:     public func loadFavouriteRestaurants(): ArrayList<RestaurantData> {\n32:         return sessionRepository.getLikedRestaurants()\n33:     }\n34: \n35:     public func loadRestaurantCatalog(): ArrayList<RestaurantData> {\n36:         return contentRepository.getRestaurants()\n37:     }\n38: \n39:     public func loadHomeState(): HomePageState {\n40:         return HomePageState(\n41:             loadAdvertisements(),\n42:             loadRecommendedCategories(),\n43:             loadFavouriteRestaurants(),\n44:             loadRestaurantCatalog()\n45:         )\n46:     }\n47: \n48:     public func buildVisibleState(query: String): HomePageState {\n49:         let state = loadHomeState()\n50:         if (query == \"\") {\n51:             return state\n52:         }\n53:         return HomePageState(\n54:             state.advertisements,\n55:             state.categories,\n56:             filterRestaurants(state.favourites, query),\n57:             filterRestaurants(state.restaurants, query)\n58:         )\n59:     }\n60: \n61:     public func buildFilteredState(query: String, selectedFilter: String): HomePageState {\n62:         let state = buildVisibleState(query)\n63:         if (selectedFilter == \"\") {\n64:             return state\n65:         }\n66:         return HomePageState(\n67:             state.advertisements,\n68:             state.categories,\n69:             filterByTag(state.favourites, selectedFilter),\n70:             filterByTag(state.restaurants, selectedFilter)\n71:         )\n72:     }\n73: \n74:     public func filtersList(): ArrayList<String> {\n75:         return filters\n76:     }\n77: \n78:     public func toggleFilter(currentFilter: String, tappedFilter: String): String {\n79:         if (currentFilter == tappedFilter) {\n80:             return \"\"\n81:         }\n82:         return tappedFilter\n83:     }\n84: \n85:     public func greetingForHour(hour: Int64): String {\n86:         if (hour >= 0 && hour <= 11) {\n87:             return \"Good Morning!\"\n88:         }\n89:         if (hour >= 12 && hour <= 15) {\n90:             return \"Good Afternoon!\"\n91:         }\n92:         return \"Good Evening!\"\n93:     }\n94: \n95:     public func selectRestaurant(restaurant: RestaurantData, onNavigate: () -> Unit): Unit {\n96:         sessionRepository.setSelectedRestaurant(restaurant)\n97:         onNavigate()\n98:     }\n99: \n100:     private func filterRestaurants(restaurants: ArrayList<RestaurantData>, query: String): ArrayList<RestaurantData> {\n101:         let filtered = ArrayList<RestaurantData>([])\n102:         for (restaurant in restaurants) {\n103:             if (matchesQuery(restaurant, query)) {\n104:                 filtered.add(restaurant)\n105:             }\n106:         }\n107:         return filtered\n108:     }\n109: \n110:     public func filterByTag(restaurants: ArrayList<RestaurantData>, tag: String): ArrayList<RestaurantData> {\n111:         let filtered = ArrayList<RestaurantData>([])\n112:         for (restaurant in restaurants) {\n113:             if (matchesTag(restaurant, tag)) {\n114:                 filtered.add(restaurant)\n115:             }\n116:         }\n117:         return filtered\n118:     }\n119: \n120:     private func matchesQuery(restaurant: RestaurantData, query: String): Bool {\n121:         return containsIgnoreCase(restaurant.name, query)\n122:             || containsIgnoreCase(restaurant.variety, query)\n123:             || containsIgnoreCase(restaurant.place, query)\n124:     }\n125: \n126:     public func matchesTag(restaurant: RestaurantData, tag: String): Bool {\n127:         match (tag) {\n128:             case \"Fast Delivery\" => restaurant.etaMinutes <= 30\n129:             case \"50% Discount\" => restaurant.averagePrice <= 2.5\n130:             case \"Great deals\" => restaurant.rating >= 4.5\n131:             case \"Non-Veg\" => !containsIgnoreCase(restaurant.variety, \"Vegetarian\")\n132:             case _ => true\n133:         }\n134:     }\n135: \n136:     public func containsIgnoreCase(source: String, query: String): Bool {\n137:         let normalizedSource = source.toLower()\n138:         let normalizedQuery = query.toLower()\n139:         let sourceLength = normalizedSource.size\n140:         let queryLength = normalizedQuery.size\n141:         if (queryLength == 0) {\n142:             return true\n143:         }\n144:         if (queryLength > sourceLength) {\n145:             return false\n146:         }\n147:         var start: Int64 = 0\n148:         while (start + queryLength <= sourceLength) {\n149:             if (normalizedSource[start..(start + queryLength)] == normalizedQuery) {\n150:                 return true\n151:             }\n152:             start += 1\n153:         }\n154:         return false\n155:     }\n156: \n157:     public func session(): SessionRepository {\n158:         return sessionRepository\n159:     }\n160: }\n\n(End of file - total 160 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.homeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\nimport std.unicode.*\n\npublic let homeStore = HomeStore()\n\npublic class HomeStore {\n    private let contentRepository = homeContentRepository\n    private let sessionRepository = sessionRepository\n    private let filters = ArrayList<String>([\n        \"Fast Delivery\",\n        \"50% Discount\",\n        \"Great deals\",\n        \"Non-Veg\"\n    ])\n","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_store.cj","time":{"start":1782640173305,"end":1782640173339}},"id":"prt_f0da260f5001wi9EV3k2rvCVJ6","sessionID":"ses_0f25e1410ffe4A3n5zSwX8chJf","messageID":"msg_f0da224ac001ckGq4oZ3BJEI23"}}
