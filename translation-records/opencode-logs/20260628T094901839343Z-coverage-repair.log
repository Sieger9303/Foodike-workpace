lue)\n593: \n594:     for field, values in append_values.items():\n595:         if field not in list_fields:\n596:             raise PatchError(f\"Append is allowed only for list fields; `{field}` is not appendable.\")\n597:         values = validate_field_value(kind, field, values)\n598:         existing = entry.get(field, [])\n599:         if not isinstance(existing, list):\n600:             raise PatchError(f\"Cannot append to `{field}` because the current value is not a list.\")\n601:         entry[field] = append_unique(existing, values)\n602: \n603:     for field, values in remove_values.items():\n604:         if field not in list_fields:\n605:             raise PatchError(f\"Remove is allowed only for list fields; `{field}` is not removable.\")\n606:         values = validate_field_value(kind, field, values)\n607:         existing = entry.get(field, [])\n608:         if not isinstance(existing, list):\n609:             raise PatchError(f\"Cannot remove from `{field}` because the current value is not a list.\")\n610:         remove_keys = {canonical_json(value) for value in values}\n611:         entry[field] = [value for value in existing if canonical_json(value) not in remove_keys]\n612: \n613:     update_fields, _, _, _ = field_sets(kind)\n614:     for field in unset_fields:\n615:         if not isinstance(field, str):\n616:             raise PatchError(\"Every `unset` item must be a string field name.\")\n617:         if field not in update_fields:\n618:             raise PatchError(f\"Field `{field}` is not writable for {kind} authority patches.\")\n619:         if field in list_fields:\n620:             entry[field] = []\n621:         elif field in object_fields(kind):\n622:             entry[field] = default_object_value(kind, field)\n623:         else:\n624:             entry[field] = \"\"\n625:         if field in text_fields and field == \"status\":\n626:             entry[field] = \"planned\"\n627: \n628: \n629: def matrix_defaulted_addition(entry: dict[str, Any]) -> dict[str, Any]:\n630:     defaults: dict[str, Any] = {\n631:         \"status\": \"planned\",\n632:         \"plannedPhase\": \"\",\n633:         \"sourceBehavior\": entry.get(\"featurePoint\", \"\"),\n634:         \"targetBehavior\": \"\",\n635:         \"verificationEvidence\": [],\n636:         \"parityLevel\": \"unverified\",\n637:         \"targetEndpoints\": [],\n638:         \"tests\": [],\n639:         \"notes\": \"\",\n640:         \"deferredReason\": \"\",\n641:         \"targetFallback\": \"\",\n642:         \"risk\": \"\",\n643:         \"futureCompletionPath\": \"\",\n644:         \"entryOrigin\": \"agent-curated\",\n645:         \"matrixSync\": {\n646:             \"status\": \"agent-curated\",\n647:             \"preserveActive\": True,\n648:             \"reason\": \"row was added through structured authority patch\",\n649:         },\n650:         \"riskTags\": [],\n651:         \"keyClasses\": [],\n652:         \"keyMethods\": [],\n653:         \"androidIds\": [],\n654:         \"dependencies\": [],\n655:         \"featurePoint\": \"\",\n656:         \"category\": \"\",\n657:         COVERAGE_FACTS_KEY: default_coverage_facts(),\n658:     }\n659:     return {**defaults, **entry}\n660: \n661: \n662: def platform_defaulted_addition(entry: dict[str, Any]) -> dict[str, Any]:\n663:     defaults: dict[str, Any] = {\n664:         \"status\": \"planned\",\n665:         \"plannedPhase\": \"\",\n666:         \"sourcePaths\": [],\n667:         \"sourceEvidence\": [],\n668:         \"requiredTargetCapabilitySearch\": [],\n669:         \"targetStrategyHint\": \"\",\n670:         \"minimumParity\": \"\",\n671:         \"requiredTests\": [],\n672:         \"allowedDeferredReasons\": [],\n673:         \"targetCapabilitySearch\": [],\n674:         \"targetApiOrLibrary\": \"\",\n675:         \"targetStrategy\": \"\",\n676:         \"targetEndpoints\": [],\n677:         \"tests\": [],\n678:         \"sdkDeclarationEvidence\": [],\n679:         \"cangjieCallableEvidence\": [],\n680:         \"discoveryOnlyEvidence\": [],\n681:         \"compileProbeEvidence\": [],\n682:         \"preResolutionDecision\": \"\",\n683:         \"phaseCapabilityResolution\": \"\",\n684:         \"blocker\": \"\",\n685:         \"targetFallback\": \"\",\n686:         \"futureCompletionPath\": \"\",\n687:         \"notes\": \"\",\n688:         CAPABILITY_FACTS_KEY: default_capability_facts(),\n689:     }\n690:     return {**defaults, **entry}\n691: \n692: \n693: def validate_addition(kind: str, addition: Any) -> dict[str, Any]:\n694:     if not isinstance(addition, dict):\n695:         raise PatchError(\"Every addition must be an object.\")\n696:     required = MATRIX_ADD_REQUIRED_FIELDS if kind == \"matrix\" else PLATFORM_ADD_REQUIRED_FIELDS\n697:     missing = [field for field in sorted(required) if not has_text_or_list(addition.get(field))]\n698:     if missing:\n699:         raise PatchError(f\"Addition is missing required field(s): {', '.join(missing)}.\")\n700:     normalized = {\n701:         field: validate_field_value(kind, field, value, add_entry=True)\n702:         for field, value in addition.items()\n703:     }\n704:     return matrix_defaulted_addition(normalized) if kind == \"matrix\" else platform_defaulted_addition(normalized)\n705: \n706: \n707: def matrix_parity_errors(entry: dict[str, Any]) -> list[str]:\n708:     status = effective_matrix_status(entry)\n709:     parity = parity_level(entry)\n710:     if status == \"implemented\" and parity != \"equivalent\":\n711:         return [\"implemented rows must use parityLevel `equivalent`.\"]\n712:     if status == \"implemented-simplified\" and parity != \"simplified\":\n713:         return [\"implemented-simplified rows must use parityLevel `simplified`.\"]\n714:     if status == \"platform-replaced\" and parity != \"platform-replaced\":\n715:         return [\"platform-replaced rows must use parityLevel `platform-replaced`.\"]\n716:     if status == \"deferred\" and parity != \"deferred\":\n717:         return [\"deferred rows must use parityLevel `deferred`.\"]\n718:     if status == \"not-applicable\" and parity not in {\"not-applicable\", \"unverified\", \"\"}:\n719:         return [\"not-applicable rows must use parityLevel `not-applicable`, `unverified`, or empty.\"]\n720:     return []\n721: \n722: \n723: def validate_matrix_entry(entry: dict[str, Any]) -> list[str]:\n724:     problems: list[str] = []\n725:     feature_id = str(entry.get(\"featureId\") or \"\").strip()\n726:     raw_status = str(entry.get(\"status\") or \"\").strip().lower()\n727:     importance = str(entry.get(\"importance\") or \"\").strip().lower()\n728:     coverage_fact_value = entry.get(COVERAGE_FACTS_KEY)\n729:     if coverage_fact_value is not None:\n730:         strict = isinstance(coverage_fact_value, dict) and coverage_fact_value.get(\"factsSource\") == \"agent\"\n731:         problems.extend(validate_coverage_facts(coverage_fact_value, strict=strict))\n732:     if not feature_id:\n733:         problems.append(\"missing featureId\")\n734:     if raw_status not in MATRIX_STATUSES:\n735:         problems.append(f\"invalid status `{raw_status}`\")\n736:     parity = str(entry.get(\"parityLevel\") or \"\").strip().lower()\n737:     if parity not in MATRIX_PARITY_LEVELS:\n738:         problems.append(f\"invalid parityLevel `{parity}`\")\n739:     problems.extend(matrix_parity_errors(entry))\n740: \n741:     important = importance in {\"critical\", \"high\"}\n742:     status = effective_matrix_status(entry)\n743:     if important and status in MATRIX_IMPLEMENTED_STATUSES:\n744:         if not has_source_behavior_evidence(entry):\n745:             problems.append(\"closed critical/high rows require sourceBehavior or sourceEvidence\")\n746:         if not has_target_behavior_evidence(entry):\n747:             problems.append(\"closed critical/high rows require targetBehavior\")\n748:         if not coverage_verification_evidence_items(entry, include_tests=True):\n749:             problems.append(\"closed critical/high rows require verificationEvidence or tests\")\n750:         if not coverage_target_endpoints(entry) and not has_text_or_list(entry.get(\"tests\")):\n751:             problems.append(\"closed critical/high rows require targetEndpoints or tests\")\n752:     if important and status == \"implemented-simplified\":\n753:         if not has_text(entry.get(\"notes\")) and not has_text(entry.get(\"targetFallback\")):\n754:             problems.append(\"implemented-simplified critical/high rows require notes or targetFallback\")\n755:     if important and status == \"deferred\":\n756:         missing = [field for field in MATRIX_DEFERRED_REQUIRED_FIELDS if not has_text_or_list(entry.get(field))]\n757:         if missing:\n758:             problems.append(\"deferred critical/high rows missing \" + \", \".join(missing))\n759:     if important and status == \"not-applicable\" and not has_text(entry.get(\"notes\")):\n760:         problems.append(\"not-applicable critical/high rows require notes\")\n761:     return problems\n762: \n763: \n764: def validate_platform_entry(entry: dict[str, Any]) -> list[str]:\n765:     problems: list[str] = []\n766:     capability_id = str(entry.get(\"capabilityId\") or \"\").strip()\n767:     raw_status = str(entry.get(\"status\") or \"\").strip().lower()\n768:     importance = str(entry.get(\"importance\") or \"\").strip().lower()\n769:     capability_fact_value = entry.get(CAPABILITY_FACTS_KEY)\n770:     if capability_fact_value is not None:\n771:         strict = isinstance(capability_fact_value, dict) and capability_fact_value.get(\"factsSource\") == \"agent\"\n772:         problems.extend(validate_capability_facts(capability_fact_value, strict=strict))\n773:     if not capability_id:\n774:         problems.append(\"missing capabilityId\")\n775:     if raw_status not in PLATFORM_CAPABILITY_STATUSES:\n776:         problems.append(f\"invalid status `{raw_status}`\")\n777: \n778: 