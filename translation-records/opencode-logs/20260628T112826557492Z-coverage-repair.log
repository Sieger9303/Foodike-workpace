{"type":"tool_use","timestamp":1782646157795,"sessionID":"ses_0f203100cffeA3WqBpv4IjDm9J","part":{"type":"tool","tool":"read","callID":"call_c0QGrSdxcWzoUjqTpKhjxewc","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\cart\\cart_page.cj","limit":320,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\cart\\cart_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart\n2: \n3: import kit.ArkUI.*\n4: import ohos.arkui.state_macro_manage.Builder\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n6: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaIcNonVeg, mediaIcVeg}\n7: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n8: import std.collection.ArrayList\n9: \n10: @Builder\n11: func buildCartTopBar(onBack: () -> Unit) {\n12:     Row {\n13:         Button(\"x\")\n14:             .onClick({ _ =>\n15:                 onBack()\n16:             })\n17:         Blank().layoutWeight(1)\n18:     }\n19:     .width(100.percent)\n20:     .alignItems(VerticalAlign.Center)\n21: }\n22: \n23: @Builder\n24: func buildCartQuantityPill(quantity: Int64, onDecrease: () -> Unit, onIncrease: () -> Unit) {\n25:     Row(space: 10) {\n26:         Text(\"-\")\n27:             .fontSize(16)\n28:             .fontWeight(FontWeight.Bold)\n29:             .onClick({ _ =>\n30:                 onDecrease()\n31:             })\n32:         Text(\"${quantity}\")\n33:             .fontSize(16)\n34:             .fontWeight(FontWeight.Medium)\n35:         Text(\"+\")\n36:             .fontSize(16)\n37:             .fontWeight(FontWeight.Bold)\n38:             .fontColor(colorDarkGreen)\n39:             .onClick({ _ =>\n40:                 onIncrease()\n41:             })\n42:     }\n43:     .padding(top: 6, right: 10, bottom: 6, left: 10)\n44:     .borderRadius(14)\n45:     .border(width: 1.px, color: 0x55000000)\n46: }\n47: \n48: @Builder\n49: func buildCartItemRow(item: CartSnapshotItemData, onDecrease: () -> Unit, onIncrease: () -> Unit) {\n50:     Row(space: 16) {\n51:         Image(if (item.menuItem.isVegetarian) { mediaIcVeg } else { mediaIcNonVeg })\n52:             .width(18)\n53:             .height(18)\n54:         Column(space: 6) {\n55:             Text(item.menuItem.dish)\n56:                 .fontSize(16)\n57:                 .fontWeight(FontWeight.Medium)\n58:             Text(cartStore.formatPrice(item.menuItem.price))\n59:                 .fontSize(14)\n60:                 .fontColor(Color.Gray)\n61:         }\n62:         .layoutWeight(1)\n63:         buildCartQuantityPill(item.quantity, onDecrease, onIncrease)\n64:     }\n65:     .width(100.percent)\n66:     .alignItems(VerticalAlign.Center)\n67: }\n68: \n69: @Builder\n70: func buildItemSection(\n71:     items: ArrayList<CartSnapshotItemData>,\n72:     note: String,\n73:     onNoteChange: (String) -> Unit,\n74:     onDecrease: (CartSnapshotItemData) -> Unit,\n75:     onIncrease: (CartSnapshotItemData) -> Unit\n76: ) {\n77:     Column(space: 14) {\n78:         if (items.size > 0) {\n79:             ForEach(items, itemGeneratorFunc: { item: CartSnapshotItemData, _: Int64 =>\n80:                 buildCartItemRow(\n81:                     item,\n82:                     { => onDecrease(item) },\n83:                     { => onIncrease(item) }\n84:                 )\n85:             })\n86:         } else {\n87:             Row {\n88:                 Text(\"Empty\")\n89:                     .fontSize(16)\n90:             }\n91:             .width(100.percent)\n92:             .justifyContent(FlexAlign.Center)\n93:         }\n94: \n95:         Divider().width(100.percent)\n96: \n97:         TextInput(text: note, placeholder: \"Write instruction for restaurant...\")\n98:             .width(100.percent)\n99:             .height(52)\n100:             .fontSize(15)\n101:             .placeholderColor(Color.Gray)\n102:             .backgroundColor(Color.White)\n103:             .onChange({ value: String =>\n104:                 onNoteChange(value)\n105:             })\n106:     }\n107:     .width(100.percent)\n108:     .padding(top: 18, right: 18, bottom: 18, left: 18)\n109:     .backgroundColor(Color.White)\n110:     .borderRadius(22)\n111: }\n112: \n113: @Builder\n114: func buildCouponBar(coupon: String, onCouponChange: (String) -> Unit) {\n115:     Row(space: 12) {\n116:         TextInput(text: coupon, placeholder: \"Add a coupon code...\")\n117:             .layoutWeight(1)\n118:             .height(52)\n119:             .fontSize(15)\n120:             .placeholderColor(Color.Gray)\n121:             .backgroundColor(Color.White)\n122:             .borderRadius(26)\n123:             .onChange({ value: String =>\n124:                 onCouponChange(value)\n125:             })\n126:         Text(\"APPLY\")\n127:             .fontSize(15)\n128:             .fontWeight(FontWeight.Bold)\n129:             .fontColor(colorDarkGreen)\n130:     }\n131:     .width(100.percent)\n132:     .padding(top: 14, right: 18, bottom: 14, left: 18)\n133:     .backgroundColor(Color.White)\n134:     .borderRadius(26)\n135:     .alignItems(VerticalAlign.Center)\n136: }\n137: \n138: @Builder\n139: func buildDeliverySection(restaurant: RestaurantData) {\n140:     Column(space: 12) {\n141:         Row {\n142:             Text(\"Deliver to:\")\n143:                 .fontWeight(FontWeight.Bold)\n144:             Blank().layoutWeight(1)\n145:             Text(\"Edit\")\n146:                 .fontColor(Color.Gray)\n147:         }\n148:         .width(100.percent)\n149: \n150:         Row {\n151:             Column(space: 6) {\n152:                 Text(\"Location:\")\n153:                 Text(\"Estimated time:\")\n154:             }\n155:             .layoutWeight(1)\n156:             Column(space: 6) {\n157:                 Text(cartStore.deliveryLocation())\n158:                 Text(cartStore.formatEta(restaurant.etaMinutes))\n159:             }\n160:         }\n161:         .width(100.percent)\n162:     }\n163:     .width(100.percent)\n164:     .padding(top: 18, right: 18, bottom: 18, left: 18)\n165:     .backgroundColor(Color.White)\n166:     .borderRadius(22)\n167: }\n168: \n169: @Builder\n170: func buildBillSection(itemTotal: Float64) {\n171:     Column(space: 12) {\n172:         Text(\"Bill Details\")\n173:             .fontSize(18)\n174:             .fontWeight(FontWeight.Bold)\n175:         Row {\n176:             Column(space: 6) {\n177:                 Text(\"Item total:\")\n178:                 Text(\"Taxes and charges:\")\n179:                 Text(\"Total:\")\n180:             }\n181:             .layoutWeight(1)\n182:             Column(space: 6) {\n183:                 Text(cartStore.formatPrice(itemTotal))\n184:                 Text(cartStore.formatPrice(cartStore.taxAmount(itemTotal)))\n185:                 Text(cartStore.formatPrice(cartStore.grandTotal(itemTotal)))\n186:             }\n187:         }\n188:         .width(100.percent)\n189:         Button(\"Proceed to Pay\")\n190:             .width(220)\n191:             .height(48)\n192:     }\n193:     .width(100.percent)\n194:     .padding(top: 18, right: 18, bottom: 18, left: 18)\n195:     .backgroundColor(Color.White)\n196:     .borderRadius(22)\n197:     .alignItems(HorizontalAlign.Center)\n198: }\n199: \n200: @Builder\n201: public func renderCartRoute(\n202:     state: CartPageState,\n203:     note: String,\n204:     coupon: String,\n205:     onNoteChange: (String) -> Unit,\n206:     onCouponChange: (String) -> Unit,\n207:     onDecrease: (CartSnapshotItemData) -> Unit,\n208:     onIncrease: (CartSnapshotItemData) -> Unit,\n209:     onBack: () -> Unit\n210: ) {\n211:     Scroll(Scroller()) {\n212:         Column(space: 16) {\n213:             buildCartTopBar(onBack)\n214:             buildItemSection(cartStore.visibleItems(state.items), note, onNoteChange, onDecrease, onIncrease)\n215:             buildCouponBar(coupon, onCouponChange)\n216:             buildDeliverySection(state.deliveryRestaurant)\n217:             buildBillSection(cartStore.itemTotal(cartStore.visibleItems(state.items)))\n218:         }\n219:         .width(100.percent)\n220:         .padding(top: 14, right: 16, bottom: 24, left: 16)\n221:     }\n222:     .scrollable(ScrollDirection.Vertical)\n223:     .scrollBar(BarState.Off)\n224:     .width(100.percent)\n225:     .height(100.percent)\n226:     .backgroundColor(0xFFE8E7E7)\n227: }\n\n(End of file - total 227 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaIcNonVeg, mediaIcVeg}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\n@Builder\nfunc buildCartTopBar(onBack: () -> Unit) {\n    Row {\n        Button(\"x\")\n            .onClick({ _ =>\n                onBack()\n            })\n        Blank().layoutWeight(1)\n    }\n    .width(100.percent)\n    .alignItems(VerticalAlign.Center)","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\cart\\cart_page.cj","time":{"start":1782646157783,"end":1782646157793}},"id":"prt_f0dfdb1d3001806ZK8Jc1tShe9","sessionID":"ses_0f203100cffeA3WqBpv4IjDm9J","messageID":"msg_f0dfd8c42001I78pljnUuj8Twg"}}
