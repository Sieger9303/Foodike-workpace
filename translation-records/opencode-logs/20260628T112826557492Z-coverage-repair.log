                          )\n81:                         }\n82: \n83:                     }\n84:                 } else {\n85:                     Column(\n86:                         horizontalAlignment = Alignment.CenterHorizontally,\n87:                         verticalArrangement = Arrangement.Center,\n88:                         modifier = Modifier\n89:                             .fillMaxWidth()\n90:                             .height(40.dp)\n91:                     ) {\n92:                         Text(text = \"Empty\")\n93:                     }\n94:                 }\n95:                 Divider(\n96:                     modifier = Modifier\n97:                         .fillMaxWidth()\n98:                         .padding(0.dp, 8.dp)\n99:                 )\n100: \n101:                 val inputValue = remember { mutableStateOf(\"\") }\n102:                 val hintState = remember {\n103:                     mutableStateOf(true)\n104:                 }\n105: \n106:                 Box {\n107:                     BasicTextField(\n108:                         value = inputValue.value,\n109:                         onValueChange = { inputValue.value = it },\n110:                         modifier = Modifier\n111:                             .fillMaxWidth()\n112:                             .height(24.dp)\n113:                             .onFocusChanged {\n114:                                 if (inputValue.value == \"\") {\n115:                                     hintState.value = !it.isFocused\n116:                                 }\n117:                             }\n118:                     )\n119: \n120:                     if (hintState.value) {\n121:                         Row(\n122:                             modifier = Modifier.fillMaxWidth(),\n123:                             horizontalArrangement = Arrangement.SpaceBetween,\n124:                             verticalAlignment = Alignment.CenterVertically\n125:                         ) {\n126:   