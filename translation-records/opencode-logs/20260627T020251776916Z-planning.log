mpl.kt\",\n+        \"app/src/main/java/com/example/foodike/data/repository/UserDataRepositoryImpl.kt\",\n+        \"app/src/main/java/com/example/foodike/domain/repository/LoginRepository.kt\",\n+        \"app/src/main/java/com/example/foodike/domain/repository/UserDataRepository.kt\"\n+      ],\n+      \"topLevelDefinitions\": [\n+        \"session persistence service\",\n+        \"selected restaurant store\",\n+        \"liked restaurant stream\",\n+        \"cart item stream\"\n+      ],\n+      \"translationGuidelines\": [\n+        \"Keep persistent login state separate from fake catalogue content.\",\n+        \"Expose stream-like update surfaces so UI refresh remains immediate after mutations.\"\n+      ]\n+    },\n+    {\n+      \"targetPath\": \"entry/src/main/cangjie/ohos_app_cangjie_entry/data/content\",\n+      \"sourceReferences\": [\n+        \"app/src/main/java/com/example/foodike/data/data_source/FakeData.kt\",\n+        \"app/src/main/java/com/example/foodike/data/repository/HomeRepositoryImpl.kt\"\n+      ],\n+      \"topLevelDefinitions\": [\n+        \"fake catalogue data\",\n+        \"ads/food/restaurant repository implementations\",\n+        \"search and lookup helpers\"\n+      ],\n+      \"translationGuidelines\": [\n+        \"Split catalog, restaurant, and helper logic into focused files rather than one giant data source translation.\"\n+      ]\n+    },\n+    {\n+      \"targetPath\": \"entry/src/main/cangjie/ohos_app_cangjie_entry/features/onboarding\",\n+      \"sourceReferences\": [\n+        \"app/src/main/java/com/example/foodike/presentation/onboarding/OnBoarding.kt\",\n+        \"app/src/main/java/com/example/foodike/presentation/onboarding/components/OnboardingPage.kt\",\n+        \"app/src/main/java/com/example/foodike/presentation/onboarding/util/OnBoardingItem.kt\"\n+      ],\n+      \"topLevelDefinitions\": [\n+        \"onboarding page\",\n+        \"pager state\",\n+        \"page item builder\"\n+      ],\n+      \"trans