x.lifecycle.ViewModel\n32: import androidx.lifecycle.viewModelScope\n33: import com.example.foodike.domain.repository.UserDataRepository\n34: import dagger.hilt.android.lifecycle.HiltViewModel\n35: import kotlinx.coroutines.launch\n36: import javax.inject.Inject\n37: \n38: @HiltViewModel\n39: class RestaurantDetailViewModel @Inject constructor(\n40:     private val userDataRepository: UserDataRepository,\n41: \n42:     ) : ViewModel() {\n43: \n44:     private val _detailScreenState = mutableStateOf(DetailScreenState())\n45:     val detailScreenState: State<DetailScreenState> = _detailScreenState\n46: \n47:     init {\n48:         viewModelScope.launch {\n49:             userDataRepository.getMenuItems().collect {\n50:                 _detailScreenState.value = detailScreenState.value.copy(\n51:                     menuList = it,\n52:                     recommendedList = it.shuffled()\n53:                         .dropLast(it.size - 5)\n54:                 )\n55:             }\n56: \n57:             userDataRepository.getSavedRestaurant().collect { restaurant ->\n58:                 _detailScreenState.value = detailScreenState.value.copy(\n59:                     restaurant = restaurant,\n60:                 )\n61:                 userDataRepository.isRestaurantLiked(restaurant).collect {\n62:                     _detailScreenState.value = detailScreenState.value.copy(\n63:                         isLiked = it\n64:                     )\n65:                 }\n66: \n67:             }\n68:         }\n69:     }\n70: \n71: \n72:     fun onEvent(event: DetailScreenEvent) {\n73:         when (event) {\n74:             is DetailScreenEvent.ToggleRecommendedSectionExpandedState -> {\n75:                 _detailScreenState.value = detailScreenState.value.copy(\n76:                     recommendedExpandedState = !detailScreenState.value.recommendedExpandedState\n77:                 )\n78:             }\n79:             is DetailScreenEvent.ToggleNonVegSectionExpandedState -> {\n80:                 _detailScreenState.value = detailScreenState.value.copy(\n81:                     nonVegExpandedState = !detailScreenState.value.nonVegExpandedState\n82:                 )\n83:             }\n84:             is DetailScreenEvent.ToggleVegSectionExpandedState -> {\n85:                 _detailScreenState.value = detailScreenState.value.copy(\n86:                     vegExpandedState = !detailScreenState.value.vegExpandedState\n87:                 )\n88:             }\n89:             is DetailScreenEvent.ToggleLikedStatus -> {\n90:                 if (_detailScreenState.value.isLiked) {\n91:                     _detailScreenState.value = detailScreenState.value.copy(\n92:                         isLiked = false\n93:                     )\n94:                 } else {\n95:                     _detailScreenState.value = detailScreenState.value.copy(\n96:                         isLiked = true\n97:                     )\n98:                 }\n99: \n100:             }\n101:         }\n102:     }\n103: }\n104: \n105: \n\n(End of file - total 105 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER","truncated":false,"loaded":[]},"title":"..\\..\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\details\\RestaurantDetailViewModel.kt","time":{"start":1782525824567,"end":1782525824597}},"id":"prt_f06d18d9b001tC1mm2RLKGEpQ0","sessionID":"ses_0f92f39d9ffeCt7pbKbzBwZvJW","messageID":"msg_f06d16285001yisLIZ9bVUI59f"}}
