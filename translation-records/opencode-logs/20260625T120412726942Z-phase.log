ce\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\data\\content\\home_content_repository.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\data\\content\\home_content_repository.cj\n@@ -0,0 +1,57 @@\n+package ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content\n+\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n+import std.collection.ArrayList\n+\n+public class HomeContentRepository {\n+    private let advertisements = ArrayList<AdvertisementData>([\n+        AdvertisementData(\"Offers for you\", \"Upto 20% discount for you\", \"chinese_bowl\"),\n+        AdvertisementData(\"Free delivery\", \"Free delivery for selected restaurants\", \"rider\"),\n+        AdvertisementData(\"Order groceries\", \"Order groceries from local vendors\", \"groceries\"),\n+        AdvertisementData(\"Pay with UPI\", \"Get extra 15% discount with UPI payment\", \"upi\")\n+    ])\n+\n+    private let categories = ArrayList<FoodCategoryData>([\n+        FoodCategoryData(\"Pizza\", \"pizza\"),\n+        FoodCategoryData(\"Biryani\", \"biryani\"),\n+        FoodCategoryData(\"Burger\", \"burger\"),\n+        FoodCategoryData(\"Chinese\", \"chinese\"),\n+        FoodCategoryData(\"Apple Pie\", \"applepie\"),\n+        FoodCategoryData(\"Paratha\", \"paratha\"),\n+        FoodCategoryData(\"Dosa\", \"dosa\")\n+    ])\n+\n+    private let restaurants = ArrayList<RestaurantData>([\n+        RestaurantData(\"George Street\", 4.6, 128, 59, \"Indian, American\", \"Mahabhairab\", 3.0, \"applepie\"),\n+        RestaurantData(\"Magnolia\", 4.3, 257, 35, \"North Indian\", \"Ketekibari\", 2.0, \"dosa\"),\n+        RestaurantData(\"Saffron Xpress\", 3.6, 79, 43, \"Chinese\", \"Mission Charali\", 3.5, \"chinese\"),\n+        RestaurantData(\"KF\", 4.9, 357, 55, \"North Indian, Vegetarian\", \"B.P. Tiniali\", 4.0, \"burger\"),\n+        RestaurantData(\"Inaya Mughlai\", 2.6, 221, 23, \"Tandoori, American\", \"Goroimari\", 2.0, \"biryani\"),\n+        RestaurantData(\"Edona\", 3.3, 207, 51, \"Italian\", \"Mission Charali\", 7.0, \"paratha\"),\n+        RestaurantData(\"Relish\", 3.9, 258, 30, \"American, French\", \"Misamari\", 1.0, \"pizza\"),\n+        RestaurantData(\"Lazziz\", 4.8, 157, 39, \"South Indian, French\", \"Jamuguri\", 4.0, \"biryani\")\n+    ])\n+\n+    public init() {}\n+\n+    public func getAds(): ArrayList<AdvertisementData> {\n+        return advertisements\n+    }\n+\n+    public func getFoodItems(): ArrayList<FoodCategoryData> {\n+        return categories\n+    }\n+\n+    public func getRestaurants(): ArrayList<RestaurantData> {\n+        return restaurants\n+    }\n+\n+    public func getRestaurantByName(name: String): Option<RestaurantData> {\n+        for (restaurant in restaurants) {\n+            if (restaurant.name == name) {\n+                return Some(restaurant)\n+            }\n+        }\n+        return None\n+    }\n+}\n\nIndex: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\data\\session\\session_repository.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\data\\session\\session_repository.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\data\\session\\session_repository.cj\n@@ -0,0 +1,31 @@\n+package ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session\n+\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.RestaurantData\n+import std.collection.ArrayList\n+\n+public class SessionRepository {\n+    private var selectedRestaurantName: String = \"\"\n+    private let likedRestaurants = ArrayList<RestaurantData>([\n+        RestaurantData(\"George Street\", 4.6, 128, 59, \"Indian, American\", \"Mahabhairab\", 3.0, \"applepie\"),\n+        RestaurantData(\"Saffron Xpress\", 3.6, 79, 43, \"Chinese\", \"Mission Charali\", 3.5, \"chinese\"),\n+        RestaurantData(\"KF\", 4.9, 357, 55, \"North Indian, Vegetarian\", \"B.P. Tiniali\", 4.0, \"burger\"),\n+        RestaurantData(\"Inaya Mughlai\", 2.6, 221, 23, \"Tandoori, American\", \"Goroimari\", 2.0, \"biryani\"),\n+        RestaurantData(\"Edona\", 3.3, 207, 51, \"Italian\", \"Mission Charali\", 7.0, \"paratha\")\n+    ])\n+\n+    public init() {}\n+\n+    public func setSelectedRestaurant(restaurant: RestaurantData): Unit {\n+        selectedRestaurantName = restaurant.name\n+    }\n+\n+    public func getSelectedRestaurantName(): String {\n+        return selectedRestaurantName\n+    }\n+\n+    public func getLikedRestaurants(): ArrayList<RestaurantData> {\n+        return likedRestaurants\n+    }\n+}\n+\n+public let sessionRepository = SessionRepository()\n\nIndex: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\common\\widgets\\search_bar.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\common\\widgets\\search_bar.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\common\\widgets\\search_bar.cj\n@@ -0,0 +1,18 @@\n+package ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets\n+\n+import kit.ArkUI.*\n+import ohos.arkui.state_macro_manage.Builder\n+\n+@Builder\n+public func renderSearchBar(query: String, onQueryChange: (String) -> Unit) {\n+    TextInput(text: query, placeholder: \"Search\")\n+        .width(100.percent)\n+        .height(52)\n+        .fontSize(16)\n+        .placeholderColor(Color.Gray)\n+        .backgroundColor(0xFFE1E1E1)\n+        .borderRadius(26)\n+        .onChange({ value: String =>\n+            onQueryChange(value)\n+        })\n+}\n\nIndex: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\common\\widgets\\restaurant_card.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\common\\widgets\\restaurant_card.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\common\\widgets\\restaurant_card.cj\n@@ -0,0 +1,105 @@\n+package ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets\n+\n+import kit.ArkUI.*\n+import ohos.arkui.state_macro_manage.Builder\n+import ohos.resource.AppResource\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.RestaurantData\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaApplePie, mediaBiryani, mediaBurger, mediaChinese, mediaDosa, mediaParatha, mediaStar}\n+\n+public func restaurantMedia(name: String): AppResource {\n+    match (name) {\n+        case \"biryani\" => mediaBiryani\n+        case \"burger\" => mediaBurger\n+        case \"chinese\" => mediaChinese\n+        case \"dosa\" => mediaDosa\n+        case \"paratha\" => mediaParatha\n+        case _ => mediaApplePie\n+    }\n+}\n+\n+public func getCustomerInfo(ratingCount: Int64): String {\n+    return if (ratingCount > 50) {\n+        \"50+\"\n+    } else if (ratingCount > 100) {\n+        \"100+\"\n+    } else if (ratingCount > 150) {\n+        \"150+\"\n+    } else if (ratingCount > 200) {\n+        \"200+\"\n+    } else if (ratingCount > 250) {\n+        \"250+\"\n+    } else if (ratingCount > 300) {\n+        \"300+\"\n+    } else if (ratingCount > 350) {\n+        \"350+\"\n+    } else if (ratingCount > 400) {\n+        \"400+\"\n+    } else if (ratingCount > 450) {\n+        \"450+\"\n+    } else if (ratingCount > 500) {\n+        \"500+\"\n+    } else if (ratingCount > 550) {\n+        \"550+\"\n+    } else if (ratingCount > 600) {\n+        \"600+\"\n+    } else if (ratingCount > 650) {\n+        \"650+\"\n+    } else if (ratingCount > 700) {\n+        \"700+\"\n+    } else if (ratingCount > 750) {\n+        \"750+\"\n+    } else if (ratingCount > 800) {\n+        \"800+\"\n+    } else {\n+        \"1000+\"\n+    }\n+}\n+\n+public func formatEta(minutes: Int64): String {\n+    let hours = minutes / 60\n+    let remainder = minutes % 60\n+    if (hours > 0) {\n+        return \"${hours} Hr ${remainder} Min\"\n+    }\n+    return \"${remainder} Min\"\n+}\n+\n+@Builder\n+public func renderRestaurantCard(restaurant: RestaurantData, onSelect: () -> Unit) {\n+    Row(space: 14) {\n+        Image(restaurantMedia(restaurant.mediaName))\n+            .width(120)\n+            .height(154)\n+            .borderRadius(12)\n+        Column(space: 8) {\n+            Text(restaurant.name)\n+                .fontSize(18)\n+                .fontWeight(FontWeight.Bold)\n+            Row(space: 6) {\n+                Image(mediaStar)\n+                    .width(18)\n+                    .height(18)\n+                Text(\"${restaurant.rating}(${getCustomerInfo(restaurant.ratingCount)})\")\n+                    .fontSize(14)\n+                Text(\".\")\n+                    .fontWeight(FontWeight.Bold)\n+                Text(formatEta(restaurant.etaMinutes))\n+                    .fontSize(14)\n+            }\n+            Text(restaurant.variety)\n+                .fontSize(14)\n+                .fontColor(Color.Gray)\n+            Text(restaurant.place)\n+                .fontSize(14)\n+                .fontColor(Color.Gray)\n+        }\n+        .layoutWeight(1)\n+    }\n+    .width(100.percent)\n+    .padding(top: 8, right: 8, bottom: 8, left: 8)\n+    .backgroundColor(Color.White)\n+    .borderRadius(16)\n+    .onClick({ _ =>\n+        onSelect()\n+    })\n+}\n\nIndex: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_store.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_store.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_store.cj\n@@ -0,0 +1,60 @@\n+package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home\n+\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.SessionRepository\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n+import std.collection.ArrayList\n+\n+public let homeStore = HomeStore()\n+\n+public class HomeStore {\n+    private let contentRepository = HomeContentRepository()\n+    private let sessionRepository = SessionRepository()\n+    private let filters = ArrayList<String>([\n+        \"Fast Delivery\",\n+        \"50% Discount\",\n+        \"Great deals\",\n+        \"Non-Veg\"\n+    ])\n+\n+    public init() {}\n+\n+    public func loadHomeState(): HomePageState {\n+        return HomePageState(\n+            contentRepository.getAds(),\n+            contentRepository.getFoodItems(),\n+            sessionRepository.getLikedRestaurants(),\n+            contentRepository.getRestaurants()\n+        )\n+    }\n+\n+    public func filtersList(): ArrayList<String> {\n+        return filters\n+    }\n+\n+    public func toggleFilter(currentFilter: String, tappedFilter: String): String {\n+        if (currentFilter == tappedFilter) {\n+            return \"\"\n+        }\n+        return tappedFilter\n+    }\n+\n+    public func greetingForHour(hour: Int64): String {\n+        if (hour >= 0 && hour <= 11) {\n+            return \"Good Morning!\"\n+        }\n+        if (hour >= 12 && hour <= 15) {\n+            return \"Good Afternoon!\"\n+        }\n+        return \"Good Evening!\"\n+    }\n+\n+    public func selectRestaurant(restaurant: RestaurantData, onNavigate: () -> Unit): Unit {\n+        sessionRepository.setSelectedRestaurant(restaurant)\n+        onNavigate()\n+    }\n+\n+    public func session(): SessionRepository {\n+        return sessionRepository\n+    }\n+}\n\nIndex: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_page.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_page.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_page.cj\n@@ -0,0 +1,238 @@\n+package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home\n+\n+import kit.ArkUI.*\n+import ohos.arkui.state_macro_manage.Builder\n+import ohos.resource.AppResource\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaChineseBowl, mediaClock, mediaGroceries, mediaIcProfile, mediaRider, mediaUpi}\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.{renderRestaurantCard, restaurantMedia, renderSearchBar}\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n+import std.collection.ArrayList\n+\n+private func homeMedia(name: String): AppResource {\n+    match (name) {\n+        case \"chinese_bowl\" => mediaChineseBowl\n+        case \"rider\" => mediaRider\n+        case \"groceries\" => mediaGroceries\n+        case \"upi\" => mediaUpi\n+        case _ => mediaClock\n+    }\n+}\n+\n+@Builder\n+func buildHomeTopSection(onProfileClick: () -> Unit) {\n+    Row {\n+        Image(mediaIcProfile)\n+            .width(36)\n+            .height(36)\n+            .borderRadius(18)\n+            .onClick({ _ =>\n+                onProfileClick()\n+            })\n+        Row(space: 4) {\n+            Text(\"Location\")\n+                .fontSize(14)\n+                .fontColor(Color.Gray)\n+            Text(\"Guwahati\")\n+                .fontSize(16)\n+                .fontWeight(FontWeight.Medium)\n+        }\n+    }\n+    .width(100.percent)\n+    .justifyContent(FlexAlign.SpaceBetween)\n+    .alignItems(VerticalAlign.Center)\n+}\n+\n+@Builder\n+func buildHomeGreeting(hour: Int64) {\n+    Column(space: 2) {\n+        Text(homeStore.greetingForHour(hour))\n+            .fontSize(28)\n+            .fontWeight(FontWeight.Light)\n+        Text(\"Andrew\")\n+            .fontSize(28)\n+            .fontWeight(FontWeight.Light)\n+    }\n+    .width(100.percent)\n+}\n+\n+@Builder\n+func buildHomeSectionTitle(title: String) {\n+    Text(title)\n+        .fontSize(20)\n+        .fontWeight(FontWeight.Light)\n+        .width(100.percent)\n+}\n+\n+@Builder\n+func buildHomeAdCards(advertisements: ArrayList<AdvertisementData>) {\n+    Scroll(Scroller()) {\n+        Row(space: 12) {\n+            ForEach(advertisements, itemGeneratorFunc: { advertisement: AdvertisementData, _: Int64 =>\n+                Row(space: 12) {\n+                    Column(space: 8) {\n+                        Text(advertisement.title)\n+                            .fontSize(22)\n+                            .fontWeight(FontWeight.Bold)\n+                        Text(advertisement.subtitle)\n+                            .fontSize(13)\n+                    }\n+                    .layoutWeight(1)\n+                    Image(homeMedia(advertisement.mediaName))\n+                        .width(92)\n+                        .height(92)\n+                }\n+                .width(260)\n+                .padding(top: 16, right: 16, bottom: 16, left: 16)\n+                .backgroundColor(0xFFF4F4F4)\n+                .borderRadius(20)\n+            })\n+        }\n+    }\n+    .scrollable(ScrollDirection.Horizontal)\n+    .scrollBar(BarState.Off)\n+    .width(100.percent)\n+    .height(140)\n+}\n+\n+@Builder\n+func buildRecommendedCategories(categories: ArrayList<FoodCategoryData>) {\n+    Scroll(Scroller()) {\n+        Row(space: 16) {\n+            ForEach(categories, itemGeneratorFunc: { category: FoodCategoryData, _: Int64 =>\n+                Column(space: 8) {\n+                    Image(restaurantMedia(category.mediaName))\n+                        .width(80)\n+                        .height(80)\n+                        .borderRadius(40)\n+                    Text(category.name)\n+                        .fontSize(14)\n+                }\n+                .alignItems(HorizontalAlign.Center)\n+            })\n+        }\n+    }\n+    .scrollable(ScrollDirection.Horizontal)\n+    .scrollBar(BarState.Off)\n+    .width(100.percent)\n+    .height(120)\n+}\n+\n+@Builder\n+func buildFavouriteStrip(favourites: ArrayList<RestaurantData>, onSelectRestaurant: (RestaurantData) -> Unit) {\n+    if (favourites.size > 0) {\n+        Column(space: 10) {\n+            buildHomeSectionTitle(\"Order from favourites\")\n+            Scroll(Scroller()) {\n+                Row(space: 12) {\n+                    ForEach(favourites, itemGeneratorFunc: { restaurant: RestaurantData, _: Int64 =>\n+                        Column(space: 8) {\n+                            Image(restaurantMedia(restaurant.mediaName))\n+                                .width(98)\n+                                .height(128)\n+                                .borderRadius(12)\n+                            Text(restaurant.name)\n+                                .fontSize(14)\n+                        }\n+                        .width(110)\n+                        .alignItems(HorizontalAlign.Center)\n+                        .onClick({ _ =>\n+                            onSelectRestaurant(restaurant)\n+                        })\n+                    })\n+                }\n+            }\n+            .scrollable(ScrollDirection.Horizontal)\n+            .scrollBar(BarState.Off)\n+            .width(100.percent)\n+            .height(170)\n+        }\n+    }\n+}\n+\n+@Builder\n+func buildFilterRow(selectedFilter: String, onToggleFilter: (String) -> Unit) {\n+    Scroll(Scroller()) {\n+        Row(space: 8) {\n+            ForEach(homeStore.filtersList(), itemGeneratorFunc: { filterName: String, _: Int64 =>\n+                Text(filterName)\n+                    .fontSize(14)\n+                    .fontColor(if (selectedFilter == filterName) { Color.White } else { Color.Black })\n+                    .padding(top: 8, right: 12, bottom: 8, left: 12)\n+                    .backgroundColor(if (selectedFilter == filterName) { 0xFF228D39 } else { Color.White })\n+                    .borderRadius(16)\n+                    .border(width: 1.px, color: 0x55000000)\n+                    .onClick({ _ =>\n+                        onToggleFilter(filterName)\n+                    })\n+            })\n+        }\n+    }\n+    .scrollable(ScrollDirection.Horizontal)\n+    .scrollBar(BarState.Off)\n+    .width(100.percent)\n+    .height(48)\n+}\n+\n+@Builder\n+func buildRestaurantList(restaurants: ArrayList<RestaurantData>, onSelectRestaurant: (RestaurantData) -> Unit) {\n+    Column(space: 10) {\n+        ForEach(restaurants, itemGeneratorFunc: { restaurant: RestaurantData, _: Int64 =>\n+            renderRestaurantCard(restaurant, { =>\n+                onSelectRestaurant(restaurant)\n+            })\n+        })\n+    }\n+    .width(100.percent)\n+}\n+\n+@Builder\n+func buildHomeFooter() {\n+    Row(space: 6) {\n+        Text(\"with\")\n+            .fontSize(24)\n+            .fontColor(Color.Gray)\n+        Text(\"love\")\n+            .fontSize(24)\n+            .fontColor(Color.Red)\n+        Text(\"from creator\")\n+            .fontSize(24)\n+            .fontColor(Color.Gray)\n+    }\n+    .width(100.percent)\n+    .justifyContent(FlexAlign.Center)\n+}\n+\n+@Builder\n+public func renderHomeRoute(\n+    state: HomePageState,\n+    hour: Int64,\n+    query: String,\n+    selectedFilter: String,\n+    onQueryChange: (String) -> Unit,\n+    onToggleFilter: (String) -> Unit,\n+    onProfileClick: () -> Unit,\n+    onSelectRestaurant: (RestaurantData) -> Unit\n+) {\n+    Scroll(Scroller()) {\n+        Column(space: 18) {\n+            buildHomeTopSection(onProfileClick)\n+            buildHomeGreeting(hour)\n+            renderSearchBar(query, onQueryChange)\n+            buildHomeAdCards(state.advertisements)\n+            buildHomeSectionTitle(\"Recommended for you\")\n+            buildRecommendedCategories(state.categories)\n+            buildFavouriteStrip(state.favourites, onSelectRestaurant)\n+            buildFilterRow(selectedFilter, onToggleFilter)\n+            buildHomeSectionTitle(\"All around you\")\n+            buildRestaurantList(state.restaurants, onSelectRestaurant)\n+            buildHomeFooter()\n+        }\n+        .width(100.percent)\n+        .padding(top: 12, right: 16, bottom: 24, left: 16)\n+    }\n+    .scrollable(ScrollDirection.Vertical)\n+    .scrollBar(BarState.Off)\n+    .width(100.percent)\n+    .height(100.percent)\n+    .backgroundColor(Color.White)\n+}\n\nIndex: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_store.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_store.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_store.cj\n@@ -0,0 +1,37 @@\n+package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history\n+\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.SessionRepository\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n+import std.collection.ArrayList\n+\n+public let historyStore = HistoryStore()\n+\n+public class HistoryStore {\n+    private let sessionRepository = SessionRepository()\n+    private let orderHistory = ArrayList<HistoryRecordData>([\n+        HistoryRecordData(\"Fish n Rolls\", \"Tezpur\", \"13 Aug 2022, 11:12 PM\", \"$7.90\", \"Chinese Shawarma\\nCombo (1)\", false, 5, 5, \"Delivered\", \"Reorder\"),\n+        HistoryRecordData(\"Fish n Rolls\", \"Tezpur\", \"13 Aug 2022, 11:12 PM\", \"$7.90\", \"Chinese Shawarma\\nCombo (1)\", false, 0, 0, \"Delivered\", \"Rate Order\")\n+    ])\n+\n+    public init() {}\n+\n+    public func loadHistoryState(): HistoryPageState {\n+        return HistoryPageState(sessionRepository.getLikedRestaurants(), orderHistory)\n+    }\n+\n+    public func tabLabel(index: Int64): String {\n+        if (index == 0) {\n+            return \"History\"\n+        }\n+        return \"Favourites\"\n+    }\n+\n+    public func selectRestaurant(restaurant: RestaurantData, onNavigate: () -> Unit): Unit {\n+        sessionRepository.setSelectedRestaurant(restaurant)\n+        onNavigate()\n+    }\n+\n+    public func session(): SessionRepository {\n+        return sessionRepository\n+    }\n+}\n\nIndex: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_page.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_page.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_page.cj\n@@ -0,0 +1,166 @@\n+package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history\n+\n+import kit.ArkUI.*\n+import ohos.arkui.state_macro_manage.Builder\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaIcNonVeg, mediaIcVeg}\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.{renderRestaurantCard, renderSearchBar}\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n+\n+@Builder\n+func buildHistoryTabs(selectedTab: Int64, onTabSelect: (Int64) -> Unit) {\n+    Row(space: 18) {\n+        Text(historyStore.tabLabel(0))\n+            .fontSize(18)\n+            .fontWeight(if (selectedTab == 0) { FontWeight.Bold } else { FontWeight.Light })\n+            .onClick({ _ =>\n+                onTabSelect(0)\n+            })\n+        Text(historyStore.tabLabel(1))\n+            .fontSize(18)\n+            .fontWeight(if (selectedTab == 1) { FontWeight.Bold } else { FontWeight.Light })\n+            .onClick({ _ =>\n+                onTabSelect(1)\n+            })\n+    }\n+    .width(100.percent)\n+}\n+\n+@Builder\n+func buildHistoryStatusRow(statusText: String) {\n+    Row(space: 6) {\n+        Text(statusText)\n+            .fontSize(14)\n+            .fontColor(Color.Gray)\n+        Text(\".\")\n+            .fontWeight(FontWeight.Bold)\n+            .fontColor(0xFF228D39)\n+    }\n+}\n+\n+@Builder\n+func buildHistoryRecordCard(record: HistoryRecordData) {\n+    Column(space: 10) {\n+        Row {\n+            Column(space: 4) {\n+                Text(record.restaurantName)\n+                    .fontWeight(FontWeight.Bold)\n+                Text(record.place)\n+                    .fontSize(14)\n+                    .fontColor(Color.Gray)\n+                Text(record.timestampText)\n+                    .fontSize(14)\n+                    .fontColor(Color.Gray)\n+            }\n+            .layoutWeight(1)\n+            Text(record.totalText)\n+                .fontSize(16)\n+        }\n+\n+        Divider().width(100.percent)\n+\n+        Row(space: 10) {\n+            Image(if (record.isVeg) { mediaIcVeg } else { mediaIcNonVeg })\n+                .width(16)\n+                .height(16)\n+            Text(record.itemSummary)\n+                .layoutWeight(1)\n+                .fontSize(14)\n+            Button(record.actionText)\n+        }\n+        .alignItems(VerticalAlign.Center)\n+\n+        if (record.deliveryRating > 0) {\n+            Row {\n+                Column(space: 4) {\n+                    Text(\"Your rating for delivery\")\n+                        .fontSize(14)\n+                        .fontColor(Color.Gray)\n+                    Text(\"Your rating for food\")\n+                        .fontSize(14)\n+                        .fontColor(Color.Gray)\n+                }\n+                .layoutWeight(1)\n+                Column(space: 4) {\n+                    Text(\"* ${record.deliveryRating}\")\n+                    Text(\"* ${record.foodRating}\")\n+                }\n+                buildHistoryStatusRow(record.statusText)\n+            }\n+            .alignItems(VerticalAlign.Center)\n+        } else {\n+            Row {\n+                Text(record.actionText)\n+                    .fontSize(16)\n+                    .fontWeight(FontWeight.Bold)\n+                    .fontColor(0xFF228D39)\n+                Blank().layoutWeight(1)\n+                buildHistoryStatusRow(record.statusText)\n+            }\n+            .alignItems(VerticalAlign.Center)\n+        }\n+    }\n+    .width(100.percent)\n+    .padding(top: 14, right: 14, bottom: 14, left: 14)\n+    .backgroundColor(Color.White)\n+    .borderRadius(16)\n+}\n+\n+@Builder\n+func buildHistoryRecords(records: std.collection.ArrayList<HistoryRecordData>) {\n+    Column(space: 10) {\n+        ForEach(records, itemGeneratorFunc: { record: HistoryRecordData, _: Int64 =>\n+            buildHistoryRecordCard(record)\n+        })\n+    }\n+    .width(100.percent)\n+}\n+\n+@Builder\n+func buildHistoryFavourites(favourites: std.collection.ArrayList<RestaurantData>, onSelectRestaurant: (RestaurantData) -> Unit) {\n+    if (favourites.size > 0) {\n+        Column(space: 10) {\n+            ForEach(favourites, itemGeneratorFunc: { restaurant: RestaurantData, _: Int64 =>\n+                renderRestaurantCard(restaurant, { =>\n+                    onSelectRestaurant(restaurant)\n+                })\n+            })\n+        }\n+        .width(100.percent)\n+    } else {\n+        Row {\n+            Text(\"Empty\")\n+                .fontSize(16)\n+        }\n+        .width(100.percent)\n+        .justifyContent(FlexAlign.Center)\n+    }\n+}\n+\n+@Builder\n+public func renderHistoryRoute(\n+    state: HistoryPageState,\n+    selectedTab: Int64,\n+    query: String,\n+    onQueryChange: (String) -> Unit,\n+    onTabSelect: (Int64) -> Unit,\n+    onSelectRestaurant: (RestaurantData) -> Unit\n+) {\n+    Scroll(Scroller()) {\n+        Column(space: 14) {\n+            renderSearchBar(query, onQueryChange)\n+            buildHistoryTabs(selectedTab, onTabSelect)\n+            if (selectedTab == 0) {\n+                buildHistoryRecords(state.records)\n+            } else {\n+                buildHistoryFavourites(state.favourites, onSelectRestaurant)\n+            }\n+        }\n+        .width(100.percent)\n+        .padding(top: 16, right: 16, bottom: 24, left: 16)\n+    }\n+    .scrollable(ScrollDirection.Vertical)\n+    .scrollBar(BarState.Off)\n+    .width(100.percent)\n+    .height(100.percent)\n+    .backgroundColor(Color.White)\n+}\n\nIndex: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase04_home_history_discovery_test.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase04_home_history_discovery_test.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase04_home_history_discovery_test.cj\n@@ -0,0 +1,77 @@\n+package ohos_app_cangjie_entry_test\n+\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home.HomeStore\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history.HistoryStore\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.getCustomerInfo\n+import std.collection.ArrayList\n+import std.unittest.*\n+import std.unittest.testmacro.*\n+\n+@Test\n+public class Phase04HomeHistoryDiscoveryTest {\n+    @TestCase\n+    public func homeStoreLoadsFixtureBackedSections(): Unit {\n+        let store = HomeStore()\n+        let state = store.loadHomeState()\n+        @Assert(state.advertisements.size, 4)\n+        @Assert(state.categories.size, 7)\n+        @Assert(state.favourites.size, 5)\n+        @A