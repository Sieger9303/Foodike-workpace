c buildHistoryRecordCard(record: HistoryRecordData) {\n42:     Column(space: 10) {\n43:         Row {\n44:             Column(space: 4) {\n45:                 Text(record.restaurantName)\n46:                     .fontWeight(FontWeight.Bold)\n47:                 Text(record.place)\n48:                     .fontSize(14)\n49:                     .fontColor(Color.Gray)\n50:                 Text(record.timestampText)\n51:                     .fontSize(14)\n52:                     .fontColor(Color.Gray)\n53:             }\n54:             .layoutWeight(1)\n55:             Text(record.totalText)\n56:                 .fontSize(16)\n57:         }\n58: \n59:         Divider().width(100.percent)\n60: \n61:         Row(space: 10) {\n62:             Image(if (record.isVeg) { mediaIcVeg } else { mediaIcNonVeg })\n63:                 .width(16)\n64:                 .height(16)\n65:             Text(record.itemSummary)\n66:                 .layoutWeight(1)\n67:                 .fontSize(14)\n68:             Button(record.actionText)\n69:         }\n70:         .alignItems(VerticalAlign.Center)\n71: \n72:         if (record.deliveryRating > 0) {\n73:             Row {\n74:                 Column(space: 4) {\n75:                     Text(\"Your rating for delivery\")\n76:                         .fontSize(14)\n77:                         .fontColor(Color.Gray)\n78:                     Text(\"Your rating for food\")\n79:                         .fontSize(14)\n80:                         .fontColor(Color.Gray)\n81:                 }\n82:                 .layoutWeight(1)\n83:                 Column(space: 4) {\n84:                     Text(\"* ${record.deliveryRating}\")\n85:                     Text(\"* ${record.foodRating}\")\n86:                 }\n87:                 buildHistoryStatusRow(record.statusText)\n88:             }\n89:             .alignItems(VerticalAlign.Center)\n90:         } else {\n91:             Row {\n92:                 Text(record.actionText)\n93:                     .fontSize(16)\n94:                     .fontWeight(FontWeight.Bold)\n95:                     .fontColor(0xFF228D39)\n96:                 Blank().layoutWeight(1)\n97:                 buildHistoryStatusRow(record.statusText)\n98:             }\n99:             .alignItems(VerticalAlign.Center)\n100:         }\n101:     }\n102:     .width(100.percent)\n103:     .padding(top: 14, right: 14, bottom: 14, left: 14)\n104:     .backgroundColor(Color.White)\n105:     .borderRadius(16)\n106: }\n107: \n108: @Builder\n109: func buildHistoryRecords(records: std.collection.ArrayList<HistoryRecordData>) {\n110:     Column(space: 10) {\n111:         ForEach(records, itemGeneratorFunc: { record: HistoryRecordData, _: Int64 =>\n112:             buildHistoryRecordCard(record)\n113:         })\n114:     }\n115:     .width(100.percent)\n116: }\n117: \n118: @Builder\n119: func buildHistoryFavourites(favourites: std.collection.ArrayList<RestaurantData>, onSelectRestaurant: (RestaurantData) -> Unit) {\n120:     if (favourites.size > 0) {\n121:         Column(space: 10) {\n122:             ForEach(favourites, itemGeneratorFunc: { restaurant: RestaurantData, _: Int64 =>\n123:                 renderRestaurantCard(restaurant, { =>\n124:                     onSelectRestaurant(restaurant)\n125:                 })\n126:             })\n127:         }\n128:         .width(100.percent)\n129:     } else {\n130:         Row {\n131:             Text(\"Empty\")\n132:                 .fontSize(16)\n133:         }\n134:         .width(100.percent)\n135:         .justifyContent(FlexAlign.Center)\n136:     }\n137: }\n138: \n139: @Builder\n140: public func renderHistoryRoute(\n141:     state: HistoryPageState,\n142:     selectedTab: Int64,\n143:     query: String,\n144:     onQueryChange: (String) -> Unit,\n145:     onTabSelect: (Int64) -> Unit,\n146:     onSelectRestaurant: (RestaurantData) -> Unit\n147: ) {\n148:     Scroll(Scroller()) {\n149:         Column(space: 14) {\n150:             renderSearchBar(query, onQueryChange)\n151:             buildHistoryTabs(selectedTab, onTabSelect)\n152:             if (selectedTab == 0) {\n153:                 buildHistoryRecords(state.records)\n154:             } else {\n155:                 buildHistoryFavourites(state.favourites, onSelectRestaurant)\n156:             }\n157:         }\n158:         .width(100.percent)\n159:         .padding(top: 16, right: 16, bottom: 24, left: 16)\n160:     }\n161:     .scrollable(ScrollDirection.Vertical)\n162:     .scrollBar(BarState.Off)\n163:     .width(100.percent)\n164:     .height(100.percent)\n165:     .backgroundColor(Color.White)\n166: }\n\n(End of file - total 166 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaIcNonVeg, mediaIcVeg}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.{renderRestaurantCard, renderSearchBar}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n\n@Builder\nfunc buildHistoryTabs(selectedTab: Int64, onTabSelect: (Int64) -> Unit) {\n    Row(space: 18) {\n        Text(historyStore.tabLabel(0))\n            .fontSize(18)\n            .fontWeight(if (selectedTab == 0) { FontWeight.Bold } else { FontWeight.Light })\n            .onClick({ _ =>\n                onTabSelect(0)\n            })\n        Text(historyStore.tabLabel(1))\n            .fontSize(18)\n            .fontWeight(if (selectedTab == 1) { FontWeight.Bold } else { FontWeight.Light })","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_page.cj","time":{"start":1782394877282,"end":1782394877289}},"id":"prt_eff0374aa001ppDQo7K4iLKb2o","sessionID":"ses_1015564daffeewn8Ynq2E7YoiC","messageID":"msg_eff032a05001OZhlj05sMkGhBt"}}
