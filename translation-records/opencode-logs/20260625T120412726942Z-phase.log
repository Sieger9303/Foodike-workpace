pp_runtime.cj\nD:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\startup\\startup_store.cj\nD:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\data\\package_anchor.cj\nD:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\package_anchor.cj\nD:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\data\\session\\login_preferences_service.cj\nD:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\onboarding\\onboarding_store.cj\nD:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_state.cj\nD:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\app_router.cj\nD:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\common\\foodike_resources.cj\nD:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\app_ability.cj\nD:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ability_stage.cj","metadata":{"count":25,"truncated":false},"title":"Foodike-Harmony","time":{"start":1782389083159,"end":1782389083193}},"id":"prt_efeab0c070012Vd82DKPKqwUhj","sessionID":"ses_1015564daffeewn8Ynq2E7YoiC","messageID":"msg_efeaaf1ed001P0ZMocGqRUfgN4"}}
{"type":"tool_use","timestamp":1782389083255,"sessionID":"ses_1015564daffeewn8Ynq2E7YoiC","part":{"type":"tool","tool":"read","callID":"call_VIGHw7Fr1xhoZtdo0X9lzE1x","state":{"status":"completed","input":{"filePath":"D:\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\components\\RestaurantCard.kt"},"output":"<path>D:\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\components\\RestaurantCard.kt</path>\n<type>file</type>\n<content>\n1: /**\n2:  *\n3:  *\tMIT License\n4:  *\n5:  *\tCopyright (c) 2026 Gautam Hazarika\n6:  *\n7:  *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n8:  *\tof this software and associated documentation files (the \"Software\"), to deal\n9:  *\tin the Software without restriction, including without limitation the rights\n10:  *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n11:  *\tcopies of the Software, and to permit persons to whom the Software is\n12:  *\tfurnished to do so, subject to the following conditions:\n13:  *\n14:  *\tThe above copyright notice and this permission notice shall be included in all\n15:  *\tcopies or substantial portions of the Software.\n16:  *\n17:  *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n18:  *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n19:  *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n20:  *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER\n21:  *\tLIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,\n22:  *\tOUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE\n23:  *\tSOFTWARE.\n24:  *\n25:  **/\n26: \n27: package com.example.foodike.presentation.components\n28: \n29: import androidx.compose.foundation.Image\n30: import androidx.compose.foundation.clickable\n31: import androidx.compose.foundation.layout.*\n32: import androidx.compose.foundation.shape.RoundedCornerShape\n33: import androidx.compose.material.Text\n34: import androidx.compose.runtime.Composable\n35: import androidx.compose.ui.Alignment\n36: import androidx.compose.ui.Modifier\n37: import androidx.compose.ui.draw.alpha\n38: import androidx.compose.ui.draw.clip\n39: import androidx.compose.ui.draw.shadow\n40: import androidx.compose.ui.layout.ContentScale\n41: import androidx.compose.ui.res.painterResource\n42: import androidx.compose.ui.text.font.FontWeight\n43: import androidx.compose.ui.text.style.TextOverflow\n44: import androidx.compose.ui.unit.dp\n45: import androidx.compose.ui.unit.sp\n46: import com.example.foodike.R\n47: import com.example.foodike.domain.model.Restaurant\n48: import com.example.foodike.presentation.common.getTimeInMins\n49: import java.lang.StringBuilder\n50: import java.util.concurrent.TimeUnit\n51: \n52: @Composable\n53: fun RestaurantCard(\n54:     restaurant: Restaurant,\n55:     modifier: Modifier\n56: ) {\n57:     Column(\n58:         modifier = Modifier\n59:             .fillMaxWidth()\n60:             .padding(8.dp, 0.dp)\n61:     )\n62:     {\n63:         Row(\n64:             modifier = modifier\n65:                 .fillMaxWidth()\n66:                 ,\n67:             horizontalArrangement = Arrangement.Start,\n68:             verticalAlignment = Alignment.CenterVertically\n69:         ) {\n70:             Image(\n71:                 painter = painterResource(id = restaurant.image),\n72:                 contentDescription = \"Restaurant\",\n73:                 modifier = Modifier\n74:                     .size(130.dp, 170.dp)\n75:                     .shadow(elevation = 0.dp, shape = RoundedCornerShape(8.dp), clip = true),\n76:                 contentScale = ContentScale.Crop\n77:             )\n78:             Column(modifier = Modifier.padding(16.dp)) {\n79:                 Text(\n80:                     text = restaurant.name,\n81:                     fontSize = 16.sp,\n82:                     fontWeight = FontWeight.Bold,\n83:                 )\n84:                 Row(\n85:                     horizontalArrangement = Arrangement.Center,\n86:                     verticalAlignment = Alignment.CenterVertically\n87:                 ) {\n88:                     Image(\n89:                         painter = painterResource(id = R.drawable.star),\n90:                         contentDescription = \"Rating\",\n91:                         modifier = Modifier\n92:                             .size(20.dp)\n93:                     )\n94:                     Spacer(modifier = Modifier.width(2.dp))\n95: \n96:                     Text(text = \"${restaurant.rating}(${getCustomerInfo(restaurant.noOfRatings)}) \")\n97:                     Text(\n98:                         text = \"·\",\n99:                         fontSize = 16.sp,\n100:                         fontWeight = FontWeight.Bold,\n101:                     )\n102:                     Text(text = restaurant.timeInMillis.getTimeInMins())\n103:                 }\n104:                 Text(\n105:                     text = restaurant.variety,\n106:                     modifier = Modifier.alpha(0.5f),\n107:                     overflow = TextOverflow.Ellipsis,\n108:                     maxLines = 1\n109:                 )\n110:                 Text(\n111:                     text = restaurant.place,\n112:                     modifier = Modifier.alpha(0.5f),\n113:                 )\n114:             }\n115: \n116:         }\n117:         Spacer(modifier = Modifier.height(18.dp))\n118: \n119:     }\n120: \n121: \n122: }\n123: \n124: \n125: fun getCustomerInfo(noOfRatings: Int): String {\n126:     return when {\n127:         noOfRatings > 50 -> {\n128:             \"50+\"\n129:         }\n130:         noOfRatings > 100 -> {\n131:             \"100+\"\n132:         }\n133:         noOfRatings > 150 -> {\n134:             \"150+\"\n135:         }\n136:         noOfRatings > 200 -> {\n