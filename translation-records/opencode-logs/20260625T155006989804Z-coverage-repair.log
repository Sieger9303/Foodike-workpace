5:     return [\n306:         item\n307:         for item in _evidence_items(value, kind=\"cangjie-sdk-declaration\")\n308:         if not _sdk_declaration_text_is_negated(item[\"detail\"].lower())\n309:     ]\n310: \n311: \n312: def _coverage_closure_from_status(status: str) -> str:\n313:     return {\n314:         \"implemented\": \"implemented\",\n315:         \"implemented-simplified\": \"simplified\",\n316:         \"platform-replaced\": \"platform-replaced\",\n317:         \"deferred\": \"deferred\",\n318:         \"not-applicable\": \"not-applicable\",\n319:     }.get(status, \"open\")\n320: \n321: \n322: def _coverage_parity_from_legacy(entry: dict[str, Any], closure_kind: str) -> str:\n323:     parity = str(entry.get(\"parityLevel\") or \"\").strip().lower()\n324:     if parity in COVERAGE_PARITY_KINDS:\n325:         return parity\n326:     return {\n327:         \"implemented\": \"equivalent\",\n328:         \"simplified\": \"simplified\",\n329:         \"platform-replaced\": \"platform-replaced\",\n330:         \"deferred\": \"deferred\",\n331:         \"not-applicable\": \"not-applicable\",\n332:     }.get(closure_kind, \"unverified\")\n333: \n334: \n335: def _coverage_verification_kind(text: str) -> tuple[str, str]:\n336:     lowered = text.lower()\n337:     if \"harness\" in lowered and any(term in lowered for term in (\"block\", \"fail\", \"unavailable\")):\n338:         return \"testEvidence\", \"harness-blocked\"\n339:     if \"test\" in lowered and any(term in lowered for term in (\"compile\", \"no-run\")):\n340:         return \"testEvidence\", \"test-compile-pass\"\n341:     if \"test\" in lowered and any(term in lowered for term in (\"pass\", \"passed\", \"verified\")):\n342:         return \"testEvidence\", \"focused-test-pass\"\n343:     if \"build\" in lowered and any(term in lowered for term in (\"pass\", \"passed\", \"success\")):\n344:         return \"buildEvidence\", \"build-pass\"\n345:     if \"runtime\" in lowered or \"smoke\" in lowered or \"emulator\" in lowered:\n346:         return \"runtimeEvidence\", \"runtime-ui-smoke-pass\"\n347:     return \"manualEvidence\", \"manual-review\"\n348: \n349: \n350: def _legacy_coverage_has_decision(entry: dict[str, Any]) -> bool:\n351:     status = str(entry.get(\"status\") or \"\").strip().lower()\n352:     if status not in {\"\", \"planned\", \"unreviewed\", \"not-covered\", \"unknown\"}:\n353:         return True\n354:     return any(\n355:         _text_items(entry.get(field))\n356:         for field in (\n357:             \"targetBehavior\",\n358:             \"verificationEvidence\",\n359:             \"targetEndpoints\",\n360:             \"deferredReason\",\n361:             \"targetFallback\",\n362:             \"risk\",\n363:             \"futureCompletionPath\",\n364:         )\n365:     )\n366: \n367: \n368: def infer_coverage_facts_from_legacy(entry: dict[str, Any]) -> dict[str, Any]:\n369:     \"\"\"Infer structured coverage facts from legacy matrix fields.\"\"\"\n370: \n371:     status = str(entry.get(\"status\") or \"\").strip().lower()\n372:     closure_kind = _coverage_closure_from_status(status)\n373:     facts = default_coverage_facts(facts_source=\"inferred-from-legacy\")\n374:     facts[\"closureKind\"] = closure_kind\n375:     facts[\"parityKind\"] = _coverage_parity_from_legacy(entry, closure_kind)\n376:     facts[\"sourceBehaviorMapped\"] = bool(\n377:         _first_text(entry.get(\"sourceBehavior\"), entry.get(\"sourceEvidence\"), entry.get(\"featurePoint\"))\n378:     )\n379:     facts[\"targetBehaviorImplemented\"] = bool(\n380:         closure_kind in {\"implemented\", \"simplified\", \"platform-replaced\"}\n381:         and _first_text(entry.get(\"targetBehavior\"))\n382:     )\n383: \n384:     if closure_kind == \"simplified\":\n385:         target_behavior = _first_text(entry.get(\"targetBehavior\"))\n386:         fallback = _first_text(entry.get(\"targetFallback\"))\n387:         facts[\"activeSimplification\"] = {\n388:             \"used\": True,\n389:             \"reason\": _first_text(entry.get(\"notes\"), entry.get(\"targetFallback\")),\n390:             \"preservedBehaviors\": [target_behavior] if target_behavior else [],\n391:             \"omittedBehaviors\": [fallback] if fallback else [],\n392:         }\n393: \n394:     if closure_kind == \"deferred\":\n395:         facts[\"activeDeferred\"] = {\n396:             \"used\": True,\n397:             \"blockerKind\": _blocker_kind_from_text(\n398:                 _normalized_text(\n399:                     entry.get(\"deferredReason\"),\n400:                     entry.get(\"risk\"),\n401:                     entry.get(\"futureCompletionPath\"),\n402:                 ),\n403:                 capability=False,\n404:             ),\n405:             \"blocker\": _first_text(entry.get(\"deferredReason\"), entry.get(\"risk\")),\n406:             \"fallbackBehavior\": _first_text(entry.get(\"targetFallback\")),\n407:             \"futureCompletionPath\": _first_text(entry.get(\"futureCompletionPath\")),\n408:         }\n409: \n410:     verification = facts[\"verification\"]\n411:     verification[\"targetEndpoints\"] = _text_items(entry.get(\"targetEndpoints\"))\n412:     for text in _text_items(entry.get(\"verificationEvidence\")):\n413:         bucket, kind = _coverage_verification_kind(text)\n414:         verification[bucket].append({\"kind\": kind, \"detail\": text})\n415:     return facts\n416: \n417: \n418: def coverage_facts(entry: dict[str, Any]) -> dict[str, Any]:\n419:     \"\"\"Return valid coverage facts, preferring agent-authored facts over legacy inference.\"\"\"\n420: \n421:     existing = entry.get(COVERAGE_FACTS_KEY)\n422:     strict_existing = isinstance(existing, dict) and existing.get(\"factsSource\") == \"agent\"\n423:     existing_valid = isinstance(existing, dict) and not validate_coverage_facts(\n424:         existing,\n425:         strict=strict_existing,\n426:     )\n427:     if existing_valid:\n428:         if existing.get(\"factsSource\") == \"agent\" or not _legacy_coverage_has_decision(entry):\n429:             return copy.deepcopy(existing)\n430:     if _legacy_coverage_has_decision(entry):\n431:         return infer_coverage_facts_from_legacy(entry)\n432:     if existing_valid:\n433:         return copy.deepcopy(existing)\n434:     return default_coverage_facts()\n435: \n436: \n437: def _capability_resolution_from_status(status: str) -> str:\n438:     return {\n439:         \"verified-direct\": \"direct-api\",\n440:         \"platform-replaced\": \"platform-replacement\",\n441:         \"implemented-fallback\": \"fallback\",\n442:         \"deferred\": \"deferred\",\n443:         \"not-applicable\": \"not-applicable\",\n444:     }.get(status, \"open\")\n445: \n446: \n447: def _compile_probe_kind(text: str) -> str:\n448:     lowered = text.lower()\n449:     if any(term in lowered for term in (\"blocked\", \"blocker\", \"unavailable\", \"missing environment\", \"harness\")):\n450:         return \"compile-probe-blocked\"\n451:     if any(term in lowered for term in (\"fail\", \"failed\", \"error\")):\n452:         return \"compile-probe-fail\"\n453:     if \"build\" in lowered:\n454:         return \"build-gate-pass\"\n455:     return \"compile-probe-pass\"\n456: \n457: \n458: def _discovery_only_kind(text: str) -> str:\n459:     lowered = text.lower()\n460:     if \"arkts\" in lowered or \"@ohos\" in lowered or \".d.ts\" in lowered or \"typescript\" in lowered:\n461:         return \"arkts-doc\"\n462:     if \"native\" in lowered or \"header\" in lowered:\n463:         return \"native-doc\"\n464:     if \"marketing\" in lowered:\n465:         return \"marketing-doc\"\n466:     if \"overview\" in lowered or \"概览\" in lowered:\n467:         return \"overview-doc\"\n468:     return \"\"\n469: \n470: \n471: def _sdk_declaration_kind(text: str) -> str:\n472:     lowered = text.lower()\n473:     if _sdk_declaration_text_is_negated(lowered):\n474:         return \"\"\