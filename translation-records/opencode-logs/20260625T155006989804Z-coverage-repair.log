-patch\",\n216:                     str(patch_file),\n217:                     \"--plan-json\",\n218:                     str(self.plan_path()),\n219:                     \"--no-markdown\",\n220:                 ]\n221:             )\n222: \n223:     def test_matrix_patch_rejects_missing_target_endpoint_file(self) -> None:\n224:         matrix = self.matrix_path()\n225:         patch_file = self.root / \"patch.json\"\n226:         write_json(\n227:             patch_file,\n228:             {\n229:                 \"updates\": [\n230:                     {\n231:                         \"featureId\": \"main-click-001\",\n232:                         \"append\": {\"targetEndpoints\": [\"entry/src/main/cangjie/missing.cj::EntryView.openDetails\"]},\n233:                     }\n234:                 ]\n235:             },\n236:         )\n237: \n238:         with self.assertRaises(PatchError):\n239:             self.run_patch(\n240:                 [\n\n(Showing lines 1-240 of 594. Use offset=241 to continue.)\n</content>","metadata":{"preview":"import json\nimport sys\nimport tempfile\nimport unittest\nfrom pathlib import Path\nfrom unittest.mock import patch\n\nfrom scripts.shared.source_coverage import patch_authority\nfrom scripts.shared.source_coverage.facts import default_capability_facts, default_coverage_facts\nfrom scripts.shared.source_coverage.patch_authority import PatchError\nfrom scripts.tests.helpers import quiet_output\n\n\ndef write_json(path: Path, data: dict) -> None:\n    path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + \"\\n\", encoding=\"utf-8\")\n\n\nclass PatchAuthorityTest(unittest.TestCase):\n    def setUp(self) -> None:\n        self.tmp = tempfile.TemporaryDirectory()","truncated":true,"loaded":[]},"title":"..\\..\\X2Cangjie\\X2Cangjie\\scripts\\tests\\test_patch_authority.py","time":{"start":1782402742930,"end":1782402742942}},"id":"prt_eff7b7a600012FNF6EwbDeGT67","sessionID":"ses_1008692e3ffes7wyEd1LjsXTmN","messageID":"msg_e