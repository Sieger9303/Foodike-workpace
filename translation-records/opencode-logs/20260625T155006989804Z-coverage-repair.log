:         }\n39:     }\n40:     .width(100.percent)\n41:     .justifyContent(FlexAlign.SpaceBetween)\n42:     .alignItems(VerticalAlign.Center)\n43: }\n44: \n45: @Builder\n46: func buildHomeGreeting(hour: Int64) {\n47:     Column(space: 2) {\n48:         Text(homeStore.greetingForHour(hour))\n49:             .fontSize(28)\n50:             .fontWeight(FontWeight.Regular)\n51:         Text(\"Andrew\")\n52:             .fontSize(28)\n53:             .fontWeight(FontWeight.Regular)\n54:     }\n55:     .width(100.percent)\n56: }\n57: \n58: @Builder\n59: func buildHomeSectionTitle(title: String) {\n60:     Text(title)\n61:         .fontSize(20)\n62:         .fontWeight(FontWeight.Regular)\n63:         .width(100.percent)\n64: }\n65: \n66: @Builder\n67: func buildHomeAdCards(advertisements: ArrayList<AdvertisementData>) {\n68:     Scroll(Scroller()) {\n69:         Row(space: 12) {\n70:             ForEach(advertisements, itemGeneratorFunc: { advertisement: AdvertisementData, _: Int64 =>\n71:                 Row(space: 12) {\n72:                     Column(space: 8) {\n73:                         Text(advertisement.title)\n74:                             .fontSize(22)\n75:                             .fontWeight(FontWeight.Bold)\n76:                         Text(advertisement.subtitle)\n77:                             .fontSize(13)\n78:                     }\n79:                     .layoutWeight(1)\n80:                     Image(homeMedia(advertisement.mediaName))\n81:                         .width(92)\n82:                         .height(92)\n83:                 }\n84:                 .width(260)\n85:                 .padding(top: 16, right: 16, bottom: 16, left: 16)\n86:                 .backgroundColor(0xFFF4F4F4)\n87:                 .borderRadius(20)\n88:             })\n89:         }\n90:     }\n91:     .scrollable(ScrollDirection.Horizontal)\n92:     .scrollBar(BarState.Off)\n93:     .width(100.percent)\n94:     .height(140)\n95: }\n96: \n97: @Builder\n98: func buildRecommendedCategories(categories: ArrayList<FoodCategoryData>) {\n99:     Scroll(Scroller()) {\n100:         Row(space: 16) {\n101:             ForEach(categories, itemGeneratorFunc: { category: FoodCategoryData, _: Int64 =>\n102:                 Column(space: 8) {\n103:                     Image(restaurantMedia(category.mediaName))\n104:                         .width(80)\n105:                         .height(80)\n106:                         .borderRadius(40)\n107:                     Text(category.name)\n108:                         .fontSize(14)\n109:                 }\n110:                 .alignItems(HorizontalAlign.Center)\n111:             })\n112:         }\n113:     }\n114:     .scrollable(ScrollDirection.Horizontal)\n115:     .scrollBar(BarState.Off)\n116:     .width(100.percent)\n117:     .height(120)\n118: }\n119: \n120: @Builder\n121: func buildFavouriteStrip(favourites: ArrayList<RestaurantData>, onSelectRestaurant: (RestaurantData) -> Unit) {\n122:     if (favourites.size > 0) {\n123:         Column(space: 10) {\n124:             buildHomeSectionTitle(\"Order from favourites\")\n125:             Scroll(Scroller()) {\n126:                 Row(space: 12) {\n127:                     ForEach(favourites, itemGeneratorFunc: { restaurant: RestaurantData, _: Int64 =>\n128:                         Column(space: 8) {\n129:                             Image(restaurantMedia(restaurant.mediaName))\n130:                                 .width(98)\n131:                                 .height(128)\n132:                                 .borderRadius(12)\n133:                             Text(restaurant.name)\n134:                                 .fontSize(14)\n135:                         }\n136:                         .width(110)\n137:                         .alignItems(HorizontalAlign.Center)\n138:                         .onClick({ _ =>\n139:                             onSelectRestaurant(restaurant)\n140:                         })\n141:                     })\n142:                 }\n143:             }\n144:             .scrollable(ScrollDirection.Horizontal)\n145:             .scrollBar(BarState.Off)\n146:             .width(100.percent)\n147:             .height(170)\n148:         }\n149:     }\n150: }\n151: \n152: @Builder\n153: func buildFilterRow(selectedFilter: String, onToggleFilter: (String) -> Unit) {\n154:     Scroll(Scroller()) {\n155:         Row(space: 8) {\n156:             ForEach(homeStore.filtersList(), itemGeneratorFunc: { filterName: String, _: Int64 =>\n157:                 Text(filterName)\n158:                     .fontSize(14)\n159:                     .fontColor(if (selectedFilter == filterName) { Color.White } else { Color.Black })\n160:                     .padding(top: 8, right: 12, bottom: 8, left: 12)\n161:                     .backgroundColor(if (selectedFilter == filterName) { 0xFF228D39 } else { Color.White })\n162:                     .borderRadius(16)\n163:                     .border(width: 1.px, color: 0x55000000)\n164:                     .onClick({ _ =>\n165:                         onToggleFilter(filterName)\n166:                     })\n167:             })\n168:         }\n169:     }\n170:     .scrollable(ScrollDirection.Horizontal)\n171:     .scrollBar(BarState.Off)\n172:     .width(100.percent)\n173:     .height(48)\n174: }\n175: \n176: @Builder\n177: func buildRestaurantList(restaurants: ArrayList<RestaurantData>, onSelectRestaurant: (RestaurantData) -> Unit) {\n178:     Column(space: 10) {\n179:         ForEach(restaurants, itemGeneratorFunc: { restaurant: RestaurantData, _: Int64 =>\n180:             renderRestaurantCard(restaurant, { =>\n181:                 onSelectRestaurant(restaurant)\n182:             })\n183:         })\n184:     }\n185:     .width(100.percent)\n186: }\n187: \n188: @Builder\n189: func buildHomeFooter() {\n190:     Row(space: 6) {\n191:         Text(\"with\")\n192:             .fontSize(24)\n193:             .fontColor(Color.Gray)\n194:         Text(\"love\")\n195:             .fontSize(24)\n196:             .fontColor(Color.Red)\n197:         Text(\"from creator\")\n198:             .fontSize(24)\n199:             .fontColor(Color.Gray)\n200:     }\n201:     .width(100.percent)\n202:     .justifyContent(FlexAlign.Center)\n203: }\n204: \n205: @Builder\n206: public func renderHomeRoute(\n207:     state: HomePageState,\n208:     hour: Int64,\n209:     query: String,\n210:     selectedFilter: String,\n211:     onQueryChange: (String) -> Unit,\n212:     onToggleFilter: (String) -> Unit,\n213:     onProfileClick: () -> Unit,\n214:     onSelectRestaurant: (RestaurantData) -> Unit\n215: ) {\n216:     Scroll(Scroller()) {\n217:         Column(space: 18) {\n218:             buildHomeTopSection(onProfileClick)\n219:             buildHomeGreeting(hour)\n220:             renderSearchBar(query, onQueryChange)\n221:             buildHomeAdCards(state.advertisements)\n222:             buildHomeSectionTitle(\"Recommended for you\")\n223:             buildRecommendedCategories(state.categories)\n224:             buildFavouriteStrip(state.favourites, onSelectRestaurant)\n225:             buildFilterRow(selectedFilter, onToggleFilter)\n226:             buildHomeSectionTitle(\"All around you\")\n227:             buildRestaurantList(state.restaurants, onSelectRestaurant)\n228:             buildHomeFooter()\n229:         }\n230:         .width(100.percent)\n231:         .padding(top: 12, right: 16, bottom: 24, left: 16)\n232:     }\n233:     .scrollable(ScrollDirection.Vertical)\n234:     .scrollBar(BarState.Off)\n235:     .width(100.percent)\n236:     .height(100.percent)\n237:     .backgroundColor(Color.White)\n238: }\n\n(End of file - total 238 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos.resource.AppResource\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaChineseBowl, mediaClock, mediaGroceries, mediaIcProfile, mediaRider, mediaUpi}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.{renderRestaurantCard, restaurantMedia, renderSearchBar}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\nprivate func homeMedia(name: String): AppResource {\n    match (name) {\n        case \"chinese_bowl\" => mediaChineseBowl\n        case \"rider\" => mediaRider\n        case \"groceries\" => mediaGroceries\n        case \"upi\" => mediaUpi\n        case _ => mediaClock\n    }\n}\n","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_page.cj","time":{"start":1782402644266,"end":1782402644279}},"id":"prt_eff79f8ee001u6YAJeALkQYonD","sessionID":"ses_1008692e3ffes7wyEd1LjsXTmN","messageID":"msg_eff79ced50019ztYajdcvRMXsA"}}
{"type":"tool_use","timestamp":1782402644367,"sessionID":"ses_1008692e3ffes7wyEd1LjsXTmN","part":{"type":"tool","tool":"read","callID":"call_7CI58T3UZRPxCS1HazY8ftsM","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj","limit":360},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n2: \n3: import kit.ArkUI.*\n4: import ohos.arkui.state_macro_manage.Builder\n5: import ohos.arkui.state_macro_manage.Component\n6: import ohos.arkui.state_macro_manage.Entry\n7: import ohos.arkui.state_macro_manage.State\n8: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n9: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.RestaurantData\n10: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history.{historyStore, renderHistoryRoute}\n11: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home.{homeStore, renderHomeRoute}\n12: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.{loginStore, renderLoginRoute}\n13: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.{onboardingStore, renderOnboardingRoute}\n14: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{profileStore, renderProfileRoute}\n15: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.runtime.{Global, bootstrapStartRoute}\n16: \n17: @Entry\n18: @Component\n19: class FoodikeBootstrap {\n20:     @State\n21:     var currentRoute: String = bootstrapStartRoute\n22: \n23:     @State\n24:     var isShellAtTop: Bool = true\n25: \n26:     @State\n27:     var onboardingPageIndex: Int64 = 0\n28: \n29:     @State\n30:     var loginEmail: String = \"\"\n31: \n32:     @State\n33:     var loginPassword: String = \"\"\n34: \n35:     @State\n36:     var loginErrorMessage: String = \"\"\n37: \n38:     @State\n39:     var homeSearchQuery: String = \"\"\n40: \n41:     @State\n42:     var homeSelectedFilter: String = \"\"\n43: \n44:     @State\n45:     var historySearchQuery: String = \"\"\n46: \n47:     @State\n48:     var historyTabIndex: Int64 = 0\n49: \n50:     private var onboardingController: SwiperController = SwiperController()\n51: \n52:     private func applyShellState(shellState: ShellRouteState): Unit {\n53:         this.currentRoute = shellState.currentRoute\n54:         this.isShellAtTop = shellState.isAtTop\n55:     }\n56: \n57:     private func shellState(): ShellRouteState {\n58:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n59:     }\n60: \n61:     private func applyShellCommand(command: ShellCommand): Unit {\n62:         let shellState = this.shellState()\n63:         shellState.applyCommand(command)\n64:         this.applyShellState(shellState)\n65:     }\n66: \n67:     private func navigateTo(route: String): Unit {\n68:         let shellState = this.shellState()\n69:         shellState.currentRoute = route\n70:         shellState.isAtTop = true\n71:         this.applyShellState(shellState)\n72:     }\n73: \n74:     private func showBottomShell(route: String): Bool {\n75:         let shellState = this.shellState()\n76:         shellState.currentRoute = route\n77:         return shellState.showBottomShell()\n78:     }\n79: \n80:     private func routeTitle(route: String): String {\n81:         match (route) {\n82:             case \"onboarding\" => \"Onboarding\"\n83:             case \"login_screen\" => \"Login\"\n84:             case \"home_screen\" => \"Home\"\n85:             case \"history\" => \"History\"\n86:             case \"cart\" => \"Cart\"\n87:             case \"profile\" => \"Profile\"\n88:             case \"restaurant_details\" => \"Restaurant Detail\"\n89:             case _ => \"Unknown Route\"\n90:         }\n91:     }\n92: \n93:     private func showToast(message: String): Unit {\n94:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n95:     }\n96: \n97:     private func clearLoginError(): Unit {\n98:         this.loginErrorMessage = \"\"\n99:     }\n100: \n101:     private func performLogin(): Unit {\n102:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n103:             this.clearLoginError()\n104:             this.navigateTo(loginStore.successRoute())\n105:             return\n106:         }\n107: \n108:         this.loginErrorMessage = loginStore.invalidLoginMessage\n109:         this.showToast(loginStore.invalidLoginMessage)\n110:     }\n111: \n112:     private func performLogout(): Unit {\n113:         profileStore.logout(Global.abilityContext)\n114:         this.loginEmail = \"\"\n115:         this.loginPassword = \"\"\n116:         this.clearLoginError()\n117:         this.onboardingPageIndex = 0\n118:         this.homeSearchQuery = \"\"\n119:         this.homeSelectedFilter = \"\"\n120:         this.historySearchQuery = \"\"\n121:         this.historyTabIndex = 0\n122:         this.navigateTo(profileStore.logoutRoute())\n123:     }\n124: \n125:     private func routeSummary(route: String): String {\n126:         match (route) {\n127:             case \"home_screen\" => \"Home now renders repository-backed discovery content, local search/filter controls, and restaurant selection before detail routing.\"\n128:             case \"history\" => \"History now preserves search plus tab-local content, reuses favourite restaurants, and saves the selected restaurant before navigation.\"\n129:             case \"cart\" => \"Cart continues to be a shell-owned placeholder route until later phases land the real content.\"\n130:             case \"restaurant_details\" => \"Restaurant detail remains in the route contract but keeps its placeholder body until later phases.\"\n131:             case _ => \"\"\n132:         }\n133:     }\n134: \n135:     private func homeHour(): Int64 {\n136:         return 9\n137:     }\n138: \n139:     private func goToProfile(): Unit {\n140:         this.navigateTo(routePath(RouteId.Profile))\n141:     }\n142: \n143:     private func goToRestaurantDetail(): Unit {\n144:         this.navigateTo(routePath(RouteId.RestaurantDetails))\n145:     }\n146: \n147:     private func selectHomeRestaurant(restaurant: RestaurantData): Unit {\n148:         homeStore.selectRestaurant(restaurant, { =>\n149:             this.goToRestaurantDetail()\n150:         })\n151:     }\n152: \n153:     private func selectHistoryRestaurant(restaurant: RestaurantData): Unit {\n154:         historyStore.selectRestaurant(restaurant, { =>\n155:             this.goToRestaurantDetail()\n156:         })\n157:     }\n158: \n159:     @Builder\n160:     private func buildOnboardingRoute() {\n161:         renderOnboardingRoute(\n162:             this.onboardingPageIndex,\n163:             this.onboardingController,\n164:             { index: Int32 =>\n165:                 this.onboardingPageIndex = Int64(index)\n166:             },\n167:             { =>\n168:                 if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n169:                     this.navigateTo(routePath(RouteId.Login))\n170:                 } else {\n171:                     this.onboardingController.showNext()\n172:                 }\n173:             }\n174:         )\n175:     }\n176: \n177:     @Builder\n178:     private func buildLoginRoute() {\n179:         renderLoginRoute(\n180:             this.loginEmail,\n181:             this.loginPassword,\n182:             this.loginErrorMessage,\n183:             { value: String =>\n184:                 this.loginEmail = value\n185:                 this.clearLoginError()\n186:             },\n187:             { value: String =>\n188:                 this.loginPassword = value\n189:                 this.clearLoginError()\n190:             },\n191:             { => this.showToast(loginStore.comingSoonMessage) },\n192:             { => this.performLogin() },\n193:             { => this.showToast(loginStore.comingSoonMessage) },\n194:             { => this.showToast(loginStore.comingSoonMessage) },\n195:             { => this.showToast(loginStore.comingSoonMessage) },\n196:             { => this.clearLoginError() }\n197:         )\n198:     }\n199: \n200:     @Builder\n201:     private func buildProfileRoute() {\n202:         renderProfileRoute(\n203:             profileStore.userName,\n204:             profileStore.userEmail,\n205:             { => this.navigateTo(profileStore.backRoute()) },\n206:             { => this.showToast(profileStore.placeholderActionMessage) },\n207:             { => this.showToast(profileStore.placeholderActionMessage) },\n208:             { => this.performLogout() }\n209:         )\n210:     }\n211: \n212:     @Builder\n213:     private func buildHomeRoute() {\n214:         renderHomeRoute(\n215:             homeStore.loadHomeState(),\n216:             this.homeHour(),\n217:             this.homeSearchQuery,\n218:             this.homeSelectedFilter,\n219:             { value: String =>\n220:                 this.homeSearchQuery = value\n221:             },\n222:             { value: String =>\n223:                 this.homeSelectedFilter = homeStore.toggleFilter(this.homeSelectedFilter, value)\n224:             },\n225:             { => this.goToProfile() },\n226:             { restaurant: RestaurantData =>\n227:                 this.selectHomeRestaurant(restaurant)\n228:             }\n229:         )\n230:     }\n231: \n232:     @Builder\n233:     private func buildHistoryRoute() {\n234:         renderHistoryRoute(\n235:             historyStore.loadHistoryState(),\n236:             this.historyTabIndex,\n237:             this.historySearchQuery,\n238:             { value: String =>\n239:                 this.historySearchQuery = value\n240:             },\n241:             { value: Int64 =>\n242:                 this.historyTabIndex = value\n243:             },\n244:             { restaurant: RestaurantData =>\n245:                 this.selectHistoryRestaurant(restaurant)\n246:             }\n247:         )\n248:     }\n249: \n250:     @Builder\n251:     private func buildPlaceholderRoute() {\n252:         Column(space: 18) {\n253:             Text(\"Foodike\")\n254:                 .fontSize(42)\n255:                 .fontWeight(FontWeight.Bold)\n256:             Text(this.routeTitle(this.currentRoute))\n257:                 .fontSize(28)\n258:             Text(this.routeSummary(this.currentRoute))\n259:                 .fontSize(16)\n260:                 .textAlign(TextAlign.Center)\n261:                 .width(86.percent)\n262: \n263:             if (this.currentRoute == routePath(RouteId.Home) || this.currentRoute == routePath(RouteId.History)) {\n264:                 Button(if (this.isShellAtTop) { \"Simulate Scrolled Content\" } else { \"Return To Top\" })\n265:                     .onClick({ _ =>\n266:                         let shellState = this.shellState()\n267:                         shellState.setTopState(!shellState.isAtTop)\n268:                         this.applyShellState(shellState)\n269:                     })\n270:             }\n271: \n272:             Button(\"Primary Route Action\")\n273:                 .onClick({ _ =>\n274:                     this.applyShellCommand(ShellCommand.PrimaryAction)\n275:                 })\n276: \n277:             if (this.showBottomShell(this.currentRoute)) {\n278:                 Row(space: 12) {\n279:                     Button(\"Home Tab\")\n280:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HomeTab) })\n281:                     Button(\"Cart\")\n282:                         .onClick({ _ => this.applyShellCommand(ShellCommand.CartAction) })\n283:                     Button(\"History Tab\")\n284:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HistoryTab) })\n285:                 }\n286:             }\n287:         }\n288:         .width(100.percent)\n289:         .height(100.percent)\n290:         .justifyContent(FlexAlign.Center)\n291:         .alignItems(HorizontalAlign.Center)\n292:         .padding(top: 24, right: 24, bottom: 24, left: 24)\n293:     }\n294: \n295:     func build() {\n296:         if (this.currentRoute == routePath(RouteId.Onboarding)) {\n297:             this.buildOnboardingRoute()\n298:         } else if (this.currentRoute == routePath(RouteId.Login)) {\n299:             this.buildLoginRoute()\n300:         } else if (this.currentRoute == routePath(RouteId.Home)) {\n301:             this.buildHomeRoute()\n302:         } else if (this.currentRoute == routePath(RouteId.History)) {\n303:             this.buildHistoryRoute()\n304:         } else if (this.currentRoute == routePath(RouteId.Profile)) {\n305:             this.buildProfileRoute()\n306:         } else {\n307:             this.buildPlaceholderRoute()\n308:         }\n309:     }\n310: }\n\n(End of file - total 310 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos.arkui.state_macro_manage.Component\nimport ohos.arkui.state_macro_manage.Entry\nimport ohos.arkui.state_macro_manage.State\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.RestaurantData\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history.{historyStore, renderHistoryRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home.{homeStore, renderHomeRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.{loginStore, renderLoginRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.{onboardingStore, renderOnboardingRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{profileStore,