ycle.ViewModel\n32: import androidx.lifecycle.viewModelScope\n33: import com.example.foodike.domain.model.Restaurant\n34: import com.example.foodike.domain.repository.UserDataRepository\n35: import com.example.foodike.presentation.home.HomeScreenEvent\n36: import dagger.hilt.android.lifecycle.HiltViewModel\n37: import kotlinx.coroutines.launch\n38: import javax.inject.Inject\n39: \n40: \n41: @HiltViewModel\n42: class HistoryViewModel @Inject constructor(\n43:     private val userDataRepository: UserDataRepository\n44: ) : ViewModel() {\n45: \n46:     private val _likedRestaurants = mutableStateOf(HistoryState())\n47:     val likedRestaurants: State<HistoryState> = _likedRestaurants\n48: \n49:     init {\n50:         viewModelScope.launch {\n51:             userDataRepository.getLikedRestaurants().collect {\n52:                 _likedRestaurants.value = likedRestaurants.value.copy(\n53:                     likedRestaurantList = it\n54:                 )\n55: \n56:             }\n57: \n58:         }\n59:     }\n60: \n61:     fun onEvent(event: HistoryEvent) {\n62:         when (event) {\n63:             is HistoryEvent.SelectRestaurant -> {\n64:                 viewModelScope.launch {\n65:                     userDataRepository.setRestaurant(event.restaurant)\n66:                     event.onClick()\n67:                 }\n68:             }\n69:         }\n70:     }\n71: \n72: }\n\n(End of file - total 72 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following cond