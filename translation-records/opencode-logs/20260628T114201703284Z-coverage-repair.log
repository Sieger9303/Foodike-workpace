java/com/example/foodike/presentation/profile/components/ProfileCard.kt\"\n55:       ],\n56:       \"featureIds\": [\n57:         \"app-src-main-java-com-example-foodike-presentation-profi-a1f2ba5cd8-001-image-viewing-bitmap-exif-handling-zoom\",\n58:         \"app-src-main-java-com-example-foodike-presentation-profi-c34aae0a57-002-navigation-surface-menu-drawer-toolbar-o\",\n59:         \"app-src-main-java-com-example-foodike-presentation-profi-e492afed0c-004-observable-state-viewmodel-flow-livedata\",\n60:         \"app-src-main-java-com-example-foodike-presentation-profi-106c8cc862-003-runtime-permission-request-permission-re\",\n61:         \"app-src-main-java-com-example-foodike-presentation-profi-1b04c65221-003-observable-state-viewmodel-flow-livedata\",\n62:         \"app-src-main-java-com-example-foodike-presentation-profi-f941f1a12e-001-runtime-permission-request-permission-re\",\n63:         \"app-src-main-java-com-example-foodike-presentation-profi-9d1239d799-002-screen-lifecycle-entry-point-initializat\",\n64:         \"app-src-main-java-com-example-foodike-presentation-profi-3fdadde96c-001-runtime-permission-request-permission-re\",\n65:         \"app-src-main-java-com-example-foodike-presentation-profi-c201c10d27-001-runtime-permission-request-permission-re\"\n66:       ],\n67:       \"resourceInputs\": [],\n68:       \"platformCapabilityIds\": [],\n69:       \"expectedTargetDomains\": [\n70:         \"ohos_app_cangjie_entry/features/profile/profile_page.cj\",\n71:         \"ohos_app_cangjie_entry/app/bootstrap_page.cj\",\n72:         \"ohos_app_cangjie_entry/features/profile/profile_store.cj\",\n73:         \"ohos_app_cangjie_entry/app/app_router.cj\"\n74:       ],\n75:       \"requiredBehaviors\": [\n76:         \"`Profile.kt` only renders the packaged profile avatar with static user text; it does not open an image viewer, decode bitmaps, inspect EXIF metadata, or support zoom/preview gestures.\",\n77:         \"`Profile.kt` renders a back command, static profile action cards, and a logout button. The back arrow calls `navController.navigateUp()`, the action cards keep placeholder click handlers, and logout clears the start destination stack before routing to onboa...\",\n78:         \"`Profile.kt` composes against `ProfileViewModel` callbacks and navigates immediately from user actions, while keeping the visible profile identity and placeholder cards static until logout is requested.\",\n79:         \"`Profile.kt` uses only packaged resources, local click handlers, and navigation callbacks; it does not request runtime permissions or access protected Android APIs.\",\n80:         \"`ProfileViewModel.onEvent` propagates the logout action by toggling login state and then invoking the navigation callback, so the profile screen reacts immediately to the logout event.\",\n81:         \"`ProfileViewModel.onEvent` only toggles persisted login state and invokes the logout callback; it does not request permissions or call protected APIs.\",\n82:         \"`ProfileViewModel` has no independent load/resume teardown path; its lifecycle responsibility is limited to servicing the logout event while the profile screen is active.\",\n83:         \"`ProfileEvent.kt` defines only the `PerformLogout` callback payload and does not represent permission requests, results, or protected API access.\",\n84:         \"`ProfileCard.kt` is a clickable text-and-divider row and does not request permissions or access protected APIs.\"\n85:       ],\n86:       \"acceptanceEvidence\": [\n87:         \"Closed critical/high features must record sourceBehavior, targetBehavior, parityLevel, targetEndpoints, and verificationEvidence.\",\n88:         \"Build pass alone is not per-feature verification.\",\n89:         \"Referenced target tests need to be covered by the latest accepted test gate or explicit verificationEvidence.\"\n90:       ],\n91:       \"riskHints\": [\n92:         \"critical/high behavior cannot close on build pass alone\"\n93:   