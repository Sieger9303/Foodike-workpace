ssert(routeService.placeholderActionMessage(), \"Coming soon!\")\n28:         @Assert(routeService.editActionMessage(), \"Coming soon!\")\n29:         @Assert(routeService.sectionActionMessage(ProfileSection.SavedAddresses), \"Coming soon!\")\n30:         @Assert(routeService.sectionActionMessage(ProfileSection.PaymentsAndRefunds), \"Coming soon!\")\n31:         @Assert(routeService.sectionActionMessage(ProfileSection.OnlineOrderingHelp), \"Coming soon!\")\n32:         @Assert(routeService.sectionActionMessage(ProfileSection.About), \"Coming soon!\")\n33:     }\n34: \n35:     @TestCase\n36:     public func profileStorePreservesLogoutRoute(): Unit {\n37:         let store = ProfileStore()\n38:         @Assert(store.logoutRoute(), routePath(RouteId.Onboarding))\n39:     }\n40: \n41:     @TestCase\n42:     public func profileStorePreservesBackAndLogoutRoutes(): Unit {\n43:         let store = ProfileStore()\n44:         let routeService = ProfileRouteService()\n45:         let backStack = ArrayList<String>([])\n46:         backStack.add(routePath(RouteId.Home))\n47:         @Assert(store.logoutRoute(), routePath(RouteId.Onboarding))\n48:         @Assert(routeService.resolveBackRoute(routePath(RouteId.Profile), backStack), routePath(RouteId.Home))\n49:         @Assert(routeService.canNavigateBack(routePath(RouteId.Profile), backStack), true)\n50:     }\n51: \n52:     @TestCase\n53:     public func profileLogoutTransitionResetsRouteStateAndReturnsOnboarding(): Unit {\n54:         let store = ProfileStore()\n55:         let routeService = ProfileRouteService()\n56:         let transition = routeService.buildLogoutTransition(store.logoutRoute())\n57:         @Assert(transition.nextRoute, routePath(RouteId.Onboarding))\n58:         @Assert(transition.resetState.loginEmail, \"\")\n59:         @Assert(transition.resetState.loginPassword, \"\")\n60:         @Assert(transition.resetState.onboardingPageIndex, 0)\n61:         @Assert(transition.resetState.homeSearchQuery, \"\")\n