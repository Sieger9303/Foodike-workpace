                      \"coverageFacts\": facts,\n343:                         },\n344:                     }\n345:                 ]\n346:             },\n347:         )\n348: \n349:         rc = self.run_patch([\"--kind\", \"matrix\", \"--authority\", str(matrix), \"--patch\", str(patch_file)])\n350: \n351:         self.assertEqual(0, rc)\n352:         updated = json.loads(matrix.read_text(encoding=\"utf-8\"))\n353:         self.assertEqual(\"implemented\", updated[\"entries\"][0][\"coverageFacts\"][\"closureKind\"])\n354:         self.assertEqual(1, updated[\"lastPatchSummary\"][\"statusCountsAfter\"][\"implemented\"])\n355: \n356:     def test_matrix_patch_accepts_structured_evidence_for_closed_rows(self) -> None:\n357:         matrix = self.matrix_path()\n358:         facts = default_coverage_facts(facts_source=\"agent\")\n359:         facts.update(\n360:             {\n361:                 \"closureKind\": \"implemented\",\n362:                 \"parityKind\": \"equivalent\",\n363:                 \"sourceBehaviorMapped\": True,\n364:                 \"targetBehaviorImplemented\": True,\n365:             }\n366:         )\n367:         facts[\"verification\"][\"targetEndpoints\"] = [\"entry/src/main/cangjie/index.cj::openDetails\"]\n368:         facts[\"verification\"][\"manualEvidence\"] = [\n369:             {\"kind\": \"manual-review\", \"detail\": \"Manual route smoke verified the translated click.\"}\n370:         ]\n371:         patch_file = self.root / \"facts-closed-row-patch.json\"\n372:         write_json(\n373:             patch_file,\n374:             {\n375:                 \"updates\": [\n376:                     {\n377:                         \"featureId\": \"main-click-001\",\n378:                         \"set\": {\n379:                             \"status\": \"implemented\",\n380:                             \"parityLevel\": \"equivalent\",\n381:                             \"targetBehavior\": \"The ArkUI button opens the details route.\",\n382:                             \"coverageFacts\": facts,\n383:                         },\n384:                     }\n385:                 ]\n386:             },\n387:         )\n388: \n389:         rc = self.run_patch([\"--kind\", \"matrix\", \"--authority\", str(matrix), \"--patch\", str(patch_file)])\n390: \n391:         self.assertEqual(0, rc)\n392:         updated = json.loads(matrix.read_text(encoding=\"utf-8\"))\n393:         entry = updated[\"entries\"][0]\n394:         self.assertEqual(\"implemented\", entry[\"status\"])\n395:         self.assertEqual(\"implemented\", entry[\"coverageFacts\"][\"closureKind\"])\n396: \n397:     def test_matrix_patch_rejects_invalid_coverage_facts(self) -> None:\n398:         matrix = self.matrix_path()\n399:         facts = default_coverage_facts(facts_source=\"agent\")\n400:         facts[\"closureKind\"] = \"mostly-done\"\n401:         patch_file = self.root / \"bad-facts-patch.json\"\n402:         write_json(\n403:             patch_file,\n404:             {\n405:                 \"updates\": [\n406:                     {\n407:                         \"featureId\": \"main-click-001\",\n408:                         \"set\": {\"coverageFacts\": facts},\n409:                     }\n410:                 ]\n411:             },\n412:         )\n413: \n414:         with self.assertRaises(PatchError):\n415:             self.run_patch([\"--kind\", \"matrix\", \"--authority\", str(matrix), \"--patch\", str(patch_file)])\n416: \n417:     def test_matrix_patch_rejects_non_agent_coverage_facts_update(self) -> None:\n418:         matrix = self.matrix_path()\n419:         facts = default_coverage_facts()\n420:         facts[\"closureKind\"] = \"implemented\"\n421:         patch_file = self.root / \"non-agent-facts-patch.json\"\n422:         write_json(\n423:             patch_file,\n424:             {\n425:                 \"updates\": [\n426:                     {\n427:                         \"featureId\": \"main-click-001\",\n428:                         \"set\": {\"coverageFacts\": facts},\n429:                     }\n430:                 ]\n431:             },\n432:         )\n433: \n434:         with self.assertRaises(PatchError):\n435:             self.run_patch([\"--kind\", \"matrix\", \"--authority\", str(matrix), \"--patch\", str(patch_file)])\n436: \n437:     def test_platform_patch_updates_deferred_capability(self) -> None:\n438:         platform = self.platform_path()\n439:         patch_file = self.root / \"platform-patch.json\"\n440:         write_json(\n441:             patch_file,\n442:             {\n443:                 \"updates\": [\n444:                     {\n445:                         \"capabilityId\": \"clipboard-pasteboard\",\n446:                         \"set\": {\n447:                             \"status\": \"deferred\",\n448:                             \"blocker\": \"Current SDK scan did not verify a pure Cangjie pasteboard API.\",\n449:                             \"targetFallback\": \"Show the value and let the user copy it manually.\",\n450:                             \"futureCompletionPath\": \"Re-check pure Cangjie pasteboard declarations in the target SDK.\",\n451:                             \"phaseCapabilityResolution\": \"resolved-deferred\",\n\n(Showing lines 32-451 of 594. Use offset=452 to continue.)\n</content>","metadata":{"preview":"        write_json(\n            path,\n            {\n                \"schemaVersion\": 1,\n                \"allowedStatuses\": [\"implemented\", \"planned\"],\n                \"entries\": [\n                    {\n                        \"featureId\": \"main-click-001\",\n                        \"featureName\": \"Main click\",\n                        \"sourcePath\": \"app/src/main/java/MainActivity.java\",\n                        \"importance\": \"high\",\n                        \"category\": \"java-source\",\n                        \"sourceEvidence\": \"path=MainActivity.java; featurePoint=onClick opens