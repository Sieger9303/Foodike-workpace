: list(COVERAGE_BLOCKER_KINDS),\n194:     }\n195: \n196: \n197: def allowed_capability_facts() -> dict[str, list[str]]:\n198:     \"\"\"Return machine-readable legal values for platform capability facts.\"\"\"\n199: \n200:     return {\n201:         \"resolutionKind\": list(CAPABILITY_RESOLUTION_KINDS),\n202:         \"apiEvidenceKinds\": list(CAPABILITY_API_EVIDENCE_KINDS),\n203:         \"callableApiEvidenceKinds\": list(CAPABILITY_CALLABLE_API_EVIDENCE_KINDS),\n204:         \"discoveryOnlyEvidenceKinds\": list(CAPABILITY_DISCOVERY_ONLY_EVIDENCE_KINDS),\n205:         \"compileProbeEvidenceKinds\": list(CAPABILITY_COMPILE_PROBE_EVIDENCE_KINDS),\n206:         \"fallbackKinds\": list(CAPABILITY_FALLBACK_KINDS),\n207:         \"blockerKinds\": list(CAPABILITY_BLOCKER_KINDS),\n208:         \"factsSource\": list(FACTS_SOURCES),\n209:     }\n210: \n211: \n212: def default_coverage_facts(*, facts_source: str = \"template\") -> dict[str, Any]:\n213:     \"\"\"Return a fresh default source coverage fact object.\"\"\"\n214: \n215:     facts = {\n216:         \"schemaVersion\": FACTS_SCHEMA_VERSION,\n217:         \"closureKind\": \"open\",\n218:         \"parityKind\": \"unverified\",\n219:         \"sourceBehaviorMapped\": False,\n220:         \"targetBehaviorImplemented\": False,\n221:         \"activeSimplification\": {\n222:             \"used\": False,\n223:             \"reason\": \"\",\n224:             \"preservedBehaviors\": [],\n225:             \"omittedBehaviors\": [],\n226:         },\n227:         \"activeDeferred\": {\n228:             \"used\": False,\n229:             \"blockerKind\": \"\",\n230:             \"blocker\": \"\",\n231:             \"fallbackBehavior\": \"\",\n232:             \"futureCompletionPath\": \"\",\n233:         },\n234:         \"verification\": {\n235:             \"targetEndpoints\": [],\n236:             \"testEvidence\": [],\n237:             \"buildEvidence\": [],\n238:             \"runtimeEvidence\": [],\n239:             \"manualEvidence\": [],\n240:         },\n241:         \"factsSource\": facts_source,\n242:     }\n243:     return copy.deepcopy(facts)\n244: \n245: \n246: def default_capability_facts(*, facts_source: str = \"template\") -> dict[str, Any]:\n247:     \"\"\"Return a fresh default platform capability fact object.\"\"\"\n248: \n249:     facts = {\n250:         \"schemaVersion\": FACTS_SCHEMA_VERSION,\n251:         \"resolutionKind\": \"open\",\n252:         \"activeFallback\": {\n253:             \"used\": False,\n254:             \"fallbackKind\": \"\",\n255:             \"reason\": \"\",\n256:             \"blocker\": \"\",\n257:         },\n258:         \"apiEvidence\": [],\n259:         \"discoveryOnlyEvidence\": [],\n260:         \"compileProbeEvidence\": [],\n261:         \"targetEndpoints\": [],\n262:         \"blocker\": {\n263:             \"used\": False,\n264:             \"kind\": \"\",\n265:             \"detail\": \"\",\n266:             \"futureCompletionPath\": \"\",\n267:         },\n268:         \"factsSource\": facts_source,\n269:     }\n270:     return copy.deepcopy(facts)\n271: \n272: \n273: def _text_items(value: Any) -> list[str]:\n274:     if isinstance(value, list):\n275:         return [str(item).strip() for item in value if str(item or \"\").strip()]\n276:     if value in (None, \"\"):\n277:         return []\n278:     text = str(value).strip()\n279:     return [text] if text else []\n280: \n281: \n282: def _first_text(*values: Any) -> str:\n283:     for value in values:\n284:         items = _text_items(value)\n285:         if items:\n286:             return items[0]\n287:     return \"\"\n288: \n289: \n290: def _normalized_text(*values: Any) -> str:\n291:     return \" \".join(item.lower() for value in values for item in _text_items(value))\n292: \n293: \n294: def _evidence_items(value: Any, *, kind: str) -> list[dict[str, str]]:\n295:     result: list[dict[str, str]] = []\n296:     for text in _text_items(value):\n297:         item: dict[str, str] = {\"kind\": kind, \"detail\": text}\n298:         if \"/\" in text or \"\\\\\" in text:\n299:             item[\"path\"] = text\n300:         result.append(item)\n301:     return result\n302: \n303: \n304: def _sdk_declaration_evidence_items(value: Any) -> list[dict[str, str]]:\n305:     return [\n306:         item\n307:         for item in _evidence_items(value, kind=\"cangjie-sdk-declaration\")\n308:         if not _sdk_declaration_text_is_negated(item[\"detail\"].lower())\n309:     ]\n310: \n311: \n312: def _coverage_closure_from_status(status: str) -> str:\n313:     return {\n314:         \"implemented\": \"implemented\",\n315:         \"implemented-simplified\": \"simplified\",\n316:         \"platform-replaced\": \"platform-replaced\",\n317:         \"deferred\": \"deferred\",\n318:         \"not-applicable\": \"not-applicable\",\n319:     }.get(status, \"open\")\n320: \n\n(Showing lines 1-320 of 998. Use offset=321 to continue.)\n</content>","metadata":{"preview":"\"\"\"Structured fact schemas for coverage and platform authority records.\"\"\"\n\nfrom __future__ import annotations\n\nimport copy\nfrom typing import Any\n\nFACTS_SCHEMA_VERSION = 1\n\nCOVERAGE_FACTS_KEY = \"coverageFacts\"\nCAPABILITY_FACTS_KEY = \"capabilityFacts\"\n\nFACTS_SOURCES = (\"agent\", \"inferred-from-legacy\", \"template\")\n\nCOVERAGE_CLOSURE_KINDS = (\n    \"open\",\n    \"implemented\",\n    \"simplified\",\n    \"platform-replaced\",\n    \"deferred\",","truncated":true,"loaded":[]},"title":"..\\..\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\facts.py","time":{"start":1782404431823,"end":1782404431832}},"id":"prt_eff953fa8004lJKZ2KZQuGecX4","sessionID":"ses_1006c5c95ffeP0kIq47sKblB1o","messageID":"msg_eff95071200109pzkZOHDLCskg"}}
