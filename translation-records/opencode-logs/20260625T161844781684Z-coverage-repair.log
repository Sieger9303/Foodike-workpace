ty.py\", updated[\"lastUpdatedBy\"])\n148:         self.assertIn(\"main-click-001\", updated[\"lastPatchSummary\"][\"updatedIds\"])\n149:         markdown = matrix.with_suffix(\".md\").read_text(encoding=\"utf-8\")\n150:         self.assertIn(\"main-click-001\", markdown)\n151:         self.assertIn(\"implemented\", markdown)\n152: \n153:     def test_matrix_patch_validates_plan_phase_and_target_endpoint(self) -> None:\n154:         matrix = self.matrix_path()\n155:         patch_file = self.root / \"patch.json\"\n156:         write_json(\n157:             patch_file,\n158:             {\n159:                 \"updates\": [\n160:                     {\n161:                         \"featureId\": \"main-click-001\",\n162:                         \"set\": {\n163:                             \"status\": \"implemented\",\n164:                             \"parityLevel\": \"equivalent\",\n165:                             \"targetBehavior\": \"The ArkUI button opens the details route.\",\n166:                         },\n167:                         \"append\": {\n168:                             \"verificationEvidence\": [\"manual route smoke shows details page after click\"],\n169:                             \"targetEndpoints\": [\"entry/src/main/cangjie/index.cj::EntryView.openDetails\"],\n170:                         },\n171:                     }\n172:                 ]\n173:             },\n174:         )\n175: \n176:         rc = self.run_patch(\n177:             [\n178:                 \"--kind\",\n179:                 \"matrix\",\n180:                 \"--authority\",\n181:                 str(matrix),\n182:                 \"--patch\",\n183:                 str(patch_file),\n184:                 \"--plan-json\",\n185:                 str(self.plan_path()),\n186:                 \"--target-project\",\n187:                 str(self.target_project()),\n188:             ]\n189:         )\n190: \n191:         self.assertEqual(0, rc)\n192: \n193:     def test_matrix_