6:     \"deferred\": {\"deferred\"},\n57:     \"not-applicable\": {\"not-applicable\"},\n58: }\n59: \n60: CAPABILITY_RESOLUTION_KINDS = (\n61:     \"open\",\n62:     \"direct-api\",\n63:     \"platform-replacement\",\n64:     \"fallback\",\n65:     \"deferred\",\n66:     \"not-applicable\",\n67: )\n68: CAPABILITY_API_EVIDENCE_KINDS = (\n69:     \"cangjie-sdk-declaration\",\n70:     \"cangjie-callable-api\",\n71:     \"harmonyos-example\",\n72:     \"third-party-package\",\n73:     \"target-endpoint\",\n74:     \"compile-probe-pass\",\n75:     \"build-gate-pass\",\n76: )\n77: CAPABILITY_CALLABLE_API_EVIDENCE_KINDS = (\n78:     \"cangjie-sdk-declaration\",\n79:     \"cangjie-callable-api\",\n80:     \"harmonyos-example\",\n81:     \"third-party-package\",\n82: )\n83: CAPABILITY_DISCOVERY_ONLY_EVIDENCE_KINDS = (\n84:     \"arkts-doc\",\n85:     \"native-doc\",\n86:     \"overview-doc\",\n87:     \"marketing-doc\",\n88:     \"unknown-language-example\",\n89: )\n90: CAPABILITY_COMPILE_PROBE_EVIDENCE_KINDS = (\n91:     \"compile-probe-pass\",\n92:     \"compile-probe-fail\",\n93:     \"compile-probe-blocked\",\n94:     \"build-gate-pass\",\n95:     \"build-gate-fail\",\n96: )\n97: CAPABILITY_FALLBACK_KINDS = (\n98:     \"local-simulation\",\n99:     \"sample-data\",\n100:     \"in-memory-state\",\n101:     \"manual-user-action\",\n102:     \"ui-disabled\",\n103:     \"product-omission\",\n104: )\n105: CAPABILITY_BLOCKER_KINDS = (\n106:     \"missing-cangjie-sdk-declaration\",\n107:     \"arkts-only-api\",\n108:     \"native-only-api\",\n109:     \"missing-package\",\n110:     \"requires-device-service\",\n111:     \"requires-credentials\",\n112:     \"requires-product-decision\",\n113:     \"compile-probe-failed\",\n114:     \"unknown\",\n115: )\n116: \n117: LEGACY_ACTIVE_FALLBACK_KEYWORDS = (\n118:     \"demo data\",\n119:     \"fake\",\n120:     \"fixture\",\n121:     \"hard-coded\",\n122:     \"hardcoded\",\n123:     \"in memory\",\n124:     \"in-memory\",\n125:     \"