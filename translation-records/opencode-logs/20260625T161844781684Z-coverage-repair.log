str(patch_file),\n247:                     \"--target-project\",\n248:                     str(self.target_project()),\n249:                     \"--no-markdown\",\n250:                 ]\n251:             )\n252: \n253:     def test_matrix_patch_rejects_missing_target_endpoint_symbol(self) -> None:\n254:         matrix = self.matrix_path()\n255:         patch_file = self.root / \"patch.json\"\n256:         write_json(\n257:             patch_file,\n258:             {\n259:                 \"updates\": [\n260:                     {\n261:                         \"featureId\": \"main-click-001\",\n262:                         \"append\": {\"targetEndpoints\": [\"entry/src/main/cangjie/index.cj::EntryView.missingAction\"]},\n263:                     }\n264:                 ]\n265:             },\n266:         )\n267: \n268:         with self.assertRaises(PatchError):\n269:             self.run_patch(\n270:                 [\n271:                     \"--kind\",\n272:                     \"matrix\",\n273:                     \"--authority\",\n274:                     str(matrix),\n275:                     \"--patch\",\n276:                     str(patch_file),\n277:                     \"--target-project\",\n278:                     str(self.target_project()),\n279:                     \"--no-markdown\",\n280:                 ]\n281:             )\n282: \n283:     def test_matrix_patch_rejects_status_without_required_evidence(self) -> None:\n284:         matrix = self.matrix_path()\n285:         patch_file = self.root / \"bad-patch.json\"\n286:         write_json(\n287:             patch_file,\n288:             {\n289:                 \"updates\": [\n290:                     {\n291:                         \"featureId\": \"main-click-001\",\n292:                         \"set\": {\"status\": \"implemented\", \"parityLevel\": \"equivalent\"},\n293:                     }\n294:                 ]\n295:             },\n296:         )\n297: \n298:         with self.assertRai