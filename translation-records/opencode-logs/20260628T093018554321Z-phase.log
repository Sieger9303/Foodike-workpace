 450) {\n39:         \"450+\"\n40:     } else if (ratingCount > 500) {\n41:         \"500+\"\n42:     } else if (ratingCount > 550) {\n43:         \"550+\"\n44:     } else if (ratingCount > 600) {\n45:         \"600+\"\n46:     } else if (ratingCount > 650) {\n47:         \"650+\"\n48:     } else if (ratingCount > 700) {\n49:         \"700+\"\n50:     } else if (ratingCount > 750) {\n51:         \"750+\"\n52:     } else if (ratingCount > 800) {\n53:         \"800+\"\n54:     } else {\n55:         \"1000+\"\n56:     }\n57: }\n58: \n59: public func usesBundledRestaurantMedia(restaurant: RestaurantData): Bool {\n60:     return restaurant.usesBundledMediaOnly()\n61: }\n62: \n63: public func formatEta(minutes: Int64): String {\n64:     let hours = minutes / 60\n65:     let remainder = minutes % 60\n66:     if (hours > 0) {\n67:         return \"${hours} Hr ${remainder} Min\"\n68:     }\n69:     return \"${remainder} Min\"\n70: }\n71: \n72: @Builder\n73: public func renderRestaurantCard(restaurant: RestaurantData, onSelect: () -> Unit) {\n74:     Row(space: 14) {\n75:         Image(restaurantMedia(restaurant.mediaName))\n76:             .width(120)\n77:             .height(154)\n78:             .borderRadius(12)\n79:         Column(space: 8) {\n80:             Text(restaurant.name)\n81:                 .fontSize(18)\n82:                 .fontWeight(FontWeight.Bold)\n83:             Row(space: 6) {\n84:                 Image(mediaStar)\n85:                     .width(18)\n86:                     .height(18)\n87:                 Text(\"${restaurant.rating}(${getCustomerInfo(restaurant.ratingCount)})\")\n88:                     .fontSize(14)\n89:                 Text(\".\")\n90:                     .fontWeight(FontWeight.Bold)\n91:                 Text(formatEta(restaurant.etaMinutes))\n92:                     .fontSize(14)\n93:             }\n94:             Text(restaurant.variety)\n95:                 .fontSize(14)\n96:                 .fontColor(Color.Gray)\n97:             Text(restaurant.place)\n98:                 .fontSize(14)\n99:                 .fontColor(Color.Gray)\n100:         }\n101:         .layoutWeight(1)\n102:     }\n103:     .width(100.percent)\n104:     .padding(top: 8, right: 8, bottom: 8, left: 8)\n105:     .backgroundColor(Color.White)\n106:     .borderRadius(16)\n107:     .onClick({ _ =>\n108:         onSelect()\n109:     })\n110: }\n\n(End of file - total 110 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos.resource.AppResource\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.RestaurantData\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaApplePie, mediaBiryani, mediaBurger, mediaChinese, mediaDosa, mediaParatha, mediaPizza, mediaStar}\n\npublic func restaurantMedia(name: String): AppResource {\n    match (name) {\n        case \"biryani\" => mediaBiryani\n        case \"burger\" => mediaBurger\n        case \"chinese\" => mediaChinese\n        case \"dosa\" => mediaDosa\n        case \"paratha\" => mediaParatha\n        case \"pizza\" => mediaPizza\n        case _ => mediaApplePie\n    }\n}\n","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\common\\widgets\\restaurant_card.cj","time":{"start":1782639054902,"end":1782639054912}},"id":"prt_f0d915031001ozuat8lSNkZeQP","sessionID":"ses_0f26f3813ffe6NuLdrdHq2lOyv","messageID":"msg_f0d91004c0016CTBZIGzCOWbx2"}}
