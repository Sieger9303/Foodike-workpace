tring): ArrayList<RestaurantData> {\n95:         let filtered = ArrayList<RestaurantData>([])\n96:         for (restaurant in restaurants) {\n97:             if (matchesTag(restaurant, tag)) {\n98:                 filtered.add(restaurant)\n99:             }\n100:         }\n101:         return filtered\n102:     }\n103: \n104:     private func matchesQuery(restaurant: RestaurantData, query: String): Bool {\n105:         return containsIgnoreCase(restaurant.name, query)\n106:             || containsIgnoreCase(restaurant.variety, query)\n107:             || containsIgnoreCase(restaurant.place, query)\n108:     }\n109: \n110:     public func matchesTag(restaurant: RestaurantData, tag: String): Bool {\n111:         match (tag) {\n112:             case \"Fast Delivery\" => restaurant.etaMinutes <= 30\n113:             case \"50% Discount\" => restaurant.averagePrice <= 2.5\n114:             case \"Great deals\" => restaurant.rating >= 4.5\n115:             case \"Non-Veg\" => !containsIgnoreCase(restaurant.variety, \"Vegetarian\")\n116:             case _ => true\n117:         }\n118:     }\n119: \n120:     public func containsIgnoreCase(source: String, query: String): Bool {\n121:         let normalizedSource = source.toLower()\n122:         let normalizedQuery = query.toLower()\n123:         let sourceLength = normalizedSource.size\n124:         let queryLength = normalizedQuery.size\n125:         if (queryLength == 0) {\n126:             return true\n127:         }\n128:         if (queryLength > sourceLength) {\n129:             return false\n130:         }\n131:         var start: Int64 = 0\n132:         while (start + queryLength <= sourceLength) {\n133:             if (normalizedSource[start..(start + queryLength)] == normalizedQuery) {\n134:                 return true\n135:             }\n136:             start += 1\n137:         }\n138:         return false\n139:     }\n140: \n141:     public func session(): SessionRepository {\n142:         return sessionRepository\n143:     }\n144: }\n\n(End of file - total 144 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.homeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\nimport std.unicode.*\n\npublic let homeStore = HomeStore()\n\npublic class HomeStore {\n    private let contentRepository = homeContentRepository\n    private let sessionRepository = sessionRepository\n    private let filters = ArrayList<String>([\n        \"Fast Delivery\",\n        \"50% Discount\",\n        \"Great deals\",\n        \"Non-Veg\"\n    ])\n","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_store.cj","time":{"start":1782639054958,"end":1782639054974}},"id":"prt_f0d91506a001XT5qN5XBSDrGKD","sessionID":"ses_0f26f3813ffe6NuLdrdHq2lOyv","messageID":"msg_f0d91004c0016CTBZIGzCOWbx2"}}
