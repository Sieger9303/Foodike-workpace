{"type":"tool_use","timestamp":1782579140369,"sessionID":"ses_0f601b585ffeXhzFroJg7XaNbQ","part":{"type":"tool","tool":"read","callID":"call_C0gS4UQOs3rCioQ96XtYGNTg","state":{"status":"completed","input":{"filePath":"C:\\Users\\Sieger\\.cangjie-sdk\\6.0\\cangjie\\api\\modules\\linux_ohos_aarch64_cjnative\\ohos\\ohos.file.photo_access_helper.cj.d","limit":120,"offset":636},"output":"<path>C:\\Users\\Sieger\\.cangjie-sdk\\6.0\\cangjie\\api\\modules\\linux_ohos_aarch64_cjnative\\ohos\\ohos.file.photo_access_helper.cj.d</path>\n<type>file</type>\n<content>\n636:  * Obtains a PhotoAccessHelper instance for accessing and modifying media files in the album.\n637:  * @param { UIAbilityContext } context - Context of the ability instance.\n638:  * @returns { PhotoAccessHelper } Instance of PhotoAccessHelper\n639:  * @throws { BusinessException } 13900020 - Invalid argument\n640:  */\n641: @!APILevel[\n642:     since: \"22\",\n643:     syscap: \"SystemCapability.FileManagement.PhotoAccessHelper.Core\",\n644:     throwexception: true\n645: ]\n646: public func getPhotoAccessHelper(context: UIAbilityContext): PhotoAccessHelper\n647: \n648: /**\n649:  * Helper functions to access photos and albums.\n650:  */\n651: @!APILevel[\n652:     since: \"22\",\n653:     syscap: \"SystemCapability.FileManagement.PhotoAccessHelper.Core\"\n654: ]\n655: public class PhotoAccessHelper {\n656:     /**\n657:      * Fetch photo assets\n658:      * @param { FetchOptions } options - Options for fetching the image and video assets.\n659:      * @returns { PhotoAssetResult } Returns the fetch result.\n660:      * @throws { BusinessException } 201 - Permission denied\n661:      * @throws { BusinessException } 13900020 - Invalid argument\n662:      * @throws { BusinessException } 14000011 - System inner fail\n663:      */\n664:     @!APILevel[\n665:         since: \"22\",\n666:         permission: \"ohos.permission.READ_IMAGEVIDEO\",\n667:         syscap: \"SystemCapability.FileManagement.PhotoAccessHelper.Core\",\n668:         throwexception: true,\n669:         workerthread: true\n670:     ]\n671:     public func getAssets(options: FetchOptions): PhotoAssetResult\n672: \n673:     /**\n674:      * Fetch a group of burst assets\n675:      * @param { String } burstKey - UUID of a set of burst photos (BURST_KEY of PhotoKeys). The value is a string of 36 characters.\n676:      * @param { FetchOptions } options - Options for fetching the burst photos.\n677:      * @returns { PhotoAssetResult } Returns the fetch result.\n678:      * @throws { BusinessException } 201 - Permission denied\n679:      * @throws { BusinessException } 14000011 - Internal system error\n680:      */\n681:     @!APILevel[\n682:         since: \"22\",\n683:         permission: \"ohos.permission.READ_IMAGEVIDEO\",\n684:         syscap: \"SystemCapability.FileManagement.PhotoAccessHelper.Core\",\n685:         throwexception: true,\n686:         workerthread: true\n687:     ]\n688:     public func getBurstAssets(burstKey: String, options: FetchOptions): PhotoAssetResult\n689: \n690:     /**\n691:      * Obtains albums based on the specified options and album type.\n692:      * Before the operation, ensure that the albums to obtain exist.\n693:      * @param { AlbumType } albumType - Type of the album.\n694:      * @param { AlbumSubtype } subtype - Album subtype.\n695:      * @param { FetchOptions } [options] - Options for fetching the albums.\n696:      * @returns { AlbumResult } Returns the fetch result\n697:      * @throws { BusinessException } 201 - Permission denied\n698:      * @throws { BusinessException } 13900020 - Invalid argument\n699:      * @throws { BusinessException } 14000011 - System inner fail\n700:      */\n701:     @!APILevel[\n702:         since: \"22\",\n703:         permission: \"ohos.permission.READ_IMAGEVIDEO\",\n704:         syscap: \"SystemCapability.FileManagement.PhotoAccessHelper.Core\",\n705:         throwexception: true,\n706:         workerthread: true\n707:     ]\n708:     public func getAlbums(albumType: AlbumType, subtype: AlbumSubtype,\n709:         options!: FetchOptions = FetchOptions([\"uri\", \"album_name\"], DataSharePredicates())): AlbumResult\n710: \n711:     /**\n712:      * Registers listening for the specified URI. This API uses a callback to return the result.\n713:      * @param { String } uri - URI of the photo asset, URI of the album, or DefaultChangeUri.\n714:      * @param { Bool } forChildUris - Whether to perform fuzzy listening.\n715:      * If uri is the URI of an album, the value true means to listen for the changes of the files in the album;\n716:      * the value false means to listen for the changes of the album only.\n717:      * If uri is the URI of a photoAsset, there is no difference between true and false for forChildUris.\n718:      * If uri is DefaultChangeUri, forChildUris must be set to true. If forChildUris is false,\n719:      * the URI cannot be found and no message can be received.\n720:      * @param { Callback1Argument<ChangeData> } callback - Callback used to return the ChangeData.\n721:      * Multiple callback listeners can be registered for a URI.\n722:      * You can use unRegisterChange to unregister all listeners for the URI or a specified callback listener.\n723:      * @throws { BusinessException } 13900012 - Permission denied\n724:      * @throws { BusinessException } 13900020 - Invalid argument\n725:      */\n726:     @!APILevel[\n727:         since: \"22\",\n728:         syscap: \"SystemCapability.FileManagement.PhotoAccessHelper.Core\",\n729:         throwexception: true\n730:     ]\n731:     public func registerChange(uri: String, forChildUris: Bool, callback: Callback1Argument<ChangeData>): Unit\n732: \n733:     /**\n734:      * Unregisters listening for the specified URI. Multiple callbacks can be registered for a URI for listening.\n735:      * You can use this API to unregister the listening of the specified callbacks or all callbacks.\n736:      * @param { String } uri - URI of the photo asset, URI of the album, or DefaultChangeUri.\n737:      * @param { ?Callback1Argument<ChangeData> } [callback] - The callback function to unregister.\n738:      * @throws { BusinessException } 13900012 - Permission denied\n739:      * @throws { BusinessException } 13900020 - Invalid argument\n740:      */\n741:     @!APILevel[\n742:         since: \"22\",\n743:         syscap: \"SystemCapability.FileManagement.PhotoAccessHelper.Core\",\n744:         throwexception: true\n745:     ]\n746:     public func unregisterChange(uri: String, callback!: ?Callback1Argument<ChangeData> = None): Unit\n747: \n748:     /**\n749:      * Create a save dialog to save photos\n750:      * @param { Array<String> } srcFileUris - List of the file uris to be saved\n751:      * @param { Array<PhotoCreationConfig> } photoCreationConfigs - List of the photo asset creation configs\n752:      * @param { Callback1Argument<Array<String>> } callback - Callback used to returns the media library file uri list to application which has been authorized\n753:      * @throws { BusinessException } 14000011 - Internal system error\n754:      */\n755:     @!APILevel[\n\n(Showing lines 636-755 of 2389. Use offset=756 to continue.)\n</content>","metadata":{"preview":" * Obtains a PhotoAccessHelper instance for accessing and modifying media files in the album.\n * @param { UIAbilityContext } context - Context of the ability instance.\n * @returns { PhotoAccessHelper } Instance of PhotoAccessHelper\n * @throws { BusinessException } 13900020 - Invalid argument\n */\n@!APILevel[\n    since: \"22\",\n    syscap: \"SystemCapability.FileManagement.PhotoAccessHelper.Core\",\n    throwexception: true\n]\npublic func getPhotoAccessHelper(context: UIAbilityContext): PhotoAccessHelper\n\n/**\n * Helper functions to access photos and albums.\n */\n@!APILevel[\n    since: \"22\",\n    syscap: \"SystemCapability.FileManagement.PhotoAccessHelper.Core\"\n]\npublic class PhotoAccessHelper {","truncated":true,"loaded":[]},"title":"C:\\Users\\Sieger\\.cangjie-sdk\\6.0\\cangjie\\api\\modules\\linux_ohos_aarch64_cjnative\\ohos\\ohos.file.photo_access_helper.cj.d","time":{"start":1782579140358,"end":1782579140368}},"id":"prt_f09ff16ee001a78Rr3ROzOSAYx","sessionID":"ses_0f601b585ffeXhzFroJg7XaNbQ","messageID":"msg_f09fef6bd001sn6AoiFUPpiNir"}}
