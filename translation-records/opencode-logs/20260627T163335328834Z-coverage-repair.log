or_evidence,\n42:         matrix_entries_by_id,\n43:         parity_level,\n44:     )\n45:     from shared.source_coverage.platform import (  # type: ignore\n46:         capability_entries_by_id,\n47:         capability_target_endpoints,\n48:         effective_capability_status,\n49:         has_compile_probe_evidence,\n50:         has_direct_unavailable_blocker,\n51:         has_replacement_api_evidence,\n52:         platform_missing_deferred_fields,\n53:     )\n54:     from shared.source_coverage.render import (  # type: ignore\n55:         platform_capability_check_markdown,\n56:         source_coverage_matrix_markdown,\n57:     )\n58:     from shared.source_coverage.utils import has_text, has_text_or_list  # type: ignore\n59: else:\n60:     from ..common import HelpFormatter, expand_path, now_iso, write_json, write_text\n61:     from .constants import (\n62:         MATRIX_DEFERRED_REQUIRED_FIELDS,\n63:         MATRIX_IMPLEMENTED_STATUSES,\n64:         MATRIX_PARITY_LEVELS,\n65:         MATRIX_STATUSES,\n66:         PLATFORM_CAPABILITY_IMPLEMENTED_STATUSES,\n67:         PLATFORM_CAPABILITY_STATUSES,\n68:     )\n69:     from .facts import (\n70:         CAPABILITY_FACTS_KEY,\n71:         COVERAGE_FACTS_KEY,\n72:         default_capability_facts,\n73:         default_coverage_facts,\n74:         validate_capability_facts,\n75:         validate_coverage_facts,\n76:     )\n77:     from .matrix import (\n78:         MATRIX_AGENT_FIELDS,\n79:         coverage_target_endpoints,\n80:         coverage_verification_evidence_items,\n81:         effective_matrix_status,\n82:         has_source_behavior_evidence,\n83:         has_target_behavior_evidence,\n84:         matrix_entries_by_id,\n85:         parity_level,\n86:     )\n87:     from .platform import (\n88:         capability_entries_by_id,\n89:         capability_target_endpoints,\n90:         effective_capability_status,\n91:         has_compile_probe_evidence,\n92:         has_direct_unavailable_blocker,\n93:         has_replacement_api_evidence,\n94:         platform_missing_deferred_fields,\n95:     )\n96:     from .render import platform_capability_check_markdown, source_coverage_matrix_markdown\n97:     from .utils import has_text, has_text_or_list\n98: \n99: \n100: MATRIX_OBJECT_FIELDS = {COVERAGE_FACTS_KEY}\n101: MATRIX_LIST_FIELDS = {\"verificationEvidence\", \"targetEndpoints\", \"tests\"}\n102: MATRIX_TEXT_FIELDS = set(MATRIX_AGENT_FIELDS) - MATRIX_LIST_FIELDS - MATRIX_OBJECT_FIELDS\n103: MATRIX_UPDATE_FIELDS = set(MATRIX_AGENT_FIELDS)\n104: MATRIX_ADD_FIELDS = MATRIX_UPDATE_FIELDS | {\n105:     \"featureId\",\n106:     \"featureName\",\n107:     \"sourcePath\",\n108:     \"importance\",\n109:     \"category\",\n110:     \"riskTags\",\n111:     \"keyClasses\",\n112:     \"keyMethods\",\n113:     \"androidIds\",\n114:     \"dependencies\",\n115:     \"featurePoint\",\n116:     \"sourceEvidence\",\n117: }\n118: MATRIX_ADD_REQUIRED_FIELDS = {\"featureId\", \"featureName\", \"sourcePath\", \"importance\", \"sourceEvidence\"}\n119: MATRIX_REQUIRED_LIST_FIELDS = (\"verificationEvidence\", \"targetEndpoints\", \"tests\")\n120: MATRIX_REQUIRED_TEXT_FIELDS = (\n121:     \"plannedPhase\",\n122:     \"sourceBehavior\",\n123:     \"targetBehavior\",\n124:     \"notes\",\n125:     \"deferredReason\",\n126:     \"targetFallback\",\n127:     \"risk\",\n128:     \"futureCompletionPath\",\n129: )\n130: \n131: PLATFORM_OBJECT_FIELDS = {CAPABILITY_FACTS_KEY}\n132: PLATFORM_LIST_FIELDS = {\n133:     \"targetCapabilitySearch\",\n134:     \"targetEndpoints\",\n135:     \"tests\",\n136:     \"sdkDeclarationEvidence\",\n137:     \"cangjieCallableEvidence\",\n138:     \"discoveryOnlyEvidence\",\n139:     \"compileProbeEvidence\",\n140: }\n141: PLATFORM_TEXT_FIELDS = {\n142:     \"status\",\n143:     \"plannedPhase\",\n144:     \"targetApiOrLibrary\",\n145:     \"targetStrategy\",\n146:     \"preResolutionDecision\",\n147:     \"phaseCapabilityResolution\",\n148:     \"blocker\",\n149:     \"