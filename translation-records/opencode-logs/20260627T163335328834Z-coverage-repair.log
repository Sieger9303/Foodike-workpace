dation.shape.RoundedCornerShape\n32: import androidx.compose.foundation.text.KeyboardOptions\n33: import androidx.compose.material.Text\n34: import androidx.compose.material.TextField\n35: import androidx.compose.material.TextFieldDefaults\n36: import androidx.compose.runtime.Composable\n37: import androidx.compose.ui.Modifier\n38: import androidx.compose.ui.draw.alpha\n39: import androidx.compose.ui.graphics.Color\n40: import androidx.compose.ui.text.input.ImeAction\n41: import androidx.compose.ui.text.input.VisualTransformation\n42: import androidx.compose.ui.unit.dp\n43: \n44: @Composable\n45: fun FoodikeTextField(\n46:     value: String,\n47:     onValueChange : (String) -> Unit,\n48:     hint: String,\n49:     keyboardOptions: KeyboardOptions = KeyboardOptions.Default.copy(\n50:         imeAction = ImeAction.Next\n51:     ),\n52:     visualTransformation: VisualTransformation = VisualTransformation.None,\n53: \n54: ) {\n55:     TextField(\n56:         value = value,\n57:         onValueChange = onValueChange,\n58:         modifier = Modifier.width(280.dp),\n59:         placeholder = {\n60:             Text(\n61:                 text = hint,\n62:                 modifier = Modifier.alpha(0.5f)\n63:             )\n64:         },\n65:         shape = RoundedCornerShape(9.dp),\n66:         colors = TextFieldDefaults.textFieldColors(\n67:             cursorColor = Color.White,\n68:             focusedIndicatorColor = Color.Transparent,\n69:             unfocusedIndicatorColor = Color.Transparent,\n70:         ),\n71:         visualTransformation = visualTransformation,\n72:         keyboardOptions = keyboardOptions,\n73:         singleLine = true\n74:     )\n75: }\n\n(End of file - total 75 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to de