.backgroundColor(if (isSelected) { colorDarkGreen } else { Color.White })\n43: }\n44: \n45: @Builder\n46: public func renderOnboardingRoute(\n47:     pageIndex: Int64,\n48:     controller: SwiperController,\n49:     onIndexChanged: (Int32) -> Unit,\n50:     onNext: () -> Unit\n51: ) {\n52:     Column(space: 24) {\n53:         Swiper(controller: controller) {\n54:             buildOnboardingCard(\n55:                 onboardingStore.slideAt(0).title,\n56:                 onboardingStore.slideAt(0).description,\n57:                 onboardingStore.slideAt(0).mediaName\n58:             )\n59:             buildOnboardingCard(\n60:                 onboardingStore.slideAt(1).title,\n61:                 onboardingStore.slideAt(1).description,\n62:                 onboardingStore.slideAt(1).mediaName\n63:             )\n64:             buildOnboardingCard(\n65:                 onboardingStore.slideAt(2).title,\n66:                 onboardingStore.slideAt(2).description,\n67:                 onboardingStore.slideAt(2).mediaName\n68:             )\n69:         }\n70:         .indicator(false)\n71:         .onChange({ index: Int32 =>\n72:             onIndexChanged(index)\n73:         })\n74:         .width(100.percent)\n75:         .height(78.percent)\n76: \n77:         Row {\n78:             Row(space: 12) {\n79:                 buildOnboardingIndicator(pageIndex == 0)\n80:                 buildOnboardingIndicator(pageIndex == 1)\n81:                 buildOnboardingIndicator(pageIndex == 2)\n82:             }\n83:             Button(\">\")\n84:                 .onClick({ _ =>\n85:                     onNext()\n86:                 })\n87:         }\n88:         .width(90.percent)\n89:         .justifyContent(FlexAlign.SpaceBetween)\n90:         .alignItems(VerticalAlign.Center)\n91:         .margin(bottom: 12)\n92:     }\n93:     .width(100.percent)\n94:     .height(100.percent)\n95:     .backgroundColor(colorDarkGreen)\n96:     .alignItems(HorizontalAlign.Center)\n97:     .justifyContent(FlexAlign.SpaceBetween)\n98: }\n\n(End of file - total 98 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos.base.ResourceStr\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n\n@Builder\nfunc buildOnboardingCard(title: ResourceStr, description: ResourceStr, mediaName: String) {\n    Column(space: 18) {\n        Image(\n            match (mediaName) {\n                case \"chinese_bowl\" => mediaChineseBowl\n                case \"rider\" => mediaRider\n                case _ => mediaClock\n            }\n        )\n            .width(72.percent)\n            .height(280)\n        Text(title)","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\onboarding\\onboarding_page.cj","time":{"start":1782578056825,"end":1782578056897}},"id":"prt_f09ee8e760011YrlOtzXqZJ3M8","sessionID":"ses_0f6120e51ffeAFmtIerTisPZLs","messageID":"msg_f09ee2a78001Koseu1Vie4Jr7s"}}
