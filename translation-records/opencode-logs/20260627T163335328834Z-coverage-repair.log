 \n126: \n127:                 Spacer(modifier = Modifier.height(16.dp))\n128: \n129:                 FoodikeTextField(\n130:                     value = password.text,\n131:                     onValueChange = { viewModel.onEvent(LoginEvent.EnteredPassword(it)) },\n132:                     hint = password.hint,\n133:                     visualTransformation = PasswordVisualTransformation(),\n134:                     keyboardOptions = KeyboardOptions.Default.copy(\n135:                         imeAction = ImeAction.Done\n136:                     ),\n137:                 )\n138: \n139: \n140:                 Spacer(modifier = Modifier.height(8.dp))\n141: \n142:                 Text(\n143:                     text = stringResource(R.string.forgot_password),\n144:                     modifier = Modifier\n145:                         .alpha(0.5f)\n146:                         .clickable {\n147:                             Toast\n148:                                 .makeText(context, R.string.coming_soon, Toast.LENGTH_SHORT)\n149:                                 .show()\n150:                         },\n151:                     fontSize = 14.sp,\n152:                 )\n153:             }\n154:             Spacer(modifier = Modifier.height(16.dp))\n155:             Button(modifier = Modifier.width(200.dp), onClick = {\n156:                 viewModel.onEvent(LoginEvent.PerformLogin {\n157:                     navController.navigate(Screen.Home.route) {\n158:                         popUpTo(navController.graph.findStartDestination().id) {\n159:                             inclusive = true\n160:                         }\n161:                     }\n162:                 })\n163:             }) {\n164:                 Text(\n165:                     text = stringResource(R.string.login),\n166:                     fontSize = 16.sp,\n167:                 )\n168:             }\n169: \n170: \n171: \n172:             Row(\n173:                 modifier = Modifier\n174:                     .fillMaxWidth()\n175:                     .padding(24.dp),\n176:                 horizontalArrangement = Arrangement.Center,\n177:                 verticalAlignment = Alignment.CenterVertically\n178:             ) {\n179:                 Divider(\n180:                     modifier = Modifier\n181:                         .weight(0.1f)\n182:                         .width(1.dp)\n183:                 )\n184:                 Spacer(modifier = Modifier.width(16.dp))\n185: \n186:                 Text(\n187:                     text = stringResource(R.string.or_sign_in_with),\n188:                     modifier = Modifier.alpha(0.5f),\n189:                     fontSize = 16.sp,\n190:                 )\n191:                 Spacer(modifier = Modifier.width(16.dp))\n192: \n193:                 Divider(\n194:                     modifier = Modifier\n195:                         .weight(0.1f)\n196:                         .width(1.dp)\n197:                 )\n198:             }\n199: \n200:             Row(\n201:                 modifier = Modifier.fillMaxWidth(),\n202:                 horizontalArrangement = Arrangement.Center,\n203:                 verticalAlignment = Alignment.CenterVertically\n204:             ) {\n205:                 Image(painter = painterResource(id = R.drawable.goog_icon),\n206:                     contentDescription = stringResource(R.string.login_with_google),\n207:                     modifier = Modifier\n208:                         .fillMaxSize(0.1f)\n209:                         .clickable {\n210:                             Toast\n211:                                 .makeText(context, R.string.coming_soon, Toast.LENGTH_SHORT)\n212:                                 .show()\n213:                         })\n214:                 Spacer(modifier = Modifier.width(16.dp))\n215:                 Image(painter = painterResource(id = R.drawable.fb_icon),\n216:                     contentDescription = stringResource(R.string.login_with_facebook),\n217:                     modifier = Modifier\n218:                         .fillMaxSize(0.1f)\n219:                         .clickable {\n220:                             Toast\n221:                                 .makeText(context, R.string.coming_soon, Toast.LENGTH_SHORT)\n222:                                 .show()\n223:                         })\n224:             }\n225:             Spacer(modifier = Modifier.height(16.dp))\n226:             Text(\n227:                 text = stringResource(R.string.new_to_foodike),\n228:                 modifier = Modifier\n229:                     .alpha(0.5f)\n230:                     .clickable {\n231:                         Toast\n232:                             .makeText(context, R.string.coming_soon, Toast.LENGTH_SHORT)\n233:                             .show()\n234:                     },\n235:             )\n236:         }\n237:     }\n238: }\n\n(End of file - total 238 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER","truncated":false