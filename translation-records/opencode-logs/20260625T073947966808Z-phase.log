re.isLastPage(this.onboardingPageIndex)) { \"Login\" } else { \"Next\" })\n183:                     .onClick({ _ =>\n184:                         if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n185:                             this.navigateTo(routePath(RouteId.Login))\n186:                         } else {\n187:                             this.onboardingController.showNext()\n188:                         }\n189:                     })\n190:             }\n191:             .width(90.percent)\n192:             .justifyContent(FlexAlign.SpaceBetween)\n193:             .alignItems(VerticalAlign.Center)\n194:             .margin(bottom: 12)\n195:         }\n196:         .width(100.percent)\n197:         .height(100.percent)\n198:         .backgroundColor(colorDarkGreen)\n199:         .alignItems(HorizontalAlign.Center)\n200:         .justifyContent(FlexAlign.SpaceBetween)\n201:     }\n202: \n203:     @Builder\n204:     private func buildLoginRoute() {\n205:         Column(space: 16) {\n206:             Text(stringWelcomeBack)\n207:                 .fontSize(32)\n208:                 .fontWeight(FontWeight.Bold)\n209: \n210:             TextInput(text: this.loginEmail, placeholder: loginStore.emailHint)\n211:                 .width(90.percent)\n212:                 .height(52)\n213:                 .fontSize(16)\n214:                 .placeholderColor(Color.Gray)\n215:                 .onChange({ value: String =>\n216:                     this.loginEmail = value\n217:                 })\n218: \n219:             TextInput(text: this.loginPassword, placeholder: loginStore.passwordHint)\n220:                 .width(90.percent)\n221:                 .height(52)\n222:                 .fontSize(16)\n223:                 .placeholderColor(Color.Gray)\n224:                 .enterKeyType(EnterKeyType.Done)\n225:                 .onChange({ value: String =>\n226:                     this.loginPassword = value\n227:                 })\n228:                 .onSubmit({ 