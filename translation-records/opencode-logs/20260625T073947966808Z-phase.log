        Divider().width(100.percent)\n333:                 }\n334:                 .width(100.percent)\n335:                 .padding(top: 10, bottom: 10)\n336:                 .onClick({ _ => this.showToast(profileStore.placeholderActionMessage) })\n337:                 Column(space: 8) {\n338:                     Text(stringPaymentsAndRefunds)\n339:                         .fontSize(21)\n340:                         .fontWeight(FontWeight.Medium)\n341:                     Text(stringRefundsInformation)\n342:                         .fontSize(15)\n343:                         .fontColor(Color.Gray)\n344:                     Divider().width(100.percent)\n345:                 }\n346:                 .width(100.percent)\n347:                 .padding(top: 10, bottom: 10)\n348:                 .onClick({ _ => this.showToast(profileStore.placeholderActionMessage) })\n349:                 Column(space: 8) {\n350:                     Text(stringOnlineOrderingHelp)\n351:                         .fontSize(21)\n352:                         .fontWeight(FontWeight.Medium)\n353:                     Text(stringOrderingInformation)\n354:                         .fontSize(15)\n355:                         .fontColor(Color.Gray)\n356:                     Divider().width(100.percent)\n357:                 }\n358:                 .width(100.percent)\n359:                 .padding(top: 10, bottom: 10)\n360:                 .onClick({ _ => this.showToast(profileStore.placeholderActionMessage) })\n361:                 Column(space: 8) {\n362:                     Text(stringAbout)\n363:                         .fontSize(21)\n364:                         .fontWeight(FontWeight.Medium)\n365:                     Text(stringAboutTheApp)\n366:                         .fontSize(15)\n367:                         .fontColor(Color.Gray)\n368:                 }\n369:                 .width(100.percent)\n370:                 .padding(top: 10, bottom: 10)\n371:                 .onClick({ _ => this.showToast(profileStore.placeholderActionMessage) })\n372:             }\n373:             .width(100.percent)\n374: \n375:             Blank()\n376:                 .layoutWeight(1)\n377: \n378:             Button(stringLogOut)\n379:                 .width(220)\n380:                 .height(50)\n381:                 .onClick({ _ =>\n382:                     this.performLogout()\n383:                 })\n384:         }\n385:         .width(100.percent)\n386:         .height(100.percent)\n387:         .padding(top: 18, right: 24, bottom: 24, left: 24)\n388:         .backgroundColor(Color.White)\n389:     }\n390: \n391:     @Builder\n392:     private func buildPlaceholderRoute() {\n393:         Column(space: 18) {\n394:             Text(\"Foodike\")\n395:                 .fontSize(42)\n396:                 .fontWeight(FontWeight.Bold)\n397:             Text(this.routeTitle(this.currentRoute))\n398:                 .fontSize(28)\n399:             Text(this.routeSummary(this.currentRoute))\n400:                 .fontSize(16)\n401:                 .textAlign(TextAlign.Center)\n402:                 .width(86.percent)\n403: \n404:             if (this.currentRoute == routePath(RouteId.Home) || this.currentRoute == routePath(RouteId.History)) {\n405:                 Button(if (this.isShellAtTop) { \"Simulate Scrolled Content\" } else { \"Return To Top\" })\n406:                     .onClick({ _ =>\n407:                         let shellState = this.shellState()\n408:                         shellState.setTopState(!shellState.isAtTop)\n409:                         this.applyShellState(shellState)\n410:                     })\n411:             }\n412: \n413:             Button(\"Primary Route Action\")\n414:                 .onClick({ _ =>\n415:                     this.applyShellCommand(ShellCommand.PrimaryAction)\n416:                 })\n417: \n418:             if (this.showBottomShell(this.currentRoute)) {\n419:                 Row(space: 12) {\n420:                     Button(\"Home Tab\")\n421:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HomeTab) })\n422:                     Button(\"Cart\")\n423:                         .onClick({ _ => this.applyShellCommand(ShellCommand.CartAction) })\n424:                     Button(\"History Tab\")\n425:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HistoryTab) })\n426:                 }\n427:             }\n428:         }\n429:         .width(100.percent)\n430:         .height(100.percent)\n431:         .justifyContent(FlexAlign.Center)\n432:         .alignItems(HorizontalAlign.Center)\n433:         .padding(top: 24, right: 24, bottom: 24, left: 24)\n434:     }\n435: \n436:     func build() {\n437:         if (this.currentRoute == routePath(RouteId.Onboarding)) {\n438:             this.buildOnboardingRoute()\n439:         } else if (this.currentRoute == routePath(RouteId.Login)) {\n440:             this.buildLoginRoute()\n441:         } else if (this.currentRoute == routePath(RouteId.Profile)) {\n442:             this.buildProfileRoute()\n443:         } else {\n444:             this.buildPlaceholderRoute()\n445:         }\n446:     }\n447: }\n\n(End of file - total 447 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\nimport kit.ArkUI.*\nimport kit.LocalizationKit.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos.arkui.state_macro_manage.Component\nimport ohos.arkui.state_macro_manage.Entry\nimport ohos.arkui.state_macro_manage.State\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.loginStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.onboardingStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.profileStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.runtime.{Global, bootstrapStartRoute}\n\n@Entry\n@Component\nclass Foodik