invalidLoginMessage\n95:     }\n96: \n97:     private func performLogout(): Unit {\n98:         profileStore.logout(Global.abilityContext)\n99:         this.loginEmail = \"\"\n100:         this.loginPassword = \"\"\n101:         this.clearLoginError()\n102:         this.onboardingPageIndex = 0\n103:         this.navigateTo(profileStore.logoutRoute())\n104:     }\n105: \n106:     private func routeSummary(route: String): String {\n107:         match (route) {\n108:             case \"home_screen\" => \"Home remains the shared shell placeholder from phase 02 while onboarding, login, and profile now run as dedicated phase-03 routes.\"\n109:             case \"history\" => \"History remains available as a shell route so profile still has a source-consistent back destination.\"\n110:             case \"cart\" => \"Cart continues to be a shell-owned placeholder route until later phases land the real content.\"\n111:             case \"restaurant_details\" => \"Restaurant detail remains in the route contract but keeps its placeholder body until later phases.\"\n112:             case _ => \"\"\n113:         }\n114:     }\n115: \n116:     @Builder\n117:     private func buildTopBar(title: ResourceStr, backLabel: ResourceStr, onBack: () -> Unit) {\n118:         Row {\n119:             Button(backLabel)\n120:                 .onClick({ _ => onBack() })\n121:             Text(title)\n122:                 .fontSize(28)\n123:                 .fontWeight(FontWeight.Bold)\n124:                 .margin(left: 16)\n125:         }\n126:         .width(100.percent)\n127:         .justifyContent(FlexAlign.Start)\n128:         .alignItems(VerticalAlign.Center)\n129:     }\n130: \n131:     @Builder\n132:     private func buildOnboardingCard(title: String, description: String, mediaName: String) {\n133:         Column(space: 18) {\n134:             Image(\n135:                 match (mediaName) {\n136:                     case \"chinese_bowl\" => mediaChineseBowl\n137:                     case \"rider\" => mediaRider\n138:                     case _ => mediaClock\n139:                 }\n140:             )\n141:                 .width(72.percent)\n142:                 .height(280)\n143:             Text(title)\n144:                 .fontSize(30)\n145:                 .fontColor(Color.White)\n146:                 .fontWeight(FontWeight.Bold)\n147:                 .textAlign(TextAlign.Center)\n148:             Text(description)\n149:                 .fontSize(17)\n150:                 .fontColor(Color.White)\n151:                 .textAlign(TextAlign.Center)\n152:                 .width(86.percent)\n153:         }\n154:         .width(100.percent)\n155:         .height(100.percent)\n156:         .justifyContent(FlexAlign.Center)\n157:         .alignItems(HorizontalAlign.Center)\n158:     }\n159: \n160:     @Builder\n161:     private func buildOnboardingIndicator(isSelected: Bool) {\n162:         Text(\" \")\n163:             .width(if (isSelected) { 24 } else { 10 })\n164:             .height(10)\n165:             .backgroundColor(if (isSelected) { Color.White } else { Color.White.opacity(0.45) })\n166:     }\n167: \n168:     @Builder\n169:     private func buildLoginErrorBanner() {\n170:         if (this.loginErrorMessage != \"\") {\n171:             Row(space: 12) {\n172:                 Text(this.loginErrorMessage)\n173:                     .fontSize(14)\n174:                     .fontColor(Color.White)\n175:                     .layoutWeight(1)\n176:                 Text(\"Dismiss\")\n177:                     .fontSize(13)\n178:                     .fontWeight(FontWeight.Medium)\n179:                     .fontColor(Color.White)\n180:                     .onClick({ _ =>\n181:                         this.clearLoginError()\n182:                     })\n183:             }\n184:             .width(90.percent)\n185:             .padding(top: 12, right: 14, bottom: 12, left: 14)\n186:             .backgroundColor(colorDarkGreen)\n187:         }\n188:     }\n189: \n190:     @Builder\n191:     private func buildOnboardingRoute() {\n192:         Column(space: 24) {\n193:             Swiper(controller: this.onboardingController) {\n194:                 this.buildOnboardingCard(\n195:                     onboardingStore.slideAt(0).title,\n196:                     onboardingStore.slideAt(0).description,\n197:                     onboardingStore.slideAt(0).mediaName\n198:                 )\n199:                 this.buildOnboardingCard(\n200:                     onboardingStore.slideAt(1).title,\n201:                     onboardingStore.slideAt(1).description,\n202:                     onboardingStore.slideAt(1).mediaName\n203:                 )\n204:                 this.buildOnboardingCard(\n205:                     onboardingStore.slideAt(2).title,\n206:                     onboardingStore.slideAt(2).description,\n207:                     onboardingStore.slideAt(2).mediaName\n208:                 )\n209:             }\n210:             .indicator(false)\n211:             .onChange({ index: Int32 =>\n212:                 this.onboardingPageIndex = Int64(index)\n213:              })\n214:             .width(100.percent)\n215:             .height(78.percent)\n216: \n217:             Row {\n218:                 Row(space: 12) {\n219:                     this.buildOnboardingIndicator(this.onboardingPageIndex == 0)\n220:                     this.buildOnboardingIndicator(this.onboardingPageIndex == 1)\n221:                     this.buildOnboardingIndicator(this.onboardingPageIndex == 2)\n222:                 }\n223:                 Button(\">\")\n224:                     .onClick({ _ =>\n225:                         if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n226:                             this.navigateTo(routePath(RouteId.Login))\n227:                         } else {\n228:                             this.onboardingController.showNext()\n229:                         }\n230:                     })\n231:    