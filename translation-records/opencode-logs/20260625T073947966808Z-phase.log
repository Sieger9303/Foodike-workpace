llRouteState(this.currentRoute, this.isShellAtTop)\n42:     }\n43: \n44:     private func applyShellCommand(command: ShellCommand): Unit {\n45:         let shellState = this.shellState()\n46:         shellState.applyCommand(command)\n47:         this.applyShellState(shellState)\n48:     }\n49: \n50:     private func navigateTo(route: String): Unit {\n51:         let shellState = this.shellState()\n52:         shellState.currentRoute = route\n53:         shellState.isAtTop = true\n54:         this.applyShellState(shellState)\n55:     }\n56: \n57:     private func showBottomShell(route: String): Bool {\n58:         let shellState = this.shellState()\n59:         shellState.currentRoute = route\n60:         return shellState.showBottomShell()\n61:     }\n62: \n63:     private func routeTitle(route: String): String {\n64:         match (route) {\n65:             case \"onboarding\" => \"Onboarding\"\n66:             case \"login_screen\" => \"Login\"\n67:             case \"home_screen\" => \"Home\"\n68:             case \"history\" => \"History\"\n69:             case \"cart\" => \"Cart\"\n70:             case \"profile\" => \"Profile\"\n71:             case \"restaurant_details\" => \"Restaurant Detail\"\n72:             case _ => \"Unknown Route\"\n73:         }\n74:     }\n75: \n76:     private func showToast(message: String): Unit {\n77:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n78:     }\n79: \n80:     private func performLogin(): Unit {\n81:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n82:             this.navigateTo(loginStore.successRoute())\n83:             return\n84:         }\n85: \n86:         this.showToast(loginStore.invalidLoginMessage)\n87:     }\n88: \n89:     private func performLogout(): Unit {\n90:         profileStore.logout(Global.abilityContext)\n91:         this.loginEmail = \"\"\n92:         this.loginPassword = \"\"\n93:         this.onboardingPageIndex = 0\n94:         this.navigateTo(profileStore.logoutRoute())\n95:     }\n96: \n97:     private func routeSummary(route: String): String {\n98:         match (route) {\n99:             case \"home_screen\" => \"Home remains the shared shell placeholder from phase 02 while onboarding, login, and profile now run as dedicated phase-03 routes.\"\n100:             case \"history\" => \"History remains available as a shell route so profile still has a source-consistent back destination.\"\n101:             case \"cart\" => \"Cart continues to be a shell-owned placeholder route until later phases land the real content.\"\n102:             case \"restaurant_details\" => \"Restaurant detail remains in the route contract but keeps its placeholder body until later phases.\"\n103:             case _ => \"\"\n104:         }\n105:     }\n106: \n107:     @Builder\n108:     private func buildTopBar(title: ResourceStr, backLabel: ResourceStr, onBack: () -> Unit) {\n109:         Row {\n110:             Button(backLabel)\n111:                 .onClick({ _ => onBack() })\n112:             Text(title)\n113:                 .fontSize(28)\n114:                 .fontWeight(FontWeight.Bold)\n115:                 .margin(left: 16)\n116:         }\n117:         .width(100.percent)\n118:         .justifyContent(FlexAlign.Start)\n119:         .alignItems(VerticalAlign.Center)\n120:     }\n121: \n122:     @Builder\n123:     private func buildOnboardingCard(title: String, description: String, mediaName: String) {\n124:         Column(space: 18) {\n125:             Image(\n126:                 match (mediaName) {\n127:                     case \"chinese_bowl\" => mediaChineseBowl\n128:                     case \"rider\" => mediaRider\n129:                     case _ => mediaClock\n130:                 }\n131:             )\n132:                 .width(72.percent)\n133:                 .height(280)\n134:             Text(title)\n135:                 .fontSize(30)\n136:                 .fontColor