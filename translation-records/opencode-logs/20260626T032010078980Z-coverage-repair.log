         item {\n216:                 Row(\n217:                     modifier = Modifier\n218:                         .fillMaxWidth()\n219:                         .padding(24.dp, 0.dp),\n220:                     verticalAlignment = Alignment.CenterVertically,\n221:                     horizontalArrangement = Arrangement.Center\n222: \n223:                 ) {\n224:                     Text(\n225:                         modifier = Modifier\n226:                             .weight(6f),\n227:                         text = stringResource(R.string.non_vegetarian),\n228:                         fontSize = 24.sp,\n229:                         fontWeight = FontWeight.Bold,\n230:                         maxLines = 1,\n231:                         overflow = TextOverflow.Ellipsis\n232:                     )\n233:                     IconButton(\n234:                         modifier = Modifier\n235:                             .weight(1f)\n236:                             .alpha(ContentAlpha.medium)\n237:                             .rotate(rotationStateNonVeg),\n238:                         onClick = {\n239:                             viewModel.onEvent(DetailScreenEvent.ToggleNonVegSectionExpandedState)\n240:                         }) {\n241:                         Icon(\n242:                             imageVector = Icons.Default.ArrowDropDown,\n243:                             contentDescription = stringResource(R.string.drop_down_arrow)\n244:                         )\n245:                     }\n246: \n247:                 }\n248: \n249:             }\n250:             if (detailScreenState.nonVegExpandedState) {\n251: \n252:                 items(nonVegList.size) {\n253:                     MenuItemCard(\n254:                         menuItem = nonVegList[it].menuItem,\n255:                     )\n256:                     if (it != (nonVegList.size - 1)) {\n257:                         Divider(\n258:                             modifier = Modifier\n259:                                 .fillMaxWidth()\n260:                                 .padding(24.dp, 0.dp)\n261:                         )\n262:                     }\n263:                 }\n264:             }\n265: \n266:             val vegList = detailScreenState.menuList.filter {\n267:                 it.menuItem.isVegetarian\n268:             }\n269: \n270:             item {\n271:                 Row(\n272:                     modifier = Modifier\n273:                         .fillMaxWidth()\n274:                         .padding(24.dp, 0.dp),\n275:                     verticalAlignment = Alignment.CenterVertically,\n276:                     horizontalArrangement = Arrangement.Center\n277: \n278:                 ) {\n279:                     Text(\n280:                         modifier = Modifier\n281:                             .weight(6f),\n282:                         text = stringResource(R.string.vegetarian),\n283:                         fontSize = 24.sp,\n284:                         fontWeight = FontWeight.Bold,\n285:                         maxLines = 1,\n286:                         overflow = TextOverflow.Ellipsis\n287:                     )\n288:                     IconButton(\n289:                         modifier = Modifier\n290:                             .weight(1f)\n291:                             .alpha(ContentAlpha.medium)\n292:                             .rotate(rotationStateVeg),\n293:                         onClick = {\n294:                             viewModel.onEvent(DetailScreenEvent.ToggleVegSectionExpandedState)\n295:                         }) {\n296:                         Icon(\n297:                             imageVector = Icons.Default.ArrowDropDown,\n298:                             contentDescription = stringResource(R.string.drop_down_arrow)\n299:                         )\n300:                     }\n301: \n302:                 }\n303: \n304:             }\n305:             if (detailScreenState.vegExpandedState) {\n306: