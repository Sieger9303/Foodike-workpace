{"type":"tool_use","timestamp":1782444041170,"sessionID":"ses_0fe0ed04dffeRxIShbWVKCrhzI","part":{"type":"tool","tool":"read","callID":"call_hbSB2qTyCzksTjx95Q7bK2Z3","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\detail\\detail_store.cj","limit":400},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\detail\\detail_store.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail\n2: \n3: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n6: import std.collection.ArrayList\n7: \n8: public let detailStore = DetailStore()\n9: \n10: public class DetailStore {\n11:     private let contentRepository = HomeContentRepository()\n12:     private let sessionRepository = sessionRepository\n13: \n14:     public init() {}\n15: \n16:     public func loadDetailState(\n17:         recommendedExpanded: Bool,\n18:         nonVegExpanded: Bool,\n19:         vegExpanded: Bool\n20:     ): DetailPageState {\n21:         let restaurant = selectedRestaurant()\n22:         let menuItems = sessionRepository.menuItemsForRestaurant(restaurant.name)\n23:         return DetailPageState(\n24:             restaurant,\n25:             recommendedExpanded,\n26:             nonVegExpanded,\n27:             vegExpanded,\n28:             menuItems,\n29:             recommendedItems(menuItems),\n30:             sessionRepository.isRestaurantLiked(restaurant)\n31:         )\n32:     }\n33: \n34:     public func selectedRestaurant(): RestaurantData {\n35:         let restaurantName = sessionRepository.getSelectedRestaurantName()\n36:         if (restaurantName != \"\") {\n37:             match (contentRepository.getRestaurantByName(restaurantName)) {\n38:                 case Some(restaurant) => return restaurant\n39:                 case None => return contentRepository.getRestaurants()[0]\n40:             }\n41:         }\n42:         return contentRepository.getRestaurants()[0]\n43:     }\n44: \n45:     public func recommendedItems(menuItems: ArrayList<DetailMenuItemData>): ArrayList<DetailMenuItemData> {\n46:         let recommended = ArrayList<DetailMenuItemData>([])\n47:         var index: Int64 = 0\n48:         for (item in menuItems) {\n49:             if (index < 5) {\n50:                 recommended.add(item)\n51:             }\n52:             index += 1\n53:         }\n54:         return recommended\n55:     }\n56: \n57:     public func nonVegItems(menuItems: ArrayList<DetailMenuItemData>): ArrayList<DetailMenuItemData> {\n58:         let filtered = ArrayList<DetailMenuItemData>([])\n59:         for (item in menuItems) {\n60:             if (!item.menuItem.isVegetarian) {\n61:                 filtered.add(item)\n62:             }\n63:         }\n64:         return filtered\n65:     }\n66: \n67:     public func vegItems(menuItems: ArrayList<DetailMenuItemData>): ArrayList<DetailMenuItemData> {\n68:         let filtered = ArrayList<DetailMenuItemData>([])\n69:         for (item in menuItems) {\n70:             if (item.menuItem.isVegetarian) {\n71:                 filtered.add(item)\n72:             }\n73:         }\n74:         return filtered\n75:     }\n76: \n77:     public func incrementQuantity(item: DetailMenuItemData): Unit {\n78:         item.quantity += 1\n79:     }\n80: \n81:     public func decrementQuantity(item: DetailMenuItemData): Unit {\n82:         if (item.quantity > 0) {\n83:             item.quantity -= 1\n84:         }\n85:     }\n86: \n87:     public func totalSelectedItems(menuItems: ArrayList<DetailMenuItemData>): Int64 {\n88:         var total: Int64 = 0\n89:         for (item in menuItems) {\n90:             total += item.quantity\n91:         }\n92:         return total\n93:     }\n94: \n95:     public func shouldShowCartAction(menuItems: ArrayList<DetailMenuItemData>): Bool {\n96:         return totalSelectedItems(menuItems) > 0\n97:     }\n98: \n99:     public func toggleLiked(restaurant: RestaurantData, currentValue: Bool): Bool {\n100:         let nextValue = !currentValue\n101:         sessionRepository.setRestaurantLiked(restaurant, nextValue)\n102:         return nextValue\n103:     }\n104: \n105:     public func formatPrice(price: Float64): String {\n106:         return \"$${price}\"\n107:     }\n108: \n109:     public func formatRatingCount(ratingCount: Int64): String {\n110:         return \"${ratingCount} ratings\"\n111:     }\n112: \n113:     public func formatRestaurantMeta(restaurant: RestaurantData): String {\n114:         return \"${restaurant.rating}(${customerCount(restaurant.ratingCount)}) · ${restaurant.etaMinutes} Min · $${restaurant.averagePrice}\"\n115:     }\n116: \n117:     public func customerCount(ratingCount: Int64): String {\n118:         if (ratingCount >= 1000) {\n119:             return \"1000+\"\n120:         }\n121:         if (ratingCount >= 100) {\n122:             return \"${ratingCount}+\"\n123:         }\n124:         return \"${ratingCount}\"\n125:     }\n126: \n127:     public func session(): SessionRepository {\n128:         return sessionRepository\n129:     }\n130: }\n\n(End of file - total 130 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\npublic let detailStore = DetailStore()\n\npublic class DetailStore {\n    private let contentRepository = HomeContentRepository()\n    private let sessionRepository = sessionRepository\n\n    public init() {}\n\n    public func loadDetailState(\n        recommendedExpanded: Bool,\n        nonVegExpanded: Bool,\n        vegExpanded: Bool\n    ): DetailPageState {","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\detail\\detail_store.cj","time":{"start":1782444041160,"end":1782444041169}},"id":"prt_f01f1a3840014IXa3A1FiznbjF","sessionID":"ses_0fe0ed04dffeRxIShbWVKCrhzI","messageID":"msg_f01f189b3001jTqAQSgXCt1pu6"}}
{"type":"tool_use","timestamp":1782444041242,"sessionID":"ses_0fe0ed04dffeRxIShbWVKCrhzI","part":{"type":"tool","tool":"read","callID":"call_3KQI5s1K90Rz7MZxc0oUH4MJ","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\detail\\detail_page.cj","limit":420},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\detail\\detail_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail\n2: \n3: import kit.ArkUI.*\n4: import ohos.arkui.state_macro_manage.Builder\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n6: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.restaurantMedia\n7: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n8: import std.collection.ArrayList\n9: \n10: @Builder\n11: func buildDetailTopBar(isLiked: Bool, onBack: () -> Unit, onToggleLike: () -> Unit, onShare: () -> Unit) {\n12:     Row {\n13:         Button(\"<\")\n14:             .onClick({ _ =>\n15:                 onBack()\n16:             })\n17:         Blank().layoutWeight(1)\n18:         Row(space: 12) {\n19:             Text(if (isLiked) { \"Heart\" } else { \"Like\" })\n20:                 .fontColor(if (isLiked) { Color.Red } else { Color.Black })\n21:                 .fontWeight(FontWeight.Bold)\n22:                 .onClick({ _ =>\n23:                     onToggleLike()\n24:                 })\n25:             Text(\"Share\")\n26:                 .fontColor(Color.Gray)\n27:                 .onClick({ _ =>\n28:                     onShare()\n29:                 })\n30:         }\n31:     }\n32:     .width(100.percent)\n33:     .alignItems(VerticalAlign.Center)\n34: }\n35: \n36: @Builder\n37: func buildRestaurantDetailCard(restaurant: RestaurantData) {\n38:     Column(space: 12) {\n39:         Text(restaurant.name)\n40:             .fontSize(26)\n41:             .fontWeight(FontWeight.Bold)\n42:         Row(space: 6) {\n43:             Image(mediaStar)\n44:                 .width(18)\n45:                 .height(18)\n46:             Text(detailStore.formatRestaurantMeta(restaurant))\n47:                 .fontSize(14)\n48:         }\n49:         Text(restaurant.variety)\n50:             .fontSize(14)\n51:             .fontColor(Color.Gray)\n52:         Text(restaurant.place)\n53:             .fontSize(14)\n54:             .fontColor(Color.Gray)\n55: \n56:         Row(space: 14) {\n57:             Image(mediaOutletCard)\n58:                 .width(42)\n59:                 .height(42)\n60:             Column(space: 4) {\n61:                 Text(\"Outlet\")\n62:                     .fontWeight(FontWeight.Medium)\n63:                 Text(\"${restaurant.etaMinutes} Min\")\n64:                     .fontColor(Color.Gray)\n65:             }\n66:             Blank().layoutWeight(1)\n67:             Column(space: 4) {\n68:                 Text(restaurant.place)\n69:                     .fontColor(Color.Gray)\n70:                 Text(\"Your location\")\n71:                     .fontColor(Color.Gray)\n72:             }\n73:         }\n74:         .width(100.percent)\n75:     }\n76:     .width(100.percent)\n77:     .padding(top: 18, right: 18, bottom: 18, left: 18)\n78:     .backgroundColor(0xFFC6FDB3)\n79:     .borderRadius(22)\n80: }\n81: \n82: @Builder\n83: func buildMenuQuantityControls(\n84:     item: DetailMenuItemData,\n85:     onAdd: () -> Unit,\n86:     onRemove: () -> Unit\n87: ) {\n88:     if (item.quantity == 0) {\n89:         Text(\"ADD\")\n90:             .fontSize(15)\n91:             .fontWeight(FontWeight.Bold)\n92:             .fontColor(colorDarkGreen)\n93:             .onClick({ _ =>\n94:                 onAdd()\n95:             })\n96:     } else {\n97:         Row(space: 10) {\n98:             Text(\"-\")\n99:                 .fontSize(16)\n100:                 .fontWeight(FontWeight.Bold)\n101:                 .onClick({ _ =>\n102:                     onRemove()\n103:                 })\n104:             Text(\"${item.quantity}\")\n105:                 .fontSize(16)\n106:                 .fontWeight(FontWeight.Medium)\n107:             Text(\"+\")\n108:                 .fontSize(16)\n109:                 .fontWeight(FontWeight.Bold)\n110:                 .fontColor(colorDarkGreen)\n111:                 .onClick({ _ =>\n112:                     onAdd()\n113:                 })\n114:         }\n115:         .padding(top: 6, right: 10, bottom: 6, left: 10)\n116:         .borderRadius(14)\n117:         .border(width: 1.px, color: 0x55000000)\n118:     }\n119: }\n120: \n121: @Builder\n122: func buildMenuItemRow(\n123:     item: DetailMenuItemData,\n124:     onAdd: () -> Unit,\n125:     onRemove: () -> Unit\n126: ) {\n127:     Row(space: 14) {\n128:         Image(if (item.menuItem.isVegetarian) { mediaIcVeg } else { mediaIcNonVeg })\n129:             .width(18)\n130:             .height(18)\n131:         Column(space: 6) {\n132:             Text(item.menuItem.dish)\n133:                 .fontSize(16)\n134:                 .fontWeight(FontWeight.Medium)\n135:             Text(detailStore.formatPrice(item.menuItem.price))\n136:                 .fontSize(14)\n137:                 .fontColor(Color.Gray)\n138:             Row(space: 6) {\n139:                 Image(mediaStar)\n140:                     .width(16)\n141:                     .height(16)\n142:                 Text(\"${item.menuItem.rating}\")\n143:                     .fontSize(13)\n144:                 Text(detailStore.formatRatingCount(item.menuItem.ratingCount))\n145:                     .fontSize(13)\n146:                     .fontColor(Color.Gray)\n147:             }\n148:         }\n149:         .layoutWeight(1)\n150:         buildMenuQuantityControls(item, onAdd, onRemove)\n151:     }\n152:     .width(100.percent)\n153:     .alignItems(VerticalAlign.Center)\n154:     .padding(top: 12, right: 0, bottom: 12, left: 0)\n155: }\n156: \n157: @Builder\n158: func buildSectionHeader(title: String, expanded: Bool, onToggle: () -> Unit) {\n159:     Row {\n160:         Text(title)\n161:             .fontSize(22)\n162:             .fontWeight(FontWeight.Bold)\n163:         Blank().layoutWeight(1)\n164:         Text(if (expanded) { \"v\" } else { \">\" })\n165:             .fontSize(20)\n166:             .fontColor(Color.Gray)\n167:             .onClick({ _ =>\n168:                 onToggle()\n169:             })\n170:     }\n171:     .width(100.percent)\n172:     .alignItems(VerticalAlign.Center)\n173: }\n174: \n175: @Builder\n176: func buildDetailSection(\n177:     title: String,\n178:     expanded: Bool,\n179:     items: ArrayList<DetailMenuItemData>,\n180:     onToggle: () -> Unit,\n181:     onAdd: (DetailMenuItemData) -> Unit,\n182:     onRemove: (DetailMenuItemData) -> Unit\n183: ) {\n184:     Column(space: 8) {\n185:         buildSectionHeader(title, expanded, onToggle)\n186:         if (expanded) {\n187:             ForEach(items, itemGeneratorFunc: { item: DetailMenuItemData, _: Int64 =>\n188:                 buildMenuItemRow(\n189:                     item,\n190:                     { => onAdd(item) },\n191:                     { => onRemove(item) }\n192:                 )\n193:             })\n194:         }\n195:     }\n196:     .width(100.percent)\n197: }\n198: \n199: @Builder\n200: func buildRestaurantHeroImage(restaurant: RestaurantData) {\n201:     Image(restaurantMedia(restaurant.mediaName))\n202:         .width(100.percent)\n203:         .height(200)\n204:         .borderRadius(22)\n205: }\n206: \n207: @Builder\n208: func buildCartFab(onOpenCart: () -> Unit) {\n209:     Row {\n210:         Blank().layoutWeight(1)\n211:         Button(\"Cart\")\n212:             .backgroundColor(colorDarkGreen)\n213:             .fontColor(Color.White)\n214:             .onClick({ _ =>\n215:                 onOpenCart()\n216:             })\n217:     }\n218:     .width(100.percent)\n219: }\n220: \n221: @Builder\n222: public func renderDetailRoute(\n223:     state: DetailPageState,\n224:     onBack: () -> Unit,\n225:     onToggleLike: () -> Unit,\n226:     onShare: () -> Unit,\n227:     onToggleRecommended: () -> Unit,\n228:     onToggleNonVeg: () -> Unit,\n229:     onToggleVeg: () -> Unit,\n230:     onAdd: (DetailMenuItemData) -> Unit,\n231:     onRemove: (DetailMenuItemData) -> Unit,\n232:     onOpenCart: () -> Unit\n233: ) {\n234:     Scroll(Scroller()) {\n235:         Column(space: 16) {\n236:             buildDetailTopBar(state.isLiked, onBack, onToggleLike, onShare)\n237:             buildRestaurantHeroImage(state.restaurant)\n238:             buildRestaurantDetailCard(state.restaurant)\n239:             buildDetailSection(\n240:                 \"Recommended\",\n241:                 state.recommendedExpanded,\n242:                 state.recommendedItems,\n243:                 onToggleRecommended,\n244:                 onAdd,\n245:                 onRemove\n246:             )\n247:             buildDetailSection(\n248:                 \"Non Vegetarian\",\n249:                 state.nonVegExpanded,\n250:                 detailStore.nonVegItems(state.menuItems),\n251:                 onToggleNonVeg,\n252:                 onAdd,\n253:                 onRemove\n254:             )\n255:             buildDetailSection(\n256:                 \"Vegetarian\",\n257:                 state.vegExpanded,\n258:                 detailStore.vegItems(state.menuItems),\n259:                 onToggleVeg,\n260:                 onAdd,\n261:                 onRemove\n262:             )\n263:             if (detailStore.shouldShowCartAction(state.menuItems)) {\n264:                 buildCartFab(onOpenCart)\n265:             }\n266:         }\n267:         .width(100.percent)\n268:         .padding(top: 14, right: 16, bottom: 24, left: 16)\n269:     }\n270:     .scrollable(ScrollDirection.Vertical)\n271:     .scrollBar(BarState.Off)\n272:     .width(100.percent)\n273:     .height(100.percent)\n274:     .backgroundColor(Color.White)\n275: }\n\n(End of file - total 275 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.restaurantMedia\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\n@Builder\nfunc buildDetailTopBar(isLiked: Bool, onBack: () -> Unit, onToggleLike: () -> Unit, onShare: () -> Unit) {\n    Row {\n        Button(\"<\")\n            .onClick({ _ =>\n                onBack()\n            })\n        Blank().layoutWeight(1)\n        Row(space: 12) {\n            Text(if (isLiked) { \"Heart\" } else { \"Like\" })\n                .fontColor(if (isLiked) { Color.Red } else { Color.Black })","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\detail\\detail_page.cj","time":{"start":1782444041233,"end":1782444041241}},"id":"prt_f01f1a3ca001H0HTRNf16PHvA8","sessionID":"ses_0fe0ed04dffeRxIShbWVKCrhzI","messageID":"msg_f01f189b3001jTqAQSgXCt1pu6"}}
{"type":"tool_use","timestamp":1782444041305,"sessionID":"ses_0fe0ed04dffeRxIShbWVKCrhzI","part":{"type":"tool","tool":"read","callID":"call_WLewRjZyYCyJBjXcaW6JlcSK","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\cart\\cart_store.cj","limit":360},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\cart\\cart_store.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart\n2: \n3: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n6: import std.collection.ArrayList\n7: \n8: public let cartStore = CartStore()\n9: \n10: public class CartStore {\n11:     private let sessionRepository = sessionRepository\n12:     private let contentRepository = HomeContentRepository()\n13: \n14:     public init() {}\n15: \n16:     public func loadCartState(): CartPageState {\n17:         let deliveryRestaurant = match (contentRepository.getRestaurantByName(\"Relish\")) {\n18:             case Some(restaurant) => restaurant\n19:             case None => contentRepository.getRestaurants()[0]\n20:         }\n21:         return CartPageState(sessionRepository.getCartItems(), deliveryRestaurant)\n22:     }\n23: \n24:     public func visibleItems(items: ArrayList<CartSnapshotItemData>): ArrayList<CartSnapshotItemData> {\n25:         let filtered = ArrayList<CartSnapshotItemData>([])\n26:         for (item in items) {\n27:             if (item.quantity > 0) {\n28:                 filtered.add(item)\n29:             }\n30:         }\n31:         return filtered\n32:     }\n33: \n34:     public func itemTotal(items: ArrayList<CartSnapshotItemData>): Float64 {\n35:         var total: Float64 = 0.0\n36:         for (item in items) {\n37:             var remaining = item.quantity\n38:             while (remaining > 0) {\n39:                 total += item.menuItem.price\n40:                 remaining -= 1\n41:             }\n42:         }\n43:         return total\n44:     }\n45: \n46:     public func incrementQuantity(item: CartSnapshotItemData): Unit {\n47:         item.quantity += 1\n48:     }\n49: \n50:     public func decrementQuantity(item: CartSnapshotItemData): Unit {\n51:         if (item.quantity > 0) {\n52:             item.quantity -= 1\n53:         }\n54:     }\n55: \n56:     public func formatPrice(price: Float64): String {\n57:         return \"$${price}\"\n58:     }\n59: \n60:     public func formatEta(minutes: Int64): String {\n61:         let hours = minutes / 60\n62:         let remainder = minutes % 60\n63:         if (hours > 0) {\n64:             return \"${hours} Hr ${remainder} Min\"\n65:         }\n66:         return \"${remainder} Min\"\n67:     }\n68: \n69:     public func taxAmount(itemTotal: Float64): Float64 {\n70:         return itemTotal * 0.18\n71:     }\n72: \n73:     public func grandTotal(itemTotal: Float64): Float64 {\n74:         return itemTotal + taxAmount(itemTotal)\n75:     }\n76: \n77:     public func deliveryLocation(): String {\n78:         return \"Guwahati\"\n79:     }\n80:     public func session(): SessionRepository {\n81:         return sessionRepository\n82:     }\n83: }\n\n(End of file - total 83 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\npublic let cartStore = CartStore()\n\npublic class CartStore {\n    private let sessionRepository = sessionRepository\n    private let contentRepository = HomeContentRepository()\n\n    public init() {}\n\n    public func loadCartState(): CartPageState {\n        let deliveryRestaurant = match (contentRepository.getRestaurantByName(\"Relish\")) {\n            case Some(restaurant) => restaurant\n            case None => contentRepository.getRestaurants()[0]\n        }","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\cart\\cart_store.cj","time":{"start":1782444041297,"end":1782444041304}},"id":"prt_f01f1a412001XgR0W1HfGeRV0l","sessionID":"ses_0fe0ed04dffeRxIShbWVKCrhzI","messageID":"msg_f01f189b3001jTqAQSgXCt1pu6"}}
{"type":"tool_use","timestamp":1782444041367,"sessionID":"ses_0fe0ed04dffeRxIShbWVKCrhzI","part":{"type":"tool","tool":"read","callID":"call_DNhDh2kvTjkXzEYuvIQCDOEH","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase05_detail_cart_state_mutations_test.cj","limit":320},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase05_detail_cart_state_mutations_test.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry_test\n2: \n3: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.DetailStore\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.CartStore\n6: import std.unittest.*\n7: import std.unittest.testmacro.*\n8: \n9: @Test\n10: public class Phase05DetailCartStateMutationsTest {\n11:     @TestCase\n12:     public func cartStoreFiltersZeroCountItemsAndPreservesSnapshotOrder(): Unit {\n13:         let store = CartStore()\n14:         let state = store.loadCartState()\n15:         let visibleItems = store.visibleItems(state.items)\n16:         @Assert(visibleItems.size, 2)\n17:         @Assert(visibleItems[0].menuItem.dish, \"Paw Bhaaji\")\n18:         @Assert(visibleItems[1].menuItem.dish, \"Veg Pulao\")\n19:     }\n20: \n21:     @TestCase\n22:     public func cartStoreCalculatesTotalsFromSnapshotQuantities(): Unit {\n23:         let store = CartStore()\n24:         let state = store.loadCartState()\n25:         let itemTotal = store.itemTotal(store.visibleItems(state.items))\n26:         @Assert(itemTotal, 12.0)\n27:         @Assert(store.taxAmount(itemTotal), 2.16)\n28:         @Assert(store.grandTotal(itemTotal), 14.16)\n29:     }\n30: \n31:     @TestCase\n32:     public func cartStoreMutatesLocalQuantitiesImmediately(): Unit {\n33:         let store = CartStore()\n34:         let state = store.loadCartState()\n35:         let firstItem = state.items[0]\n36: \n37:         @Assert(firstItem.quantity, 1)\n38:         store.incrementQuantity(firstItem)\n39:         @Assert(firstItem.quantity, 2)\n40:         store.decrementQuantity(firstItem)\n41:         @Assert(firstItem.quantity, 1)\n42:         store.decrementQuantity(firstItem)\n43:         @Assert(firstItem.quantity, 0)\n44:         store.decrementQuantity(firstItem)\n45:         @Assert(firstItem.quantity, 0)\n46:     }\n47: \n48:     @TestCase\n49:     public func cartStoreKeepsSourceDeliveryPlaceholders(): Unit {\n50:         let store = CartStore()\n51:         let state = store.loadCartState()\n52:         @Assert(state.deliveryRestaurant.name, \"Relish\")\n53:         @Assert(store.deliveryLocation(), \"Guwahati\")\n54:         @Assert(store.formatEta(state.deliveryRestaurant.etaMinutes), \"30 Min\")\n55:     }\n56: \n57:     @TestCase\n58:     public func detailStoreLoadsSelectedRestaurantAndRecommendedMenuSlice(): Unit {\n59:         let store = DetailStore()\n60:         let contentRepository = HomeContentRepository()\n61:         let restaurant = match (contentRepository.getRestaurantByName(\"Relish\")) {\n62:             case Some(found) => found\n63:             case None => contentRepository.getRestaurants()[0]\n64:         }\n65:         store.session().setSelectedRestaurant(restaurant)\n66: \n67:         let state = store.loadDetailState(true, true, true)\n68:         @Assert(state.restaurant.name, \"Relish\")\n69:         @Assert(state.recommendedItems.size, 5)\n70:         @Assert(state.recommendedItems[0].menuItem.dish, \"Masala Dosa\")\n71:     }\n72: \n73:     @TestCase\n74:     public func detailStorePreservesSectionFilteringAndCartVisibilityRules(): Unit {\n75:         let store = DetailStore()\n76:         let contentRepository = HomeContentRepository()\n77:         let restaurant = match (contentRepository.getRestaurantByName(\"George Street\")) {\n78:             case Some(found) => found\n79:             case None => contentRepository.getRestaurants()[0]\n80:         }\n81:         store.session().setSelectedRestaurant(restaurant)\n82: \n83:         let state = store.loadDetailState(true, true, true)\n84:         let nonVegItems = store.nonVegItems(state.menuItems)\n85:         let vegItems = store.vegItems(state.menuItems)\n86:         @Assert(nonVegItems.size, 4)\n87:         @Assert(vegItems.size, 4)\n88:         @Assert(store.shouldShowCartAction(state.menuItems), false)\n89: \n90:         store.incrementQuantity(state.menuItems[0])\n91:         @Assert(store.shouldShowCartAction(state.menuItems), true)\n92:         @Assert(store.totalSelectedItems(state.menuItems), 1)\n93:         store.decrementQuantity(state.menuItems[0])\n94:         @Assert(store.totalSelectedItems(state.menuItems), 0)\n95:     }\n96: \n97:     @TestCase\n98:     public func detailStoreTogglesLikedStateForSelectedRestaurant(): Unit {\n99:         let store = DetailStore()\n100:         let contentRepository = HomeContentRepository()\n101:         let restaurant = match (contentRepository.getRestaurantByName(\"Relish\")) {\n102:             case Some(found) => found\n103:             case None => contentRepository.getRestaurants()[0]\n104:         }\n105: \n106:         store.session().setRestaurantLiked(restaurant, false)\n107:         let liked = store.toggleLiked(restaurant, false)\n108:         @Assert(liked, true)\n109:         @Assert(store.session().isRestaurantLiked(restaurant), true)\n110:         let unliked = store.toggleLiked(restaurant, true)\n111:         @Assert(unliked, false)\n112:     }\n113: }\n\n(End of file - total 113 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.DetailStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.CartStore\nimport std.unittest.*\nimport std.unittest.testmacro.*\n\n@Test\npublic class Phase05DetailCartStateMutationsTest {\n    @TestCase\n    public func cartStoreFiltersZeroCountItemsAndPreservesSnapshotOrder(): Unit {\n        let store = CartStore()\n        let state = store.loadCartState()\n        let visibleItems = store.visibleItems(state.items)\n        @Assert(visibleItems.size, 2)\n        @Assert(visibleItems[0].menuItem.dish, \"Paw Bhaaji\")\n        @Assert(visibleItems[1].menuItem.dish, \"Veg Pulao\")\n    }\n","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\test\\cangjie\\phase05_detail_cart_state_mutations_test.cj","time":{"start":1782444041361,"end":1782444041366}},"id":"prt_f01f1a452001DgmgxGC9OJCvY7","sessionID":"ses_0fe0ed04dffeRxIShbWVKCrhzI","messageID":"msg_f01f189b3001jTqAQSgXCt1pu6"}}
