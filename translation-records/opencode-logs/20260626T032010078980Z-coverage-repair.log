ceInputs\": [],\n85:       \"platformCapabilityIds\": [],\n86:       \"expectedTargetDomains\": [\n87:         \"ohos_app_cangjie_entry/features/cart/cart_page.cj\",\n88:         \"ohos_app_cangjie_entry/app/bootstrap_page.cj\",\n89:         \"ohos_app_cangjie_entry/features/cart/cart_store.cj\"\n90:       ],\n91:       \"requiredBehaviors\": [\n92:         \"Cart composes item, coupon, delivery, and bill sections only; it does not render a bitmap preview, gallery viewer, zoom surface, or EXIF-aware image flow.\",\n93:         \"Cart owns a route-local navigation surface with a close button that calls `navController.navigateUp()`, and it keeps the cart sections inside one scrollable screen instead of exposing drawer or tab navigation.\",\n94:         \"Cart observes `viewModel.cartState` and immediately recomposes the item list when the snapshot changes, while note text stays local to the cart item section.\",\n95:         \"Cart updates system-bar colors and composes cart sections, but it does not request runtime permissions, handle permission callbacks, or call protected Android APIs.\",\n96:         \"Cart performs route-entry setup by collecting the current cart snapshot from `CartViewModel`, applying cart-specific window styling, and rendering the cart sections from that route-local state.\",\n97:         \"CartViewModel exposes observable cart state from repository flow collection so the cart route can render from the latest snapshot and filter visible items in UI.\",\n98:         \"CartViewModel collects cart items from the repository only; it does not request permissions, process permission results, or access protected APIs.\",\n99:         \"CartViewModel performs cart-screen initialization in `init` by starting collection of `userDataRepository.getCartItems()` so the cart snapshot is ready as soon as the screen observes it.\",\n100:         \"DeliverySection renders delivery labels, a placeholder edit affordance, and ETA text only; it does not show a bitmap preview, gallery image, or zoomable media content.\",\n101:         \"DeliverySection does not request location or delivery-related permissions; it only renders placeholder text and an edit icon with no action.\",\n102:         \"ItemSection renders each cart row through `CartItemCard`, which shows veg/non-veg image badges beside the dish name, and also keeps the note editor placeholder visible below the item list.\",\n103:         \"ItemSection and CartItemCard preserve immediate local UI state updates: the instruction text field updates as the user types, and each item row updates its local quantity immediately on add/remove taps without repository wiring.\",\n104:         \"ItemSection and CartItemCard do not request runtime permissions; they only render cart rows, local quantity controls, and a local note editor.\",\n105:         \"CouponBar keeps coupon text in local composable state and updates the input value immediately as the user types while the apply action stays visible but inert.\",\n106:         \"CouponBar only captures coupon text locally and shows an `APPLY` affordance; it does not request permissions or access protected APIs.\",\n107:         \"CouponBar does not expose persisted settings, toggles, or configuration options; it only holds local coupon text for the current cart screen.\",\n108:         \"BillSection calculates and displays totals plus a pay button placeholder; it does not request permissions or use protected APIs.\"\n109:       ],\n110:       \"acceptanceEvidence\": [\n111:         \"Closed critical/high features must record sourceBehavior, targetBehavior, parityLevel, targetEndpoints, and verificationEvidence.\",\n112:         \"Build pass alone is not per-feature verification.\",\n113:         \"Referenced target tests are not strong evidence until a latest test gate PASS or explicit harness blocker is recorded.\"\n114:       ],\n115:       \"riskHints\": [\n116:         \"critical/high behavior cannot close on build pass alone\"\n117:       ],\n118:       \"matrixRows\": [\n119:         {\n120:           \"kind\": \"source-feature\",\n121:           \"featureId\": \"app-src-main-java-com-example-foodike-presentation-cart-eaf4711dc9-001-image-viewing-bitmap-exif-handling-zoom\",\n122:           \"featureName\": \"Image viewing, bitmap/exif handling, zoom, preview, or gallery display behavior.\",\n123:           \"sourcePath\": \"app/src/main/java/com/example/foodike/presentation/cart/Cart.kt\",\n124:           \"importance\": \"critical\",\n125:           \"plannedPhase\": \"phase-05-detail-cart-state-mutations\",\n126:           \"status\": \"not-applicable\",\n127:           \"parityLevel\": \"not-applicable\",\n128:           \"verdict\": \"complete\",\n129:           \"reasons\": [\n130:             \"not-applicable has source/notes explanation\"\n131:           ],\n132:           \"targetEndpoints\": [],\n133:           \"tests\": []\n134:         },\n135:         {\n136:           \"kind\": \"source-feature\",\n137:           \"featureId\": \"app-src-main-java-com-example-foodike-presentation-cart-4c136b2d3d-002-navigation-surface-menu-drawer-toolbar-o\",\n138:           \"featureName\": \"Navigation surface, menu, drawer, toolbar, or tab command behavior.\",\n139:           \"sourcePath\": \"app/src/main/java/com/example/foodike/presentation/cart/Cart.kt\",\n140:           \"importance\": \"critical\",\n141:           \"plannedPhase\": \"phase-05-detail-cart-state-mutations\",\n142:           \"status\": \"implemented\",\n143:           \"parityLevel\": \"equivalent\",\n144:           \"verdict\": \"complete\",\n145:           \"reasons\": [\n146:             \"implemented with behavior, parity, endpoint, and verification evidence\"\n147:           ],\n148:           \"targetEndpoints\": [\n149:             \"entry/src/main/cangjie/ohos_app_cangjie_entry/features/cart/cart_page.cj::buildCartTopBar\",\n150:             \"entry/src/main/cangjie/ohos_app_cangjie_entry/features/cart/cart