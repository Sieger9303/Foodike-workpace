ion)\n\n  Line 861:         updated_ids.append(item_id)\n\n  Line 862:         touched_entries.append(entry)\n\n  Line 895:         contextual_entries.append(entry)\n\n  Line 898:             errors.append({id_field: entry.get(id_field, \"\"), \"problems\": problems})\n","metadata":{"matches":68,"truncated":false},"title":"operations|op\\]|featureId|append|remove|set|patch\\[","time":{"start":1782714894957,"end":1782714895005}},"id":"prt_f12168a6a0017yhgZzbhjhlHlm","sessionID":"ses_0edec9d59ffesgtxbqGLBL7RFa","messageID":"msg_f12166c97001mYbiFSu6Gxw63l"}}
{"type":"tool_use","timestamp":1782714895158,"sessionID":"ses_0edec9d59ffesgtxbqGLBL7RFa","part":{"type":"tool","tool":"read","callID":"call_fCtuXpCSFlPg9jsWCHl3xYxJ","state":{"status":"completed","input":{"filePath":"D:\\X2Cangjie\\X2Cangjie\\docs\\unified-cangjie-translation-workflow.zh.md","limit":120,"offset":70},"output":"<path>D:\\X2Cangjie\\X2Cangjie\\docs\\unified-cangjie-translation-workflow.zh.md</path>\n<type>file</type>\n<content>\n70: ```\n71: \n72: 该参数会透传给已接入的下游 `opencode-cj` 工作流，只增强 prompt 约束，不改变静态分析、mapcir 或构建门禁逻辑。\n73: \n74: 如果希望在 planning 前让 `opencode-cj` 先逐代码文件走读源项目，并记录关键功能、类、方法/函数、资源证据和迁移注意点，可加：\n75: \n76: ```bash\n77: --source-walkthrough\n78: ```\n79: \n80: 该选项会在下游 planning 前额外启动一次 source walkthrough session，写入 `translation-inputs/agent-source-walkthrough.md`，并创建或更新 `source-coverage-matrix.json/md` 与 `platform-capability-check.json/md`。脚本生成的 `source-file-inventory.*` 会逐代码文件列出功能提示和关键类/方法/函数，作为 agent 走读的起始索引；agent 仍需在行为不清楚时回查源文件，并对 critical/high 平台能力补充 CangjieSkills、HarmonyOS-Examples、HarmonyOS/Cangjie 文档或包索引查证记录。\n81: \n82: 覆盖报告默认启用但只预警，不会因为代码行数不接近而阻断翻译。它会列出关键源文件、源功能覆盖矩阵、平台能力检查、资源/本地化覆盖、目标侧 placeholder/stub/in-memory/deferred 等弱化信号，以及 target/source 规模比例。对于源项目非空文本行数不少于 3000 的项目，目标非空 LoC 低于源项目 75% 会作为 medium 代码规模预警，低于 50% 会作为 high-risk gap；这不是要求机械凑行数，而是把大幅缩水作为功能遗漏或平台弱化的强信号。健康的 target/source LoC 比例不代表功能已覆盖，只是消除了一个代码规模预警；功能覆盖仍要看矩阵、平台能力检查、资源覆盖、弱化信号和测试。`source-coverage-matrix-template.*` 与 `platform-capability-template.*` 每次按源项目重新生成；`source-coverage-matrix.json/md` 和 `platform-capability-check.json/md` 是 agent 维护的工作记录，缺失时从模板初始化，之后脚本不覆盖已有矩阵/检查。阶段 prompt 会要求 agent 对本阶段相关的关键源功能、平台能力、资源和测试做映射、弥补或明确 deferred。critical/high 功能如果标记为 `implemented-simplified`，必须写清简化内容、保留的用户可见行为、目标端点或测试证据，以及源代码/平台证据；数量或占比过高会进入 findings。critical/high 功能如果标记为 `deferred`，必须写清 `sourceEvidence`、`deferredReason`、`targetFallback`、`risk` 和 `futureCompletionPath`。critical/high 平台能力在标记直接实现、平台替换、fallback 或 deferred 前，必须先查 CangjieSkills/HarmonyOS/Cangjie API 文档和 HarmonyOS-Examples；如果需要第三方包或库，才额外通过 `https://pkg.cangjie-lang.cn` 或 cjpm 包查询能力确认包可用性。cjpm/项目管理文档只用于确认选定依赖如何写入 `cjpm.toml`，不能单独作为平台能力可用性的证据。如果平台已有合适 API、Kit、示例或包，必须使用真实能力或记录为 `platform-replaced`，不能用本地 mock、sample data、in-memory simulation 等 fallback 关闭能力。缺少查证记录或存在“有真实能力却 fallback”的记录会进入 high-risk findings。`deferred` 被视为最后手段；数量/占比过高、缺少具体 blocker、使用泛化理由或批量复用同一套理由，都会进入矩阵 findings。\n83: \n84: `source-coverage-matrix.json` 和 `platform-capability-check.json` 虽然仍是 agent 维护的权威文件，但大批量或关键字段更新应优先通过 `scripts/shared/source_coverage/patch_authority.py` 执行。该工具读取严格 JSON patch payload，通过 `featureId` / `capabilityId` 定位行，支持 `set`、`append`、`remove` 和少量新增行，并在写回前校验字段白名单、status/parity 一致性、critical/high 必填证据、deferred blocker/fallback/future path，以及 active entries 的重复 id。工具写回 JSON 后会直接同步对应 Markdown mirror，避免 agent 临时拼超长 shell 或整文件重写时造成 JSON 失败、字段漂移、Markdown 与 authority 不一致。\n85: \n86: 如果希望每个阶段结束后主动修补当前阶段的功能/规模覆盖缺口，可加：\n87: \n88: ```bash\n89: --repair-coverage-gaps\n90: ```\n91: \n92: 该选项会在 phase 实现会话之后、build gate 之前额外启动一次 phase-scoped coverage repair 会话。repair 会话必须先从 `plan.md` / `plan.json` 判断当前 phase 范围，只修当前阶段承诺的功能、资源、测试、状态/数据行为或无法解释的代码规模差距；全项目 coverage 仍低但属于未来 phase 的内容只能记录为 out of scope，不得提前实现。默认最多 1 轮；需要更强收敛时可加 `--coverage-repair-rounds <n>`。\n93: \n94: 不管是否开启 coverage repair，phase session 开始前都会刷新一份当前阶段任务清单：\n95: \n96: ```text\n97: translation-inputs/phase-task-checklist.md\n98: translation-inputs/phase-task-checklist.json\n99: translation-inputs/phase-task-checklists/<phase>.md\n100: translation-inputs/phase-task-checklists/<phase>.json\n101: translation-inputs/phase-capability-checklist.md\n102: translation-inputs/phase-capability-checklist.json\n103: translation-inputs/phase-capability-checklists/<phase>.md\n104: translation-inputs/phase-capability-checklists/<phase>.json\n105: ```\n106: \n107: `phase-task-checklist.*` 把当前 phase 的覆盖矩阵和平台能力检查汇总为 `implementationGroups`、`mustComplete`、证据不足、fallback/deferred、测试提示和源文件范围，供 agent 在动手前读取。`implementationGroups` 是准备期 contract 入口，会按源端行为、资源迁移、平台能力、验证工作和结构风险分组，并带上预期目标域、风险提示、验收证据和测试状态提示；平台能力组还会带派生的 `capabilityEvidenceProfile`，用于区分 ArkTS/native/overview discovery-only、纯仓颉可调用证据、SDK declaration 和 compile probe 建议；`testHarnessStatus` 会汇总最新 test gate、目标测试文件和疑似 SDK/env blocker。修复时仍以 matrix/capability/test evidence 为事实来源。不合格的 `implemented-simplified`、平台能力 fallback 证据不足、或“记录了目标 API/Kit 却仍使用本地 fallback”的条目会进入 mustComplete。`phase-capability-checklist.*` 只聚焦当前 phase 的 critical/high 平台能力预解析状态；如果仍存在 unresolved、discovery-only 或 compile-probe-recommended 平台能力，编排脚本会先启动 capability pre-resolution session，要求 agent 查证 HarmonyOS/Cangjie 文档、CangjieSkills、示例、SDK 声明或包索引，并只更新 `platform-capability-check.*`，不实现目标代码。确认真实 API/Kit/package 可用时，不得用本地 mock、sample data、in-memory simulation 等 fallback 关闭。prompt 中出现的 workflow/orchestrator 脚本路径只用于追踪来源，不是让 agent 自行执行这些外层脚本。清单本身只生成报告；是否阻断 phase 由下面的 hard gate 决定。\n108: \n109: `capability-sdk-probe-cache.*` 是准备期 SDK 候选扫描缓存，只列出当前 SDK 里可见的纯仓颉声明或 `.cjo` 候选，不直接改变 `platform-capability-check.*` 的 authority 状态。`phase-capability-checklist.*` 会把相关候选挂到当前 phase 的 capability item 上；agent 仍需结合 CangjieSkills、HarmonyOS/Cangjie 文档、示例、包索引、target-context compile probe 或明确 blocker 来维护最终能力记录。\n110: \n111: 如果希望阶段覆盖修复后仍有当前阶段缺口时立即阻断流水线，可加：\n112: \n113: ```bash\n114: --phase-coverage-hard-gate\n115: ```\n116: \n117: 该选项会在阶段内 coverage repair 之后运行只针对当前 phase 的 hard gate，写出 `translation-inputs/phase-coverage-gate-report.*` 和 `translation-inputs/phase-coverage-gates/<phase>.*`。如果当前 phase 的 critical/high 覆盖矩阵条目仍处于 `planned`、`unreviewed`、`not-covered`、非法状态，deferred 缺少具体 blocker/fallback/risk/future path，`implemented-simplified` 缺少具体原因/端点/测试证据，或当前 phase 的平台能力仍 open、证据不足、用了不合格本地 fallback，就让该 phase 失败，不进入后续 build gate / 下一 phase。它不会因为未来阶段尚未实现而失败，和最终全项目的 `--fail-on-high-risk-coverage-gap` 是两个不同粒度的门禁。\n118: \n119: 若需要在完整流水线最终验收时把高风险覆盖差距作为失败，可显式加：\n120: \n121: ```bash\n122: --fail-on-high-risk-coverage-gap\n123: ```\n124: \n125: 在 `--run-all` 中，该选项不会让前几个 phase 因“全项目还没做完”而提前失败；中间 coverage 仍作为 warning 和阶段内 repair 输入。所有请求的 phase 完成后，脚本会执行最终全项目 coverage gate；如果仍存在 high-risk gap，则自动启动 final coverage repair，并在修复后重新运行最终 gate。最终修复轮数默认 1，可用 `--final-coverage-repair-rounds <n>` 调整。\n126: \n127: 测试迁移是默认翻译要求：如果源项目有测试，应迁移或适配到目标项目；如果没有测试，应生成适量核心行为测试；如果测试过少，应补充高风险行为测试。下游 task template 会给出基于路径扫描的 Source Test Inventory 作为 planning 起点；它不是完整测试发现器，agent 仍需按当前 phase 回查必要源文件。无法自动化的测试项需要记录 deferred validation。\n128: \n129: ArkTS 项目默认会同时运行轻量扫描和基于 `ohos-typescript` 编译器 API 的静态分析：\n130: \n131: ```bash\n132: --arkts-analysis-backend both\n133: ```\n134: \n135: 可选值：\n136: \n137: - `lightweight`：只运行快速扫描，适合调试或缺少 Node/pnpm 环境时兜底。\n138: - `compiler`：只运行 ArkTS compiler-based analysis，失败会阻断准备流程。\n139: - `both`：先运行轻量扫描，再运行 compiler-based analysis；compiler 后端失败时记录 warning 并继续。\n140: \n141: 如果需要显式指定 extractor 位置：\n142: \n143: ```bash\n144: --arkts-extractor-root <extract_arkts_definitions-dir>\n145: ```\n146: \n147: 如果已经构建过 extractor，可加：\n148: \n149: ```bash\n150: --skip-arkts-extractor-build\n151: ```\n152: \n153: 如果希望完全切换到 ArkTS 专用独立翻译流程，而不走当前统一框架，可显式使用：\n154: \n155: ```bash\n156: --arkts-engine standalone\n157: ```\n158: \n159: 该模式下统一入口只做 source discovery、preflight 前置检查、standalone 配置生成和日志记录，随后直接调用 ArkTS standalone workflow。它不会运行当前统一流程中的 `skills-check`、ArkTS analyzer、compiler analysis、mapcir、统一 task template、统一 downstream runner 或统一 build gate。\n160: \n161: 当前 bundled ArkTS standalone workflow 的实现路径为：\n162: \n163: ```text\n164: X2Cangjie/ssct-arkts2cangjie/\n165: ```\n166: \n167: standalone 模式主要用于 ArkTS 专项对比实验或验证独立 ArkTS 翻译流程。它支持 `--run-all`、`--planning-only` 和 `--fix-build`；不支持 `--phase` / `--phases`，因为 standalone workflow 内部有自己的阶段状态机。\n168: \n169: 该 workflow 内部按既有实现调用 `opencode run`。统一入口默认会在 `translation-records/arkts-standalone/bin/` 下生成一个局部 `opencode` shim，把这次子进程里的 `opencode` 映射到 `opencode-cj`，以保持仓颉专用 OpenCode 的使用约定。默认映射目标是：\n170: \n171: ```bash\n172: --arkts-standalone-opencode-bin opencode-cj\n173: ```\n174: \n175: 如果需要对比普通 OpenCode 或自定义可执行文件，可以显式修改该参数。生成的配置、shim、workflow root 和日志会记录在 `translation-records/arkts-standalone/standalone-report.*`。\n176: \n177: 只准备输入时：\n178: \n179: ```bash\n180: --prepare-inputs --execute\n181: ```\n182: \n183: 只规划：\n184: \n185: ```bash\n186: --planning-only\n187: ```\n188: \n189: 继续某个阶段：\n\n(Showing lines 70-189 of 345. Use offset=190 to continue.)\n</content>","metadata":{"preview":"```\n\n该参数会透传给已接入的下游 `opencode-cj` 工作流，只增强 prompt 约束，不改变静态分析、mapcir 或构建门禁逻辑。\n\n如果希望在 planning 前让 `opencode-cj` 先逐代码文件走读源项目，并记录关键功能、类、方法/函数、资源证据和迁移注意点，可加：\n\n```bash\n--source-walkthrough\n```\n\n该选项会在下游 planning 前额外启动一次 source walkthrough session，写入 `translation-inputs/agent-source-walkthrough.md`，并创建或更新 `source-coverage-matrix.json/md` 与 `platform-capability-check.json/md`。脚本生成的 `source-file-inventory.*` 会逐代码文件列出功能提示和关键类/方法/函数，作为 agent 走读的起始索引；agent 仍需在行为不清楚时回查源文件，并对 critical/high 平台能力补充 CangjieSkills、HarmonyOS-Examples、HarmonyOS/Cangjie 文档或包索引查证记录。\n\n覆盖报告默认启用但只预警，不会因为代码行数不接近而阻断翻译。它会列出关键源文件、源功能覆盖矩阵、平台能力检查、资源/本地化覆盖、目标侧 placeholder/stub/in-memory/deferred 等弱化信号，以及 target/source 规模比例。对于源项目非空文本行数不少于 3000 的项目，目标非空 LoC 低于源项目 75% 会作为 medium 代码规模预警，低于 50% 会作为 high-risk gap；这不是要求机械凑行数，而是把大幅缩水作为功能遗漏或平台弱化的强信号。健康的 target/source LoC 比例不代表功能已覆盖，只是消除了一个代码规模预警；功能覆盖仍要看矩阵、平台能力检查、资源覆盖、弱化信号和测试。`source-coverage-matrix-template.*` 与 `platform-capability-template.*` 每次按源项目重新生成；`source-coverage-matrix.json/md` 和 `platform-capability-check.json/md` 是 agent 维护的工作记录，缺失时从模板初始化，之后脚本不覆盖已有矩阵/检查。阶段 prompt 会要求 agent 对本阶段相关的关键源功能、平台能力、资源和测试做映射、弥补或明确 deferred。critical/high 功能如果标记为 `implemented-simplified`，必须写清简化内容、保留的用户可见行为、目标端点或测试证据，以及源代码/平台证据；数量或占比过高会进入 findings。critical/high 功能如果标记为 `deferred`，必须写清 `sourceEvidence`、`deferredReason`、`targetFallback`、`risk` 和 `futureCompletionPath`。critical/high 平台能力在标记直接实现、平台替换、fallback 或 deferred 前，必须先查 CangjieSkills/HarmonyOS/Cangjie API 文档和 HarmonyOS-Examples；如果需要第三方包或库，才额外通过 `https://pkg.cangjie-lang.cn` 或 cjpm 包查询能力确认包可用性。cjpm/项目管理文档只用于确认选定依赖如何写入 `cjpm.toml`，不能单独作为平台能力可用性的证据。如果平台已有合适 API、Kit、示例或包，必须使用真实能力或记录为 `platform-replaced`，不能用本地 mock、sample data、in-memory simulation 等 fallback 关闭能力。缺少查证