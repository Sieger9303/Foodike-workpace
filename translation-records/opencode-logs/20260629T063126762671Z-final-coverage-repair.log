{"type":"tool_use","timestamp":1782714720067,"sessionID":"ses_0edec9d59ffesgtxbqGLBL7RFa","part":{"type":"tool","tool":"read","callID":"call_wnYm891vfgQkhQyOYcpDoFRH","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\profile\\profile_store.cj","limit":400,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\profile\\profile_store.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile\n2: \n3: import kit.AbilityKit.UIAbilityContext\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.loginPreferencesService\n5: \n6: public let profileStore = ProfileStore()\n7: \n8: public enum ProfileSection {\n9:     | SavedAddresses\n10:     | PaymentsAndRefunds\n11:     | OnlineOrderingHelp\n12:     | About\n13: }\n14: \n15: public class ProfileStore {\n16:     private let preferencesService = loginPreferencesService\n17: \n18:     public let userName: String = \"Andrew Howard\"\n19:     public let userEmail: String = \"andrewhoward@gmail.com\"\n20: \n21:     public init() {}\n22: \n23:     public func profileSectionCount(): Int64 {\n24:         return 4\n25:     }\n26: \n27:     public func performEditAction(): Bool {\n28:         return false\n29:     }\n30: \n31:     public func performSectionAction(section: ProfileSection): Bool {\n32:         match (section) {\n33:             case ProfileSection.SavedAddresses => false\n34:             case ProfileSection.PaymentsAndRefunds => false\n35:             case ProfileSection.OnlineOrderingHelp => false\n36:             case ProfileSection.About => false\n37:         }\n38:     }\n39: \n40:     public func logout(context: UIAbilityContext): Bool {\n41:         preferencesService.logout(context)\n42:         return true\n43:     }\n44: \n45:     public func logoutRoute(): String {\n46:         return \"onboarding\"\n47:     }\n48: }\n\n(End of file - total 48 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile\n\nimport kit.AbilityKit.UIAbilityContext\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.loginPreferencesService\n\npublic let profileStore = ProfileStore()\n\npublic enum ProfileSection {\n    | SavedAddresses\n    | PaymentsAndRefunds\n    | OnlineOrderingHelp\n    | About\n}\n\npublic class ProfileStore {\n    private let preferencesService = loginPreferencesService\n\n    public let userName: String = \"Andrew Howard\"\n    public let userEmail: String = \"andrewhoward@gmail.com\"\n","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\profile\\profile_store.cj","time":{"start":1782714720021,"end":1782714720066}},"id":"prt_f1213df140022egjBmL4mnsUo0","sessionID":"ses_0edec9d59ffesgtxbqGLBL7RFa","messageID":"msg_f1213967e001QP9qckb7YuqTxU"}}
{"type":"tool_use","timestamp":1782714720071,"sessionID":"ses_0edec9d59ffesgtxbqGLBL7RFa","part":{"type":"tool","tool":"read","callID":"call_vknQdj7nsMj3JxAnTBbCiQgN","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase06_profile_capabilities_verification_test.cj","limit":400,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase06_profile_capabilities_verification_test.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry_test\n2: \n3: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, routePath}\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{ProfileRouteService, ProfileSection, ProfileStore}\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.startup.startupStore\n6: import std.collection.ArrayList\n7: import std.unittest.*\n8: import std.unittest.testmacro.*\n9: \n10: @Test\n11: public class Phase06ProfileCapabilitiesVerificationTest {\n12:     @TestCase\n13:     public func profileStorePreservesStaticIdentity(): Unit {\n14:         let store = ProfileStore()\n15:         @Assert(store.userName, \"Andrew Howard\")\n16:         @Assert(store.userEmail, \"andrewhoward@gmail.com\")\n17:         @Assert(store.profileSectionCount(), 4)\n18:     }\n19: \n20:     @TestCase\n21:     public func profileStoreKeepsEditAndSectionActionsInert(): Unit {\n22:         let store = ProfileStore()\n23:         @Assert(store.performEditAction(), false)\n24:         @Assert(store.performSectionAction(ProfileSection.SavedAddresses), false)\n25:         @Assert(store.performSectionAction(ProfileSection.PaymentsAndRefunds), false)\n26:         @Assert(store.performSectionAction(ProfileSection.OnlineOrderingHelp), false)\n27:         @Assert(store.performSectionAction(ProfileSection.About), false)\n28:     }\n29: \n30:     @TestCase\n31:     public func profileStorePreservesLogoutRoute(): Unit {\n32:         let store = ProfileStore()\n33:         @Assert(store.logoutRoute(), routePath(RouteId.Onboarding))\n34:     }\n35: \n36:     @TestCase\n37:     public func profileStorePreservesBackAndLogoutRoutes(): Unit {\n38:         let store = ProfileStore()\n39:         let routeService = ProfileRouteService()\n40:         let backStack = ArrayList<String>([])\n41:         backStack.add(routePath(RouteId.Home))\n42:         @Assert(store.logoutRoute(), routePath(RouteId.Onboarding))\n43:         @Assert(routeService.resolveBackRoute(routePath(RouteId.Profile), backStack), routePath(RouteId.Home))\n44:         @Assert(routeService.canNavigateBack(routePath(RouteId.Profile), backStack), true)\n45:     }\n46: \n47:     @TestCase\n48:     public func profileLogoutTransitionResetsRouteStateAndReturnsOnboarding(): Unit {\n49:         let store = ProfileStore()\n50:         let routeService = ProfileRouteService()\n51:         let transition = routeService.buildLogoutTransition(store.logoutRoute())\n52:         @Assert(transition.nextRoute, routePath(RouteId.Onboarding))\n53:         @Assert(transition.resetState.loginEmail, \"\")\n54:         @Assert(transition.resetState.loginPassword, \"\")\n55:         @Assert(transition.resetState.onboardingPageIndex, 0)\n56:         @Assert(transition.resetState.homeSearchQuery, \"\")\n57:         @Assert(transition.resetState.homeSelectedFilter, \"\")\n58:         @Assert(transition.resetState.historySearchQuery, \"\")\n59:         @Assert(transition.resetState.historyTabIndex, 0)\n60:     }\n61: \n62:     @TestCase\n63:     public func profileBackRouteUsesTheNavigationStackWhenPresent(): Unit {\n64:         let routeService = ProfileRouteService()\n65:         let backStack = ArrayList<String>([])\n66:         backStack.add(routePath(RouteId.Home))\n67:         backStack.add(routePath(RouteId.History))\n68:         @Assert(routeService.resolveBackRoute(routePath(RouteId.Profile), backStack), routePath(RouteId.History))\n69:         @Assert(routeService.canNavigateBack(routePath(RouteId.Profile), backStack), true)\n70:         let emptyBackStack = ArrayList<String>([])\n71:         @Assert(routeService.resolveBackRoute(routePath(RouteId.Profile), emptyBackStack), routePath(RouteId.Profile))\n72:         @Assert(routeService.canNavigateBack(routePath(RouteId.Profile), emptyBackStack), false)\n73:     }\n74: \n75:     @TestCase\n76:     public func startupResolverReturnsOnboardingAfterLogoutStyleState(): Unit {\n77:         @Assert(startupStore.resolveStartRoute(false), routePath(RouteId.Onboarding))\n78:         @Assert(startupStore.resolveStartRoute(true), routePath(RouteId.Home))\n79:     }\n80: \n81:     @TestCase\n82:     public func sourceExampleUnitAssertionIntentIsCoveredByTargetHarness(): Unit {\n83:         @Assert(2 + 2, 4)\n84:     }\n85: }\n\n(End of file - total 85 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, routePath}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{ProfileRouteService, ProfileSection, ProfileStore}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.startup.startupStore\nimport std.collection.ArrayList\nimport std.unittest.*\nimport std.unittest.testmacro.*\n\n@Test\npublic class Phase06ProfileCapabilitiesVerificationTest {\n    @TestCase\n    public func profileStorePreservesStaticIdentity(): Unit {\n        let store = ProfileStore()\n        @Assert(store.userName, \"Andrew Howard\")\n        @Assert(store.userEmail, \"andrewhoward@gmail.com\")\n        @Assert(store.profileSectionCount(), 4)\n    }\n\n    @TestCase","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\test\\cangjie\\phase06_profile_capabilities_verification_test.cj","time":{"start":1782714720047,"end":1782714720070}},"id":"prt_f1213df2d001pU4Hfff5DdbfCL","sessionID":"ses_0edec9d59ffesgtxbqGLBL7RFa","messageID":"msg_f1213967e001QP9qckb7YuqTxU"}}
