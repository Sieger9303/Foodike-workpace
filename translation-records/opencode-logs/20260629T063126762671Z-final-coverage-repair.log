ontentDescription = stringResource(R.string.display_picture)\n124:                     )\n125:                     Spacer(modifier = Modifier.height(4.dp))\n126:                     Text(\n127:                         text = stringResource(R.string.edit),\n128:                         color = MaterialTheme.colors.primary,\n129:                         modifier = Modifier.clickable {\n130: \n131:                         },\n132:                         fontWeight = FontWeight.Bold\n133:                     )\n134:                 }\n135: \n136: \n137:             }\n138: \n139: \n140:         }\n141:         Divider(\n142:             modifier = Modifier\n143:                 .fillMaxWidth()\n144:                 .padding(12.dp),\n145:             color = Color.Black\n146:         )\n147:         Column(\n148:             modifier = Modifier.fillMaxWidth()\n149:         ) {\n150:             Spacer(modifier = Modifier.height(8.dp))\n151: \n152:             ProfileCard(\n153:                 title = stringResource(R.string.saved_addresses),\n154:                 subtext = stringResource(R.string.add_edit_and_delete_saved_addresses),\n155:                 onClick = {\n156: \n157:                 }\n158:             )\n159:             ProfileCard(\n160:                 title = stringResource(R.string.payments_and_refunds),\n161:                 subtext = stringResource(R.string.information_about_refunds_and_payments),\n162:                 onClick = {\n163:                 }\n164:             )\n165:             ProfileCard(\n166:                 title = stringResource(R.string.online_ordering_help),\n167:                 subtext = stringResource(R.string.information_about_ordering_food),\n168:                 onClick = {\n169:                 }\n170:             )\n171:             ProfileCard(\n172:                 title = stringResource(R.string.about),\n173:                 subtext = stringResource(R.string.about_the_app),\n174:                 onClick = {\n175:   