ta(\"Mutton Pulao\", 7.75, 2.9, 13, false), 0),\n47:         DetailMenuItemData(MenuItemData(\"Prawns Chilli\", 5.75, 3.5, 75, false), 0),\n48:         DetailMenuItemData(MenuItemData(\"Veg Fried Rice\", 3.75, 4.1, 73, true), 0),\n49:         DetailMenuItemData(MenuItemData(\"Masala Dosa\", 4.50, 4.4, 77, true), 0)\n50:     ])\n51: \n52:     public init() {}\n53: \n54:     public func setSelectedRestaurant(restaurant: RestaurantData): Unit {\n55:         selectedRestaurantName = restaurant.name\n56:         replaceSelectedMenu(menuItemsForRestaurant(restaurant.name))\n57:     }\n58: \n59:     public func setRestaurant(restaurant: RestaurantData): Unit {\n60:         setSelectedRestaurant(restaurant)\n61:     }\n62: \n63:     public func getSelectedRestaurantName(): String {\n64:         return selectedRestaurantName\n65:     }\n66: \n67:     public func getSavedRestaurantName(): String {\n68:         return selectedRestaurantName\n69:     }\n70: \n71:     public func getLikedRestaurants(): ArrayList<RestaurantData> {\n72:         return likedRestaurants\n73:     }\n74: \n75:     public func getCartItems(): ArrayList<CartSnapshotItemData> {\n76:         return cartItems\n77:     }\n78: \n79:     public func menuItemsForRestaurant(name: String): ArrayList<DetailMenuItemData> {\n80:         if (name == \"George Street\" || name == \"Edona\" || name == \"Hermes Kitchen\" || name == \"Naga Kitchen\" || name == \"99 Reasons to Eat\") {\n81:             return menu1\n82:         }\n83:         if (name == \"Saffron Xpress\" || name == \"KF\" || name == \"Kanha\" || name == \"Cafe Lighton\" || name == \"Rock n Rolls\") {\n84:             return menu3\n85:         }\n86:         return menu2\n87:     }\n88: \n89:     public func getMenuItems(): ArrayList<DetailMenuItemData> {\n90:         return selectedRestaurantMenuItems\n91:     }\n92: \n93:     public func isRestaurantLiked(restaurant: RestaurantData): Bool {\n94:         return containsLikedRestaurant(restaurant.name)\n95:     }\n96: \n97:     public func setRestaurantLiked(restaurant: RestaurantData, liked: Bool): Unit {\n98:         if (liked) {\n99:             if (!containsLikedRestaurant(restaurant.name)) {\n100:                 likedRestaurants.add(restaurant)\n101:             }\n102:             return\n103:         }\n104:         removeLikedRestaurant(restaurant.name)\n105:     }\n106: \n107:     public func restaurantSelectionRouteToken(): String {\n108:         return selectedRestaurantName\n109:     }\n110: \n111:     private func replaceSelectedMenu(sourceMenu: ArrayList<DetailMenuItemData>): Unit {\n112:         selectedRestaurantMenuItems.clear()\n113:         for (item in sourceMenu) {\n114:             selectedRestaurantMenuItems.add(\n115:                 DetailMenuItemData(\n116:                     MenuItemData(\n117:                         item.menuItem.dish,\n118:                         item.menuItem.price,\n119:                         item.menuItem.rating,\n120:                         item.menuItem.ratingCount,\n121:                         item.menuItem.isVegetarian\n122:                     ),\n123:                     0\n124:                 )\n125:             )\n126:         }\n127:     }\n128: \n129:     private func containsLikedRestaurant(name: String): Bool {\n130:         for (restaurant in likedRestaurants) {\n131:             if (restaurant.name == name) {\n132:                 return true\n133:             }\n134:         }\n135:         return false\n136:     }\n137: \n138:     private func removeLikedRestaurant(name: String): Unit {\n139:         var index: Int64 = 0\n140:         while (index < likedRestaurants.size) {\n141:             if (likedRestaurants[index].name == name) {\n142:                 likedRestaurants.remove(at: index)\n143:                 return\n144:             }\n145:             index += 1\n146:         }\n147:     }\n148: }\n149: \n150: public let sessionRepository = SessionRepository()\n\n(End of file - total 150