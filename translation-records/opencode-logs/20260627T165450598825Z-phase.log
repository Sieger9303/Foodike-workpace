ode for scoped home/history domain and presentation groups","status":"pending","priority":"high"},{"content":"Implement missing HarmonyOS target behavior for scoped groups only","status":"pending","priority":"high"},{"content":"Run focused verification for changed target modules within harness budget","status":"pending","priority":"medium"},{"content":"Update source coverage and platform capability authority records for completed scoped rows","status":"pending","priority":"high"}],"truncated":false},"title":"5 todos","time":{"start":1782579299557,"end":1782579299560}},"id":"prt_f0a017f0f003e4ynXVpbEnApv0","sessionID":"ses_0f5fe9798ffe4oHJyj719rZuqI","messageID":"msg_f0a016982001aR98kEeQbzBkEX"}}
