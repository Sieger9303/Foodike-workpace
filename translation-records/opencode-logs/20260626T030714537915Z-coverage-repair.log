tate(shellState)\n370:                     })\n371:             }\n372: \n373:             Button(\"Primary Route Action\")\n374:                 .onClick({ _ =>\n375:                     this.applyShellCommand(ShellCommand.PrimaryAction)\n376:                 })\n377: \n378:             if (this.showBottomShell(this.currentRoute)) {\n379:                 Row(space: 12) {\n380:                     Button(\"Home Tab\")\n381:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HomeTab) })\n382:                     Button(\"Cart\")\n383:                         .onClick({ _ => this.applyShellCommand(ShellCommand.CartAction) })\n384:                     Button(\"History Tab\")\n385:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HistoryTab) })\n386:                 }\n387:             }\n388:         }\n389:         .width(100.percent)\n390:         .height(100.percent)\n391:         .justifyContent(FlexAlign.Center)\n392:         .alignItems(HorizontalAlign.Center)\n393:         .padding(top: 24, right: 24, bottom: 24, left: 24)\n394:     }\n395: \n396:     func build() {\n397:         if (this.currentRoute == routePath(RouteId.Onboarding)) {\n398:             this.buildOnboardingRoute()\n399:         } else if (this.currentRoute == routePath(RouteId.Login)) {\n400:             this.buildLoginRoute()\n401:         } else if (this.currentRoute == routePath(RouteId.Home)) {\n402:             this.buildHomeRoute()\n403:         } else if (this.currentRoute == routePath(RouteId.History)) {\n404:             this.buildHistoryRoute()\n405:         } else if (this.currentRoute == routePath(RouteId.Cart)) {\n406:             this.buildCartRoute()\n407:         } else if (this.currentRoute == routePath(RouteId.RestaurantDetails)) {\n408:             this.buildDetailRoute()\n409:         } else if (this.currentRoute == routePath(RouteId.Profile)) {\n410:             this.buildProfileRoute()\n411:         } else {\n412:             this.buildPlaceholderRoute()\n413:         }\n414:     }\n415: }\n\n(End of file - total 415 lines)\n</content>","metadata":{"preview":"        renderHistoryRoute(\n            historyStore.loadHistoryState(),\n            this.historyTabIndex,\n            this.historySearchQuery,\n            { value: String =>\n                this.historySearchQuery = value\n            },\n            { value: Int64 =>\n                this.historyTabIndex = value\n            },\n            { restaurant: RestaurantData =>\n                this.selectHistoryRestaurant(restaurant)\n            }\n        )\n    }\n\n    @Builder\n    private func buildCartRoute() {\n        renderCartRoute(\n            cartStore.loadCartState(),","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj","time":{"start":1782443264259,"end":1782443264266}},"id":"prt_f01e5c8af001Akr73Xu33U0Lmb","sessionID":"ses_0fe1aa5d9ffesFmHB6DHkAouwB","messageID":"msg_f01e5a68500186Snckldtjzmf4"}}
{"type":"tool_use","timestamp":1782443264331,"sessionID":"ses_0fe1aa5d9ffesFmHB6DHkAouwB","part":{"type":"tool","tool":"read","callID":"call_2S59V3SGf1xduuKs9KykPbRi","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase05_detail_cart_state_mutations_test.cj","limit":220},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase05_detail_cart_state_mutations_test.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry_test\n2: \n3: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.DetailStore\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.CartStore\n6: import std.unittest.*\n7: import std.unittest.testmacro.*\n8: \n9: @Test\n10: public class Phase05DetailCartStateMutationsTest {\n11:     @TestCase\n12:     public func cartStoreFiltersZeroCountItemsAndPreservesSnapshotOrder(): Unit {\n13:         let store = CartStore()\n14:         let state = store.loadCartState()\n15:         let visibleItems = store.visibleItems(state.items)\n16:         @Assert(visibleItems.size, 2)\n17:         @Assert(visibleItems[0].menuItem.dish, \"Paw Bhaaji\")\n18:         @Assert(visibleItems[1].menuItem.dish, \"Veg Pulao\")\n19:     }\n20: \n21:     @TestCase\n22:     public func cartStoreCalculatesTotalsFromSnapshotQuantities(): Unit {\n23:         let store = CartStore()\n24:         let state = store.loadCartState()\n25:         let itemTotal = store.itemTotal(store.visibleItems(state.items))\n26:         @Assert(itemTotal, 12.0)\n27:         @Assert(store.taxAmount(itemTotal), 2.16)\n28:         @Assert(store.grandTotal(itemTotal), 14.16)\n29:     }\n30: \n31:     @TestCase\n32:     public func cartStoreKeepsSourceDeliveryPlaceholders(): Unit {\n33:         let store = CartStore()\n34:         let state = store.loadCartState()\n35:         @Assert(state.deliveryRestaurant.name, \"Relish\")\n36:         @Assert(store.deliveryLocation(), \"Guwahati\")\n37:         @Assert(store.formatEta(state.deliveryRestaurant.etaMinutes), \"30 Min\")\n38:     }\n39: \n40:     @TestCase\n41:     public func detailStoreLoadsSelectedRestaurantAndRecommendedMenuSlice(): Unit {\n42:         let store = DetailStore()\n43:         let contentRepository = HomeContentRepository()\n44:         let restaurant = match (contentRepository.getRestaurantByName(\"Relish\")) {\n45:             case Some(found) => found\n46:             case None => contentRepository.getRestaurants()[0]\n47:         }\n48:         store.session().setSelectedRestaurant(restaurant)\n49: \n50:         let state = store.loadDetailState(true, true, true)\n51:         @Assert(state.restaurant.name, \"Relish\")\n52:         @Assert(state.recommendedItems.size, 5)\n53:         @Assert(state.recommendedItems[0].menuItem.dish, \"Masala Dosa\")\n54:     }\n55: \n56:     @TestCase\n57:     public func detailStorePreservesSectionFilteringAndCartVisibilityRules(): Unit {\n58:         let store = DetailStore()\n59:         let contentRepository = HomeContentRepository()\n60:         let restaurant = match (contentRepository.getRestaurantByName(\"George Street\")) {\n61:             case Some(found) => found\n62:             case None => contentRepository.getRestaurants()[0]\n63:         }\n64:         store.session().setSelectedRestaurant(restaurant)\n65: \n66:         let state = store.loadDetailState(true, true, true)\n67:         let nonVegItems = store.nonVegItems(state.menuItems)\n68:         let vegItems = store.vegItems(state.menuItems)\n69:         @Assert(nonVegItems.size, 4)\n70:         @Assert(vegItems.size, 4)\n71:         @Assert(store.shouldShowCartAction(state.menuItems), false)\n72: \n73:         store.incrementQuantity(state.menuItems[0])\n74:         @Assert(store.shouldShowCartAction(state.menuItems), true)\n75:         @Assert(store.totalSelectedItems(state.menuItems), 1)\n76:         store.decrementQuantity(state.menuItems[0])\n77:         @Assert(store.totalSelectedItems(state.menuItems), 0)\n78:     }\n79: \n80:     @TestCase\n81:     public func detailStoreTogglesLikedStateForSelectedRestaurant(): Unit {\n82:         let store = DetailStore()\n83:         let contentRepository = HomeContentRepository()\n84:         let restaurant = match (contentRepository.getRestaurantByName(\"Relish\")) {\n85:             case Some(found) => found\n86:             case None => contentRepository.getRestaurants()[0]\n87:         }\n88: \n89:         store.session().setRestaurantLiked(restaurant, false)\n90:         let liked = store.toggleLiked(restaurant, false)\n91:         @Assert(liked, true)\n92:         @Assert(store.session().isRestaurantLiked(restaurant), true)\n93:         let unliked = store.toggleLiked(restaurant, true)\n94:         @Assert(unliked, false)\n95:     }\n96: }\n\n(End of file - total 96 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.DetailStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.CartStore\nimport std.unittest.*\nimport std.unittest.testmacro.*\n\n@Test\npublic class Phase05DetailCartStateMutationsTest {\n    @TestCase\n    public func cartStoreFiltersZeroCountItemsAndPreservesSnapshotOrder(): Unit {\n        let store = CartStore()\n        let state = store.loadCartState()\n        let visibleItems = store.visibleItems(state.items)\n        @Assert(visibleItems.size, 2)\n        @Assert(visibleItems[0].menuItem.dish, \"Paw Bhaaji\")\n        @Assert(visibleItems[1].menuItem.dish, \"Veg Pulao\")\n    }\n","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\test\\cangjie\\phase05_detail_cart_state_mutations_test.cj","time":{"start":1782443264323,"end":1782443264330}},"id":"prt_f01e5c904001DLidSWm6Gqkq6N","sessionID":"ses_0fe1aa5d9ffesFmHB6DHkAouwB","messageID":"msg_f01e5a68500186Snckldtjzmf4"}}
