{"type":"tool_use","timestamp":1782536530670,"sessionID":"ses_0f88b7e2cffeUNurzZTLCWOa0i","part":{"type":"tool","tool":"read","callID":"call_Gz13Q6qYmbycjocpsizwJRc0","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj","limit":300,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n2: \n3: import kit.ArkUI.*\n4: import ohos.base.ResourceStr\n5: import ohos.arkui.state_macro_manage.Builder\n6: import ohos.arkui.state_macro_manage.Component\n7: import ohos.arkui.state_macro_manage.Entry\n8: import ohos.arkui.state_macro_manage.State\n9: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n10: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.{CartSnapshotItemData, DetailMenuItemData, DetailPageState, RestaurantData}\n11: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.{cartStore, renderCartRoute}\n12: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.{detailStore, renderDetailRoute}\n13: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history.{historyStore, renderHistoryRoute}\n14: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home.{homeStore, renderHomeRoute}\n15: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.{loginStore, renderLoginRoute}\n16: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.{onboardingStore, renderOnboardingRoute}\n17: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{profileStore, renderProfileRoute}\n18: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.runtime.{Global, bootstrapStartRoute}\n19: \n20: @Entry\n21: @Component\n22: class FoodikeBootstrap {\n23:     @State\n24:     var currentRoute: String = bootstrapStartRoute\n25: \n26:     @State\n27:     var isShellAtTop: Bool = true\n28: \n29:     @State\n30:     var onboardingPageIndex: Int64 = 0\n31: \n32:     @State\n33:     var loginEmail: String = \"\"\n34: \n35:     @State\n36:     var loginPassword: String = \"\"\n37: \n38:     @State\n39:     var loginErrorMessage: String = \"\"\n40: \n41:     @State\n42:     var homeSearchQuery: String = \"\"\n43: \n44:     @State\n45:     var homeSelectedFilter: String = \"\"\n46: \n47:     @State\n48:     var historySearchQuery: String = \"\"\n49: \n50:     @State\n51:     var historyTabIndex: Int64 = 0\n52: \n53:     @State\n54:     var previousRoute: String = \"home_screen\"\n55: \n56:     @State\n57:     var cartNote: String = \"\"\n58: \n59:     @State\n60:     var cartCoupon: String = \"\"\n61: \n62:     @State\n63:     var cartMutationRevision: Int64 = 0\n64: \n65:     @State\n66:     var detailRecommendedExpanded: Bool = true\n67: \n68:     @State\n69:     var detailNonVegExpanded: Bool = true\n70: \n71:     @State\n72:     var detailVegExpanded: Bool = true\n73: \n74:     @State\n75:     var detailLiked: Bool = false\n76: \n77:     @State\n78:     var detailMutationRevision: Int64 = 0\n79: \n80:     private var onboardingController: SwiperController = SwiperController()\n81: \n82:     private func applyShellState(shellState: ShellRouteState): Unit {\n83:         this.currentRoute = shellState.currentRoute\n84:         this.isShellAtTop = shellState.isAtTop\n85:     }\n86: \n87:     private func shellState(): ShellRouteState {\n88:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n89:     }\n90: \n91:     private func applyShellCommand(command: ShellCommand): Unit {\n92:         let shellState = this.shellState()\n93:         shellState.applyCommand(command)\n94:         this.applyShellState(shellState)\n95:     }\n96: \n97:     private func navigateTo(route: String): Unit {\n98:         let shellState = this.shellState()\n99:         this.previousRoute = shellState.currentRoute\n100:         shellState.currentRoute = route\n101:         shellState.isAtTop = true\n102:         this.applyShellState(shellState)\n103:     }\n104: \n105:     private func navigateBack(): Unit {\n106:         let targetRoute = this.previousRoute\n107:         this.previousRoute = this.currentRoute\n108:         this.navigateTo(targetRoute)\n109:     }\n110: \n111:     private func showBottomShell(route: String): Bool {\n112:         let shellState = this.shellState()\n113:         shellState.currentRoute = route\n114:         return shellState.showBottomShell()\n115:     }\n116: \n117:     private func routeTitle(route: String): ResourceStr {\n118:         routeLabelByPath(route)\n119:     }\n120: \n121:     private func showToast(message: String): Unit {\n122:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n123:     }\n124: \n125:     private func clearLoginError(): Unit {\n126:         this.loginErrorMessage = \"\"\n127:     }\n128: \n129:     private func performLogin(): Unit {\n130:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n131:             this.clearLoginError()\n132:             this.navigateTo(loginStore.successRoute())\n133:             return\n134:         }\n135: \n136:         this.loginErrorMessage = loginStore.invalidLoginMessage\n137:         this.showToast(loginStore.invalidLoginMessage)\n138:     }\n139: \n140:     private func performLogout(): Unit {\n141:         profileStore.logout(Global.abilityContext)\n142:         this.loginEmail = \"\"\n143:         this.loginPassword = \"\"\n144:         this.clearLoginError()\n145:         this.onboardingPageIndex = 0\n146:         this.homeSearchQuery = \"\"\n147:         this.homeSelectedFilter = \"\"\n148:         this.historySearchQuery = \"\"\n149:         this.historyTabIndex = 0\n150:         this.navigateTo(profileStore.logoutRoute())\n151:     }\n152: \n153:     private func routeSummary(route: String): String {\n154:         match (route) {\n155:             case \"home_screen\" => \"Home now renders repository-backed discovery content, local search/filter controls, and restaurant selection before detail routing.\"\n156:             case \"history\" => \"History now preserves search plus tab-local content, reuses favourite restaurants, and saves the selected restaurant before navigation.\"\n157:             case \"cart\" => \"Cart now renders snapshot-backed items, a local note editor, a local coupon field, delivery details, and bill totals without adding new checkout persistence flows.\"\n158:             case \"restaurant_details\" => \"Restaurant detail now reads the selected restaurant, preserves local section expansion and like state, keeps menu quantity controls local to the route, and shows the cart action only when selected quantities are non-zero.\"\n159:             case _ => \"\"\n160:         }\n161:     }\n162: \n163:     private func homeHour(): Int64 {\n164:         return 9\n165:     }\n166: \n167:     private func goToProfile(): Unit {\n168:         this.navigateTo(routePath(RouteId.Profile))\n169:     }\n170: \n171:     private func goToRestaurantDetail(): Unit {\n172:         this.detailRecommendedExpanded = true\n173:         this.detailNonVegExpanded = true\n174:         this.detailVegExpanded = true\n175:         this.detailLiked = detailStore.session().isRestaurantLiked(detailStore.selectedRestaurant())\n176:         this.detailMutationRevision = 0\n177:         this.navigateTo(routePath(RouteId.RestaurantDetails))\n178:     }\n179: \n180:     private func detailState(): DetailPageState {\n181:         return detailStore.loadDetailState(\n182:             this.detailRecommendedExpanded,\n183:             this.detailNonVegExpanded,\n184:             this.detailVegExpanded\n185:         )\n186:     }\n187: \n188:     private func selectHomeRestaurant(restaurant: RestaurantData): Unit {\n189:         hom