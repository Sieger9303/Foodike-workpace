{"type":"tool_use","timestamp":1782416643691,"sessionID":"ses_0ffc82e87ffeknZ19ViXwtZ5zV","part":{"type":"tool","tool":"apply_patch","callID":"call_z0ElP1B9OjiPPvOMkiSfzmuQ","state":{"status":"completed","input":{"patchText":"*** Begin Patch\n*** Add File: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\cart\\cart_page.cj\n+package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart\n+\n+import kit.ArkUI.*\n+import ohos.arkui.state_macro_manage.Builder\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n+import std.collection.ArrayList\n+\n+@Builder\n+func buildCartTopBar(onBack: () -> Unit) {\n+    Row {\n+        Button(\"x\")\n+            .onClick({ _ =>\n+                onBack()\n+            })\n+        Blank().layoutWeight(1)\n+    }\n+    .width(100.percent)\n+    .alignItems(VerticalAlign.Center)\n+}\n+\n+@Builder\n+func buildCartQuantityPill(quantity: Int64) {\n+    Row(space: 10) {\n+        Text(\"-\")\n+            .fontSize(16)\n+            .fontWeight(FontWeight.Bold)\n+        Text(\"${quantity}\")\n+            .fontSize(16)\n+            .fontWeight(FontWeight.Medium)\n+        Text(\"+\")\n+            .fontSize(16)\n+            .fontWeight(FontWeight.Bold)\n+            .fontColor(colorDarkGreen)\n+    }\n+    .padding(top: 6, right: 10, bottom: 6, left: 10)\n+    .borderRadius(14)\n+    .border(width: 1.px, color: 0x55000000)\n+}\n+\n+@Builder\n+func buildCartItemRow(item: CartSnapshotItemData) {\n+    Row(space: 16) {\n+        Text(if (item.menuItem.isVegetarian) { \"VEG\" } else { \"NON-VEG\" })\n+            .fontSize(12)\n+            .fontWeight(FontWeight.Bold)\n+            .fontColor(if (item.menuItem.isVegetarian) { colorDarkGreen } else { Color.Red })\n+        Column(space: 6) {\n+            Text(item.menuItem.dish)\n+                .fontSize(16)\n+                .fontWeight(FontWeight.Medium)\n+            Text(cartStore.formatPrice(item.menuItem.price))\n+                .fontSize(14)\n+                .fontColor(Color.Gray)\n+        }\n+        .layoutWeight(1)\n+        buildCartQuantityPill(item.quantity)\n+    }\n+    .width(100.percent)\n+    .alignItems(VerticalAlign.Center)\n+}\n+\n+@Builder\n+func buildItemSection(items: ArrayList<CartSnapshotItemData>, note: String, onNoteChange: (String) -> Unit) {\n+    Column(space: 14) {\n+        if (items.size > 0) {\n+            ForEach(items, itemGeneratorFunc: { item: CartSnapshotItemData, _: Int64 =>\n+                buildCartItemRow(item)\n+            })\n+        } else {\n+            Row {\n+                Text(\"Empty\")\n+                    .fontSize(16)\n+            }\n+            .width(100.percent)\n+            .justifyContent(FlexAlign.Center)\n+        }\n+\n+        Divider().width(100.percent)\n+\n+        TextInput(text: note, placeholder: \"Write instruction for restaurant...\")\n+            .width(100.percent)\n+            .height(52)\n+            .fontSize(15)\n+            .placeholderColor(Color.Gray)\n+            .backgroundColor(Color.White)\n+            .onChange({ value: String =>\n+                onNoteChange(value)\n+            })\n+    }\n+    .width(100.percent)\n+    .padding(top: 18, right: 18, bottom: 18, left: 18)\n+    .backgroundColor(Color.White)\n+    .borderRadius(22)\n+}\n+\n+@Builder\n+func buildCouponBar(coupon: String, onCouponChange: (String) -> Unit) {\n+    Row(space: 12) {\n+        TextInput(text: coupon, placeholder: \"Add a coupon code...\")\n+            .layoutWeight(1)\n+            .height(52)\n+            .fontSize(15)\n+            .placeholderColor(Color.Gray)\n+            .backgroundColor(Color.White)\n+            .borderRadius(26)\n+            .onChange({ value: String =>\n+                onCouponChange(value)\n+            })\n+        Text(\"APPLY\")\n+            .fontSize(15)\n+            .fontWeight(FontWeight.Bold)\n+            .fontColor(colorDarkGreen)\n+    }\n+    .width(100.percent)\n+    .padding(top: 14, right: 18, bottom: 14, left: 18)\n+    .backgroundColor(Color.White)\n+    .borderRadius(26)\n+    .alignItems(VerticalAlign.Center)\n+}\n+\n+@Builder\n+func buildDeliverySection(restaurant: RestaurantData) {\n+    Column(space: 12) {\n+        Row {\n+            Text(\"Deliver to:\")\n+                .fontWeight(FontWeight.Bold)\n+            Blank().layoutWeight(1)\n+            Text(\"Edit\")\n+                .fontColor(Color.Gray)\n+        }\n+        .width(100.percent)\n+\n+        Row {\n+            Column(space: 6) {\n+                Text(\"Location:\")\n+                Text(\"Estimated time:\")\n+            }\n+            .layoutWeight(1)\n+            Column(space: 6) {\n+                Text(cartStore.deliveryLocation())\n+                Text(cartStore.formatEta(restaurant.etaMinutes))\n+            }\n+        }\n+        .width(100.percent)\n+    }\n+    .width(100.percent)\n+    .padding(top: 18, right: 18, bottom: 18, left: 18)\n+    .backgroundColor(Color.White)\n+    .borderRadius(22)\n+}\n+\n+@Builder\n+func buildBillSection(itemTotal: Float64) {\n+    let taxes = cartStore.taxAmount(itemTotal)\n+    let total = cartStore.grandTotal(itemTotal)\n+\n+    Column(space: 12) {\n+        Text(\"Bill Details\")\n+            .fontSize(18)\n+            .fontWeight(FontWeight.Bold)\n+        Row {\n+            Column(space: 6) {\n+                Text(\"Item total:\")\n+                Text(\"Taxes and charges:\")\n+                Text(\"Total:\")\n+            }\n+            .layoutWeight(1)\n+            Column(space: 6) {\n+                Text(cartStore.formatPrice(itemTotal))\n+                Text(cartStore.formatPrice(taxes))\n+                Text(cartStore.formatPrice(total))\n+            }\n+        }\n+        .width(100.percent)\n+        Button(\"Proceed to Pay\")\n+            .width(220)\n+            .height(48)\n+    }\n+    .w