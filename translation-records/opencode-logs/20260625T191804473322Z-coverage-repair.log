evidence,\n94:         platform_missing_deferred_fields,\n95:     )\n96:     from .render import platform_capability_check_markdown, source_coverage_matrix_markdown\n97:     from .utils import has_text, has_text_or_list\n98: \n99: \n100: MATRIX_OBJECT_FIELDS = {COVERAGE_FACTS_KEY}\n101: MATRIX_LIST_FIELDS = {\"verificationEvidence\", \"targetEndpoints\", \"tests\"}\n102: MATRIX_TEXT_FIELDS = set(MATRIX_AGENT_FIELDS) - MATRIX_LIST_FIELDS - MATRIX_OBJECT_FIELDS\n103: MATRIX_UPDATE_FIELDS = set(MATRIX_AGENT_FIELDS)\n104: MATRIX_ADD_FIELDS = MATRIX_UPDATE_FIELDS | {\n105:     \"featureId\",\n106:     \"featureName\",\n107:     \"sourcePath\",\n108:     \"importance\",\n109:     \"category\",\n110:     \"riskTags\",\n111:     \"keyClasses\",\n112:     \"keyMethods\",\n113:     \"androidIds\",\n114:     \"dependencies\",\n115:     \"featurePoint\",\n116:     \"sourceEvidence\",\n117: }\n118: MATRIX_ADD_REQUIRED_FIELDS = {\"featureId\", \"featureName\", \"sourcePath\", \"importance\", \"sourceEvidence\"}\n119: MATRIX_REQUIRED_LIST_FIELDS = (\"verificationEvidence\", \"targetEndpoints\", \"tests\")\n120: MATRIX_REQUIRED_TEXT_FIELDS = (\n121:     \"plannedPhase\",\n122:     \"sourceBehavior\",\n123:     \"targetBehavior\",\n124:     \"notes\",\n125:     \"deferredReason\",\n126:     \"targetFallback\",\n127:     \"risk\",\n128:     \"futureCompletionPath\",\n129: )\n130: \n131: PLATFORM_OBJECT_FIELDS = {CAPABILITY_FACTS_KEY}\n132: PLATFORM_LIST_FIELDS = {\n133:     \"targetCapabilitySearch\",\n134:     \"targetEndpoints\",\n135:     \"tests\",\n136:     \"sdkDeclarationEvidence\",\n137:     \"cangjieCallableEvidence\",\n138:     \"discoveryOnlyEvidence\",\n139:     \"compileProbeEvidence\",\n140: }\n141: PLATFORM_TEXT_FIELDS = {\n142:     \"status\",\n143:     \"plannedPhase\",\n144:     \"targetApiOrLibrary\",\n145:     \"targetStrategy\",\n146:     \"preResolutionDecision\",\n147:     \"phaseCapabilityResolution\",\n148:     \"blocker\",\n149:     \"targetFallback\",\n150:     \"futureCompletionPath\",\n151:     \"notes\",\n152: }\n153: PLATFORM_UPDATE_FIELDS = PLATFORM_LIST_FIELDS | PLATFORM_TEXT_FIELDS | PLATFORM_OBJECT_FIELDS\n154: PLATFORM_ADD_FIELDS = PLATFORM_UPDATE_FIELDS | {\n155:     \"capabilityId\",\n156:     \"capabilityName\",\n157:     \"importance\",\n158:     \"sourcePaths\",\n159:     \"sourceEvidence\",\n160:     \"sourceEvidenceSummary\",\n161:     \"requiredTargetCapabilitySearch\",\n162:     \"targetStrategyHint\",\n163:     \"minimumParity\",\n164:     \"requiredTests\",\n165:     \"allowedDeferredReasons\",\n166: }\n167: PLATFORM_ADD_REQUIRED_FIELDS = {\"capabilityId\", \"capabilityName\", \"importance\", \"sourceEvidenceSummary\"}\n168: \n169: \n170: class PatchError(ValueError):\n171:     \"\"\"Raised for user-facing patch validation errors.\"\"\"\n172: \n173: \n174: @dataclass(frozen=True)\n175: class PatchContext:\n176:     target_project: Path | None = None\n177:     legal_phases: frozenset[str] | None = None\n178:     allow_missing_endpoints: bool = False\n179:     allow_unknown_phase: bool = False\n180: \n181: \n182: def parse_args() -> argparse.Namespace:\n183:     parser = argparse.ArgumentParser(\n184:         description=(\n185:             \"Apply a strict JSON patch payload to source-coverage-matrix.json or \"\n186:             \"platform-capability-check.json and optionally sync the Markdown view.\"\n187:         ),\n188:         formatter_class=HelpFormatter,\n189:     )\n190:     parser.add_argument(\n191:         \"--kind\",\n192:         choices=(\"auto\", \"matrix\", \"platform\"),\n193:         default=\"auto\",\n194:         help=\"Authority type. auto infers from the authority filename.\",\n195:     )\n196:     parser.add_argument(\"--authority\", required=True, help=\"Authority JSON path to patch.\")\n197:     parser.add_argument(\n198:         \"--patch\",\n199:         default=\"\",\n200:         help=\"Strict JSON patch payload. Omit with --validate-only to just validate the authority.\",\n201:     )\n202:     parser.add_argument(\"--validate-only\", action=\"store_true\", help=\"Validate the authority without applying a patch.\")\n203:     parser.add_argument(\"--dry-run\", action=\"store_true\", help=\"Validate and summarize without writing files.\")\n204:     parser.add_argument(\n205:         \"--markdown\",\n206:         default=\"\",\n207:         help=\"Markdown mirror path. Defaults to the authority path with .md suffix.\",\n208:     )\n209:     parser.add_argument(\"--no-markdown\", action=\"store_true\", help=\"Do not sync the Markdown mirror.\")\n210:     parser.add_argument(\"--summary-json\", default=\"\", help=\"Optional path for a machine-readable patch summary.\")\n211:     parser.add_argument(\n212:         \"--max-markdown-files\",\n213:         type=int,\n214:         default=250,\n215:         help=\"Maximum rows rendered in the Markdown mirror.\",\n216:     )\n217:     parser.add_argument(\n218:         \"--target-project\",\n219:         default=\"\",\n220:         help=(\n221:             \"Optional target project root. When set, targetEndpoints touched by this patch must point \"\n222:             \"to existing target files, with optional ::symbol checks.\"\n223:         ),\n224:     )\n225:     parser.add_argument(\n226:         \"--plan-json\",\n227:         default=\"\",\n228:         help=\"Optional strict plan.json. When set, plannedPhase values touched by this patch must exist in phases[].\",\n229:     )\n230:     parser.add_argument(\n231:         \"--allow-missing-endpoints\",\n232:         action=\"store_true\",\n233:         help=\"Skip targetEndpoints filesystem/symbol validation even when --target-project is set.\",\n234:     )\n235:     parser.add_argument(\n236:         \"--allow-unknown-phase\",\n237:         action=\"store_true\",\n238:         help=\"Skip plannedPhase validation even when --plan-json is set.\",\n239:     )\n240:     return parser.parse_args()\n241: \n242: \n243: def load_strict_json(path: Path, label: str) -> Any:\n244:     try:\n245:         return json.loads(path.read_text(encoding=\"utf-8\"))\n246:     except FileNotFoundError as exc:\n247:         raise PatchError(f\"{label} does not exist: {path}\") from exc\n248:     except json.JSONDecodeError as exc:\n249:         raise PatchError(f\"{label} is not strict JSON: {exc}\") from exc\n250:     except OSError as exc:\n251:         raise PatchError(f\"Could not read {label}: {exc}\") from exc\n252: \n253: \n254: def phase_label(raw: str) -> str:\n255:     value = str(raw).strip()\n256:     if not value:\n257:         return \"\"\n258:     if value.isdigit():\n259:         return f\"phase-{int(value):02d}\"\n260:     return value\n261: \n262: \n263: def phases_from_plan_data(data: Any) -> list[str]:\n264:     if not isinstance(data, dict):\n265:         return []\n266:     phases = data.get(\"phases\")\n267:     if not isinstance(phases, list):\n268:         return []\n269:     found: list[str] = []\n270:     for item in phases:\n271:         candidate = \"\"\n272:         if isinstance(item, dict):\n273:             candidate = str(item.get(\"id\") or item.get(\"name\") or item.get(\"phase\") or \"\").strip()\n274:         elif isinstance(item, str):\n275:             candidate = item.strip()\n276:         labeled = phase_label(candidate)\n277:         if labeled:\n278:             found.append(labeled)\n279:     return list(dict.fromkeys(found))\n280: \n281: \n282: def patch_context_from_args(args: argparse.Namespace) -> PatchContext:\n283:     target_project = expand_path(args.target_project) if args.target_project else None\n284:     if target_project is not None and not target_project.exists():\n285:         raise PatchError(f\"target project does not exist: {target_project}\")\n286:     if target_project is not None and not target_project.is_dir():\n287:         raise PatchError(f\"target project is not a directory: {target_project}\")\n288: \n289:     legal_phases: frozenset[str] | None = None\n290:     if args.plan_json and not args.allow_unknown_phase:\n291:         plan_path = expand_path(args.plan_json)\n292:         if plan_path is None:\n293:             raise PatchError(\"--plan-json was provided but did not resolve to a path.\")\n294:         plan_data = load_strict_json(plan_path, \"plan json\")\n295:         phases = phases_from_plan_data(plan_data)\n296:         if not phases:\n297:             raise PatchError(f\"plan json does not define a non-empty top-level phases array: {plan_path}\")\n298:         legal_phases = frozenset(phases)\n299: \n300:     return PatchContext(\n301:         target_project=target_project,\n302:         legal_phases=legal_phases,\n303:         allow_missing_endpoints=bool(args.allow_missing_endpoints),\n304:         allow_unknown_phase=bool(args.allow_unknown_phase),\n305:     )\n306: \n307: \n308: def infer_kind(kind: str, authority: Path) -> str:\n309:     if kind != \"auto\":\n310:         return kind\n311:     name = authority.name\n312:     if name == \"source-coverage-matrix.json\":\n313:         return \"matrix\"\n314:     if name == \"platform-capability-check.json\":\n315:         return \"platform\"\n316:     raise PatchError(\n317:         \"Could not infer authority kind from filename. Pass --kind matrix or --kind platform explicitly.\"\n318:     )\n319: \n320: \n321: def entry_id_field(kind: str) -> str:\n322:     return \"featureId\" if kind == \"matrix\" else \"capabilityId\"\n323: \n324: \n325: def entries_by_id(kind: str, authority: dict[str, Any]) -> tuple[dict[str, dict[str, Any]], list[str]]:\n326:     return matrix_entries_by_id(authority) if kind == \"matrix\" else capability_entries_by_id(authority)\n327: \n328: \n329: def status_counts(kind: str, authority: dict[str, Any]) -> Counter[str]:\n330:     counts: Counter[str] = Counter()\n331:     for entry in authority.get(\"entries\", []):\n332:         if not isinstance(entry, dict):\n333:             continue\n334:         if kind == \"matrix\":\n335:             status = effective_matrix_status(entry)\n336:         else:\n337:             status = effective_capability_status(entry)\n338:         counts[status] += 1\n339:     return counts\n340: \n341: \n342: def validate_authority_shape(kind: str, authority: Any) -> dict[str, dict[str, Any]]:\n343:     if not isinstance(authority, dict):\n344:         raise PatchError(\"Authority JSON must be an object.\")\n345:     entries = authority.get(\"entries\")\n346:     if not isinstance(entries, list):\n347:         raise PatchError(\"Authority JSON must contain an `entries` list.\")\n348:     id_field = entry_id_field(kind)\n349:     missing_ids = [\n350:         str(index)\n351:         for index, entry in enumerate(entries, start=1)\n352:         if not isinstance(entry, dict) or not str(entry.get(id_field) or \"\").strip()\n353:     ]\n354:     if missing_ids:\n355:         raise PatchError(f\"Authority has entries without explicit `{id_field}` at positions: {', '.join(missing_ids[:20])}.\")\n356:     by_id, problems = entries_by_id(kind, authority)\n357:     if problems:\n358:         raise PatchError(\"Authority structural problem(s): \" + \"; \".join(problems[:20]))\n359:     return by_id\n360: \n361: \n362: def split_target_endpoint(endpoint: str) -> tuple[str, str]:\n363:     raw_path, sep, raw_symbol = endpoint.partition(\"::\")\n364:     endpoint_path = raw_path.strip().strip(\"`\")\n365:     symbol = raw_symbol.strip().strip(\"`\") if sep else \"\"\n366:     # Accept common line suffixes such as foo.cj:42 without treating the line\n367:     # number as part of the path.\n368:     endpoint_path = re.sub(r\"(\\.(?:cj|json|ets|ts|js|xml|toml|yaml|yml|md|txt)):\\d+$\", r\"\\1\", endpoint_path)\n369:     return endpoint_path, symbol\n370: \n371: \n372: def endpoint_file_path(target_project: Path, endpoint_path: str) -> Path:\n373:     normalized = endpoint_path.replace(\"\\\\\", \"/\")\n374:     candidate = Path(normalized)\n375:     if candidate.is_absolute():\n376:         return candidate\n377:     return target_project / candidate\n378: \n379: \n380: def symbol_tokens(symbol: str) -> list[str]:\n381:     return [\n382:         token\n383:         for token in re.split(r\"[^A-Za-z0-9_]+\", symbol)\n384:         if token and token not in {\"self\", \"this\", \"prototype\"}\n385:     ]\n386: \n387: \n388: def validate_target_endpoint(target_project: Path, endpoint: Any) -> list[str]:\n389:     if not isinstance(endpoint, str) or not endpoint.strip():\n390:         return [\"targetEndpoint values must be non-empty strings\"]\n391:     endpoint_path, symbol = split_target_endpoint(endpoint)\n392:     if not endpoint_path:\n393:         return [f\"targetEndpoint `{endpoint}` is missing a target file path\"]\n394:     path = endpoint_file_path(target_project, endpoint_path)\n395:     if not path.exists():\n396:         return [f\"targetEndpoint `{endpoint}` file does not exist: {path}\"]\n397:     if not path.is_file():\n398:         return [f\"targetEndpoint `{endpoint}` is not a file: {path}\"]\n399:     tokens = symbol_tokens(symbol)\n400:     if tokens:\n401:         try:\n402:             text = path.read_text(encoding=\"utf-8\", errors=\"replace\")\n403:         except OSError as exc:\n404:             return [f\"targetEndpoint `{endpoint}` could not be read for symbol validation: {exc}\"]\n405:         missing = [token for token in tokens if token not in text]\n406:         if missing:\n407:             return [f\"targetEndpoint `{endpoint}` symbol token(s) not found in {path}: {', '.join(missing)}\"]\n408:     return []\n409: \n410: \n411: def contextual_validation_errors(\n412:     kind: str,\n413:     entry: dict[str, Any],\n414:     context: PatchContext,\n415: ) -> list[str]:\n416:     problems: list[str] = []\n417:     if context.legal_phases is not None and not context.allow_unknown_phase:\n418:         planned_phase = phase_label(str(entry.get(\"plannedPhase\") or \"\"))\n419:         if planned_phase and planned_phase not in context.legal_phases:\n420:             shown = \", \".join(sorted(context.legal_phases)[:20])\n421:             problems.append(f\"plannedPhase `{planned_phase}` is not present in plan phases: {shown}\")\n422: \n423:     if context.target_project is not None and not context.allow_missing_endpoints:\n424:         endpoints = coverage_target_endpoints(entry) if kind == \"matrix\" else capability_target_endpoints(entry)\n425:         if isinstance(endpoints, list):\n426:             for endpoint in endpoints:\n427:                 problems.extend(validate_target_endpoint(context.target_project, endpoint))\n428:     return problems\n429: \n430: \n431: def validate_contextual_entries(\n432:     kind: str,\n433:     entries: list[dict[str, Any]],\n434:     context: PatchContext,\n435: ) -> None:\n436:     if context.legal_phases is None and (context.target_project is None or context.allow_missing_endpoints):\n437:         return\n438:     id_field = entry_id_field(kind)\n439:     errors: list[dict[str, Any]] = []\n440:     for entry in entries:\n441:         problems = contextual_validation_errors(kind, entry, context)\n442:         if problems:\n443:             errors.append({id_field: entry.get(id_field, \"\"), \"problems\": problems})\n444:     if errors:\n445:         shown = \"; \".join(f\"{item.get(id_field)}: {', '.join(item['problems'])}\" for item in errors[:20])\n446:         raise PatchError(f\"Authority context validation failed for {len(errors)} entrie(s): {shown}\")\n447: \n448: \n449: def ensure_object(value: Any, field: str) -> dict[str, Any]:\n450:     if value is None:\n451:         return {}\n452:     if not isinstance(value, dict):\n453:         raise PatchError(f\"`{field}` must be an object.\")\n454:     return value\n455: \n456: \n457: def ensure_list(value: Any, field: str) -> list[Any]:\n458:     if value is None:\n459:         return []\n460:     if not isinstance(value, list):\n461:         raise PatchError(f\"`{field}` must be a list.\")\n462:     return value\n463: \n464: \n465: def canonical_json(value: Any) -> str:\n466:     return json.dumps(value, ensure_ascii=False, sort_keys=True, separators=(\",\", \":\"))\n467: \n468: \n469: def append_unique(existing: list[Any], values: list[Any]) -> list[Any]:\n470:     result = list(existing)\n471:     seen = {canonical_json(item) for item in result}\n472:     for value in values:\n473:         key = canonical_json(value)\n474:         if key not in seen:\n475:             result.append(value)\n476:             seen.add(key)\n477:     return result\n478: \n479: \n480: def validate_patch_payload(payload: Any) -> dict[str, Any]:\n481:     if not isinstance(payload, dict):\n482:         raise PatchError(\"Patch payload must be a JSON object.\")\n483:     allowed = {\"schemaVersion\", \"purpose\", \"updates\", \"add\", \"additions\"}\n484:     unknown = sorted(set(payload) - allowed)\n485:     if unknown:\n486:         raise PatchError(f\"Patch payload has unknown top-level field(s): {', '.join(unknown)}.\")\n487:     updates = payload.get(\"updates\", [])\n488:     additions = payload.get(\"add\", payload.get(\"additions\", []))\n489:     if not isinstance(updates, list):\n490:         raise PatchError(\"Patch payload `updates` must be a list.\")\n491:     if not isinstance(additions, list):\n492:         raise PatchError(\"Patch payload `add`/`additions` must be a list.\")\n493:     if not updates and not additions:\n494:         raise PatchError(\"Patch payload must contain at least one update or addition.\")\n495:     return {\"updates\": updates, \"additions\": additions}\n496: \n497: \n498: def field_sets(kind: str) -> tuple[set[str], set[str], set[str], set[str]]:\n499:     if kind == \"matrix\":\n500:         return MATRIX_UPDATE_FIELDS, MATRIX_ADD_FIELDS, MATRIX_LIST_FIELDS, MATRIX_TEXT_FIELDS\n501:     return PLATFORM_UPDATE_FIELDS, PLATFORM_ADD_FIELDS, PLATFORM_LIST_FIELDS, PLATFORM_TEXT_FIELDS\n502: \n503: \n504: def object_fields(kind: str) -> set[str]:\n505:     return MATRIX_OBJECT_FIELDS if kind == \"matrix\" else PLATFORM_OBJECT_FIELDS\n506: \n507: \n508: def default_object_value(kind: str, field: str) -> dict[str, Any]:\n509:     if kind == \"matrix\" and field == COVERAGE_FACTS_KEY:\n510:         return default_coverage_facts()\n511:     if kind == \"platform\" and field == CAPABILITY_FACTS_KEY:\n512:         return default_capability_facts()\n513:     return {}\n514: \n515: \n516: def validate_object_field(kind: str, field: str, value: Any) -> dict[str, Any]:\n517:     if not isinstance(value, dict):\n518:         raise PatchError(f\"Field `{field}` must be an object.\")\n519:     if field in {COVERAGE_FACTS_KEY, CAPABILITY_FACTS_KEY} and value.get(\"factsSource\") != \"agent\":\n520:         raise PatchError(f\"Field `{field}` updates must use factsSource `agent`.\")\n521:     strict = value.get(\"factsSource\") == \"agent\"\n522:     problems = (\n523:         validate_coverage_facts(value, strict=strict)\n524:         if kind == \"matrix\" and field == COVERAGE_FACTS_KEY\n525:         else validate_capability_facts(value, strict=strict)\n526:     )\n527:     if problems:\n528:         raise PatchError(f\"Field `{field}` has invalid structured facts: \" + \"; \".join(problems[:12]))\n529:     return copy.deepcopy(value)\n530: \n531: \n532: def validate_field_value(kind: str, field: str, value: Any, *, add_entry: bool = False) -> Any:\n533:     update_fields, add_fields, list_fields, text_fields = field_sets(kind)\n534:     allowed = add_fields if add_entry else update_fields\n535:     if field not in allowed:\n536:         raise PatchError(f\"Field `{field}` is not writable for {kind} authority patches.\")\n537:     if field in object_fields(kind):\n538:         return validate_object_field(kind, field, value)\n539:     if field in list_fields:\n540:         if not isinstance(value, list):\n541:             raise PatchError(f\"Field `{field}` must be a list.\")\n542:         return value\n543:     if field in text_fields:\n544:         if not isinstance(value, str):\n545:             raise PatchError(f\"Field `{field}` must be a string.\")\n546:         if field == \"status\":\n547:             return value.strip().lower()\n548:         if field == \"parityLevel\":\n549:             return value.strip().lower()\n550:         return value\n551:     if field in {\"riskTags\", \"keyClasses\", \"keyMethods\", \"androidIds\", \"dependencies\", \"sourcePaths\"}:\n552:         if not isinstance(value, list):\n553:             raise PatchError(f\"Field `{field}` must be a list.\")\n554:     elif field in {\"sourceEvidence\", \"requiredTargetCapabilitySearch\", \"requiredTests\", \"allowedDeferredReasons\"}:\n555:         if kind == \"platform\" and field != \"sourceEvidence\" and not isinstance(value, list):\n556:             raise PatchError(f\"Field `{field}` must be a list.\")\n557:         if kind == \"platform\" and field == \"sourceEvidence\" and not isinstance(value, list):\n558:             raise PatchError(\"Field `sourceEvidence` must be a list for platform additions.\")\n559:         if kind == \"matrix\" and field == \"sourceEvidence\" and not isinstance(value, str):\n560:             raise PatchError(\"Field `sourceEvidence` must be a string for matrix additions.\")\n561:     elif field in {\n562:         \"featureId\",\n563:         \"featureName\",\n564:         \"sourcePath\",\n565:         \"importance\",\n566:         \"category\",\n567:         \"featurePoint\",\n568:         \"capabilityId\",\n569:         \"capabilityName\",\n570:         \"sourceEvidenceSummary\",\n571:         \"targetStrategyHint\",\n572:         \"minimumParity\",\n573:     }:\n574:         if not isinstance(value, str):\n575:             raise PatchError(f\"Field `{field}` must be a string.\")\n576:     return value\n577: \n578: \n579: def patch_entry(kind: str, entry: dict[str, Any], update: dict[str, Any]) -> None:\n580:     allowed_ops = {\"featureId\", \"capabilityId\", \"set\", \"append\", \"remove\", \"unset\"}\n581:     unknown = sorted(set(update) - allowed_ops)\n582:     if unknown:\n583:         raise PatchError(f\"Update for `{entry.get(entry_id_field(kind), '')}` has unknown operation field(s): {', '.join(unknown)}.\")\n584: \n585:     set_values = ensure_object(update.get(\"set\"), \"set\")\n586:     append_values = ensure_object(update.get(\"append\"), \"append\")\n587:     remove_values = ensure_object(update.get(\"remove\"), \"remove\")\n588:     unset_fields = ensure_list(update.get(\"unset\"), \"unset\")\n589:     _, _, list_fields, text_fields = field_sets(kind)\n590: \n591:     for field, value in set_values.items():\n592:         entry[field] = validate_field_value(kind, field, value)\n593: \n594:     for field, values in append_values.items():\n595:         if field not in list_fields:\n596:             raise PatchError(f\"Append is allowed only for list fields; `{field}` is not appendable.\")\n597:         values = validate_field_value(kind, field, values)\n598:         existing = entry.get(field, [])\n599:         if not isinstance(existing, list):\n600:             raise PatchError(f\"Cannot append to `{field}` because the current value is not a list.\")\n601:         entry[field] = append_unique(existing, values)\n602: \n603:     for field, values in remove_values.items():\n604:         if field not in list_fields:\n605:             raise PatchError(f\"Remove is allowed only for list fields; `{field}` is not removable.\")\n606:         values = validate_field_value(kind, field, values)\n607:         existing = entry.get(field, [])\n608:         if not isinstance(existing, list):\n609:             raise PatchError(f\"Cannot remove from `{field}` because the current value is not a list.\")\n610:         remove_keys = {canonical_json(value) for value in values}\n611:         entry[field] = [value for value in existing if canonical_json(value) not in remove_keys]\n612: \n613:     update_fields, _, _, _ = field_sets(kind)\n614:     for field in unset_fields:\n615:         if not isinstance(field, str):\n616:             raise PatchError(\"Every `unset` item must be a string field name.\")\n617:         if field not in update_fields:\n618:             raise PatchError(f\"Field `{field}` is not writable for {kind} authority patches.\")\n619:         if field in list_fields:\n620:             entry[field] = []\n621:         elif field in object_fields(kind):\n622:             entry[field] = default_object_value(kind, field)\n623:         else:\n624:             entry[field] = \"\"\n625:         if field in text_fields and field == \"status\":\n626:             entry[field] = \"planned\"\n627: \n628: \n629: def matrix_defaulted_addition(entry: dict[str, Any]) -> dict[str, Any]:\n630:     defaults: dict[str, Any] = {\n631:         \"status\": \"planned\",\n632:         \"plannedPhase\": \"\",\n633:         \"sourceBehavior\": entry.get(\"featurePoint\", \"\"),\n634:         \"targetBehavior\": \"\",\n635:         \"verificationEvidence\": [],\n636:         \"parityLevel\": \"unverified\",\n637:         \"targetEndpoints\": [],\n638:         \"tests\": [],\n639:         \"notes\": \"\",\n640:         \"deferredReason\": \"\",\n641:         \"targetFallback\": \"\",\n642:         \"risk\": \"\",\n643:         \"futureCompletionPath\": \"\",\n644:         \"entryOrigin\": \"agent-curated\",\n645:         \"matrixSync\": {\n646:             \"status\": \"agent-curated\",\n647:             \"preserveActive\": True,\n648:             \"reason\": \"row was added through structured authority patch\",\n649:         },\n650:         \"riskTags\": [],\n651:         \"keyClasses\": [],\n652:         \"keyMethods\": [],\n653:         \"androidIds\": [],\n654:         \"dependencies\": [],\n655:         \"featurePoint\": \"\",\n656:         \"category\": \"\",\n657:         COVERAGE_FACTS_KEY: default_coverage_facts(),\n658:     }\n659:     return {**defaults, **entry}\n660: \n661: \n662: def platform_defaulted_addition(entry: dict[str, Any]) -> dict[str, Any]:\n663:     defaults: dict[str, Any] = {\n664:         \"status\": \"planned\",\n665:         \"plannedPhase\": \"\",\n666:         \"sourcePaths\": [],\n667:         \"sourceEvidence\": [],\n668:         \"requiredTargetCapabilitySearch\": [],\n669:         \"targetStrategyHint\": \"\",\n670:         \"minimumParity\": \"\",\n671:         \"requiredTests\": [],\n672:         \"allowedDeferredReasons\": [],\n673:         \"targetCapabilitySearch\": [],\n674:         \"targetApiOrLibrary\": \"\",\n675:         \"targetStrategy\": \"\",\n676:         \"targetEndpoints\": [],\n677:         \"tests\": [],\n678:         \"sdkDeclarationEvidence\": [],\n679:         \"cangjieCallableEvidence\": [],\n680:         \"discoveryOnlyEvidence\": [],\n681:         \"compileProbeEvidence\": [],\n682:         \"preResolutionDecision\": \"\",\n683:         \"phaseCapabilityResolution\": \"\",\n684:         \"blocker\": \"\",\n685:         \"targetFallback\": \"\",\n686:         \"futureCompletionPath\": \"\",\n687:         \"notes\": \"\",\n688:         CAPABILITY_FACTS_KEY: default_capability_facts(),\n689:     }\n690:     return {**defaults, **entry}\n691: \n692: \n693: def validate_addition(kind: str, addition: Any) -> dict[str, Any]:\n694:     if not isinstance(addition, dict):\n695:         raise PatchError(\"Every addition must be an object.\")\n696:     required = MATRIX_ADD_REQUIRED_FIELDS if kind == \"matrix\" else PLATFORM_ADD_REQUIRED_FIELDS\n697:     missing = [field for field in sorted(required) if not has_text_or_list(addition.get(field))]\n698:     if missing:\n699:         raise PatchError(f\"Addition is missing required field(s): {', '.join(missing)}.\")\n700:     normalized = {\n701:         field: validate_field_value(kind, field, value, add_entry=True)\n702:         for field, value in addition.items()\n703:     }\n704:     return matrix_defaulted_addition(normalized) if kind == \"matrix\" else platform_defaulted_addition(normalized)\n705: \n706: \n707: def matrix_parity_errors(entry: dict[str, Any]) -> list[str]:\n708:     status = effective_matrix_status(entry)\n709:     parity = parity_level(entry)\n710:     if status == \"implemented\" and parity != \"equivalent\":\n711:         return [\"implemented rows must use parityLevel `equivalent`.\"]\n712:     if status == \"implemented-simplified\" and parity != \"simplified\":\n713:         return [\"implemented-simplified rows must use parityLevel `simplified`.\"]\n714:     if status == \"platform-replaced\" and parity != \"platform-replaced\":\n715:         return [\"platform-replaced rows must use parityLevel `platform-replaced`.\"]\n716:     if status == \"deferred\" and parity != \"deferred\":\n717:         return [\"deferred rows must use parityLevel `deferred`.\"]\n718:     if status == \"not-applicable\" and parity not in {\"not-applicable\", \"unverified\", \"\"}:\n719:         return [\"not-applicable rows must use parityLevel `not-applicable`, `unverified`, or empty.\"]\n720:     return []\n721: \n722: \n723: def validate_matrix_entry(entry: dict[str, Any]) -> list[str]:\n724:     problems: list[str] = []\n725:     feature_id = str(entry.get(\"featureId\") or \"\").strip()\n726:     raw_status = str(entry.get(\"status\") or \"\").strip().lower()\n727:     importance = str(entry.get(\"importance\") or \"\").strip().lower()\n728:     coverage_fact_value = entry.get(COVERAGE_FACTS_KEY)\n729:     if coverage_fact_value is not None:\n730:         strict = isinstance(coverage_fact_value, dict) and coverage_fact_value.get(\"factsSource\") == \"agent\"\n731:         problems.extend(validate_coverage_facts(coverage_fact_value, strict=strict))\n732:     if not feature_id:\n733:         problems.append(\"missing featureId\")\n734:     if raw_status not in MATRIX_STATUSES:\n735:         problems.append(f\"invalid status `{raw_status}`\")\n736:     parity = str(entry.get(\"parityLevel\") or \"\").strip().lower()\n737:     if parity not in MATRIX_PARITY_LEVELS:\n738:         problems.append(f\"invalid parityLevel `{parity}`\")\n739:     problems.extend(matrix_parity_errors(entry))\n740: \n741:     important = importance in {\"critical\", \"high\"}\n742:     status = effective_matrix_status(entry)\n743:     if important and status in MATRIX_IMPLEMENTED_STATUSES:\n744:         if not has_source_behavior_evidence(entry):\n745:             problems.append(\"closed critical/high rows require sourceBehavior or sourceEvidence\")\n746:         if not has_target_behavior_evidence(entry):\n747:             problems.append(\"closed critical/high rows require targetBehavior\")\n748:         if not coverage_verification_evidence_items(entry, include_tests=True):\n749:             problems.append(\"closed critical/high rows require verificationEvidence or tests\")\n750:         if not coverage_target_endpoints(entry) and not has_text_or_list(entry.get(\"tests\")):\n751:             problems.append(\"closed critical/high rows require targetEndpoints or tests\")\n752:     if important and status == \"implemented-simplified\":\n753:         if not has_text(entry.get(\"notes\")) and not has_text(entry.get(\"targetFallback\")):\n754:             problems.append(\"implemented-simplified critical/high rows require notes or targetFallback\")\n755:     if important and status == \"deferred\":\n756:         missing = [field for field in MATRIX_DEFERRED_REQUIRED_FIELDS if not has_text_or_list(entry.get(field))]\n757:         if missing:\n758:             problems.append(\"deferred critical/high rows missing \" + \", \".join(missing))\n759:     if important and status == \"not-applicable\" and not has_text(entry.get(\"notes\")):\n760:         problems.append(\"not-applicable critical/high rows require notes\")\n761:     return problems\n762: \n763: \n764: def validate_platform_entry(entry: dict[str, Any]) -> list[str]:\n765:     problems: list[str] = []\n766:     capability_id = str(entry.get(\"capabilityId\") or \"\").strip()\n767:     raw_status = str(entry.get(\"status\") or \"\").strip().lower()\n768:     importance = str(entry.get(\"importance\") or \"\").strip().lower()\n769:     capability_fact_value = entry.get(CAPABILITY_FACTS_KEY)\n770:     if capability_fact_value is not None:\n771:         strict = isinstance(capability_fact_value, dict) and capability_fact_value.get(\"factsSource\") == \"agent\"\n772:         problems.extend(validate_capability_facts(capability_fact_value, strict=strict))\n773:     if not capability_id:\n774:         problems.append(\"missing capabilityId\")\n775:     if raw_status not in PLATFORM_CAPABILITY_STATUSES:\n776:         problems.append(f\"invalid status `{raw_status}`\")\n777: \n778:     important = importance in {\"critical\", \"high\"}\n779:     status = effective_capability_status(entry)\n780:     if important and (status in PLATFORM_CAPABILITY_IMPLEMENTED_STATUSES or status == \"deferred\"):\n781:         if not (\n782:             has_text_or_list(entry.get(\"targetCapabilitySearch\"))\n783:             or has_replacement_api_evidence(entry)\n784:             or has_direct_unavailable_blocker(entry)\n785:         ):\n786:             problems.append(\"resolved/deferred critical/high capabilities require targetCapabilitySearch\")\n787:     if important and status in PLATFORM_CAPABILITY_IMPLEMENTED_STATUSES:\n788:         if not has_replacement_api_evidence(entry) and not has_text_or_list(entry.get(\"targetApiOrLibrary\")):\n789:             problems.append(\"implemented critical/high capabilities require targetApiOrLibrary\")\n790:         if not has_replacement_api_evidence(entry) and not has_text(entry.get(\"targetStrategy\")):\n791:             problems.append(\"implemented critical/high capabilities require targetStrategy\")\n792:         if status in {\"verified-direct\", \"platform-replaced\"} and not capability_target_endpoints(entry):\n793:             problems.append(\"verified-direct/platform-replaced critical/high capabilities require targetEndpoints\")\n794:         if not has_text_or_list(entry.get(\"tests\")) and not has_text(entry.get(\"notes\")) and not has_compile_probe_evidence(entry):\n795:             problems.append(\"implemented critical/high capabilities require tests or notes\")\n796:     if important and status == \"deferred\":\n797:         missing = platform_missing_deferred_fields(entry)\n798:         if missing:\n799:             problems.append(\"deferred critical/high capabilities missing \" + \", \".join(missing))\n800:     if important and status == \"not-applicable\" and not has_text(entry.get(\"notes\")):\n801:         problems.append(\"not-applicable critical/high capabilities require notes\")\n802:     return problems\n803: \n804: \n805: def validate_entry(kind: str, entry: dict[str, Any]) -> list[str]:\n806:     return validate_matrix_entry(entry) if kind == \"matrix\" else validate_platform_entry(entry)\n807: \n808: \n809: def render_markdown(kind: str, authority: dict[str, Any], max_files: int) -> str:\n810:     if kind == \"matrix\":\n811:         return source_coverage_matrix_markdown(authority, max_files)\n812:     return platform_capability_check_markdown(authority, max_files)\n813: \n814: \n815: def apply_patch_payload(\n816:     kind: str,\n817:     authority: dict[str, Any],\n818:     payload: dict[str, Any],\n819:     *,\n820:     context: PatchContext | None = None,\n821: ) -> dict[str, Any]:\n822:     normalized = validate_patch_payload(payload)\n823:     id_field = entry_id_field(kind)\n824:     before_counts = status_counts(kind, authority)\n825:     entries = authority[\"entries\"]\n826:     by_id = validate_authority_shape(kind, authority)\n827: \n828:     added_ids: list[str] = []\n829:     updated_ids: list[str] = []\n830:     touched_entries: list[dict[str, Any]] = []\n831: \n832:     for raw_addition in normalized[\"additions\"]:\n833:         addition = validate_addition(kind, raw_addition)\n834:         item_id = str(addition.get(id_field) or \"\").strip()\n835:         if item_id in by_id:\n836:             raise PatchError(f\"Cannot add duplicate {id_field} `{item_id}`.\")\n837:         problems = validate_entry(kind, addition)\n838:         if problems:\n839:             raise PatchError(f\"Addition `{item_id}` is invalid: \" + \"; \".join(problems))\n840:         entries.append(addition)\n841:         by_id[item_id] = addition\n842:         added_ids.append(item_id)\n843:         touched_entries.append(addition)\n844: \n845:     id_to_index = {str(entry.get(id_field)): index for index, entry in enumerate(entries) if isinstance(entry, dict)}\n846:     for raw_update in normalized[\"updates\"]:\n847:         if not isinstance(raw_update, dict):\n848:             raise PatchError(\"Every update must be an object.\")\n849:         item_id = str(raw_update.get(id_field) or \"\").strip()\n850:         if not item_id:\n851:             raise PatchError(f\"Every update must include `{id_field}`.\")\n852:         if item_id not in id_to_index:\n853:             raise PatchError(f\"Unknown {id_field} `{item_id}`.\")\n854:         entry = entries[id_to_index[item_id]]\n855:         if not isinstance(entry, dict):\n856:             raise PatchError(f\"Entry for `{item_id}` is not an object.\")\n857:         patch_entry(kind, entry, raw_update)\n858:         problems = validate_entry(kind, entry)\n859:         if problems:\n860:             raise PatchError(f\"Updated entry `{item_id}` is invalid: \" + \"; \".join(problems))\n861:         updated_ids.append(item_id)\n862:         touched_entries.append(entry)\n863: \n864:     validate_authority_shape(kind, authority)\n865:     if context is not None:\n866:         validate_contextual_entries(kind, touched_entries, context)\n867:     after_counts = status_counts(kind, authority)\n868:     authority[\"lastUpdatedBy\"] = \"source_coverage/patch_authority.py\"\n869:     authority[\"lastPatchedAt\"] = now_iso()\n870:     authority[\"lastPatchSummary\"] = {\n871:         \"kind\": kind,\n872:         \"updatedEntries\": len(updated_ids),\n873:         \"addedEntries\": len(added_ids),\n874:         \"updatedIds\": updated_ids,\n875:         \"addedIds\": added_ids,\n876:         \"statusCountsBefore\": dict(sorted(before_counts.items())),\n877:         \"statusCountsAfter\": dict(sorted(after_counts.items())),\n878:     }\n879:     return authority[\"lastPatchSummary\"]\n880: \n881: \n882: def validate_existing_authority(\n883:     kind: str,\n884:     authority: dict[str, Any],\n885:     *,\n886:     context: PatchContext | None = None,\n887: ) -> dict[str, Any]:\n888:     validate_authority_shape(kind, authority)\n889:     errors: list[dict[str, Any]] = []\n890:     id_field = entry_id_field(kind)\n891:     contextual_entries: list[dict[str, Any]] = []\n892:     for entry in authority.get(\"entries\", []):\n893:         if not isinstance(entry, dict):\n894:             continue\n895:         contextual_entries.append(entry)\n896:         problems = validate_entry(kind, entry)\n897:         if problems:\n898:             errors.append({id_field: entry.get(id_field, \"\"), \"problems\": problems})\n899:     if errors:\n900:         shown = \"; \".join(f\"{item.get(id_field)}: {', '.join(item['problems'])}\" for item in errors[:20])\n901:         raise PatchError(f\"Authority validation failed for {len(errors)} entrie(s): {shown}\")\n902:     if context is not None:\n903:         validate_contextual_entries(kind, contextual_entries, context)\n904:     return {\n905:         \"kind\": kind,\n906:         \"validatedEntries\": len(authority.get(\"entries\", [])),\n907:         \"statusCounts\": dict(sorted(status_counts(kind, authority).items())),\n908:     }\n909: \n910: \n911: def print_summary(summary: dict[str, Any], *, dry_run: bool, markdown_path: Path | None) -> None:\n912:     action = \"Validated\" if \"validatedEntries\" in summary else \"Patched\"\n913:     suffix = \" (dry run)\" if dry_run else \"\"\n914:     print(f\"{action} {summary.get('kind', 'authority')} authority{suffix}.\")\n915:     if \"validatedEntries\" in summary:\n916:         print(f\"Validated entries: {summary.get('validatedEntries', 0)}\")\n917:     else:\n918:         print(f\"Updated entries: {summary.get('updatedEntries', 0)}\")\n919:         print(f\"Added entries: {summary.get('addedEntries', 0)}\")\n920:         ids = list(summary.get(\"updatedIds\", [])) + list(summary.get(\"addedIds\", []))\n921:         if ids:\n922:             print(\"Touched ids: \" + \", \".join(str(item) for item in ids[:20]))\n923:     counts = summary.get(\"statusCountsAfter\") or summary.get(\"statusCounts\")\n924:     if isinstance(counts, dict):\n925:         print(\"Status counts: \" + \", \".join(f\"{key}={value}\" for key, value in sorted(counts.items())))\n926:     if markdown_path is not None and not dry_run:\n927:         print(f\"Markdown synced: {markdown_path}\")\n928: \n929: \n930: def main() -> int:\n931:     args = parse_args()\n932:     authority_path = expand_path(args.authority)\n933:     patch_path = expand_path(args.patch) if args.patch else None\n934:     summary_path = expand_path(args.summary_json) if args.summary_json else None\n935:     if authority_path is None:\n936:         raise SystemExit(\"--authority is required\")\n937:     kind = infer_kind(args.kind, authority_path)\n938:     context = patch_context_from_args(args)\n939:     authority_raw = load_strict_json(authority_path, \"authority\")\n940:     if not isinstance(authority_raw, dict):\n941:         raise PatchError(\"Authority JSON must be an object.\")\n942:     authority = copy.deepcopy(authority_raw)\n943: \n944:     if args.validate_only:\n945:         summary = validate_existing_authority(kind, authority, context=context)\n946:     else:\n947:         if patch_path is None:\n948:             raise PatchError(\"--patch is required unless --validate-only is used.\")\n949:         payload = load_strict_json(patch_path, \"patch payload\")\n950:         summary = apply_patch_payload(kind, authority, payload, context=context)\n951: \n952:     markdown_path: Path | None = None\n953:     if not args.no_markdown:\n954:         markdown_path = expand_path(args.markdown) if args.markdown else authority_path.with_suffix(\".md\")\n955: \n956:     if not args.dry_run:\n957:         if not args.validate_only:\n958:             write_json(authority_path, authority)\n959:         if markdown_path is not None:\n960:             write_text(markdown_path, render_markdown(kind, authority, args.max_markdown_files))\n961:         if summary_path is not None:\n962:             write_json(summary_path, {\"schemaVersion\": 1, \"generatedAt\": now_iso(), **summary})\n963: \n964:     print_summary(summary, dry_run=args.dry_run, markdown_path=markdown_path)\n965:     return 0\n966: \n967: \n968: if __name__ == \"__main__\":\n969:     try:\n970:         raise SystemExit(main())\n971:     except PatchError as exc:\n972:         print(f\"patch-authority: {exc}\", file=sys.stderr)\n973:         raise SystemExit(2) from exc\n\n(End of file - total 973 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n\"\"\"Apply narrow, validated patches to agent-maintained coverage authorities.\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport copy\nimport json\nimport re\nimport sys\nfrom collections import Counter\nfrom dataclasses import dataclass\nfrom pathlib import Path\nfrom typing import Any\n\nif __package__ in (None, \"\"):\n    sys.path.insert(0, str(Path(__file__).resolve().parents[2]))\n    from shared.common import HelpFormatter, expand_path, now_iso, write_json, write_text  # type: ignore\n    from shared.source_coverage.constants import (  # type: ignore\n        MATRIX_DEFERRED_REQUIRED_FIELDS,","truncated":false,"loaded":[]},"title":"..\\..\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\patch_authority.py","time":{"start":1782417024283,