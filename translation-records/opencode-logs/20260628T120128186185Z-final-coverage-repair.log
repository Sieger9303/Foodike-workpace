), backStack), routePath(RouteId.History))\n33:         let emptyBackStack = ArrayList<String>([])\n34:         @Assert(resolveProfileBackRoute(routePath(RouteId.Profile), emptyBackStack), routePath(RouteId.Profile))\n35:     }\n36: \n37:     @TestCase\n38:     public func startupResolverReturnsOnboardingAfterLogoutStyleState(): Unit {\n39:         @Assert(resolveStartRoute(false), routePath(RouteId.Onboarding))\n40:         @Assert(resolveStartRoute(true), routePath(RouteId.Home))\n41:     }\n42: \n43:     @TestCase\n44:     public func sourceExampleUnitAssertionIntentIsCoveredByTargetHarness(): Unit {\n45:         @Assert(2 + 2, 4)\n46:     }\n47: }\n\n(End of file - total 47 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, resolveProfileBackRoute, resolveStartRoute, routePath}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.ProfileStore\nimport std.collection.ArrayList\nimport std.unittest.*\nimport std.unittest.testmacro.*\n\n@Test\npublic class Phase06ProfileCapabilitiesVerificationTest {\n    @TestCase\n    public func profileStorePreservesStaticIdentityAndPlaceholderActions(): Unit {\n        let store = ProfileStore()\n        @Assert(store.userName, \"Andrew Howard\")\n        @Assert(store.userEmail, \"andrewhoward@gmail.com\")\n        @Assert(store.profileSectionCount(), 4)\n        @Assert(store.actionFeedbackMessage(), \"Coming soon!\")\n        @Assert(store.placeholderActionMessage, store.actionFeedbackMessage())\n    }\n","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\test\\cangjie\\phase06_profile_capabilities_verification_test.cj","time":{"start":1782648124543,"end":1782648124600}},"id":"prt_f0e1bb47e001eH8S4JTURy0sE4","sessionID":"ses_0f1e4d4a1ffeoT1UiZp4w0hPGt","messageID":"msg_f0e1b68ce001ryPiT83fWHrUMA"}}
