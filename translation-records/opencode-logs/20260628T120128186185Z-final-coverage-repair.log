{"type":"tool_use","timestamp":1782648124605,"sessionID":"ses_0f1e4d4a1ffeoT1UiZp4w0hPGt","part":{"type":"tool","tool":"read","callID":"call_WnfG0J2CT7O951MbKSuacqEm","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj","limit":400,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n2: \n3: import kit.ArkUI.*\n4: import ohos.base.ResourceStr\n5: import ohos.arkui.state_macro_manage.Builder\n6: import ohos.arkui.state_macro_manage.Component\n7: import ohos.arkui.state_macro_manage.Entry\n8: import ohos.arkui.state_macro_manage.State\n9: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n10: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.{CartSnapshotItemData, DetailMenuItemData, DetailPageState, RestaurantData}\n11: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.{cartStore, renderCartRoute}\n12: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.{detailStore, renderDetailRoute}\n13: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history.{historyStore, renderHistoryRoute}\n14: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home.{homeStore, renderHomeRoute}\n15: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.{loginStore, renderLoginRoute}\n16: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.{onboardingStore, renderOnboardingRoute}\n17: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{profileRouteService, profileStore, renderProfileRoute}\n18: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.runtime.{Global, bootstrapStartRoute}\n19: import std.collection.ArrayList\n20: \n21: @Entry\n22: @Component\n23: class FoodikeBootstrap {\n24:     @State\n25:     var currentRoute: String = bootstrapStartRoute\n26: \n27:     @State\n28:     var isShellAtTop: Bool = true\n29: \n30:     @State\n31:     var onboardingPageIndex: Int64 = 0\n32: \n33:     @State\n34:     var loginEmail: String = \"\"\n35: \n36:     @State\n37:     var loginPassword: String = \"\"\n38: \n39:     @State\n40:     var loginErrorMessage: String = \"\"\n41: \n42:     @State\n43:     var homeSearchQuery: String = \"\"\n44: \n45:     @State\n46:     var homeSelectedFilter: String = \"\"\n47: \n48:     @State\n49:     var historySearchQuery: String = \"\"\n50: \n51:     @State\n52:     var historyTabIndex: Int64 = 0\n53: \n54:     @State\n55:     var previousRoute: String = \"home_screen\"\n56: \n57:     @State\n58:     var cartNote: String = \"\"\n59: \n60:     @State\n61:     var cartCoupon: String = \"\"\n62: \n63:     @State\n64:     var cartMutationRevision: Int64 = 0\n65: \n66:     @State\n67:     var detailRecommendedExpanded: Bool = true\n68: \n69:     @State\n70:     var detailNonVegExpanded: Bool = true\n71: \n72:     @State\n73:     var detailVegExpanded: Bool = true\n74: \n75:     @State\n76:     var detailLiked: Bool = false\n77: \n78:     @State\n79:     var detailMutationRevision: Int64 = 0\n80: \n81:     private var onboardingController: SwiperController = SwiperController()\n82:     private var routeBackStack: ArrayList<String> = ArrayList<String>([])\n83: \n84:     private func applyShellState(shellState: ShellRouteState): Unit {\n85:         this.currentRoute = shellState.currentRoute\n86:         this.isShellAtTop = shellState.isAtTop\n87:     }\n88: \n89:     private func shellState(): ShellRouteState {\n90:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n91:     }\n92: \n93:     private func applyShellCommand(command: ShellCommand): Unit {\n94:         let shellState = this.shellState()\n95:         shellState.applyCommand(command)\n96:         this.applyShellState(shellState)\n97:     }\n98: \n99:     private func navigateTo(route: String): Unit {\n100:         if (this.currentRoute != route) {\n101:             this.routeBackStack.add(this.currentRoute)\n102:         }\n103:         this.previousRoute = this.currentRoute\n104:         let shellState = this.shellState()\n105:         shellState.currentRoute = route\n106:         shellState.isAtTop = true\n107:         this.applyShellState(shellState)\n108:     }\n109: \n110:     private func navigateBack(): Unit {\n111:         if (this.routeBackStack.size == 0) {\n112:             return\n113:         }\n114:         let targetIndex = this.routeBackStack.size - 1\n115:         let targetRoute = this.routeBackStack[targetIndex]\n116:         this.routeBackStack.remove(at: targetIndex)\n117:         this.previousRoute = this.currentRoute\n118:         let shellState = this.shellState()\n119:         shellState.currentRoute = targetRoute\n120:         shellState.isAtTop = true\n121:         this.applyShellState(shellState)\n122:     }\n123: \n124:     private func handleProfileBack(): Unit {\n125:         if (!profileRouteService.canNavigateBack(this.currentRoute, this.routeBackStack)) {\n126:             return\n127:         }\n128:         this.navigateBack()\n129:     }\n130: \n131:     private func showBottomShell(route: String): Bool {\n132:         let shellState = this.shellState()\n133:         shellState.currentRoute = route\n134:         return shellState.showBottomShell()\n135:     }\n136: \n137:     private func routeTitle(route: String): ResourceStr {\n138:         routeLabelByPath(route)\n139:     }\n140: \n141:     private func showToast(message: String): Unit {\n142:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n143:     }\n144: \n145:     private func clearLoginError(): Unit {\n146:         this.loginErrorMessage = \"\"\n147:     }\n148: \n149:     private func performLogin(): Unit {\n150:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n151:             this.clearLoginError()\n152:             this.navigateTo(loginStore.successRoute())\n153:             return\n154:         }\n155: \n156:         this.loginErrorMessage = loginStore.invalidLoginMessage\n157:         this.showToast(loginStore.invalidLoginMessage)\n158:     }\n159: \n160:     private func performLogout(): Unit {\n161:         profileStore.logout(Global.abilityContext)\n162:         let resetState = profileRouteService.resetAfterLogout()\n163:         this.loginEmail = resetState.loginEmail\n164:         this.loginPassword = resetState.loginPassword\n165:         this.clearLoginError()\n166:         this.onboardingPageIndex = resetState.onboardingPageIndex\n167:         this.homeSearchQuery = resetState.homeSearchQuery\n168:         this.homeSelectedFilter = resetState.homeSelectedFilter\n169:         this.historySearchQuery = resetState.historySearchQuery\n170:         this.historyTabIndex = resetState.historyTabIndex\n171:         this.routeBackStack.clear()\n172:         this.navigateTo(profileStore.logoutRoute())\n173:     }\n174: \n175:     private func handleProfileEdit(): Unit {\n176:         this.showToast(profileRouteService.placeholderActionMessage())\n177:     }\n178: \n179:     private func handleProfileSectionAction(): Unit {\n180:         this.showToast(profileRouteService.placeholderActionMessage())\n181:     }\n182: \n183:     private func handleProfileLogout(): Unit {\n184:         this.performLogout()\n185:     }\n186: \n187:     private func routeSummary(route: String): String {\n188:         match (route) {\n189:             case \"home_screen\" => \"Home now renders repository-backed discovery content, local search/filter controls, and restaurant selection before detail routing.\"\n190:             case \"history\" => \"History now preserves search plus tab-local content, reuses favourite restaurants, and saves the selected restaurant before navigation.\"\n191:             case \"cart\" => \"Cart now renders snapshot-backed items, a local note editor, a local coupon field, delivery details, and bill totals without adding new checkout persistence flows.\"\n192:             case \"restaurant_details\" => \"Restaurant detail now reads the selected restaurant, preserves local section expansion and like state, keeps menu quantity controls local to the route, and shows the cart action only when selected quantities are non-zero.\"\n193:             case _ => \"\"\n194:         }\n195:     }\n196: \n197:     private func homeHour(): Int64 {\n198:         return 9\n199:     }\n200: \n201:     private func goToProfile(): Unit {\n202:         this.navigateTo(routePath(RouteId.Profile))\n203:     }\n204: \n205:     private func goToRestaurantDetail(): Unit {\n206:         this.detailRecommendedExpanded = true\n207:         this.detailNonVegExpanded = true\n208:         this.detailVegExpanded = true\n209:         this.detailLiked = detailStore.session().isRestaurantLiked(detailStore.selectedRestaurant())\n210:         this.detailMutationRevision = 0\n211:         this.navigateTo(routePath(RouteId.RestaurantDetails))\n212:     }\n213: \n214:     private func detailState(): DetailPageState {\n215:         return detailStore.loadDetailState(\n216:             this.detailRecommendedExpanded,\n217:             this.detailNonVegExpanded,\n218:             this.detailVegExpanded\n219:         )\n220:     }\n221: \n222:     private func selectHomeRestaurant(restaurant: RestaurantData): Unit {\n223:         homeStore.selectRestaurant(restaurant, { =>\n224:             this.goToRestaurantDetail()\n225:         })\n226:     }\n227: \n228:     private func selectHistoryRestaurant(restaurant: RestaurantData): Unit {\n229:         historyStore.selectRestaurant(restaurant, { =>\n230:             this.goToRestaurantDetail()\n231:         })\n232:     }\n233: \n234:     @Builder\n235:     private func buildOnboardingRoute() {\n236:         renderOnboardingRoute(\n237:             this.onboardingPageIndex,\n238:             this.onboardingController,\n239:             { index: Int32 =>\n240:                 this.onboardingPageIndex = Int64(index)\n241:             },\n242:             { =>\n243:                 if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n244:                     this.navigateTo(routePath(RouteId.Login))\n245:                 } else {\n246:                     this.onboardingController.showNext()\n247:                 }\n248:             }\n249:         )\n250:     }\n251: \n252:     @Builder\n253:     private func buildLoginRoute() {\n254:         renderLoginRoute(\n255:             this.loginEmail,\n256:             this.loginPassword,\n257:             this.loginErrorMessage,\n258:             { value: String =>\n259:                 this.loginEmail = value\n260:                 this.clearLoginError()\n261:             },\n262:             { value: String =>\n263:                 this.loginPassword = value\n264:                 this.clearLoginError()\n265:             },\n266:             { => this.showToast(loginStore.comingSoonMessage) },\n267:             { => this.performLogin() },\n268:             { => this.showToast(loginStore.comingSoonMessage) },\n269:             { => this.showToast(loginStore.comingSoonMessage) },\n270:             { => this.showToast(loginStore.comingSoonMessage) },\n271:             { => this.clearLoginError() }\n272:         )\n273:     }\n274: \n275:     @Builder\n276:     private func buildProfileRoute() {\n277:         renderProfileRoute(\n278:             profileStore.userName,\n279:             profileStore.userEmail,\n280:             { => this.handleProfileBack() },\n281:             { => this.handleProfileEdit() },\n282:             { => this.handleProfileSectionAction() },\n283:             { => this.handleProfileLogout() }\n284:         )\n285:     }\n286: \n287:     @Builder\n288:     private func buildHomeRoute() {\n289:         renderHomeRoute(\n290:             homeStore.buildFilteredState(this.homeSearchQuery, this.homeSelectedFilter),\n291:             this.homeHour(),\n292:             this.homeSearchQuery,\n293:             this.homeSelectedFilter,\n294:             { value: String =>\n295:                 this.homeSearchQuery = value\n296:             },\n297:             { value: String =>\n298:                 this.homeSelectedFilter = homeStore.toggleFilter(this.homeSelectedFilter, value)\n299:             },\n300:             { => this.goToProfile() },\n301:             { restaurant: RestaurantData =>\n302:                 this.selectHomeRestaurant(restaurant)\n303:             }\n304:         )\n305:     }\n306: \n307:     @Builder\n308:     private func buildHistoryRoute() {\n309:         renderHistoryRoute(\n310:             historyStore.buildVisibleState(this.historySearchQuery),\n311:             this.historyTabIndex,\n312:             this.historySearchQuery,\n313:             { value: String =>\n314:                 this.historySearchQuery = value\n315:             },\n316:             { value: Int64 =>\n317:                 this.historyTabIndex = value\n318:             },\n319:             { restaurant: RestaurantData =>\n320:                 this.selectHistoryRestaurant(restaurant)\n321:             }\n322:         )\n323:     }\n324: \n325:     @Builder\n326:     private func buildCartRoute() {\n327:         renderCartRoute(\n328:             cartStore.loadCartState(),\n329:             this.cartNote,\n330:             this.cartCoupon,\n331:             { value: String =>\n332:                 this.cartNote = value\n333:             },\n334:             { value: String =>\n335:                 this.cartCoupon = value\n336:             },\n337:             { item: CartSnapshotItemData =>\n338:                 cartStore.decrementQuantity(item)\n339:                 this.cartMutationRevision += 1\n340:             },\n341:             { item: CartSnapshotItemData =>\n342:         