ary\": \"该示例通过通过[fillColor](#func-fillcolorresourcecolor)接口在竖直轴上重复绘制图片。 <!-- run --> package ohos_app_cangjie_entry import kit.ArkUI.* import ohos.arkui.state_macro_manage.* import ohos.i18n.*\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/API/arkui-cj/cj-image-video-image/Image/示例代码/示例8设置SVG图片的填充颜色_0312600c.md\"\r\n      ],\r\n      \"source\": null,\r\n      \"doc_kind\": null\r\n    },\r\n    {\r\n      \"example_id\": \"example.harmonyos-6-1-8k-api-arkui-cj-cj-image-video-image-image-abstract-md\",\r\n      \"title\": \".abstract\",\r\n      \"score\": 127.36,\r\n      \"summary\": \"本目录包含使用仓颉语言在 ArkUI 框架下进行图片处理的示例代码。内容涵盖了基本图片格式加载、事件处理、图片填充模式设置、动态图片源切换以及 SVG 颜色修改等核心功能。这些示例旨在帮助 HarmonyOS 开发者深入理解 Image 组件的用法及交互逻辑，适合正在使用仓颉语言进行应用开发的用户参考。\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/API/arkui-cj/cj-image-video-image/Image/示例代码/.abstract.md\"\r\n      ],\r\n      \"source\": null,\r\n      \"doc_kind\": null\r\n    }\r\n  ],\r\n  \"docs\": [\r\n    {\r\n      \"doc_id\": \"doc.harmonyos-6-1-8k-guide-media-image-overview\",\r\n      \"title\": \"image\",\r\n      \"score\": 106.48,\r\n      \"summary\": \"This directory serves as a comprehensive technical resource for the Image Kit, specifically focusing on image processing capabilities within the OpenHarmony and HarmonyOS ecosystems using the Cangjie (仓颉) programming lan\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/Guide/media/image/.overview.md\"\r\n      ],\r\n      \"source\": \"harmonyos-6.1-8k\",\r\n      \"doc_kind\": \"overview\"\r\n    },\r\n    {\r\n      \"doc_id\": \"doc.harmonyos-6-1-8k-api-medialibrarykit-cj-apis-file-photo-access-helper-ohosfilephoto-access-helper-class-mediaassetchangerequest-static-func-createimage-f9225996\",\r\n      \"title\": \"static func createImageAssetRequest(UIAbilityContext, String)\",\r\n      \"score\": 102.097,\r\n      \"summary\": \"public static func createImageAssetRequest(context: UIAbilityContext, fileUri: String): MediaAssetChangeRequest 