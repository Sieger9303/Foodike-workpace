fecycle.viewModelScope\n33: import com.example.foodike.data.repository.Results\n34: import com.example.foodike.domain.repository.HomeRepository\n35: import com.example.foodike.domain.repository.UserDataRepository\n36: import dagger.hilt.android.lifecycle.HiltViewModel\n37: import kotlinx.coroutines.launch\n38: import javax.inject.Inject\n39: \n40: @HiltViewModel\n41: class HomeViewModel @Inject constructor(\n42:     private val repository: HomeRepository,\n43:     private val userDataRepository: UserDataRepository,\n44: \n45: ) : ViewModel() {\n46: \n47:     private val _homeScreenState = mutableStateOf(\n48:         HomeScreenState()\n49:     )\n50:     val homeScreenState: State<HomeScreenState> = _homeScreenState\n51: \n52:     init {\n53:         viewModelScope.launch {\n54:             when (val result = repository.getAds()) {\n55:                 is Results.Success -> _homeScreenState.value = homeScreenState.value.copy(\n56:                     adsList = result.data\n57:                 )\n58:                 is Results.Error -> {\n59:                 }\n60:             }\n61: \n62:             when (val result = repository.getFoodItems()) {\n63:                 is Results.Success -> _homeScreenState.value = homeScreenState.value.copy(\n64:                     foodList = result.data\n65:                 )\n66:                 is Results.Error -> {\n67: \n68:                 }\n69:             }\n70: \n71:             when (val result = repository.getRestaurants()) {\n72:                 is Results.Success -> _homeScreenState.value = homeScreenState.value.copy(\n73:                     restaurantList = result.data,\n74:                 )\n75:                 is Results.Error -> {\n76: \n77:                 }\n78:             }\n79: \n80:             userDataRepository.getLikedRestaurants().collect {\n81:                 _homeScreenState.value = homeScreenState.value.copy(\n82:                     likedRestaurantList = it\n83:                 )\n84: \n85:             }\n86: \n87:         }\n88: \n89: \n90:     }\n91: \n92:     fun onEvent(event: HomeScreenEvent) {\n93:         when (event) {\n94:             is HomeScreenEvent.SelectRestaurant -> {\n95:                 viewModelScope.launch {\n96:                     userDataRepository.setRestaurant(event.restaurant)\n97:                     event.onClick()\n98:                 }\n99:             }\n100:         }\n101:     }\n102: \n103: \n104: }\n\n(End of file - total 104 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER","truncated":false,"loaded":[]},"title":"..\\..\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\home\\HomeViewModel.kt","time":{"start":1782524279272,"end":1782524279277}},"id":"prt_f06b9f9b3001zaWS770vruvuYE","sessionID":"ses_0f9472ca8fferkuSd47fh38tnz","messageID":"msg_f06b9c332001YaMwe0e18TgL2w"}}
{"type":"tool_use","timestamp":1782524279340,"sessionID":"ses_0f9472ca8fferkuSd47fh38tnz","part":{"type":"tool","tool":"read","callID":"call_cRexNL2PRaCKUUKOUD2mbkZq","state":{"status":"completed","input":{"filePath":"D:\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\details\\RestaurantDetailViewModel.kt"},"output":"<path>D:\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\details\\RestaurantDetailViewModel.kt</path>\n<type>file</type>\n<content>\n1: /**\n2:  *\n3:  *\tMIT License\n4:  *\n5:  *\tCopyright (c) 2026 Gautam Hazarika\n6:  *\n7:  *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n8:  *\tof this software and associated documentation files (the \"Software\"), to deal\n9:  *\tin the Software without restriction, including without limitation the rights\n10:  *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n11:  *\tcopies of the Software, and to permit persons to whom the Software is\n12:  *\tfurnished to do so, subject to the following conditions:\n13:  *\n14:  *\tThe above copyright notice and this permission notice shall be included in all\n15:  *\tcopies or substantial portions of the Software.\n16:  *\n17:  *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n18:  *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n19:  *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n20:  *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER\n21:  *\tLIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,\n22:  *\tOUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE\n23:  *\tSOFTWARE.\n24:  *\n25:  **/\n26: \n27: package com.example.foodike.presentation.details\n28: \n29: import androidx.compose.runtime.State\n30: import androidx.compose.runtime.mutableStateOf\n31: import androidx.lifecycle.ViewModel\n32: import androidx.lifecycle.viewModelScope\n33: import com.example.foodike.domain.repository.UserDataRepository\n34: import dagger.hilt.android.lifecycle.HiltViewModel\n35: import kotlinx.coroutines.launch\n36: import javax.inject.Inject\n37: \n38: @HiltViewModel\n39: class RestaurantDetailViewModel @Inject constructor(\n40:     private val userDataRepository: UserDataRepository,\n41: \n42:     ) : ViewModel() {\n43: \n44:     private val _detailScreenState = mutableStateOf(DetailScreenState())\n45:     val detailScreenState: State<DetailScreenState> = _detailScreenState\n46: \n47:     init {\n48:         viewModelScope.launch {\n49:             userDataRepository.getMenuItems().collect {\n50:                 _detailScreenState.value = detailScreenState.value.copy(\n51:                     menuList = it,\n52:                     recommendedList = it.shuffled()\n53:                         .dropLast(it.size - 5)\n54:                 )\n55:             }\n56: \n57:             userDataRepository.getSavedRestaurant().collect { restaurant ->\n58:                 _detailScreenState.value = detailScreenState.value.copy(\n59:                     restaurant = restaurant,\n60:                 )\n61:                 userDataRepository.isRestaurantLiked(restaurant).collect {\n62:                     _detailScreenState.value = detailScreenState.value.copy(\n63:                         isLiked = it\n64:                     )\n65:                 }\n66: \n67:             }\n68:         }\n69:     }\n70: \n71: \n72:     fun onEvent(event: DetailScreenEvent) {\n73:         when (event) {\n74:             is DetailScreenEvent.ToggleRecommendedSectionExpandedState -> {\n75:                 _detailScreenState.value = detailScreenState.value.copy(\n76:                     recommendedExpandedState = !detailScreenState.value.recommendedExpandedState\n77:                 )\n78:             }\n79:             is DetailScreenEvent.ToggleNonVegSectionExpandedState -> {\n80:                 _detailScreenState.value = detailScreenState.value.copy(\n81:                     nonVegExpandedState = !detailScreenState.value.nonVegExpandedState\n82:                 )\n83:             }\n84:             is DetailScreenEvent.ToggleVegSectionExpandedState -> {\n85:                 _detailScreenState.value = detailScreenState.value.copy(\n86:                     vegExpandedState = !detailScreenState.value.vegExpandedState\n87:                 )\n88:             }\n89:             is DetailScreenEvent.ToggleLikedStatus -> {\n90:                 if (_detailScreenState.value.isLiked) {\n91:                     _detailScreenState.value = detailScreenState.value.copy(\n92:                         isLiked = false\n93:                     )\n94:                 } else {\n95:                     _detailScreenState.value = detailScreenState.value.copy(\n96:                         isLiked = true\n97:                     )\n98:                 }\n99: \n100:             }\n101:         }\n102:     }\n103: }\n104: \n105: \n\n(End of file - total 105 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER","truncated":false,"loaded":[]},"title":"..\\..\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\details\\RestaurantDetailViewModel.kt","time":{"start":1782524279335,"end":1782524279340}},"id":"prt_f06b9f9eb001FCjax4yn1gy96p","sessionID":"ses_0f9472ca8fferkuSd47fh38tnz","messageID":"msg_f06b9c332001YaMwe0e18TgL2w"}}
