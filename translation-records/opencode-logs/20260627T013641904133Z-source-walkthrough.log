 import androidx.compose.foundation.clickable\n34: import androidx.compose.foundation.layout.Arrangement\n35: import androidx.compose.foundation.layout.Column\n36: import androidx.compose.foundation.layout.Row\n37: import androidx.compose.foundation.layout.Spacer\n38: import androidx.compose.foundation.layout.fillMaxSize\n39: import androidx.compose.foundation.layout.fillMaxWidth\n40: import androidx.compose.foundation.layout.height\n41: import androidx.compose.foundation.layout.padding\n42: import androidx.compose.foundation.layout.width\n43: import androidx.compose.foundation.text.KeyboardOptions\n44: import androidx.compose.material.Button\n45: import androidx.compose.material.Divider\n46: import androidx.compose.material.Scaffold\n47: import androidx.compose.material.ScaffoldState\n48: import androidx.compose.material.SnackbarDuration\n49: import androidx.compose.material.Text\n50: import androidx.compose.material.rememberScaffoldState\n51: import androidx.compose.runtime.Composable\n52: import androidx.compose.runtime.LaunchedEffect\n53: import androidx.compose.runtime.getValue\n54: import androidx.compose.ui.Alignment\n55: import androidx.compose.ui.Modifier\n56: import androidx.compose.ui.draw.alpha\n57: import androidx.compose.ui.graphics.Color\n58: import androidx.compose.ui.graphics.toArgb\n59: import androidx.compose.ui.platform.LocalContext\n60: import androidx.compose.ui.res.painterResource\n61: import androidx.compose.ui.res.stringResource\n62: import androidx.compose.ui.text.input.ImeAction\n63: import androidx.compose.ui.text.input.PasswordVisualTransformation\n64: import androidx.compose.ui.unit.dp\n65: import androidx.compose.ui.unit.sp\n66: import androidx.hilt.navigation.compose.hiltViewModel\n67: import androidx.navigation.NavGraph.Companion.findStartDestination\n68: import androidx.navigation.NavHostController\n69: import com.example.foodike.R\n70: import com.example.foodike.presentation.login.components.FoodikeTextField\n71: import com.example.foodike.presentation.util.Screen\n72: import kotlinx.coroutines.flow.collectLatest\n73: \n74: @SuppressLint(\"UnusedMaterialScaffoldPaddingParameter\")\n75: @Composable\n76: fun LoginScreen(\n77:     viewModel: LoginViewModel = hiltViewModel(),\n78:     navController: NavHostController,\n79: ) {\n80: \n81:     val scaffoldState: ScaffoldState = rememberScaffoldState()\n82: \n83:     val email by viewModel.email\n84:     val password by viewModel.password\n85: \n86:     LaunchedEffect(key1 = true) {\n87:         viewModel.eventFlow.collectLatest { event ->\n88:             when (event) {\n89:                 is UiEvent.ShowSnackbar -> {\n90:                     scaffoldState.snackbarHostState.showSnackbar(\n91:                         message = event.message, duration = SnackbarDuration.Short\n92:                     )\n93:                 }\n94:             }\n95:         }\n96:     }\n97: \n98:     Scaffold(scaffoldState = scaffoldState) {\n99:         Column(\n100:             modifier = Modifier.fillMaxSize(),\n101:             verticalArrangement = Arrangement.Center,\n102:             horizontalAlignment = Alignment.CenterHorizontally\n103:         ) {\n104: \n105:             val context = LocalContext.current as Activity\n106: \n107:             context.window.statusBarColor = Color.Gray.toArgb()\n108:             context.window.navigationBarColor = Color.White.toArgb()\n109: \n110:             Text(\n111:                 text = stringResource(R.string.welcome_back), fontSize = 24.sp\n112:             )\n113: \n114:             Spacer(modifier = Modifier.height(24.dp))\n115: \n116:             Column(\n117:                 horizontalAlignment = Alignment.End\n118: \n119:             ) {\n120:                 FoodikeTextField(\n121:                     value = email.text,\n122:                     onValueChange = { viewModel.onEvent(LoginEvent.EnteredEmail(it)) },\n123:                     hint = email.hint\n124:                 )\n125: \n126: \n127:         