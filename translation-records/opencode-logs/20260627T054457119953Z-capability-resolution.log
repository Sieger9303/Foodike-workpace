{"type":"tool_use","timestamp":1782539204687,"sessionID":"ses_0f863e659ffe0XQS54yysW5yx4","part":{"type":"tool","tool":"read","callID":"call_cNyE32Co74iPerthDoKTgXZF","state":{"status":"completed","input":{"filePath":"D:\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\patch_authority.py","limit":180,"offset":815},"output":"<path>D:\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\patch_authority.py</path>\n<type>file</type>\n<content>\n815: def apply_patch_payload(\n816:     kind: str,\n817:     authority: dict[str, Any],\n818:     payload: dict[str, Any],\n819:     *,\n820:     context: PatchContext | None = None,\n821: ) -> dict[str, Any]:\n822:     normalized = validate_patch_payload(payload)\n823:     id_field = entry_id_field(kind)\n824:     before_counts = status_counts(kind, authority)\n825:     entries = authority[\"entries\"]\n826:     by_id = validate_authority_shape(kind, authority)\n827: \n828:     added_ids: list[str] = []\n829:     updated_ids: list[str] = []\n830:     touched_entries: list[dict[str, Any]] = []\n831: \n832:     for raw_addition in normalized[\"additions\"]:\n833:         addition = validate_addition(kind, raw_addition)\n834:         item_id = str(addition.get(id_field) or \"\").strip()\n835:         if item_id in by_id:\n836:             raise PatchError(f\"Cannot add duplicate {id_field} `{item_id}`.\")\n837:         problems = validate_entry(kind, addition)\n838:         if problems:\n839:             raise PatchError(f\"Addition `{item_id}` is invalid: \" + \"; \".join(problems))\n840:         entries.append(addition)\n841:         by_id[item_id] = addition\n842:         added_ids.append(item_id)\n843:         touched_entries.append(addition)\n844: \n845:     id_to_index = {str(entry.get(id_field)): index for index, entry in enumerate(entries) if isinstance(entry, dict)}\n846:     for raw_update in normalized[\"updates\"]:\n847:         if not isinstance(raw_update, dict):\n848:             raise PatchError(\"Every update must be an object.\")\n849:         item_id = str(raw_update.get(id_field) or \"\").strip()\n850:         if not item_id:\n851:             raise PatchError(f\"Every update must include `{id_field}`.\")\n852:         if item_id not in id_to_index:\n853:             raise PatchError(f\"Unknown {id_field} `{item_id}`.\")\n854:         entry = entries[id_to_index[item_id]]\n855:         if not isinstance(entry, dict):\n856:             raise PatchError(f\"Entry for `{item_id}` is not an object.\")\n857:         patch_entry(kind, entry, raw_update)\n858:         problems = validate_entry(kind, entry)\n859:         if problems:\n860:             raise PatchError(f\"Updated entry `{item_id}` is invalid: \" + \"; \".join(problems))\n861:         updated_ids.append(item_id)\n862:         touched_entries.append(entry)\n863: \n864:     validate_authority_shape(kind, authority)\n865:     if context is not None:\n866:         validate_contextual_entries(kind, touched_entries, context)\n867:     after_counts = status_counts(kind, authority)\n868:     authority[\"lastUpdatedBy\"] = \"source_coverage/patch_authority.py\"\n869:     authority[\"lastPatchedAt\"] = now_iso()\n870:     authority[\"lastPatchSummary\"] = {\n871:         \"kind\": kind,\n872:         \"updatedEntries\": len(updated_ids),\n873:         \"addedEntries\": len(added_ids),\n874:         \"updatedIds\": updated_ids,\n875:         \"addedIds\": added_ids,\n876:         \"statusCountsBefore\": dict(sorted(before_counts.items())),\n877:         \"statusCountsAfter\": dict(sorted(after_counts.items())),\n878:     }\n879:     return authority[\"lastPatchSummary\"]\n880: \n881: \n882: def validate_existing_authority(\n883:     kind: str,\n884:     authority: dict[str, Any],\n885:     *,\n886:     context: PatchContext | None = None,\n887: ) -> dict[str, Any]:\n888:     validate_authority_shape(kind, authority)\n889:     errors: list[dict[str, Any]] = []\n890:     id_field = entry_id_field(kind)\n891:     contextual_entries: list[dict[str, Any]] = []\n892:     for entry in authority.get(\"entries\", []):\n893:         if not isinstance(entry, dict):\n894:             continue\n895:         contextual_entries.append(entry)\n896:         problems = validate_entry(kind, entry)\n897:         if problems:\n898:             errors.append({id_field: entry.get(id_field, \"\"), \"problems\": problems})\n899:     if errors:\n900:         shown = \"; \".join(f\"{item.get(id_field)}: {', '.join(item['problems'])}\" for item in errors[:20])\n901:         raise PatchError(f\"Authority validation failed for {len(errors)} entrie(s): {shown}\")\n902:     if context is not None:\n903:         validate_contextual_entries(kind, contextual_entries, context)\n904:     return {\n905:         \"kind\": kind,\n906:         \"validatedEntries\": len(authority.get(\"entries\", [])),\n907:         \"statusCounts\": dict(sorted(status_counts(kind, authority).items())),\n908:     }\n909: \n910: \n911: def print_summary(summary: dict[str, Any], *, dry_run: bool, markdown_path: Path | None) -> None:\n912:     action = \"Validated\" if \"validatedEntries\" in summary else \"Patched\"\n913:     suffix = \" (dry run)\" if dry_run else \"\"\n914:     print(f\"{action} {summary.get('kind', 'authority')} authority{suffix}.\")\n915:     if \"validatedEntries\" in summary:\n916:         print(f\"Validated entries: {summary.get('validatedEntries', 0)}\")\n917:     else:\n918:         print(f\"Updated entries: {summary.get('updatedEntries', 0)}\")\n919:         print(f\"Added entries: {summary.get('addedEntries', 0)}\")\n920:         ids = list(summary.get(\"updatedIds\", [])) + list(summary.get(\"addedIds\", []))\n921:         if ids:\n922:             print(\"Touched ids: \" + \", \".join(str(item) for item in ids[:20]))\n923:     counts = summary.get(\"statusCountsAfter\") or summary.get(\"statusCounts\")\n924:     if isinstance(counts, dict):\n925:         print(\"Status counts: \" + \", \".join(f\"{key}={value}\" for key, value in sorted(counts.items())))\n926:     if markdown_path is not None and not dry_run:\n927:         print(f\"Markdown synced: {markdown_path}\")\n928: \n929: \n930: def main() -> int:\n931:     args = parse_args()\n932:     authority_path = expand_path(args.authority)\n933:     patch_path = expand_path(args.patch) if args.patch else None\n934:     summary_path = expand_path(args.summary_json) if args.summary_json else None\n935:     if authority_path is None:\n936:         raise SystemExit(\"--authority is required\")\n937:     kind = infer_kind(args.kind, authority_path)\n938:     context = patch_context_from_args(args)\n939:     authority_raw = load_strict_json(authority_path, \"authority\")\n940:     if not isinstance(authority_raw, dict):\n941:         raise PatchError(\"Authority JSON must be an object.\")\n942:     authority = copy.deepcopy(authority_raw)\n943: \n944:     if args.validate_only:\n945:         summary = validate_existing_authority(kind, authority, context=context)\n946:     else:\n947:         if patch_path is None:\n948:             raise PatchError(\"--patch is required unless --validate-only is used.\")\n949:         payload = load_strict_json(patch_path, \"patch payload\")\n950:         summary = apply_patch_payload(kind, authority, payload, context=context)\n951: \n952:     markdown_path: Path | None = None\n953:     if not args.no_markdown:\n954:         markdown_path = expand_path(args.markdown) if args.markdown else authority_path.with_suffix(\".md\")\n955: \n956:     if not args.dry_run:\n957:         if not args.validate_only:\n958:             write_json(authority_path, authority)\n959:         if markdown_path is not None:\n960:             write_text(markdown_path, render_markdown(kind, authority, args.max_markdown_files))\n961:         if summary_path is not None:\n962:             write_json(summary_path, {\"schemaVersion\": 1, \"generatedAt\": now_iso(), **summary})\n963: \n964:     print_summary(summary, dry_run=args.dry_run, markdown_path=markdown_path)\n965:     return 0\n966: \n967: \n968: if __name__ == \"__main__\":\n969:     try:\n970:         raise SystemExit(main())\n971:     except PatchError as exc:\n972:         print(f\"patch-authority: {exc}\", file=sys.stderr)\n973:         raise SystemExit(2) from exc\n\n(End of file - total 973 lines)\n</content>","metadata":{"preview":"def apply_patch_payload(\n    kind: str,\n    authority: dict[str, Any],\n    payload: dict[str, Any],\n    *,\n    context: PatchContext | None = None,\n) -> dict[str, Any]:\n    normalized = validate_patch_payload(payload)\n    id_field = entry_id_field(kind)\n    before_counts = status_counts(kind, authority)\n    entries = authority[\"entries\"]\n    by_id = validate_authority_shape(kind, authority)\n\n    added_ids: list[str] = []\n    updated_ids: list[str] = []\n    touched_entries: list[dict[str, Any]] = []\n\n    for raw_addition in normalized[\"additions\"]:\n        addition = validate_addition(kind, raw_addition)\n        item_id = str(addition.get(id_field) or \"\").strip()","truncated":false,"loaded":[]},"title":"..\\..\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\patch_authority.py","time":{"start":1782539204681,"end":1782539204686}},"id":"prt_f079db848001IpcRYFp5Sb4uxn","sessionID":"ses_0f863e659ffe0XQS54yysW5yx4","messageID":"msg_f079d5c55001IEhm53qg916aKd"}}
