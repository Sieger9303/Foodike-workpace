mQuantity(dish, nextQuantity)\n112:         }\n113:     }\n114: \n115:     public func decrementMenuItemQuantity(dish: String): Unit {\n116:         let nextQuantity = updateSelectedMenuQuantity(dish, -1)\n117:         if (nextQuantity >= 0) {\n118:             syncCartItemQuantity(dish, nextQuantity)\n119:         }\n120:     }\n121: \n122:     public func menuItemsForRestaurant(name: String): ArrayList<DetailMenuItemData> {\n123:         if (name == \"George Street\" || name == \"Edona\" || name == \"Hermes Kitchen\" || name == \"Naga Kitchen\" || name == \"99 Reasons to Eat\") {\n124:             return menu1\n125:         }\n126:         if (name == \"Saffron Xpress\" || name == \"KF\" || name == \"Kanha\" || name == \"Cafe Lighton\" || name == \"Rock n Rolls\") {\n127:             return menu3\n128:         }\n129:         return menu2\n130:     }\n131: \n132:     public func getMenuItems(): ArrayList<DetailMenuItemData> {\n133:         return selectedRestaurantMenuItems\n134:     }\n135: \n136:     public func isRestaurantLiked(restaurant: RestaurantData): Bool {\n137:         return containsLikedRestaurant(restaurant.name)\n138:     }\n139: \n140:     public func setRestaurantLiked(restaurant: RestaurantData, liked: Bool): Unit {\n141:         if (liked) {\n142:             if (!containsLikedRestaurant(restaurant.name)) {\n143:                 likedRestaurants.add(restaurant)\n144:             }\n145:             return\n146:         }\n147:         removeLikedRestaurant(restaurant.name)\n148:     }\n149: \n150:     public func restaurantSelectionRouteToken(): String {\n151:         return selectedRestaurantName\n152:     }\n153: \n154:     private func replaceSelectedMenu(sourceMenu: ArrayList<DetailMenuItemData>): Unit {\n155:         selectedRestaurantMenuItems.clear()\n156:         for (item in sourceMenu) {\n157:             selectedRestaurantMenuItems.add(\n158:                 DetailMenuItemData(\n159:                     MenuItemData(\n160:                         item.menuItem.dish,\n161:                         item.menuItem.price,\n162:                         item.menuItem.rating,\n163:                         item.menuItem.ratingCount,\n164:                         item.menuItem.isVegetarian\n165:                     ),\n166:                     cartQuantityForDish(item.menuItem.dish)\n167:                 )\n168:             )\n169:         }\n170:     }\n171: \n172:     private func updateSelectedMenuQuantity(dish: String, delta: Int64): Int64 {\n173:         for (item in selectedRestaurantMenuItems) {\n174:             if (item.menuItem.dish == dish) {\n175:                 let nextQuantity = item.quantity + delta\n176:                 if (nextQuantity < 0) {\n177:                     return item.quantity\n178:                 }\n179:                 item.quantity = nextQuantity\n180:                 return item.quantity\n181:             }\n182:         }\n183:         return -1\n184:     }\n185: \n186:     private func syncCartItemQuantity(dish: String, quantity: Int64): Unit {\n187:         for (item in cartItems) {\n188:             if (item.menuItem.dish == dish) {\n189:                 item.quantity = quantity\n190:                 return\n191:             }\n192:         }\n193: \n194:         if (quantity > 0) {\n195:             match (menuItemForDish(dish)) {\n196:                 case Some(menuItem) =>\n197:                     cartItems.add(\n198:                         CartSnapshotItemData(\n199:                             MenuItemData(\n200:                                 menuItem.dish,\n201:                                 menuItem.price,\n202:                                 menuItem.rating,\n203:                                 menuItem.ratingCount,\n204:                                 menuItem.isVegetarian\n205:                             ),\n206:                             quantity\n207:                         )\n208:                     )\n209:                 case None =>\n210:                     return\n211:             }\n212:         }\n213:     }\n214: \n215:     private func cartQuantityForDish(dish: String): Int64 {\n216:         for (item in cartItems) {\n217:             if (item.menuItem.dish == dish) {\n218:                 return item.quantity\n219:             }\n220:         }\n221:         return 0\n222:     }\n223: \n224:     private func menuItemForDish(dish: String): Option<MenuItemData> {\n225:         for (item in selectedRestaurantMenuItems) {\n226:             if (item.menuItem.dish == dish) {\n227:                 return Some(item.menuItem)\n228:             }\n229:         }\n230:         return None<MenuItemData>\n231:     }\n232: \n233:     private func containsLikedRestaurant(name: String): Bool {\n234:         for (restaurant in likedRestaurants) {\n235:             if (restaurant.name == name) {\n236:                 return true\n237:             }\n238:         }\n239:         return false\n240:     }\n241: \n242:     private func removeLikedRestaurant(name: String): Unit {\n243:         var index: Int64 = 0\n244:         while (index < likedRestaurants.size) {\n245:             if (likedRestaurants[index].name == name) {\n246:                 likedRestaurants.remove(at: index)\n247:                 return\n248:             }\n249:             index += 1\n250:         }\n251:     }\n252: }\n253: \n254: public let sessionRepository = SessionRepository()\n\n(End of file - total 254 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.RestaurantData\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.{CartSnapshotItemData, DetailMenuItemData, MenuItemData}\nimport std.collection.ArrayList\n\npublic class SessionRepository {\n    private var selectedRestaurantName: String = \"\"\n    private let selectedRestaurantMenuItems = ArrayList<DetailMenuItemData>([])\n    private let likedResta