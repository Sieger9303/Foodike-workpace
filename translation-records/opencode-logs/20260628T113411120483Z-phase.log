n978:       ],\n979:       \"stateDataBehavior\": [\n980:         \"Detail screen consumes selected restaurant and menu/cart streams from shared repository state.\",\n981:         \"Recommended, non-veg, and veg sections preserve independent expansion state.\",\n982:         \"Like toggle updates visible state immediately.\",\n983:         \"Cart page filters out zero-count items and keeps summary sections visible.\"\n984:       ],\n985:       \"deferredRisks\": [\n986:         \"Source cart increment/decrement callbacks are placeholders; target needs a documented parity decision on mutation depth.\",\n987:         \"Share action remains placeholder unless product specifies outbound sharing UX.\"\n988:       ],\n989:       \"implementationGroups\": [\n990:         {\n991:           \"groupId\": \"phase-05-detail-state-and-sections\",\n992:           \"title\": \"Detail state, menu grouping, and toggles\",\n993:           \"groupType\": \"source-behavior\",\n994:           \"priority\": \"critical\",\n995:           \"sourcePaths\": [\n996:             \"app/src/main/java/com/example/foodike/presentation/details/RestaurantDetail.kt\",\n997:             \"app/src/main/java/com/example/foodike/presentation/details/RestaurantDetailViewModel.kt\",\n998:             \"app/src/main/java/com/example/foodike/presentation/details/DetailScreenState.kt\",\n999:             \"app/src/main/java/com/example/foodike/presentation/details/components/*.kt\",\n1000:             \"app/src/main/java/com/example/foodike/data/repository/UserDataRepositoryImpl.kt\"\n1001:           ],\n1002:           \"sourceMethods\": [\n1003:             \"RestaurantDetail\",\n1004:             \"RestaurantDetailViewModel.onEvent\",\n1005:             \"getSavedRestaurant\",\n1006:             \"getMenuItems\",\n1007:             \"isRestaurantLiked\"\n1008:           ],\n1009:           \"featureIds\": [\n1010:             \"app-src-main-java-com-example-foodike-presentation-detai-958b17f285-005-observa