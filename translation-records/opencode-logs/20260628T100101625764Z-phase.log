= \"\") {\n38:             match (contentRepository.getRestaurantByName(restaurantName)) {\n39:                 case Some(restaurant) => return restaurant\n40:                 case None => return contentRepository.getRestaurants()[0]\n41:             }\n42:         }\n43:         return contentRepository.getRestaurants()[0]\n44:     }\n45: \n46:     private func selectedMenuItems(restaurant: RestaurantData): ArrayList<DetailMenuItemData> {\n47:         let menuItems = sessionRepository.getMenuItems()\n48:         if (menuItems.size > 0) {\n49:             return menuItems\n50:         }\n51:         return sessionRepository.menuItemsForRestaurant(restaurant.name)\n52:     }\n53: \n54:     public func recommendedItems(menuItems: ArrayList<DetailMenuItemData>): ArrayList<DetailMenuItemData> {\n55:         let shuffled = ArrayList<DetailMenuItemData>(menuItems)\n56:         let rng = Random()\n57:         var index: Int64 = shuffled.size - 1\n58:         while (index > 0) {\n59:             let swapIndex = rng.nextInt64(index + 1)\n60:             let current = shuffled[index]\n61:             shuffled[index] = shuffled[swapIndex]\n62:             shuffled[swapIndex] = current\n63:             index -= 1\n64:         }\n65: \n66:         let recommended = ArrayList<DetailMenuItemData>([])\n67:         var recommendedIndex: Int64 = 0\n68:         for (item in shuffled) {\n69:             if (recommendedIndex >= 5) {\n70:                 break\n71:             }\n72:             recommended.add(item)\n73:             recommendedIndex += 1\n74:         }\n75:         return recommended\n76:     }\n77: \n78:     public func nonVegItems(menuItems: ArrayList<DetailMenuItemData>): ArrayList<DetailMenuItemData> {\n79:         let filtered = ArrayList<DetailMenuItemData>([])\n80:         for (item in menuItems) {\n81:             if (!item.menuItem.isVegetarian) {\n82:                 filtered.add(item)\n83:             }\n84:         }\n85:         return filtered\n86:     }\n87: \n88:     public func vegItems(menuItems: ArrayList<DetailMenuItemData>): ArrayList<DetailMenuItemData> {\n89:         let filtered = ArrayList<DetailMenuItemData>([])\n90:         for (item in menuItems) {\n91:             if (item.menuItem.isVegetarian) {\n92:                 filtered.add(item)\n93:             }\n94:         }\n95:         return filtered\n96:     }\n97: \n98:     public func incrementQuantity(item: DetailMenuItemData): Unit {\n99:         item.quantity += 1\n100:     }\n101: \n102:     public func decrementQuantity(item: DetailMenuItemData): Unit {\n103:         if (item.quantity > 0) {\n104:             item.quantity -= 1\n105:         }\n106:     }\n107: \n108:     public func totalSelectedItems(menuItems: ArrayList<DetailMenuItemData>): Int64 {\n109:         var total: Int64 = 0\n110:         for (item in menuItems) {\n111:             total += item.quantity\n112:         }\n113:         return total\n114:     }\n115: \n116:     public func shouldShowCartAction(menuItems: ArrayList<DetailMenuItemData>): Bool {\n117:         return totalSelectedItems(menuItems) > 0\n118:     }\n119: \n120:     public func toggleLiked(restaurant: RestaurantData, currentValue: Bool): Bool {\n\n(Showing lines 1-120 of 151. Use offset=121 to continue.)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.homeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\nimport std.random.Random\n\npublic let detailStore = DetailStore()\n\npublic class DetailStore {\n    private let contentRepository = homeContentRepository\n    private let sessionRepository = sessionRepository\n\n    public init() {}\n\n    public func loadDetailState(\n        recommendedExpanded: Bool,\n        nonVe