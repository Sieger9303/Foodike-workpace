   buildOnboardingFooter(pageIndex, onNext)\n102:     }\n103:     .width(100.percent)\n104:     .height(100.percent)\n105:     .backgroundColor(colorDarkGreen)\n106:     .alignItems(HorizontalAlign.Center)\n107:     .justifyContent(FlexAlign.SpaceBetween)\n108: }\n\n(End of file - total 108 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos.base.ResourceStr\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n\n@Builder\nfunc buildOnboardingCard(title: ResourceStr, description: ResourceStr, mediaName: String) {\n    Column(space: 18) {\n        Image(\n            match (mediaName) {\n                case \"chinese_bowl\" => mediaChineseBowl\n                case \"rider\" => mediaRider\n                case _ => mediaClock\n            }\n        )\n            .width(72.percent)\n            .height(280)\n        Text(title)","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\onboarding\\onboarding_page.cj","time":{"start":1782642274287,"end":1782642274315}},"id":"prt_f0dc26feb001UtVygUbGxkHEmn","sessionID":"ses_0f23f646fffeIlhRSa9CLSMWRJ","messageID":"msg_f0dc24e2c0015DX97IkQHZ7EbJ"}}
