ngWelcomeBack)\n45:             .fontSize(32)\n46:             .fontWeight(FontWeight.Bold)\n47: \n48:         buildLoginErrorBanner(errorMessage, onDismissError)\n49: \n50:         TextInput(text: email, placeholder: loginStore.emailHint)\n51:             .width(90.percent)\n52:             .height(52)\n53:             .fontSize(16)\n54:             .placeholderColor(Color.Gray)\n55:             .onChange({ value: String =>\n56:                 onEmailChange(value)\n57:             })\n58: \n59:         TextInput(text: password, placeholder: loginStore.passwordHint)\n60:             .width(90.percent)\n61:             .height(52)\n62:             .fontSize(16)\n63:             .placeholderColor(Color.Gray)\n64:             .enterKeyType(EnterKeyType.Done)\n65:             .onChange({ value: String =>\n66:                 onPasswordChange(value)\n67:             })\n68:             .onSubmit({ _ =>\n69:                 onPerformLogin()\n70:             })\n71: \n72:         Text(stringForgotPassword)\n73:             .fontSize(14)\n74:             .fontColor(Color.Gray)\n75:             .width(90.percent)\n76:             .textAlign(TextAlign.End)\n77:             .onClick({ _ =>\n78:                 onForgotPassword()\n79:             })\n80: \n81:         Button(stringLogin)\n82:             .width(220)\n83:             .height(50)\n84:             .onClick({ _ =>\n85:                 onPerformLogin()\n86:             })\n87: \n88:         Row {\n89:             Text(stringOrSignInWith)\n90:                 .fontSize(16)\n91:                 .fontColor(Color.Gray)\n92:         }\n93:         .margin(top: 8)\n94: \n95:         Row(space: 20) {\n96:             Image(mediaGoogIcon)\n97:                 .width(48)\n98:                 .height(48)\n99:                 .onClick({ _ =>\n100:                     onGoogleLogin()\n101:                 })\n102:             Image(mediaFbIcon)\n103:                 .width(48)\n104:                 .height(48)\n105:           