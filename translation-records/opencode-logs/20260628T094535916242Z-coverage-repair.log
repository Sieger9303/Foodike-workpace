taurant(restaurant)\n97:         onNavigate()\n98:     }\n99: \n100:     private func filterRestaurants(restaurants: ArrayList<RestaurantData>, query: String): ArrayList<RestaurantData> {\n101:         let filtered = ArrayList<RestaurantData>([])\n102:         for (restaurant in restaurants) {\n103:             if (matchesQuery(restaurant, query)) {\n104:                 filtered.add(restaurant)\n105:             }\n106:         }\n107:         return filtered\n108:     }\n109: \n110:     public func filterByTag(restaurants: ArrayList<RestaurantData>, tag: String): ArrayList<RestaurantData> {\n111:         let filtered = ArrayList<RestaurantData>([])\n112:         for (restaurant in restaurants) {\n113:             if (matchesTag(restaurant, tag)) {\n114:                 filtered.add(restaurant)\n115:             }\n116:         }\n117:         return filtered\n118:     }\n119: \n120:     private func matchesQuery(restaurant: RestaurantData, query: String): Bool {\n\n(Showing lines 1-120 of 160. Use offset=121 to continue.)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.homeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\nimport std.unicode.*\n\npublic let homeStore = HomeStore()\n\npublic class HomeStore {\n    private let contentRepository = homeContentRepository\n    private let sessionRepository = sessionRepository\n    private let filters = ArrayList<String>([\n        \"Fast Delivery\",\n        \"50% Discount\",\n        \"Great deals\",\n        \"Non-Veg\"\n    ])\n","truncated":true,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_store.cj","time":{"start":1782640010741,"end":1782640010749}},"id":"prt_f