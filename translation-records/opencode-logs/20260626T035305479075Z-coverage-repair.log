{"type":"tool_use","timestamp":1782446118868,"sessionID":"ses_0fdf0abbcffeXZ79acy1pUYMV9","part":{"type":"tool","tool":"read","callID":"call_UAOsw3kmziEQ09vZg5Ue7YLg","state":{"status":"completed","input":{"filePath":"D:\\X2Cangjie\\X2Cangjie\\scripts\\tests\\test_patch_authority.py","offset":1,"limit":220},"output":"<path>D:\\X2Cangjie\\X2Cangjie\\scripts\\tests\\test_patch_authority.py</path>\n<type>file</type>\n<content>\n1: import json\n2: import sys\n3: import tempfile\n4: import unittest\n5: from pathlib import Path\n6: from unittest.mock import patch\n7: \n8: from scripts.shared.source_coverage import patch_authority\n9: from scripts.shared.source_coverage.facts import default_capability_facts, default_coverage_facts\n10: from scripts.shared.source_coverage.patch_authority import PatchError\n11: from scripts.tests.helpers import quiet_output\n12: \n13: \n14: def write_json(path: Path, data: dict) -> None:\n15:     path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + \"\\n\", encoding=\"utf-8\")\n16: \n17: \n18: class PatchAuthorityTest(unittest.TestCase):\n19:     def setUp(self) -> None:\n20:         self.tmp = tempfile.TemporaryDirectory()\n21:         self.root = Path(self.tmp.name)\n22: \n23:     def tearDown(self) -> None:\n24:         self.tmp.cleanup()\n25: \n26:     def run_patch(self, args: list[str]) -> int:\n27:         with patch.object(sys, \"argv\", [\"patch_authority.py\", *args]), quiet_output():\n28:             return patch_authority.main()\n29: \n30:     def matrix_path(self) -> Path:\n31:         path = self.root / \"source-coverage-matrix.json\"\n32:         write_json(\n33:             path,\n34:             {\n35:                 \"schemaVersion\": 1,\n36:                 \"allowedStatuses\": [\"implemented\", \"planned\"],\n37:                 \"entries\": [\n38:                     {\n39:                         \"featureId\": \"main-click-001\",\n40:                         \"featureName\": \"Main click\",\n41:                         \"sourcePath\": \"app/src/main/java/MainActivity.java\",\n42:                         \"importance\": \"high\",\n43:                         \"category\": \"java-source\",\n44:                         \"sourceEvidence\": \"path=MainActivity.java; featurePoint=onClick opens details\",\n45:                         \"status\": \"planned\",\n46:                         \"plannedPhase\": \"phase-01\",\n47:                         \"sourceBehavior\": \"Clicking the main button opens the details page.\",\n48:                         \"targetBehavior\": \"\",\n49:                         \"verificationEvidence\": [],\n50:                         \"parityLevel\": \"unverified\",\n51:                         \"targetEndpoints\": [],\n52:                         \"tests\": [],\n53:                         \"notes\": \"\",\n54:                         \"deferredReason\": \"\",\n55:                         \"targetFallback\": \"\",\n56:                         \"risk\": \"\",\n57:                         \"futureCompletionPath\": \"\",\n58:                     }\n59:                 ],\n60:             },\n61:         )\n62:         return path\n63: \n64:     def plan_path(self) -> Path:\n65:         path = self.root / \"plan.json\"\n66:         write_json(path, {\"phases\": [{\"id\": \"phase-01\"}, {\"id\": \"phase-05\"}]})\n67:         return path\n68: \n69:     def target_project(self) -> Path:\n70:         target = self.root / \"target\"\n71:         (target / \"entry/src/main/cangjie\").mkdir(parents=True)\n72:         (target / \"entry/src/main/cangjie/index.cj\").write_text(\n73:             \"class EntryView {\\n\"\n74:             \"  func openDetails() {}\\n\"\n75:             \"}\\n\",\n76:             encoding=\"utf-8\",\n77:         )\n78:         return target\n79: \n80:     def platform_path(self) -> Path:\n81:         path = self.root / \"platform-capability-check.json\"\n82:         write_json(\n83:             path,\n84:             {\n85:                 \"schemaVersion\": 1,\n86:                 \"entries\": [\n87:                     {\n88:                         \"capabilityId\": \"clipboard-pasteboard\",\n89:                         \"capabilityName\": \"Clipboard / pasteboard\",\n90:                         \"importance\": \"high\",\n91:                         \"sourcePaths\": [\"ClipboardHelper.java\"],\n92:                         \"sourceEvidence\": [],\n93:                         \"sourceEvidenceSummary\": \"Source uses clipboard APIs.\",\n94:                         \"status\": \"planned\",\n95:                         \"plannedPhase\": \"phase-05\",\n96:                         \"targetCapabilitySearch\": [],\n97:                         \"targetApiOrLibrary\": \"\",\n98:                         \"targetStrategy\": \"\",\n99:                         \"targetEndpoints\": [],\n100:                         \"tests\": [],\n101:                         \"sdkDeclarationEvidence\": [],\n102:                         \"cangjieCallableEvidence\": [],\n103:                         \"discoveryOnlyEvidence\": [],\n104:                         \"compileProbeEvidence\": [],\n105:                         \"preResolutionDecision\": \"\",\n106:                         \"phaseCapabilityResolution\": \"\",\n107:                         \"blocker\": \"\",\n108:                         \"targetFallback\": \"\",\n109:                         \"futureCompletionPath\": \"\",\n110:                         \"notes\": \"\",\n111:                     }\n112:                 ],\n113:             },\n114:         )\n115:         return path\n116: \n117:     def test_matrix_patch_updates_authority_and_markdown(self) -> None:\n118:         matrix = self.matrix_path()\n119:         patch_file = self.root / \"patch.json\"\n120:         write_json(\n121:             patch_file,\n122:             {\n123:                 \"updates\": [\n124:                     {\n125:                         \"featureId\": \"main-click-001\",\n126:                         \"set\": {\n127:                             \"status\": \"implemented\",\n128:                             \"parityLevel\": \"equivalent\",\n129:                             \"targetBehavior\": \"The ArkUI button opens the details route.\",\n130:                         },\n131:                         \"append\": {\n132:                             \"verificationEvidence\": [\"manual route smoke shows details page after click\"],\n133:                             \"targetEndpoints\": [\"entry/src/main/cangjie/index.cj::openDetails\"],\n134:                         },\n135:                     }\n136:                 ]\n137:             },\n138:         )\n139: \n140:         rc = self.run_patch([\"--kind\", \"matrix\", \"--authority\", str(matrix), \"--patch\", str(patch_file)])\n141: \n142:         self.assertEqual(0, rc)\n143:         updated = json.loads(matrix.read_text(encoding=\"utf-8\"))\n144:         entry = updated[\"entries\"][0]\n145:         self.assertEqual(\"implemented\", entry[\"status\"])\n146:         self.assertEqual(\"equivalent\", entry[\"parityLevel\"])\n147:         self.assertEqual(\"source_coverage/patch_authority.py\", updated[\"lastUpdatedBy\"])\n148:         self.assertIn(\"main-click-001\", updated[\"lastPatchSummary\"][\"updatedIds\"])\n149:         markdown = matrix.with_suffix(\".md\").read_text(encoding=\"utf-8\")\n150:         self.assertIn(\"main-click-001\", markdown)\n151:         self.assertIn(\"implemented\", markdown)\n152: \n153:     def test_matrix_patch_validates_plan_phase_and_target_endpoint(self) -> None:\n154:         matrix = self.matrix_path()\n155:         patch_file = self.root / \"patch.json\"\n156:         write_json(\n157:             patch_file,\n158:             {\n159:                 \"updates\": [\n160:                     {\n161:                         \"featureId\": \"main-click-001\",\n162:                         \"set\": {\n163:                             \"status\": \"imp