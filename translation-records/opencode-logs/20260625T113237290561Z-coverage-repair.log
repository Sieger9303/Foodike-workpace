{"type":"tool_use","timestamp":1782387204406,"sessionID":"ses_101725145ffej8BoFsdX6HrgJf","part":{"type":"tool","tool":"read","callID":"call_ONgMhewLoCTR75dQam34nknw","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj","limit":320},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n2: \n3: import kit.ArkUI.*\n4: import ohos.arkui.state_macro_manage.Builder\n5: import ohos.arkui.state_macro_manage.Component\n6: import ohos.arkui.state_macro_manage.Entry\n7: import ohos.arkui.state_macro_manage.State\n8: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n9: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.{loginStore, renderLoginRoute}\n10: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.{onboardingStore, renderOnboardingRoute}\n11: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{profileStore, renderProfileRoute}\n12: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.runtime.{Global, bootstrapStartRoute}\n13: \n14: @Entry\n15: @Component\n16: class FoodikeBootstrap {\n17:     @State\n18:     var currentRoute: String = bootstrapStartRoute\n19: \n20:     @State\n21:     var isShellAtTop: Bool = true\n22: \n23:     @State\n24:     var onboardingPageIndex: Int64 = 0\n25: \n26:     @State\n27:     var loginEmail: String = \"\"\n28: \n29:     @State\n30:     var loginPassword: String = \"\"\n31: \n32:     @State\n33:     var loginErrorMessage: String = \"\"\n34: \n35:     private var onboardingController: SwiperController = SwiperController()\n36: \n37:     private func applyShellState(shellState: ShellRouteState): Unit {\n38:         this.currentRoute = shellState.currentRoute\n39:         this.isShellAtTop = shellState.isAtTop\n40:     }\n41: \n42:     private func shellState(): ShellRouteState {\n43:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n44:     }\n45: \n46:     private func applyShellCommand(command: ShellCommand): Unit {\n47:         let shellState = this.shellState()\n48:         shellState.applyCommand(command)\n49:         this.applyShellState(shellState)\n50:     }\n51: \n52:     private func navigateTo(route: String): Unit {\n53:         let shellState = this.shellState()\n54:         shellState.currentRoute = route\n55:         shellState.isAtTop = true\n56:         this.applyShellState(shellState)\n57:     }\n58: \n59:     private func showBottomShell(route: String): Bool {\n60:         let shellState = this.shellState()\n61:         shellState.currentRoute = route\n62:         return shellState.showBottomShell()\n63:     }\n64: \n65:     private func routeTitle(route: String): String {\n66:         match (route) {\n67:             case \"onboarding\" => \"Onboarding\"\n68:             case \"login_screen\" => \"Login\"\n69:             case \"home_screen\" => \"Home\"\n70:             case \"history\" => \"History\"\n71:             case \"cart\" => \"Cart\"\n72:             case \"profile\" => \"Profile\"\n73:             case \"restaurant_details\" => \"Restaurant Detail\"\n74:             case _ => \"Unknown Route\"\n75:         }\n76:     }\n77: \n78:     private func showToast(message: String): Unit {\n79:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n80:     }\n81: \n82:     private func clearLoginError(): Unit {\n83:         this.loginErrorMessage = \"\"\n84:     }\n85: \n86:     private func performLogin(): Unit {\n87:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n88:             this.clearLoginError()\n89:             this.navigateTo(loginStore.successRoute())\n90:             return\n91:         }\n92: \n93:         this.loginErrorMessage = loginStore.invalidLoginMessage\n94:     }\n95: \n96:     private func performLogout(): Unit {\n97:         profileStore.logout(Global.abilityContext)\n98:         this.loginEmail = \"\"\n99:         this.loginPassword = \"\"\n100:         this.clearLoginError()\n101:         this.onboardingPageIndex = 0\n102:         this.navigateTo(profileStore.logoutRoute())\n103:     }\n104: \n105:     private func routeSummary(route: String): String {\n106:         match (route) {\n107:             case \"home_screen\" => \"Home remains the shared shell placeholder from phase 02 while onboarding, login, and profile now run as dedicated phase-03 routes.\"\n108:             case \"history\" => \"History remains available as a shell route so profile still has a source-consistent back destination.\"\n109:             case \"cart\" => \"Cart continues to be a shell-owned placeholder route until later phases land the real content.\"\n110:             case \"restaurant_details\" => \"Restaurant detail remains in the route contract but keeps its placeholder body until later phases.\"\n111:             case _ => \"\"\n112:         }\n113:     }\n114: \n115:     @Builder\n116:     private func buildOnboardingRoute() {\n117:         renderOnboardingRoute(\n118:             this.onboardingPageIndex,\n119:             this.onboardingController,\n120:             { index: Int32 =>\n121:                 this.onboardingPageIndex = Int64(index)\n122:             },\n123:             { =>\n124:                 if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n125:                     this.navigateTo(routePath(RouteId.Login))\n126:                 } else {\n127:                     this.onboardingController.showNext()\n128:                 }\n129:             }\n130:         )\n131:     }\n132: \n133:     @Builder\n134:     private func buildLoginRoute() {\n135:         renderLoginRoute(\n136:             this.loginEmail,\n137:             this.loginPassword,\n138:             this.loginErrorMessage,\n139:             { value: String =>\n140:                 this.loginEmail = value\n141:                 this.clearLoginError()\n142:             },\n143:             { value: String =>\n144:                 this.loginPassword = value\n145:                 this.clearLoginError()\n146:             },\n147:             { => this.showToast(loginStore.comingSoonMessage) },\n148:             { => this.performLogin() },\n149:             { => this.showToast(loginStore.comingSoonMessage) },\n150:             { => this.showToast(loginStore.comingSoonMessage) },\n151:             { => this.showToast(loginStore.comingSoonMessage) },\n152:             { => this.clearLoginError() }\n153:         )\n154:     }\n155: \n156:     @Builder\n157:     private func buildProfileRoute() {\n158:         renderProfileRoute(\n159:             profileStore.userName,\n160:             profileStore.userEmail,\n161:             { => this.navigateTo(profileStore.backRoute()) },\n162:             { => this.showToast(profileStore.placeholderActionMessage) },\n163:             { => this.showToast(profileStore.placeholderActionMessage) },\n164:             { => this.performLogout() }\n165:         )\n166:     }\n167: \n168:     @Builder\n169:     private func buildPlaceholderRoute() {\n170:         Column(space: 18) {\n171:             Text(\"Foodike\")\n172:                 .fontSize(42)\n173:                 .fontWeight(FontWeight.Bold)\n174:             Text(this.routeTitle(this.currentRoute))\n175:                 .fontSize(28)\n176:             Text(this.routeSummary(this.currentRoute))\n177:                 .fontSize(16)\n178:                 .textAlign(TextAlign.Center)\n179:                 .width(86.percent)\n180: \n181:             if (this.currentRoute == routePath(RouteId.Home) || this.currentRoute == routePath(RouteId.History)) {\n182:                 Button(if (this.isShellAtTop) { \"Simulate Scrolled Content\" } else { \"Return To Top\" })\n183:                     .onClick({ _ =>\n184:                         let shellState = this.shellState()\n185:                         shellState.setTopState(!shellState.isAtTop)\n186:                         this.applyShellState(shellState)\n187:                     })\n188:             }\n189: \n190:             Button(\"Primary Route Action\")\n191:                 .onClick({ _ =>\n192:                     this.applyShellCommand(ShellCommand.PrimaryAction)\n193:                 })\n194: \n195:             if (this.showBottomShell(this.currentRoute)) {\n196:                 Row(space: 12) {\n197:                     Button(\"Home Tab\")\n198:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HomeTab) })\n199:                     Button(\"Cart\")\n200:                         .onClick({ _ => this.applyShellCommand(ShellCommand.CartAction) })\n201:                     Button(\"History Tab\")\n202:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HistoryTab) })\n203:                 }\n204:             }\n205:         }\n206:         .width(100.percent)\n207:         .height(100.percent)\n208:         .justifyContent(FlexAlign.Center)\n209:         .alignItems(HorizontalAlign.Center)\n210:         .padding(top: 24, right: 24, bottom: 24, left: 24)\n211:     }\n212: \n213:     func build() {\n214:         if (this.currentRoute == routePath(RouteId.Onboarding)) {\n215:             this.buildOnboardingRoute()\n216:         } else if (this.currentRoute == routePath(RouteId.Login)) {\n217:             this.buildLoginRoute()\n218:         } else if (this.currentRoute == routePath(RouteId.Profile)) {\n219:             this.buildProfileRoute()\n220:         } else {\n221:             this.buildPlaceholderRoute()\n222:         }\n223:     }\n224: }\n\n(End of file - total 224 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builde