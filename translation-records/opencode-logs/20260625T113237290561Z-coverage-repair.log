{"type":"tool_use","timestamp":1782387333616,"sessionID":"ses_101725145ffej8BoFsdX6HrgJf","part":{"type":"tool","tool":"read","callID":"call_0Py9aJK6bwFhgl41g3gzWZz3","state":{"status":"completed","input":{"filePath":"D:\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\patch_authority.py","offset":460,"limit":220},"output":"<path>D:\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\patch_authority.py</path>\n<type>file</type>\n<content>\n460:     if field in text_fields:\n461:         if not isinstance(value, str):\n462:             raise PatchError(f\"Field `{field}` must be a string.\")\n463:         if field == \"status\":\n464:             return value.strip().lower()\n465:         if field == \"parityLevel\":\n466:             return value.strip().lower()\n467:         return value\n468:     if field in {\"riskTags\", \"keyClasses\", \"keyMethods\", \"androidIds\", \"dependencies\", \"sourcePaths\"}:\n469:         if not isinstance(value, list):\n470:             raise PatchError(f\"Field `{field}` must be a list.\")\n471:     elif field in {\"sourceEvidence\", \"requiredTargetCapabilitySearch\", \"requiredTests\", \"allowedDeferredReasons\"}:\n472:         if kind == \"platform\" and field != \"sourceEvidence\" and not isinstance(value, list):\n473:             raise PatchError(f\"Field `{field}` must be a list.\")\n474:         if kind == \"platform\" and field == \"sourceEvidence\" and not isinstance(value, list):\n475:             raise PatchError(\"Field `sourceEvidence` must be a list for platform additions.\")\n476:         if kind == \"matrix\" and field == \"sourceEvidence\" and not isinstance(value, str):\n477:             raise PatchError(\"Field `sourceEvidence` must be a string for matrix additions.\")\n478:     elif field in {\n479:         \"featureId\",\n480:         \"featureName\",\n481:         \"sourcePath\",\n482:         \"importance\",\n483:         \"category\",\n484:         \"featurePoint\",\n485:         \"capabilityId\",\n486:         \"capabilityName\",\n487:         \"sourceEvidenceSummary\",\n488:         \"targetStrategyHint\",\n489:         \"minimumParity\",\n490:     }:\n491:         if not isinstance(value, str):\n492:             raise PatchError(f\"Field `{field}` must be a string.\")\n493:     return value\n494: \n495: \n496: def patch_entry(kind: str, entry: dict[str, Any], update: dict[str, Any]) -> None:\n497:     allowed_ops = {\"featureId\", \"capabilityId\", \"set\", \"append\", \"remove\", \"unset\"}\n498:     unknown = sorted(set(update) - allowed_ops)\n499:     if unknown:\n500:         raise PatchError(f\"Update for `{entry.get(entry_id_field(kind), '')}` has unknown operation field(s): {', '.join(unknown)}.\")\n501: \n502:     set_values = ensure_object(update.get(\"set\"), \"set\")\n503:     append_values = ensure_object(update.get(\"append\"), \"append\")\n504:     remove_values = ensure_object(update.get(\"remove\"), \"remove\")\n505:     unset_fields = ensure_list(update.get(\"unset\"), \"unset\")\n506:     _, _, list_fields, text_fields = field_sets(kind)\n507: \n508:     for field, value in set_values.items():\n509:         entry[field] = validate_field_value(kind, field, value)\n510: \n511:     for field, values in append_values.items():\n512:         if field not in list_fields:\n513:             raise PatchError(f\"Append is allowed only for list fields; `{field}` is not appendable.\")\n514:         values = validate_field_value(kind, field, values)\n515:         existing = entry.get(field, [])\n516:         if not isinstance(existing, list):\n517:             raise PatchError(f\"Cannot append to `{field}` because the current value is not a list.\")\n518:         entry[field] = append_unique(existing, values)\n519: \n520:     for field, values in remove_values.items():\n521:         if field not in list_fields:\n522:             raise PatchError(f\"Remove is allowed only for list fields; `{field}` is not removable.\")\n523:         values = validate_field_value(kind, field, values)\n524:         existing = entry.get(field, [])\n525:         if not isinstance(existing, list):\n526:             raise PatchError(f\"Cannot remove from `{field}` because the current value is not a list.\")\n527:         remove_keys = {canonical_json(value) for value in values}\n528:         entry[field] = [value for value in existing if canonical_json(value) not in remove_keys]\n529: \n530:     update_fields, _, _, _ = field_sets(kind)\n531:     for field in unset_fields:\n532:         if not isinstance(field, str):\n533:             raise PatchError(\"Every `unset` item must be a string field name.\")\n534:         if field not in update_fields:\n535:             raise PatchError(f\"Field `{field}` is not writable for {kind} authority patches.\")\n536:         entry[field] = [] if field in list_fields else \"\"\n537:         if field in text_fields and field == \"status\":\n538:             entry[field] = \"planned\"\n539: \n540: \n541: def matrix_defaulted_addition(entry: dict[str, Any]) -> dict[str, Any]:\n542:     defaults: dict[str, Any] = {\n543:         \"status\": \"planned\",\n544:         \"plannedPhase\": \"\",\n545:         \"sourceBehavior\": entry.get(\"featurePoint\", \"\"),\n546:         \"targetBehavior\": \"\",\n547:         \"verificationEvidence\": [],\n548:         \"parityLevel\": \"unverified\",\n549:         \"targetEndpoints\": [],\n550:         \"tests\": [],\n551:         \"notes\": \"\",\n552:         \"deferredReason\": \"\",\n553:         \"targetFallback\": \"\",\n554:         \"risk\": \"\",\n555:         \"futureCompletionPath\": \"\",\n556:         \"entryOrigin\": \"agent-curated\",\n557:         \"matrixSync\": {\n558:             \"status\": \"agent-curated\",\n559:             \"preserveActive\": True,\n560:             \"reason\": \"row was added through structured authority patch\",\n561:         },\n562:         \"riskTags\": [],\n563:         \"keyClasses\": [],\n564:         \"keyMethods\": [],\n565:         \"androidIds\": [],\n566:         \"dependencies\": [],\n567:         \"featurePoint\": \"\",\n568:         \"category\": \"\",\n569:     }\n570:     return {**defaults, **entry}\n571: \n572: \n573: def platform_defaulted_addition(entry: dict[str, Any]) -> dict[str, Any]:\n574:     defaults: dict[str, Any] = {\n575:         \"status\": \"planned\",\n576:         \"plannedPhase\": \"\",\n577:         \"sourcePaths\": [],\n578:         \"sourceEvidence\": [],\n579:         \"requiredTargetCapabilitySearch\": [],\n580:         \"targetStrategyHint\": \"\",\n581:         \"minimumParity\": \"\",\n582:         \"requiredTests\": [],\n583:         \"allowedDeferredReasons\": [],\n584:         \"targetCapabilitySearch\": [],\n585:         \"targetApiOrLibrary\": \"\",\n586:         \"targetStrategy\": \"\",\n587:         \"targetEndpoints\": [],\n588:         \"tests\": [],\n589:         \"sdkDeclarationEvidence\": [],\n590:         \"cangjieCallableEvidence\": [],\n591:         \"discoveryOnlyEvidence\": [],\n592:         \"compileProbeEvidence\": [],\n593:         \"preResolutionDecision\": \"\",\n594:         \"phaseCapabilityResolution\": \"\",\n595:         \"blocker\": \"\",\n596:         \"targetFallback\": \"\",\n597:         \"futureCompletionPath\": \"\",\n598:         \"notes\": \"\",\n599:     }\n600:     return {**defaults, **entry}\n601: \n602: \n603: def validate_addition(kind: str, addition: Any) -> dict[str, Any]:\n604:     if not isinstance(addition, dict):\n605:         raise PatchError(\"Every addition must be an object.\")\n606:     required = MATRIX_ADD_REQUIRED_FIELDS if kind == \"matrix\" else PLATFORM_ADD_REQUIRED_FIELDS\n607:     missing = [field for field in sorted(required) if not has_text_or_list(addition.get(field))]\n608:     if missing:\n609:         raise PatchError(f\"Addition is missing required field(s): {', '.join(missing)}.\")\n610:     normalized = {\n611:         field: validate_field_value(kind, field, value, add_