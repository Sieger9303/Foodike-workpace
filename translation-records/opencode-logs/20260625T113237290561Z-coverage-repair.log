{"type":"tool_use","timestamp":1782387184898,"sessionID":"ses_101725145ffej8BoFsdX6HrgJf","part":{"type":"tool","tool":"read","callID":"call_NlyDzS0vFtJcWlI1tQfY9Ayo","state":{"status":"completed","input":{"filePath":"D:\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\login\\LoginScreen.kt","limit":320},"output":"<path>D:\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\login\\LoginScreen.kt</path>\n<type>file</type>\n<content>\n1: /**\n2:  *\n3:  *\tMIT License\n4:  *\n5:  *\tCopyright (c) 2026 Gautam Hazarika\n6:  *\n7:  *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n8:  *\tof this software and associated documentation files (the \"Software\"), to deal\n9:  *\tin the Software without restriction, including without limitation the rights\n10:  *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n11:  *\tcopies of the Software, and to permit persons to whom the Software is\n12:  *\tfurnished to do so, subject to the following conditions:\n13:  *\n14:  *\tThe above copyright notice and this permission notice shall be included in all\n15:  *\tcopies or substantial portions of the Software.\n16:  *\n17:  *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n18:  *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n19:  *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n20:  *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER\n21:  *\tLIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,\n22:  *\tOUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE\n23:  *\tSOFTWARE.\n24:  *\n25:  **/\n26: \n27: package com.example.foodike.presentation.login\n28: \n29: import android.annotation.SuppressLint\n30: import android.app.Activity\n31: import android.widget.Toast\n32: import androidx.compose.foundation.Image\n33: import androidx.compose.foundation.clickable\n34: import androidx.compose.foundation.layout.Arrangement\n35: import androidx.compose.foundation.layout.Column\n36: import androidx.compose.foundation.layout.Row\n37: import androidx.compose.foundation.layout.Spacer\n38: import androidx.compose.foundation.layout.fillMaxSize\n39: import androidx.compose.foundation.layout.fillMaxWidth\n40: import androidx.compose.foundation.layout.height\n41: import androidx.compose.foundation.layout.padding\n42: import androidx.compose.foundation.layout.width\n43: import androidx.compose.foundation.text.KeyboardOptions\n44: import androidx.compose.material.Button\n45: import androidx.compose.material.Divider\n46: import androidx.compose.material.Scaffold\n47: import androidx.compose.material.ScaffoldState\n48: import androidx.compose.material.SnackbarDuration\n49: import androidx.compose.material.Text\n50: import androidx.compose.material.rememberScaffoldState\n51: import androidx.compose.runtime.Composable\n52: import androidx.compose.runtime.LaunchedEffect\n53: import androidx.compose.runtime.getValue\n54: import androidx.compose.ui.Alignment\n55: import androidx.compose.ui.Modifier\n56: import androidx.compose.ui.draw.alpha\n57: import androidx.compose.ui.graphics.Color\n58: import androidx.compose.ui.graphics.toArgb\n59: import androidx.compose.ui.platform.LocalContext\n60: import androidx.compose.ui.res.painterResource\n61: import androidx.compose.ui.res.stringResource\n62: import androidx.compose.ui.text.input.ImeAction\n63: import androidx.compose.ui.text.input.PasswordVisualTransformation\n64: import androidx.compose.ui.unit.dp\n65: import androidx.compose.ui.unit.sp\n66: import androidx.hilt.navigation.compose.hiltViewModel\n67: import androidx.navigation.NavGraph.Companion.findStartDestination\n68: import androidx.navigation.NavHostController\n69: import com.example.foodike.R\n70: import com.example.foodike.presentation.login.components.FoodikeTextField\n71: import com.example.foodike.presentation.util.Screen\n72: import kotlinx.coroutines.flow.collectLatest\n73: \n74: @SuppressLint(\"UnusedMaterialScaffoldPaddingParameter\")\n75: @Composable\n76: fun LoginScreen(\n77:     viewModel: LoginViewModel = hiltViewModel(),\n78:     navController: NavHostController,\n79: ) {\n80: \n81:     val scaffoldState: ScaffoldState = rememberScaffoldState()\n82: \n83:     val email by viewModel.email\n84:     val password by viewModel.password\n85: \n86:     LaunchedEffect(key1 = true) {\n87:         viewModel.eventFlow.collectLatest { event ->\n88:             when (event) {\n89:                 is UiEvent.ShowSnackbar -> {\n90:                     scaffoldState.snackbarHostState.showSnackbar(\n91:                         message = event.message, duration = SnackbarDuration.Short\n92:                     )\n93:                 }\n94:             }\n95:         }\n96:     }\n97: \n98:     Scaffold(scaffoldState = scaffoldState) {\n99:         Column(\n100:             modifier = Modifier.fillMaxSize(),\n101:             verticalArrangement = Arrangement.Center,\n102:             horizontalAlignment = Alignment.CenterHorizontally\n103:         ) {\n104: \n105:             val context = LocalContext.current as Activity\n106: \n107:             context.window.statusBarColor = Color.Gray.toArgb()\n108:             context.window.navigationBarColor = Color.White.toArgb()\n109: \n110:             Text(\n111:                 text = stringResource(R.string.welcome_back), fontSize = 24.sp\n112:             )\n113: \n114:             Spacer(modifier = Modifier.height(24.dp))\n115: \n116:             Column(\n117:                 horizontalAlignment = Alignment.End\n118: \n119:             ) {\n120:                 FoodikeTextField(\n121:                     value = email.text,\n122:                     onValueChange = { viewModel.onEvent(LoginEvent.EnteredEmail(it)) },\n123:                     hint = email.hint\n124:                 )\n125: \n126: \n127:                 Spacer(modifier = Modifier.height(16.dp))\n128: \n129:                 FoodikeTextField(\n130:                     value = password.text,\n131:                     onValueChange = { viewModel.onEvent(LoginEvent.EnteredPassword(it)) },\n132:                     hint = password.hint,\n133:                     visualTransformation = PasswordVisualTransformation(),\n134:                     keyboardOptions = KeyboardOptions.Default.copy(\n135:                         imeAction = ImeAction.Done\n136:                     ),\n137:                 )\n138: \n139: \n140:                 Spacer(modifier = Modifier.height(8.dp))\n141: \n142:                 Text(\n143:                     text = stringResource(R.string.forgot_password),\n144:                     modifier = Modifier\n145:                         .alpha(0.5f)\n146:                         .clickable {\n147:                             Toast\n148:                                 .makeText(context, R.string.coming_soon, Toast.LENGTH_SHORT)\n149:                                 .show()\n150:                         },\n151:                     fontSize = 14.sp,\n152:                 )\n153:             }\n154:             Spacer(modifier = Modifier.height(16.dp))\n155:             Button(modifier = Modifier.width(200.dp), onClick = {\n156:                 viewModel.onEvent(LoginEvent.PerformLogin {\n157:                     navController.navigate(Screen.Home.route) {\n158:                         popUpTo(navController.graph.findStartDestination().id) {\n159:                             inclusive = true\n160:                         }\n161:                     }\n162:                 })\n163:             }) {\n164:                 Text(\n165:                     text = stringResource(R.string.login),\n166:                     fontSize = 16.sp,\n167:                 )\n168:             }\n169: \n170: \n171: \n172:             Row(\n173:                 modifier = Modifier\n174:                     .fillMaxWidth()\n175:                     .padding(24.dp),\n176:                 horizontalArrangement = Arrangement.Center,\n177:                 verticalAlignment = Alignment.CenterVertically\n178:             ) {\n179:                 Divider(\n180:                     modifier = Modifier\n181:                         .weight(0.1f)\n182:                         .width(1.dp)\n183:                 )\n184:                 Spacer(modifier = Modifier.width(16.dp))\n185: \n186:                 Text(\n187:                     text = stringResource(R.string.or_sign_in_with),\n188:                     modifier = Modifier.alpha(0.5f),\n189:                     fontSize = 16.sp,\n190:                 )\n191:                 Spacer(modifier = Modifier.width(16.dp))\n192: \n193:                 Divider(\n194:                     modifier = Modifier\n195:                         .weight(0.1f)\n196:                         .width(1.dp)\n197:                 )\n198:             }\n199: \n200:             Row(\n201:                 modifier = Modifier.fillMaxWidth(),\n202:                 horizontalArrangement = Arrangement.Center,\n203:                 verticalAlignment = Alignment.CenterVertically\n204:             ) {\n205:                 Image(painter = painterResource(id = R.drawable.goog_icon),\n206:                     contentDescription = stringResource(R.string.login_with_google),\n207:                     modifier = Modifier\n208:                         .fillMaxSize(0.1f)\n209:                         .clickable {\n210:                             Toast\n211:                                 .makeText(context, R.string.coming_soon, Toast.LENGTH_SHORT)\n212:                                 .show()\n213:                         })\n214:                 Spacer(modifier = Modifier.width(16.dp))\n215:                 Image(painter = painterResource(id = R.drawable.fb_icon),\n216:                     contentDescription = stringResource(R.string.login_with_facebook),\n217:   