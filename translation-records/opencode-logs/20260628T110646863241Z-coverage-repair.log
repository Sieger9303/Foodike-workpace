{"type":"tool_use","timestamp":1782644844096,"sessionID":"ses_0f216e552ffekvSSMPwudetYAO","part":{"type":"tool","tool":"read","callID":"call_tjf83svUWiR8qmu8OsqAFcKR","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj","limit":320,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n2: \n3: import kit.ArkUI.*\n4: import ohos.base.ResourceStr\n5: import ohos.arkui.state_macro_manage.Builder\n6: import ohos.arkui.state_macro_manage.Component\n7: import ohos.arkui.state_macro_manage.Entry\n8: import ohos.arkui.state_macro_manage.State\n9: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n10: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.{CartSnapshotItemData, DetailMenuItemData, DetailPageState, RestaurantData}\n11: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.{cartStore, renderCartRoute}\n12: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.{detailStore, renderDetailRoute}\n13: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history.{historyStore, renderHistoryRoute}\n14: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home.{homeStore, renderHomeRoute}\n15: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.{loginStore, renderLoginRoute}\n16: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.{onboardingStore, renderOnboardingRoute}\n17: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{profileStore, renderProfileRoute}\n18: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.runtime.{Global, bootstrapStartRoute}\n19: import std.collection.ArrayList\n20: \n21: @Entry\n22: @Component\n23: class FoodikeBootstrap {\n24:     @State\n25:     var currentRoute: String = bootstrapStartRoute\n26: \n27:     @State\n28:     var isShellAtTop: Bool = true\n29: \n30:     @State\n31:     var onboardingPageIndex: Int64 = 0\n32: \n33:     @State\n34:     var loginEmail: String = \"\"\n35: \n36:     @State\n37:     var loginPassword: String = \"\"\n38: \n39:     @State\n40:     var loginErrorMessage: String = \"\"\n41: \n42:     @State\n43:     var homeSearchQuery: String = \"\"\n44: \n45:     @State\n46:     var homeSelectedFilter: String = \"\"\n47: \n48:     @State\n49:     var historySearchQuery: String = \"\"\n50: \n51:     @State\n52:     var historyTabIndex: Int64 = 0\n53: \n54:     @State\n55:     var previousRoute: String = \"home_screen\"\n56: \n57:     @State\n58:     var cartNote: String = \"\"\n59: \n60:     @State\n61:     var cartCoupon: String = \"\"\n62: \n63:     @State\n64:     var cartMutationRevision: Int64 = 0\n65: \n66:     @State\n67:     var detailRecommendedExpanded: Bool = true\n68: \n69:     @State\n70:     var detailNonVegExpanded: Bool = true\n71: \n72:     @State\n73:     var detailVegExpanded: Bool = true\n74: \n75:     @State\n76:     var detailLiked: Bool = false\n77: \n78:     @State\n79:     var detailMutationRevision: Int64 = 0\n80: \n81:     private var onboardingController: SwiperController = SwiperController()\n82:     private var routeBackStack: ArrayList<String> = ArrayList<String>([])\n83: \n84:     private func applyShellState(shellState: ShellRouteState): Unit {\n85:         this.currentRoute = shellState.currentRoute\n86:         this.isShellAtTop = shellState.isAtTop\n87:     }\n88: \n89:     private func shellState(): ShellRouteState {\n90:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n91:     }\n92: \n93:     private func applyShellCommand(command: ShellCommand): Unit {\n94:         let shellState = this.shellState()\n95:         shellState.applyCommand(command)\n96:         this.applyShellState(shellState)\n97:     }\n98: \n99:     private func navigateTo(route: String): Unit {\n100:         if (this.currentRoute != route) {\n101:             this.routeBackStack.add(this.currentRoute)\n102:         }\n103:         this.previousRoute = this.currentRoute\n104:         let shellState = this.shellState()\n105:         shellState.currentRoute = route\n106:         shellState.isAtTop = true\n107:         this.applyShellState(shellState)\n108:     }\n109: \n110:     private func navigateBack(): Unit {\n111:         if (this.routeBackStack.size == 0) {\n112:             return\n113:         }\n114:         let targetIndex = this.routeBackStack.size - 1\n115:         let targetRoute = this.routeBackStack[targetIndex]\n116:         this.routeBackStack.remove(at: targetIndex)\n117:         this.previousRoute = this.currentRoute\n118:         let shellState = this.shellState()\n119:         shellState.currentRoute = targetRoute\n120:         shellState.isAtTop = true\n121:         this.applyShellState(shellState)\n122:     }\n123: \n124:     private func showBottomShell(route: String): Bool {\n125:         let shellState = this.shellState()\n126:         shellState.currentRoute = route\n127:         return shellState.showBottomShell()\n128:     }\n129: \n130:     private func routeTitle(route: String): ResourceStr {\n131:         routeLabelByPath(route)\n132:     }\n133: \n134:     private func showToast(message: String): Unit {\n135:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n136:     }\n137: \n138:     private func clearLoginError(): Unit {\n139:         this.loginErrorMessage = \"\"\n140:     }\n141: \n142:     private func performLogin(): Unit {\n143:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n144:             this.clearLoginError()\n145:             this.navigateTo(loginStore.successRoute())\n146:             return\n147:         }\n148: \n149:         this.loginErrorMessage = loginStore.invalidLoginMessage\n150:         this.showToast(loginStore.invalidLoginMessage)\n151:     }\n152: \n153:     private func performLogout(): Unit {\n154:         profileStore.logout(Global.abilityContext)\n155:         this.loginEmail = \"\"\n156:         this.loginPassword = \"\"\n157:         this.clearLoginError()\n158:         this.onboardingPageIndex = 0\n159:         this.homeSearchQuery = \"\"\n160:         this.homeSelectedFilter = \"\"\n161:         this.historySearchQuery = \"\"\n162:         this.historyTabIndex = 0\n163:         this.routeBackStack.clear()\n164:         this.navigateTo(profileStore.logoutRoute())\n165:     }\n166: \n167:     private func routeSummary(route: String): String {\n168:         match (route) {\n169:             case \"home_screen\" => \"Home now renders repository-backed discovery content, local search/filter controls, and restaurant selection before detail routing.\"\n170:             case \"history\" => \"History now preserves search plus tab-local content, reuses favourite restaurants, and saves the selected restaurant before navigation.\"\n171:             case \"cart\" => \"Cart now renders snapshot-backed items, a local note editor, a local coupon field, delivery details, and bill totals without adding new checkout persistence flows.\"\n172:             case \"restaurant_details\" => \"Restaurant detail now reads the selected restaurant, preserves local section expansion and like state, keeps menu quantity controls local to the route, and shows the cart action only when selected quantities are non-zero.\"\n173:             case _ => \"\"\n174:         }\n175:     }\n176: \n177:     private func homeHour(): Int64 {\n178:         return 9\n179:     }\n180: \n181:     private func goToProfile(): Unit {\n182:         this.navigateTo(routePath(RouteId.Profile))\n183:     }\n184: \n185:     private func goToRestaurantDetail(): Unit {\n186:         this.detailRecommendedExpanded = true\n187:         this.detailNonVegExpanded = true\n188:         this.detailVegExpanded = true\n189:         this.detailLiked = detailStore.session().isRestaurantLiked(detailStore.selectedRestaurant())\n190:         this.detailMutationRevision = 0\n191:         this.navigateTo(routePath(RouteId.RestaurantDetails))\n192:     }\n193: \n194:     private func detailState(): DetailPageState {\n195:         return detailStore.loadDetailState(\n196:             this.detailRecommendedExpanded,\n197:             this.detailNonVegExpanded,\n198:             this.detailVegExpanded\n199:         )\n200:     }\n201: \n202:     private func selectHomeRestaurant(restaurant: RestaurantData): Unit {\n203:         homeStore.selectRestaurant(restaurant, { =>\n204:             this.goToRestaurantDetail()\n205:         })\n206:     }\n207: \n208:     private func selectHistoryRestaurant(restaurant: RestaurantData): Unit {\n209:         historyStore.selectRestaurant(restaurant, { =>\n210:             this.goToRestaurantDetail()\n211:         })\n212:     }\n213: \n214:     @Builder\n215:     private func buildOnboardingRoute() {\n216:         renderOnboardingRoute(\n217:             this.onboardingPageIndex,\n218:             this.onboardingController,\n219:             { index: Int32 =>\n220:                 this.onboardingPageIndex = Int64(index)\n221:             },\n222:             { =>\n223:                 if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n224:                     this.navigateTo(routePath(RouteId.Login))\n225:                 } else {\n226:                     this.onboardingController.showNext()\n227:                 }\n228:             }\n229:         )\n230:     }\n231: \n232:     @Builder\n233:     private func buildLoginRoute() {\n234:         renderLoginRoute(\n235:             this.loginEmail,\n236:             this.loginPassword,\n237:             this.loginErrorMessage,\n238:             { value: String =>\n239:                 this.loginEmail = value\n240:                 this.clearLoginError()\n241:             },\n242:             { value: String =>\n243:                 this.loginPassword = value\n244:                 this.clearLoginError()\n245:             },\n246:             { => this.showToast(loginStore.comingSoonMessage) },\n247:             { => this.performLogin() },\n248:             { => this.showToast(loginStore.comingSoonMessage) },\n249:             { => this.showToast(loginStore.comingSoonMessage) },\n250:             { => this.showToast(loginStore.comingSoonMessage) },\n251:             { => this.clearLoginError() }\n252:         )\n253:     }\n254: \n255:     @Builder\n256:     private func buildProfileRoute() {\n257:         renderProfileRoute(\n258:             profileStore.userName,\n259:             profileStore.userEmail,\n260:             { => this.navigateTo(profileStore.backRoute()) },\n261:             { => this.showToast(profileStore.placeholderActionMessage) },\n262:             { => this.showToast(profileStore.placeholderActionMessage) },\n263:             { => this.performLogout() }\n264:         )\n265:     }\n266: \n267:     @Builder\n268:     private func buildHomeRoute() {\n269:         renderHomeRoute(\n270:             homeStore.buildFilteredState(this.homeSearchQuery, this.homeSelectedFilter),\n271:             this.homeHour(),\n272:             this.homeSearchQuery,\n273:             this.homeSelectedFilter,\n274:             { value: String =>\n275:                 this.homeSearchQuery = value\n276:             },\n277:             { value: String =>\n278:                 this.homeSelectedFilter = homeStore.toggleFilter(this.homeSelectedFilter, value)\n279:             },\n280:             { => this.goToProfile() },\n281:             { restaurant: RestaurantData =>\n282:                 this.selectHomeRestaurant(restaurant)\n283:             }\n284:         )\n285:     }\n286: \n287:     @Builder\n288:     private func buildHistoryRoute() {\n289:         renderHistoryRoute(\n290:             historyStore.buildVisibleState(this.historySearchQuery),\n291:             this.historyTabIndex,\n292:             this.historySearchQuery,\n293:             { value: String =>\n294:                 this.historySearchQuery = value\n295:             },\n296:             { value: Int64 =>\n297:                 this.historyTabIndex = value\n298:             },\n299:             { restaurant: RestaurantData =>\n300:                 this.selectHistoryRestaurant(restaurant)\n301:             }\n302:         )\n303:     }\n304: \n305:     @Builder\n306:     private func buildCartRoute() {\n307:         renderCartRoute(\n308:             cartStore.loadCartState(),\n309:             this.cartNote,\n310:             this.cartCoupon,\n311:             { value: String =>\n312:                 this.cartNote = value\n313:             },\n314:             { value: String =>\n315:                 this.cartCoupon = value\n316:             },\n317:             { item: CartSnapshotItemData =>\n318:                 cartStore.decrementQuantity(item)\n319:                 this.cartMutationRevision += 1\n320:             },\n\n(Showing lines 1-320 of 434. Use offset=321 to continue.)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\nimport kit.ArkUI.*\nimport ohos.base.ResourceStr\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos.arkui.state_macro_manage.Component\nimport ohos.arkui.state_macro_manage.Entry\nimport ohos.arkui.state_macro_manage.State\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.{CartSnapshotItemData, DetailMenuItemData, DetailPageState, RestaurantData}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.{cartStore, renderCartRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.{detailStore, renderDetailRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history.{historyStore, renderHistoryRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home.{homeStore, renderHomeRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.{loginStore, renderLoginRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.{onboardingStore, renderOnboardingRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{profileStore, renderProfileRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.runtime.{Global, bootstrapStartRoute}\nimport std.collection.ArrayList\n","truncated":true,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj","time":{"start":1782644844085,"end":1782644844096}},"id":"prt_f0de9a6330012oN7ObME1xm2hs","sessionID":"ses_0f216e552ffekvSSMPwudetYAO","messageID":"msg_f0de97320001SYy0lz3HemXgib"}}
{"type":"tool_use","timestamp":1782644844097,"sessionID":"ses_0f216e552ffekvSSMPwudetYAO","part":{"type":"tool","tool":"read","callID":"call_uMJyU83HgLjRwOy6biRLUpQe","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\detail\\detail_store.cj","limit":420,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\detail\\detail_store.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail\n2: \n3: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.homeContentRepository\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n6: import std.collection.ArrayList\n7: import std.random.Random\n8: \n9: public let detailStore = DetailStore()\n10: \n11: public class DetailStore {\n12:     private let contentRepository = homeContentRepository\n13:     private let sessionRepository = sessionRepository\n14: \n15:     public init() {}\n16: \n17:     public func loadDetailState(\n18:         recommendedExpanded: Bool,\n19:         nonVegExpanded: Bool,\n20:         vegExpanded: Bool\n21:     ): DetailPageState {\n22:         let restaurant = selectedRestaurant()\n23:         let menuItems = selectedMenuItems(restaurant)\n24:         return DetailPageState(\n25:             restaurant,\n26:             recommendedExpanded,\n27:             nonVegExpanded,\n28:             vegExpanded,\n29:             menuItems,\n30:             recommendedItems(menuItems),\n31:             sessionRepository.isRestaurantLiked(restaurant)\n32:         )\n33:     }\n34: \n35:     public func selectedRestaurant(): RestaurantData {\n36:         let restaurantName = sessionRepository.getSelectedRestaurantName()\n37:         if (restaurantName != \"\") {\n38:             match (contentRepository.getRestaurantByName(restaurantName)) {\n39:                 case Some(restaurant) => return restaurant\n40:                 case None => return contentRepository.getRestaurants()[0]\n41:             }\n42:         }\n43:         return contentRepository.getRestaurants()[0]\n44:     }\n45: \n46:     private func selectedMenuItems(restaurant: RestaurantData): ArrayList<DetailMenuItemData> {\n47:         let menuItems = sessionRepository.getMenuItems()\n48:         if (menuItems.size > 0) {\n49:             return menuItems\n50:         }\n51:         return sessionRepository.menuItemsForRestaurant(restaurant.name)\n52:     }\n53: \n54:     public func recommendedItems(menuItems: ArrayList<DetailMenuItemData>): ArrayList<DetailMenuItemData> {\n55:         let shuffled = ArrayList<DetailMenuItemData>(menuItems)\n56:         let rng = Random()\n57:         var index: Int64 = shuffled.size - 1\n58:         while (index > 0) {\n59:             let swapIndex = rng.nextInt64(index + 1)\n60:             let current = shuffled[index]\n61:             shuffled[index] = shuffled[swapIndex]\n62:             shuffled[swapIndex] = current\n63:             index -= 1\n64:         }\n65: \n66:         let recommended = ArrayList<DetailMenuItemData>([])\n67:         var recommendedIndex: Int64 = 0\n68:         for (item in shuffled) {\n69:             if (recommendedIndex >= 5) {\n70:                 break\n71:             }\n72:             recommended.add(item)\n73:             recommendedIndex += 1\n74:         }\n75:         return recommended\n76:     }\n77: \n78:     public func nonVegItems(menuItems: ArrayList<DetailMenuItemData>): ArrayList<DetailMenuItemData> {\n79:         let filtered = ArrayList<DetailMenuItemData>([])\n80:         for (item in menuItems) {\n81:             if (!item.menuItem.isVegetarian) {\n82:                 filtered.add(item)\n83:             }\n84:         }\n85:         return filtered\n86:     }\n87: \n88:     public func vegItems(menuItems: ArrayList<DetailMenuItemData>): ArrayList<DetailMenuItemData> {\n89:         let filtered = ArrayList<DetailMenuItemData>([])\n90:         for (item in menuItems) {\n91:             if (item.menuItem.isVegetarian) {\n92:                 filtered.add(item)\n93:             }\n94:         }\n95:         return filtered\n96:     }\n97: \n98:     public func incrementQuantity(item: DetailMenuItemData): Unit {\n99:         sessionRepository.incrementMenuItemQuantity(item.menuItem.dish)\n100:     }\n101: \n102:     public func decrementQuantity(item: DetailMenuItemData): Unit {\n103:         sessionRepository.decrementMenuItemQuantity(item.menuItem.dish)\n104:     }\n105: \n106:     public func totalSelectedItems(menuItems: ArrayList<DetailMenuItemData>): Int64 {\n107:         var total: Int64 = 0\n108:         for (item in menuItems) {\n109:             total += item.quantity\n110:         }\n111:         return total\n112:     }\n113: \n114:     public func shouldShowCartAction(menuItems: ArrayList<DetailMenuItemData>): Bool {\n115:         return totalSelectedItems(menuItems) > 0\n116:     }\n117: \n118:     public func toggleLiked(restaurant: RestaurantData, currentValue: Bool): Bool {\n119:         let nextValue = !currentValue\n120:         sessionRepository.setRestaurantLiked(restaurant, nextValue)\n121:         return nextValue\n122:     }\n123: \n124:     public func formatPrice(price: Float64): String {\n125:         return \"$${price}\"\n126:     }\n127: \n128:     public func formatRatingCount(ratingCount: Int64): String {\n129:         return \"${ratingCount} ratings\"\n130:     }\n131: \n132:     public func formatRestaurantMeta(restaurant: RestaurantData): String {\n133:         return \"${restaurant.rating}(${customerCount(restaurant.ratingCount)}) · ${restaurant.etaMinutes} Min · $${restaurant.averagePrice}\"\n134:     }\n135: \n136:     public func customerCount(ratingCount: Int64): String {\n137:         if (ratingCount >= 1000) {\n138:             return \"1000+\"\n139:         }\n140:         if (ratingCount >= 100) {\n141:             return \"${ratingCount}+\"\n142:         }\n143:         return \"${ratingCount}\"\n144:     }\n145: \n146:     public func session(): SessionRepository {\n147:         return sessionRepository\n148:     }\n149: }\n\n(End of file - total 149 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.homeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\nimport std.random.Random\n\npublic let detailStore = DetailStore()\n\npublic class DetailStore {\n    private let contentRepository = homeContentRepository\n    private let sessionRepository = sessionRepository\n\n    public init() {}\n\n    public func loadDetailState(\n        recommendedExpanded: Bool,\n        nonVegExpanded: Bool,\n        vegExpanded: Bool","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\detail\\detail_store.cj","time":{"start":1782644844073,"end":1782644844097}},"id":"prt_f0de9a625001drRewMzWZymTyB","sessionID":"ses_0f216e552ffekvSSMPwudetYAO","messageID":"msg_f0de97320001SYy0lz3HemXgib"}}
{"type":"tool_use","timestamp":1782644844099,"sessionID":"ses_0f216e552ffekvSSMPwudetYAO","part":{"type":"tool","tool":"read","callID":"call_3I3IVZNY7AJlPru9dms6iVqI","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\detail\\detail_page.cj","limit":420,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\detail\\detail_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail\n2: \n3: import kit.ArkUI.*\n4: import ohos.arkui.state_macro_manage.Builder\n5: import ohos.base.ResourceStr\n6: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n7: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.restaurantMedia\n8: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n9: import std.collection.ArrayList\n10: \n11: @Builder\n12: func buildDetailTopBar(isLiked: Bool, onBack: () -> Unit, onToggleLike: () -> Unit, onShare: () -> Unit) {\n13:     Row {\n14:         Button(\"<\")\n15:             .onClick({ _ =>\n16:                 onBack()\n17:             })\n18:         Blank().layoutWeight(1)\n19:         Row(space: 12) {\n20:             Text(if (isLiked) { \"Heart\" } else { \"Like\" })\n21:                 .fontColor(if (isLiked) { Color.Red } else { Color.Black })\n22:                 .fontWeight(FontWeight.Bold)\n23:                 .onClick({ _ =>\n24:                     onToggleLike()\n25:                 })\n26:             Text(stringShare)\n27:                 .fontColor(Color.Gray)\n28:                 .onClick({ _ =>\n29:                     onShare()\n30:                 })\n31:         }\n32:     }\n33:     .width(100.percent)\n34:     .alignItems(VerticalAlign.Center)\n35: }\n36: \n37: @Builder\n38: func buildRestaurantDetailCard(restaurant: RestaurantData) {\n39:     Column(space: 12) {\n40:         Text(restaurant.name)\n41:             .fontSize(26)\n42:             .fontWeight(FontWeight.Bold)\n43:         Row(space: 6) {\n44:             Image(mediaStar)\n45:                 .width(18)\n46:                 .height(18)\n47:             Text(detailStore.formatRestaurantMeta(restaurant))\n48:                 .fontSize(14)\n49:         }\n50:         Text(restaurant.variety)\n51:             .fontSize(14)\n52:             .fontColor(Color.Gray)\n53:         Text(restaurant.place)\n54:             .fontSize(14)\n55:             .fontColor(Color.Gray)\n56: \n57:         Row(space: 14) {\n58:             Image(mediaOutletCard)\n59:                 .width(42)\n60:                 .height(42)\n61:             Column(space: 4) {\n62:                 Text(stringOutlet)\n63:                     .fontWeight(FontWeight.Medium)\n64:                 Text(\"${restaurant.etaMinutes} Min\")\n65:                     .fontColor(Color.Gray)\n66:             }\n67:             Blank().layoutWeight(1)\n68:             Column(space: 4) {\n69:                 Text(restaurant.place)\n70:                     .fontColor(Color.Gray)\n71:                 Text(stringYourLocation)\n72:                     .fontColor(Color.Gray)\n73:             }\n74:         }\n75:         .width(100.percent)\n76:     }\n77:     .width(100.percent)\n78:     .padding(top: 18, right: 18, bottom: 18, left: 18)\n79:     .backgroundColor(0xFFC6FDB3)\n80:     .borderRadius(22)\n81: }\n82: \n83: @Builder\n84: func buildMenuQuantityControls(\n85:     item: DetailMenuItemData,\n86:     onAdd: () -> Unit,\n87:     onRemove: () -> Unit\n88: ) {\n89:     if (item.quantity == 0) {\n90:         Text(stringAdd)\n91:             .fontSize(15)\n92:             .fontWeight(FontWeight.Bold)\n93:             .fontColor(colorDarkGreen)\n94:             .onClick({ _ =>\n95:                 onAdd()\n96:             })\n97:     } else {\n98:         Row(space: 10) {\n99:             Text(stringSubtract)\n100:                 .fontSize(16)\n101:                 .fontWeight(FontWeight.Bold)\n102:                 .onClick({ _ =>\n103:                     onRemove()\n104:                 })\n105:             Text(\"${item.quantity}\")\n106:                 .fontSize(16)\n107:                 .fontWeight(FontWeight.Medium)\n108:             Text(\"+\")\n109:                 .fontSize(16)\n110:                 .fontWeight(FontWeight.Bold)\n111:                 .fontColor(colorDarkGreen)\n112:                 .onClick({ _ =>\n113:                     onAdd()\n114:                 })\n115:         }\n116:         .padding(top: 6, right: 10, bottom: 6, left: 10)\n117:         .borderRadius(14)\n118:         .border(width: 1.px, color: 0x55000000)\n119:     }\n120: }\n121: \n122: @Builder\n123: func buildMenuItemRow(\n124:     item: DetailMenuItemData,\n125:     onAdd: () -> Unit,\n126:     onRemove: () -> Unit\n127: ) {\n128:     Row(space: 14) {\n129:         Image(if (item.menuItem.isVegetarian) { mediaIcVeg } else { mediaIcNonVeg })\n130:             .width(18)\n131:             .height(18)\n132:         Column(space: 6) {\n133:             Text(item.menuItem.dish)\n134:                 .fontSize(16)\n135:                 .fontWeight(FontWeight.Medium)\n136:             Text(detailStore.formatPrice(item.menuItem.price))\n137:                 .fontSize(14)\n138:                 .fontColor(Color.Gray)\n139:             Row(space: 6) {\n140:                 Image(mediaStar)\n141:                     .width(16)\n142:                     .height(16)\n143:                 Text(\"${item.menuItem.rating}\")\n144:                     .fontSize(13)\n145:                 Text(detailStore.formatRatingCount(item.menuItem.ratingCount))\n146:                     .fontSize(13)\n147:                     .fontColor(Color.Gray)\n148:             }\n149:         }\n150:         .layoutWeight(1)\n151:         buildMenuQuantityControls(item, onAdd, onRemove)\n152:     }\n153:     .width(100.percent)\n154:     .alignItems(VerticalAlign.Center)\n155:     .padding(top: 12, right: 0, bottom: 12, left: 0)\n156: }\n157: \n158: @Builder\n159: func buildSectionHeader(title: ResourceStr, expanded: Bool, onToggle: () -> Unit) {\n160:     Row {\n161:         Text(title)\n162:             .fontSize(22)\n163:             .fontWeight(FontWeight.Bold)\n164:         Blank().layoutWeight(1)\n165:         Text(if (expanded) { \"v\" } else { \">\" })\n166:             .fontSize(20)\n167:             .fontColor(Color.Gray)\n168:             .onClick({ _ =>\n169:                 onToggle()\n170:             })\n171:     }\n172:     .width(100.percent)\n173:     .alignItems(VerticalAlign.Center)\n174: }\n175: \n176: @Builder\n177: func buildDetailSection(\n178:     title: ResourceStr,\n179:     expanded: Bool,\n180:     items: ArrayList<DetailMenuItemData>,\n181:     onToggle: () -> Unit,\n182:     onAdd: (DetailMenuItemData) -> Unit,\n183:     onRemove: (DetailMenuItemData) -> Unit\n184: ) {\n185:     Column(space: 8) {\n186:         buildSectionHeader(title, expanded, onToggle)\n187:         if (expanded) {\n188:             ForEach(items, itemGeneratorFunc: { item: DetailMenuItemData, _: Int64 =>\n189:                 buildMenuItemRow(\n190:                     item,\n191:                     { => onAdd(item) },\n192:                     { => onRemove(item) }\n193:                 )\n194:             })\n195:         }\n196:     }\n197:     .width(100.percent)\n198: }\n199: \n200: @Builder\n201: func buildRestaurantHeroImage(restaurant: RestaurantData) {\n202:     Image(restaurantMedia(restaurant.mediaName))\n203:         .width(100.percent)\n204:         .height(200)\n205:         .borderRadius(22)\n206: }\n207: \n208: @Builder\n209: func buildCartFab(onOpenCart: () -> Unit) {\n210:     Row {\n211:         Blank().layoutWeight(1)\n212:         Button(stringCart)\n213:             .backgroundColor(colorDarkGreen)\n214:             .fontColor(Color.White)\n215:             .onClick({ _ =>\n216:                 onOpenCart()\n217:             })\n218:     }\n219:     .width(100.percent)\n220: }\n221: \n222: @Builder\n223: public func renderDetailRoute(\n224:     state: DetailPageState,\n225:     onBack: () -> Unit,\n226:     onToggleLike: () -> Unit,\n227:     onShare: () -> Unit,\n228:     onToggleRecommended: () -> Unit,\n229:     onToggleNonVeg: () -> Unit,\n230:     onToggleVeg: () -> Unit,\n231:     onAdd: (DetailMenuItemData) -> Unit,\n232:     onRemove: (DetailMenuItemData) -> Unit,\n233:     onOpenCart: () -> Unit\n234: ) {\n235:     Scroll(Scroller()) {\n236:         Column(space: 16) {\n237:             buildDetailTopBar(state.isLiked, onBack, onToggleLike, onShare)\n238:             buildRestaurantHeroImage(state.restaurant)\n239:             buildRestaurantDetailCard(state.restaurant)\n240:             buildDetailSection(\n241:                 stringRecommended,\n242:                 state.recommendedExpanded,\n243:                 state.recommendedItems,\n244:                 onToggleRecommended,\n245:                 onAdd,\n246:                 onRemove\n247:             )\n248:             buildDetailSection(\n249:                 stringNonVegetarian,\n250:                 state.nonVegExpanded,\n251:                 detailStore.nonVegItems(state.menuItems),\n252:                 onToggleNonVeg,\n253:                 onAdd,\n254:                 onRemove\n255:             )\n256:             buildDetailSection(\n257:                 stringVegetarian,\n258:                 state.vegExpanded,\n259:                 detailStore.vegItems(state.menuItems),\n260:                 onToggleVeg,\n261:                 onAdd,\n262:                 onRemove\n263:             )\n264:             if (detailStore.shouldShowCartAction(state.menuItems)) {\n265:                 buildCartFab(onOpenCart)\n266:             }\n267:         }\n268:         .width(100.percent)\n269:         .padding(top: 14, right: 16, bottom: 24, left: 16)\n270:     }\