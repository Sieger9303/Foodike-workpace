oute\n92: }\n93: \n94: public func primaryActionTarget(route: String): String {\n95:     match (route) {\n96:         case \"onboarding\" => routePath(RouteId.Login)\n97:         case \"login_screen\" => routePath(RouteId.Home)\n98:         case \"home_screen\" => routePath(RouteId.RestaurantDetails)\n99:         case \"history\" => routePath(RouteId.Profile)\n100:         case \"cart\" => routePath(RouteId.Home)\n101:         case \"profile\" => routePath(RouteId.Onboarding)\n102:         case \"restaurant_details\" => routePath(RouteId.Home)\n103:         case _ => routePath(RouteId.Home)\n104:     }\n105: }\n106: \n107: public func primaryActionLabel(route: String): ResourceStr {\n108:     routeLabelByPath(primaryActionTarget(route))\n109: }\n110: \n111: public func primaryActionLabelText(route: String): String {\n112:     routeLabelTextByPath(primaryActionTarget(route))\n113: }\n\n(End of file - total 113 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\nimport ohos.base.ResourceStr\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{stringAppName, stringCart, stringHistory, stringHome, stringLogin, stringProfileTitle, stringRestaurant}\nimport std.collection.ArrayList\n\npublic enum RouteId {\n    | Onboarding\n    | Login\n    | Home\n    | History\n    | Cart\n    | Profile\n    | RestaurantDetails\n}\n\npublic enum ShellCommand {\n    | HomeTab\n    | HistoryTab\n    | CartAction","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\route_registry.cj","time":{"start":1782644844104,"end":1782644844108}},"id":"prt_f0de9a647001nYc3oJ54R427zO","sessionID":"ses_0f216e552ffekvSSMPwudetYAO","messageID":"msg_f0de97320001SYy0lz3HemXgib"}}
