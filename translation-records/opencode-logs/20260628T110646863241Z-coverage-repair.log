ohos_app_cangjie_entry/domain/discovery_models.cj\",\n77:         \"ohos_app_cangjie_entry/features/detail/detail_store.cj\"\n78:       ],\n79:       \"requiredBehaviors\": [\n80:         \"`FoodikeBootstrap.buildCartRoute` reloads `CartPageState` when the cart route renders, keeps note/coupon route state alive while the route is active, and preserves the source's single active-screen composition pattern without adding extra resume/pause hooks.\",\n81:         \"`buildCartRoute` reloads `CartPageState` from `CartStore`, `renderCartRoute` derives visible items through `cartStore.visibleItems(...)`, and quantity changes propagate through the shared session repository so cart contents and totals refresh immediately ac...\",\n82:         \"The translated cart store and route bootstrap preserve this permission-free state-loading flow.\",\n83:         \"`CartStore.loadCartState()` is invoked each time `FoodikeBootstrap.buildCartRoute` renders the cart route, preserving source entrypoint loading semantics without adding extra lifecycle phases.\",\n84:         \"`CartStore.loadCartState()` reads the shared session cart snapshot, and `FoodikeBootstrap.buildCartRoute` rerenders after cart mutations so translated cart state stays synchronized with session-backed quantity changes.\",\n85:         \"The HarmonyOS target keeps `MenuItem` as pure menu data through `MenuItemData`, then consumes that data from detail/cart stores and pages without placing navigation behavior inside the domain model layer.\",\n86:         \"The HarmonyOS target keeps the menu item model as data-only through `MenuItemData` and related detail/cart snapshot wrappers, with no permission handling placed in the domain model layer.\",\n87:         \"The HarmonyOS target keeps cart-page state data-only through `CartPageState`, with cart navigation owned by page/bootstrap builders rather than the state model.\",\n88:         \"`CartPageState` preserves the same data-only role in the HarmonyOS target without any permission path.\",\n89:         \"The HarmonyOS target preserves this role through `CartSnapshotItemData`, which is consumed by cart/detail stores and pages while keeping all route and toolbar behavior outside the domain model layer.\"\n90:       ],\n91:       \"acceptanceEvidence\": [\n92:         \"Replace broad endpoints with precise target functions, types, resources, or tests before closing the group.\"\n93:       ],\n94:       \"riskHints\": [\n95:         \"current evidence uses broad shell/root/whole-file endpoints\"\n96:       ],\n97:       \"matrixRows\": [\n98:         {\n99:           \"kind\": \"source-feature\",\n100:           \"featureId\": \"app-src-main-java-com-example-foodike-presentation-cart-9969033ff2-004-screen-lifecycle-entry-point-initializat\",\n101:           \"featureName\": \"Screen lifecycle, entry point initialization, resume/pause refresh, or teardown behavior.\",\n102:           \"sourcePath\": \"app/src/main/java/com/example/foodike/presentation/cart/Cart.kt\",\n103:           \"importance\": \"critical\",\n104:           \"plannedPhase\": \"phase-05-detail-cart\",\n105:           \"status\": \"implemented\",\n106:           \"parityLevel\": \"equivalent\",\n107:           \"verdict\": \"complete\",\n108:           \"reasons\": [\n109:             \"implemented with behavior, parity, endpoint, and verification evidence\"\n110:           ],\n111:           \"targetEndpoints\": [\n112:             \"entry/src/main/cangjie/ohos_app_cangjie_entry/app/bootstrap_page.cj::buildCartRoute\",\n113:             \"entry/src/main/cangjie/ohos_app_cangjie_entry/features/cart/cart_store.cj::loadCartState\",\n114:             \"entry/src/main/cangjie/ohos_app_cangjie_entry/features/cart/cart_page.cj::renderCartRoute\"\n115:           ],\n116:           \"tests\": []\n117:         },\n118:         {\n119:           \"kind\": \"source-feature\",\n120:           \"featureId\": \"app-src-main-java-com-example-foodike-presentation-cart-f1f520ab22-00