n76:             .height(120.dp)\n77:             .fillMaxWidth()\n78:             .padding(24.dp),\n79:         horizontalArrangement = Arrangement.SpaceBetween\n80:     ) {\n81: \n82: \n83:         Column(\n84:         ) {\n85:             Row(\n86:                 horizontalArrangement = Arrangement.Center,\n87:                 verticalAlignment = Alignment.CenterVertically\n88:             ) {\n89:                 if (menuItem.isVegetarian) {\n90:                     Image(\n91:                         modifier = Modifier.size(18.dp),\n92:                         painter = painterResource(id = R.drawable.ic_veg),\n93:                         contentDescription = stringResource(R.string.vegetarian)\n94:                     )\n95:                 } else {\n96:                     Image(\n97:                         modifier = Modifier.size(16.dp),\n98:                         painter = painterResource(id = R.drawable.ic_non_veg),\n99:                         contentDescription = stringResource(R.string.non_vegetarian)\n100:                     )\n101:                 }\n102:                 Spacer(modifier = Modifier.width(8.dp))\n103:                 Text(text = menuItem.dish)\n104:             }\n105: \n106:             Text(text = \"  $  ${menuItem.price}\", overflow = TextOverflow.Ellipsis)\n107:             Row {\n108:                 Icon(\n109:                     imageVector = Icons.Filled.Star,\n110:                     contentDescription = stringResource(id = R.string.rating),\n111:                     tint = Color(0xFFFF7A00)\n112:                 )\n113:                 Text(text = menuItem.rating.toString())\n114:                 Text(\n115:                     text = \" · \",\n116:                     fontSize = 16.sp,\n117:                     fontWeight = FontWeight.Bold,\n118:                 )\n119:                 Text(\n120:                     text = \"${menuItem.noOfRatings} ratings\",\n121:                 )\n122:             }\n123:         }\n124: \n125:         if (\n126:             state == 0\n127:         ) {\n128:             Column(\n129:                 modifier = Modifier\n130:                     .fillMaxHeight(),\n131:                 verticalArrangement = Arrangement.Center,\n132:                 horizontalAlignment = Alignment.CenterHorizontally\n133:             )\n134:             {\n135:                 Row {\n136:                     Text(\n137:                         text = stringResource(R.string.add),\n138:                         modifier = Modifier.clickable {\n139:                             state++\n140: \n141:                         },\n142:                         color = MaterialTheme.colors.primary,\n143:                         fontWeight = FontWeight.Bold\n144:                     )\n145:                     Spacer(modifier = Modifier.width(24.dp))\n146:                 }\n147:             }\n148:         } else {\n149:             Column(\n150:                 modifier = Modifier\n151:                     .fillMaxHeight(),\n152:                 verticalArrangement = Arrangement.Center,\n153:                 horizontalAlignment = Alignment.CenterHorizontally\n154:             ) {\n155:                 Surface(\n156:                     modifier = Modifier\n157: \n158:                         .border(\n159:                             BorderStroke(1.dp, Color.Black.copy(0.5f)),\n160:                             MaterialTheme.shapes.medium\n161:                         ),\n162:                     shape = MaterialTheme.shapes.medium,\n163:                     color = Color.White,\n164:                     contentColor = MaterialTheme.colors.primary\n165:                 ) {\n166:                     Row(\n167:                         modifier = Modifier.padding(4.dp),\n168:                         horizontalArrangement = Arrangement.Center,\n169:                         verticalAlignment = Alignment.CenterVertically\n170:                     ) {\n171: \n172:                         Icon(\n173:                             imageVector = Icons.Default.Remove,\n174:                             contentDescription = stringResource(R.string.subtract),\n175:                             modifier = Modifier\n176:                                 .padding(3.dp, 0.dp)\n177:                                 .size(20.dp)\n178:                                 .clickable {\n179:                                     state--\n180:                                 }\n181:                         )\n182: \n183:                         Text(text = state.toString())\n184: \n185:                         Icon(\n186:                             imageVector = Icons.Filled.Add,\n187:                             contentDescription = stringResource(R.string.add),\n188:                             modifier = Modifier\n189:                                 .padding(3.dp, 0.dp)\n190:                                 .size(20.dp)\n191:                                 .clickable {\n192:                                     state++\n193:                                 }\n194:                         )\n195: \n196: \n197:                     }\n198: \n199:                 }\n200:             }\n201:         }\n202:     }\n203: }\n\n(End of file - total 203 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\