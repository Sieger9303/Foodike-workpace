{"type":"tool_use","timestamp":1782578379215,"sessionID":"ses_0f60d3641ffeUjzsRShUMpCtKy","part":{"type":"tool","tool":"read","callID":"call_aDVm1981EtHr8NJmkbAXErW1","state":{"status":"completed","input":{"filePath":"D:\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\util\\Navigation.kt","limit":280,"offset":1},"output":"<path>D:\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\util\\Navigation.kt</path>\n<type>file</type>\n<content>\n1: /**\n2:  *\n3:  *\tMIT License\n4:  *\n5:  *\tCopyright (c) 2026 Gautam Hazarika\n6:  *\n7:  *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n8:  *\tof this software and associated documentation files (the \"Software\"), to deal\n9:  *\tin the Software without restriction, including without limitation the rights\n10:  *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n11:  *\tcopies of the Software, and to permit persons to whom the Software is\n12:  *\tfurnished to do so, subject to the following conditions:\n13:  *\n14:  *\tThe above copyright notice and this permission notice shall be included in all\n15:  *\tcopies or substantial portions of the Software.\n16:  *\n17:  *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n18:  *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n19:  *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n20:  *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER\n21:  *\tLIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,\n22:  *\tOUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE\n23:  *\tSOFTWARE.\n24:  *\n25:  **/\n26: \n27: package com.example.foodike.presentation.util\n28: \n29: import android.annotation.SuppressLint\n30: import androidx.compose.foundation.layout.*\n31: import androidx.compose.foundation.lazy.LazyListState\n32: import androidx.compose.foundation.lazy.rememberLazyListState\n33: import androidx.compose.material.*\n34: import androidx.compose.material.icons.Icons\n35: import androidx.compose.material.icons.filled.Home\n36: import androidx.compose.material.icons.outlined.ShoppingCart\n37: import androidx.compose.runtime.Composable\n38: import androidx.compose.runtime.derivedStateOf\n39: import androidx.compose.runtime.getValue\n40: import androidx.compose.runtime.remember\n41: import androidx.compose.ui.Alignment\n42: import androidx.compose.ui.Modifier\n43: import androidx.compose.ui.graphics.Color\n44: import androidx.compose.ui.res.painterResource\n45: import androidx.compose.ui.res.stringResource\n46: import androidx.compose.ui.unit.dp\n47: import androidx.navigation.NavGraph.Companion.findStartDestination\n48: import androidx.navigation.NavHostController\n49: import androidx.navigation.compose.NavHost\n50: import androidx.navigation.compose.composable\n51: import androidx.navigation.compose.currentBackStackEntryAsState\n52: import androidx.navigation.compose.rememberNavController\n53: import com.example.foodike.presentation.cart.Cart\n54: import com.example.foodike.presentation.details.RestaurantDetail\n55: import com.example.foodike.presentation.history.History\n56: import com.example.foodike.presentation.home.Home\n57: import com.example.foodike.presentation.home.components.FoodikeBottomNavigation\n58: import com.example.foodike.presentation.login.LoginScreen\n59: import com.example.foodike.presentation.onboarding.OnBoarding\n60: import com.example.foodike.presentation.profile.Profile\n61: import com.google.accompanist.pager.ExperimentalPagerApi\n62: \n63: \n64: @OptIn(ExperimentalPagerApi::class)\n65: @Composable\n66: fun NavigationGraph(\n67:     navController: NavHostController,\n68:     startDestination: String,\n69:     scrollState: LazyListState\n70: ) {\n71: \n72:     NavHost(\n73:         navController = navController,\n74:         startDestination = startDestination\n75:     ) {\n76:         composable(\n77:             route = Screen.Onboarding.route,\n78:         ) {\n79:             OnBoarding(navController = navController)\n80:         }\n81:         composable(\n82:             route = Screen.LoginScreen.route,\n83:         ) {\n84:             LoginScreen(navController = navController)\n85:         }\n86: \n87:         composable(\n88:             route = Screen.Home.route\n89:         ) {\n90:             Home(navController = navController, scrollState = scrollState)\n91:         }\n92:         composable(\n93:             route = Screen.History.route\n94:         ) {\n95:             History(navHostController = navController)\n96:         }\n97:         composable(\n98:             route = Screen.Cart.route\n99:         ) {\n100:             Cart(navController = navController)\n101:         }\n102:         composable(\n103:             route = Screen.Profile.route\n104:         ) {\n105:             Profile(navController = navController)\n106:         }\n107: \n108:         composable(\n109:             route = Screen.Onboarding.route,\n110:         ) {\n111:             OnBoarding(navController = navController)\n112:         }\n113:         composable(\n114:             route = Screen.RestaurantDetails.route,\n115:         ) {\n116:             RestaurantDetail(\n117:                 navController = navController\n118:             )\n119:         }\n120:     }\n121: \n122: }\n123: \n124: @SuppressLint(\"UnusedMaterialScaffoldPaddingParameter\")\n125: @Composable\n126: fun SetupNavigation(startDestination: String) {\n127: \n128:     val navController = rememberNavController()\n129: \n130: \n131:     val navBackStackEntry by navController.currentBackStackEntryAsState()\n132:     val currentRoute = navBackStackEntry?.destination?.route\n133: \n134: \n135:     val scrollState = rememberLazyListState()\n136:     val state by remember { derivedStateOf { scrollState.firstVisibleItemIndex == 0 } }\n137: \n138: \n139:     Scaffold(\n140:         bottomBar = {\n141:             if ((currentRoute == Screen.Home.route || currentRoute == Screen.History.route) && state) {\n142: \n143:                 Column(\n144:                     modifier = Modifier.padding(115.dp, 25.dp),\n145:                     horizontalAlignment = Alignment.CenterHorizontally\n146:                 ) {\n147: \n148:                     Box(\n149:                         contentAlignment = Alignment.Center\n150:                     ) {\n151:                         BottomBar(navController = navController)\n152:                         Column {\n153:                             FloatingActionButton(\n154:                                 onClick = {\n155:                                     navController.navigate(Screen.Cart.route)\n156: \n157:                                 },\n158:                                 backgroundColor = MaterialTheme.colors.primary\n159:                             ) {\n160:                                 Icon(Icons.Outlined.ShoppingCart, \"Cart\")\n161:                             }\n162:                             Spacer(modifier = Modifier.height(26.dp))\n163:                         }\n164:                     }\n165:                 }\n166:             }\n167:         }\n168:     ) {\n169:         NavigationGraph(\n170:             navController = navController,\n171:             scrollState = scrollState,\n172:             startDestination = startDestination\n173:         )\n174:     }\n175: }\n176: \n177: \n178: @Composable\n179: fun BottomBar(navController: NavHostController) {\n180:     val navBackStackEntry by navController.currentBackStackEntryAsState()\n181:     val currentRoute = navBackStackEntry?.destination?.route\n182: \n183:     FoodikeBottomNavigation(\n184:         backgroundColor = Color(0xFFE1E1E1)\n185: \n186:     ) {\n187:         BottomNavigationItem(\n188:             icon =\n189:             {\n190:                 Icon(\n191:                     imageVector = Icons.Filled.Home,\n192:                     contentDescription = stringResource(com.example.foodike.R.string.home),\n193:                 )\n194:             },\n195: \n196:             selectedContentColor = Color.Black,\n197:             unselectedContentColor = Color.White,\n198:             alwaysShowLabel = false,\n199:             selected = currentRoute == Screen.Home.route,\n200: \n201:             onClick = {\n202:                 navController.navigate(Screen.Home.route) {\n203:                     // Pop up to the start destination of the graph to\n204:                     // avoid building up a large stack of destinations\n205:                     // on the back stack as users select items\n206:                     popUpTo(navController.graph.findStartDestination().id) {\n207:                         saveState = true\n208:                     }\n209:                     // Avoid multiple copies of the same destination when\n210:                     // reselecting the same item\n211:                     launchSingleTop = true\n212:                     // Restore state when reselecting a previously selected item\n213:                     restoreState = true\n214:                 }\n215:             }\n216:         )\n217: \n218:         Row() {\n219:             Spacer(modifier = Modifier.width(56.dp))\n220:         }\n221: \n222: \n223:         BottomNavigationItem(\n224:             icon =\n225:             {\n226:                 Icon(\n227:                     painter = painterResource(com.example.foodike.R.drawable.ic_baseline_assignment_24),\n228:                     contentDescription = stringResource(com.example.foodike.R.string.history),\n229:                 )\n230:             },\n231: \n232:             selectedContentColor = Color.Black,\n233:             unselectedContentColor = Color.White,\n234:             alwaysShowLabel = false,\n235:             selected = currentRoute == Screen.History.route,\n236:             onClick = {\n237:                 navController.navigate(Screen.History.route) {\n238:                     // Pop up to the start destination of the graph to\n239:                     // avoid building up a large stack of destinations\n240:                     // on the back stack as users select items\n241:                     popUpTo(navController.graph.findStartDestination().id) {\n242:                         saveState = true\n243:                     }\n244:                     // Avoid multiple copies of the same destination when\n245:                     // reselecting the same item\n246:                     launchSingleTop = true\n247:                     // Restore state when reselecting a previously selected item\n248:                     restoreState = true\n249:                 }\n250:             }\n251:         )\n252: \n253:     }\n254: \n255: }\n\n(End of file - total 255 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER","truncated":false,"loaded":[]},"title":"..\\..\\Kotlin2Cangj