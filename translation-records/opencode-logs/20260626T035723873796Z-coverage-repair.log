\n241:           \"path\": \"C:\\\\Program Files\\\\Huawei\\\\DevEco Studio\\\\sdk\\\\default\\\\hms\\\\native\",\n242:           \"exists\": false,\n243:           \"valid\": false\n244:         },\n245:         {\n246:           \"path\": \"\\\\opt\\\\DevEco-Studio\\\\sdk\\\\default\\\\openharmony\\\\native\",\n247:           \"exists\": false,\n248:           \"valid\": false\n249:         },\n250:         {\n251:           \"path\": \"\\\\opt\\\\DevEco-Studio\\\\sdk\\\\default\\\\hms\\\\native\",\n252:           \"exists\": false,\n253:           \"valid\": false\n254:         }\n255:       ]\n256:     },\n257:     \"hostSdk\": {\n258:       \"selectedPath\": \"\",\n259:       \"candidates\": [],\n260:       \"source\": \"not-darwin\"\n\n(Showing lines 1-260 of 796. Use offset=261 to continue.)\n</content>","metadata":{"preview":"{\n  \"schemaVersion\": 1,\n  \"generatedAt\": \"2026-06-26T03:49:44+00:00\",\n  \"phase\": \"phase-06-polish-tests-verification\",\n  \"workspaceRoot\": \"D:\\\\workspace\\\\Foodike\",\n  \"targetProject\": \"D:\\\\workspace\\\\Foodike\\\\Foodike-Harmony\",\n  \"outputDir\": \"D:\\\\workspace\\\\Foodike\\\\translation-inputs\",\n  \"reportDir\": \"D:\\\\workspace\\\\Foodike\\\\translation-inputs\\\\test-build-reports\\\\phase-06-polish-tests-verification\",\n  \"markdownPath\": \"D:\\\\workspace\\\\Foodike\\\\translation-inputs\\\\test-build-reports\\\\phase-06-polish-tests-verification\\\\test-build-report.md\",\n  \"jsonPath\": \"D:\\\\workspace\\\\Foodike\\\\translation-inputs\\\\test-build-reports\\\\phase-06-polish-tests-verification\\\\test-build-report.json\",\n  \"logPath\": \"D:\\\\workspace\\\\Foodike\\\\translation-inputs\\\\test-build-reports\\\\phase-06-polish-tests-verification\\\\test-build.log\",\n  \"platform\": {\n    \"osName\": \"nt\",\n    \"sysPlatform\": \"win32\",\n    \"pathSeparator\": \";\"\n  },\n  \"target\": \"aarch64-linux-ohos\",\n  \"result\": \"TEST_COMPILE_FAIL\",\n  \"recommendedOwner\": \"opencode-c