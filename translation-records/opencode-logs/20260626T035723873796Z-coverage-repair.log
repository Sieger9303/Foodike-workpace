:             case Some(found) => found\n81:             case None => contentRepository.getRestaurants()[0]\n82:         }\n83:         store.session().setSelectedRestaurant(restaurant)\n84: \n85:         let state = store.loadDetailState(true, true, true)\n86:         let nonVegItems = store.nonVegItems(state.menuItems)\n87:         let vegItems = store.vegItems(state.menuItems)\n88:         @Assert(nonVegItems.size, 4)\n89:         @Assert(vegItems.size, 4)\n90:         @Assert(store.shouldShowCartAction(state.menuItems), false)\n91: \n92:         store.incrementQuantity(state.menuItems[0])\n93:         @Assert(store.shouldShowCartAction(state.menuItems), true)\n94:         @Assert(store.totalSelectedItems(state.menuItems), 1)\n95:         store.decrementQuantity(state.menuItems[0])\n96:         @Assert(store.totalSelectedItems(state.menuItems), 0)\n97:     }\n98: \n99:     @TestCase\n100:     public func detailStoreTogglesLikedStateForSelectedRestaurant(): Unit {\n101:         let store = DetailStore()\n102:         let contentRepository = HomeContentRepository()\n103:         let restaurant = match (contentRepository.getRestaurantByName(\"Relish\")) {\n104:             case Some(found) => found\n105:             case None => contentRepository.getRestaurants()[0]\n106:         }\n107: \n108:         store.session().setRestaurantLiked(restaurant, false)\n109:         let liked = store.toggleLiked(restaurant, false)\n110:         @Assert(liked, true)\n111:         @Assert(store.session().isRestaurantLiked(restaurant), true)\n112:         let unliked = store.toggleLiked(restaurant, true)\n113:         @Assert(unliked, false)\n114:     }\n115: }\n\n(End of file - total 115 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.DetailStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie