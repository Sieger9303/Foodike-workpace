edExpanded = !this.detailRecommendedExpanded\n341:             },\n342:             { =>\n343:                 this.detailNonVegExpanded = !this.detailNonVegExpanded\n344:             },\n345:             { =>\n346:                 this.detailVegExpanded = !this.detailVegExpanded\n347:             },\n348:             { item: DetailMenuItemData =>\n349:                 detailStore.incrementQuantity(item)\n350:                 this.detailMutationRevision += 1\n351:             },\n352:             { item: DetailMenuItemData =>\n353:                 detailStore.decrementQuantity(item)\n354:                 this.detailMutationRevision += 1\n355:             },\n356:             { =>\n357:                 this.navigateTo(routePath(RouteId.Cart))\n358:             }\n359:         )\n360:     }\n361: \n362:     @Builder\n363:     private func buildPlaceholderRoute() {\n364:         Column(space: 18) {\n365:             Text(\"Foodike\")\n366:                 .fontSize(42)\n367:                 .fontWeight(FontWeight.Bold)\n368:             Text(this.routeTitle(this.currentRoute))\n369:                 .fontSize(28)\n370:             Text(this.routeSummary(this.currentRoute))\n371:                 .fontSize(16)\n372:                 .textAlign(TextAlign.Center)\n373:                 .width(86.percent)\n374: \n375:             if (this.currentRoute == routePath(RouteId.Home) || this.currentRoute == routePath(RouteId.History)) {\n376:                 Button(if (this.isShellAtTop) { \"Simulate Scrolled Content\" } else { \"Return To Top\" })\n377:                     .onClick({ _ =>\n378:                         let shellState = this.shellState()\n379:                         shellState.setTopState(!shellState.isAtTop)\n380:                         this.applyShellState(shellState)\n381:                     })\n382:             }\n383: \n384:             Button(\"Primary Route Action\")\n385:                 .onClick({ _ =>\n386:                     this.applyShellCommand(ShellCommand.PrimaryAction)\n387:                 })\n388: \n389:             if (this.showBottomShell(this.currentRoute)) {\n390:                 Row(space: 12) {\n391:                     Button(\"Home Tab\")\n392:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HomeTab) })\n393:                     Button(\"Cart\")\n394:                         .onClick({ _ => this.applyShellCommand(ShellCommand.CartAction) })\n395:                     Button(\"History Tab\")\n396:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HistoryTab) })\n397:                 }\n398:             }\n399:         }\n400:         .width(100.percent)\n401:         .height(100.percent)\n402:         .justifyContent(FlexAlign.Center)\n403:         .alignItems(HorizontalAlign.Center)\n404:         .padding(top: 24, right: 24, bottom: 24, left: 24)\n405:     }\n406: \n407:     func build() {\n408:         if (this.currentRoute == routePath(RouteId.Onboarding)) {\n409:             this.buildOnboardingRoute()\n410:         } else if (this.currentRoute == routePath(RouteId.Login)) {\n411:             this.buildLoginRoute()\n412:         } else if (this.currentRoute == routePath(RouteId.Home)) {\n413:             this.buildHomeRoute()\n414:         } else if (this.currentRoute == routePath(RouteId.History)) {\n415:             this.buildHistoryRoute()\n416:         } else if (this.currentRoute == routePath(RouteId.Cart)) {\n417:             this.buildCartRoute()\n418:         } else if (this.currentRoute == routePath(RouteId.RestaurantDetails)) {\n419:             this.buildDetailRoute()\n420:         } else if (this.currentRoute == routePath(RouteId.Profile)) {\n421:             this.buildProfileRoute()\n422:         } else {\n423:             this.buildPlaceholderRoute()\n424:         }\n425:     }\n426: }\n\n(End of file - total 426 lines)\n</content>","metadata":{"preview":"    private func buildCartRoute() {\n        renderCartRoute(\n           