out.Arrangement\n31: import androidx.compose.foundation.layout.Column\n32: import androidx.compose.foundation.layout.Row\n33: import androidx.compose.foundation.layout.Spacer\n34: import androidx.compose.foundation.layout.fillMaxHeight\n35: import androidx.compose.foundation.layout.fillMaxWidth\n36: import androidx.compose.foundation.layout.height\n37: import androidx.compose.foundation.layout.padding\n38: import androidx.compose.foundation.layout.size\n39: import androidx.compose.foundation.layout.width\n40: import androidx.compose.foundation.shape.RoundedCornerShape\n41: import androidx.compose.material.Card\n42: import androidx.compose.material.Text\n43: import androidx.compose.runtime.Composable\n44: import androidx.compose.ui.Alignment\n45: import androidx.compose.ui.Modifier\n46: import androidx.compose.ui.draw.alpha\n47: import androidx.compose.ui.graphics.Color\n48: import androidx.compose.ui.res.painterResource\n49: import androidx.compose.ui.res.stringResource\n50: import androidx.compose.ui.text.font.FontWeight\n51: import androidx.compose.ui.text.style.TextOverflow\n52: import androidx.compose.ui.unit.dp\n53: import androidx.compose.ui.unit.sp\n54: import com.example.foodike.R\n55: import com.example.foodike.domain.model.Restaurant\n56: import com.example.foodike.presentation.common.getTimeInMins\n57: import com.example.foodike.presentation.components.getCustomerInfo\n58: \n59: \n60: @Composable\n61: fun RestaurantDetailCard(\n62:     restaurant: Restaurant\n63: ) {\n64:     Card(\n65:         modifier = Modifier\n66:             .fillMaxWidth()\n67:             .height(250.dp),\n68:         shape = RoundedCornerShape(15.dp),\n69:         backgroundColor = Color(0xFFC6FDB3)\n70:     ) {\n71:         Column(\n72:             modifier = Modifier.padding(24.dp),\n73:         ) {\n74:             Text(\n75:                 text = restaurant.name,\n76:                 fontWeight = FontWeight.Bold,\n77:                 fontSize = 24.sp\n78:             )\n79:             Row(\n80:                 horizontalArrangement = Arrangement.Center,\n81:                 verticalAlignment = Alignment.CenterVertically\n82:             ) {\n83:                 Image(\n84:                     painter = painterResource(id = R.drawable.star),\n85:                     contentDescription = stringResource(R.string.rating),\n86:                     modifier = Modifier\n87:                         .size(20.dp)\n88:                 )\n89:                 Spacer(modifier = Modifier.width(2.dp))\n90: \n91:                 Text(text = \"${restaurant.rating}(${getCustomerInfo(restaurant.noOfRatings)}) \")\n92:                 Text(\n93:                     text = \"·\",\n94:                     fontSize = 16.sp,\n95:                     fontWeight = FontWeight.Bold,\n96:                 )\n97:                 Text(text = restaurant.timeInMillis.getTimeInMins())\n98:                 Text(\n99:                     text = \"·\",\n100:                     fontSize = 16.sp,\n101:                     fontWeight = FontWeight.Bold,\n102:                 )\n103:                 Text(text = \" $${restaurant.averagePrice} \")\n104: \n105:             }\n106:             Text(\n107:                 text = restaurant.variety,\n108:                 modifier = Modifier.alpha(0.5f),\n109:                 overflow = TextOverflow.Ellipsis,\n110:                 maxLines = 1\n111:             )\n112:             Text(\n113:                 text = restaurant.place,\n114:                 modifier = Modifier.alpha(0.5f),\n115:             )\n116: \n117:             Row(\n118:                 modifier = Modifier.padding(0.dp, 24.dp),\n119:                 verticalAlignment = Alignment.CenterVertically,\n120:                 horizontalArrangement = Arrangement.Center\n121:             ) {\n122:                 Image(\n123:                     modifier = Modifier.size(50.dp),\n124:                     painter = painterResource(id = R.drawable.outlet_card),\n125:                     contentDescription = stringResource(R.string.outlet),\n126:                 )\n127:                 Column(\n128:                     modifier = Modifier.fillMaxHeight(),\n129:                     verticalArrangement = Arrangement.SpaceBetween\n130:                 ) {\n131:                     Row {\n132:                         Text(\n133:                             text = stringResource(R.string.outlet_2),\n134:                             fontSize = 16.sp\n135:                         )\n136:                     }\n137:                     Row {\n138:                         Text(text = restaurant.timeInMillis.getTimeInMins())\n139:                     }\n140:                 }\n141:                 Spacer(modifier = Modifier.width(24.dp))\n142:                 Column(\n143:                     modifier = Modifier.fillMaxHeight(),\n144:                     verticalArrangement = Arrangement.SpaceBetween,\n145:                     horizontalAlignment = Alignment.Start\n146:                 ) {\n147:                     Row {\n148:                         Text(\n149:                             text = restaurant.place, modifier = Modifier.alpha(0.5f),\n150:                         )\n151:                     }\n152:                     Row {\n153:                         Text(\n154:                             text = stringResource(R.string.your_location),\n155:                             modifier = Modifier.alpha(0.5f),\n156:                         )\n157:                     }\n158:                 }\n159:             }\n160:         }\n161:     }\n162: }\n\n(End of file - total 162 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto