         \"preserveActive\": True,\n648:             \"reason\": \"row was added through structured authority patch\",\n649:         },\n650:         \"riskTags\": [],\n651:         \"keyClasses\": [],\n652:         \"keyMethods\": [],\n653:         \"androidIds\": [],\n654:         \"dependencies\": [],\n655:         \"featurePoint\": \"\",\n656:         \"category\": \"\",\n657:         COVERAGE_FACTS_KEY: default_coverage_facts(),\n658:     }\n659:     return {**defaults, **entry}\n660: \n661: \n662: def platform_defaulted_addition(entry: dict[str, Any]) -> dict[str, Any]:\n663:     defaults: dict[str, Any] = {\n664:         \"status\": \"planned\",\n665:         \"plannedPhase\": \"\",\n666:         \"sourcePaths\": [],\n667:         \"sourceEvidence\": [],\n668:         \"requiredTargetCapabilitySearch\": [],\n669:         \"targetStrategyHint\": \"\",\n670:         \"minimumParity\": \"\",\n671:         \"requiredTests\": [],\n672:         \"allowedDeferredReasons\": [],\n673:         \"targetCapabilitySearch\": [],\n674:         \"targetApiOrLibrary\": \"\",\n675:         \"targetStrategy\": \"\",\n676:         \"targetEndpoints\": [],\n677:         \"tests\": [],\n678:         \"sdkDeclarationEvidence\": [],\n679:         \"cangjieCallableEvidence\": [],\n680:         \"discoveryOnlyEvidence\": [],\n681:         \"compileProbeEvidence\": [],\n682:         \"preResolutionDecision\": \"\",\n683:         \"phaseCapabilityResolution\": \"\",\n684:         \"blocker\": \"\",\n685:         \"targetFallback\": \"\",\n686:         \"futureCompletionPath\": \"\",\n687:         \"notes\": \"\",\n688:         CAPABILITY_FACTS_KEY: default_capability_facts(),\n689:     }\n690:     return {**defaults, **entry}\n691: \n692: \n693: def validate_addition(kind: str, addition: Any) -> dict[str, Any]:\n694:     if not isinstance(addition, dict):\n695:         raise PatchError(\"Every addition must be an object.\")\n696:     required = MATRIX_ADD_REQUIRED_FIELDS if kind == \"matrix\" else PLATFORM_ADD_REQUIRED_FIELDS\n697:     missing = [field for field in sorted(required) if not has_text_or_list(addition.get(field))]\n698:     if missing:\n699:         raise PatchError(f\"Addition is missing required field(s): {', '.join(missing)}.\")\n700:     normalized = {\n701:         field: validate_field_value(kind, field, value, add_entry=True)\n702:         for field, value in addition.items()\n703:     }\n704:     return matrix_defaulted_addition(normalized) if kind == \"matrix\" else platform_defaulted_addition(normalized)\n705: \n706: \n707: def matrix_parity_errors(entry: dict[str, Any]) -> list[str]:\n708:     status = effective_matrix_status(entry)\n709:     parity = parity_level(entry)\n710:     if status == \"implemented\" and parity != \"equivalent\":\n711:         return [\"implemented rows must use parityLevel `equivalent`.\"]\n712:     if status == \"implemented-simplified\" and parity != \"simplified\":\n713:         return [\"implemented-simplified rows must use parityLevel `simplified`.\"]\n714:     if status == \"platform-replaced\" and parity != \"platform-replaced\":\n715:         return [\"platform-replaced rows must use parityLevel `platform-replaced`.\"]\n716:     if status == \"deferred\" and parity != \"deferred\":\n717:         return [\"deferred rows must use parityLevel `deferred`.\"]\n718:     if status == \"not-applicable\" and parity not in {\"not-applicable\", \"unverified\", \"\"}:\n719:         return [\"not-applicable rows must use parityLevel `not-applicable`, `unverified`, or empty.\"]\n720:     return []\n721: \n722: \n723: def validate_matrix_entry(entry: dict[str, Any]) -> list[str]:\n724:     problems: list[str] = []\n725:     feature_id = str(entry.get(\"featureId\") or \"\").strip()\n726:     raw_status = str(entry.get(\"status\") or \"\").strip().lower()\n727:     importance = str(entry.get(\"importance\") or \"\").strip().lower()\n728:     coverage_fact_value = entry.get(COVERAGE_FACTS_KEY)\n729:     if coverage_fact_value is not None:\n730:         strict = isinstance(coverage_fact_value, dict) and coverage_fact_value.get(\"factsSource\") == \"agent\"\n731:         problems.extend(validate_coverage_facts(coverage_fact_value, strict=strict))\n732:     if not feature_id:\n733:         problems.append(\"missing featureId\")\n734:     if raw_status not in MATRIX_STATUSES:\n735:         problems.append(f\"invalid status `{raw_status}`\")\n736:     parity = str(entry.get(\"parityLevel\") or \"\").strip().lower()\n737:     if parity not in MATRIX_PARITY_LEVELS:\n738:         problems.append(f\"invalid parityLevel `{parity}`\")\n739:     problems.extend(matrix_parity_errors(entry))\n740: \n741:     important = importance in {\"critical\", \"high\"}\n742:     status = effective_matrix_status(entry)\n743:     if important and status in MATRIX_IMPLEMENTED_STATUSES:\n744:         if not has_source_behavior_evidence(entry):\n745:             problems.append(\"closed critical/high rows require sourceBehavior or sourceEvidence\")\n746:         if not has_target_behavior_evidence(entry):\n747:             problems.append(\"closed critical/high rows require targetBehavior\")\n748:         if not coverage_verification_evidence_items(entry, include_tests=True):\n749:             problems.append(\"closed critical/high rows require verificationEvidence or tests\")\n750:         if not coverage_target_endpoints(entry) and not has_text_or_list(entry.get(\"tests\")):\n751:             problems.append(\"closed critical/high rows require targetEndpoints or tests\")\n752:     if important and status == \"implemented-simplified\":\n753:         if not has_text(entry.get(\"notes\")) and not has_text(entry.get(\"targetFallback\")):\n754:             problems.append(\"implemented-simplified critical/high rows require notes or targetFallback\")\n755:     if important and status == \"deferred\":\n756:         missing = [field for field in MATRIX_DEFERRED_REQUIRED_FIELDS if not has_text_or_list(entry.get(field))]\n757:         if missing:\n758:             problems.append(\"deferred critical/high rows missing \" + \", \".join(missing))\n759:     if important and status == \"not-applicable\" and not has_text(entry.get(\"notes\")):\n760:         problems.append(\"not-applicable critical/high rows require notes\")\n761:     return problems\n762: \n763: \n764: def validate_platform_entry(entry: dict[str, Any]) -> list[str]:\n765:     problems: list[str] = []\n766:     capability_id = str(entry.get(\"capabilityId\") or \"\").strip()\n767:     raw_status = str(entry.get(\"status\") or \"\").strip().lower()\n768:     importance = str(entry.get(\"importance\") or \"\").strip().lower()\n769:     capability_fact_value = entry.get(CAPABILITY_FACTS_KEY)\n770:     if capability_fact_value is not None:\n771:         strict = isinstance(capability_fact_value, dict) and capability_fact_value.get(\"factsSource\") == \"agent\"\n772:         problems.extend(validate_capability_facts(capability_fact_value, strict=strict))\n773:     if not capability_id:\n774:         problems.append(\"missing capabilityId\")\n775:     if raw_status not in PLATFORM_CAPABILITY_STATUSES:\n776:         problems.append(f\"invalid status `{raw_status}`\")\n777: \n778:     important = importance in {\"critical\", \"high\"}\n779:     status = effective_capability_status(entry)\n780:     if important and (status in PLATFORM_CAPABILITY_IMPLEMENTED_STATUSES or status == \"deferred\"):\n781:         if not (\n782:             has_text_or_list(entry.get(\"targetCapabilitySearch\"))\n783:             or has_replacement_api_evidence(entry)\n784:             or has_direct_unavailable_blocker(entry)\n785:         ):\n786:             problems.append(\"resolved/deferred critical/high capabilities require targetCapabilitySearch\")\n787:     if important and status in PLATFORM_CAPABILITY_IMPLEMENTED_STATUSES:\n788:         if not has_replacement_api_evidence(entry) and not has_text_or_list(entry.get(\"targetApiOrLibrary\")):\n789:             problems.append(\"implemented critical/high capabilities require targetApiOrLibrary\")\n790:         if not has_replacement_api_evidence(entry) and not has_text(entry.get(\"targetStrategy\")):\n791:             problems.append(\"implemented critical/high capabilities require targetStrategy\")\n792:         if status in {\"verified-direct\", \"platform-replaced\"} and not capability_target_endpoints(entry):\n793:             problems.append(\"verified-direct/platform-replaced critical/high capabilities require targetEndpoints\")\n794:         if not has_text_or_list(entry.get(\"tests\")) and not has_text(entry.get(\"notes\")) and not has_compile_probe_evidence(entry):\n795:             problems.append(\"implemented critical/high capabilities require tests or notes\")\n796:     if important and status == \"deferred\":\n797:         missing = platform_missing_deferred_fields(entry)\n798:         if missing:\n799:             problems.append(\"deferred critical/high capabilities missing \" + \", \".join(missing))\n\n(Showing lines 580-799 of 973. Use offset=800 to continue.)\n</content>","metadata":{"preview":"    allowed_ops = {\"featureId\", \"capabilityId\", \"set\", \"append\", \"remove\", \"unset\"}\n    unknown = sorted(set(update) - allowed_ops)\n    if unknown:\n        raise PatchError(f\"Update for `{entry.get(entry_id_field(kind), '')}` has unknown operation field(s): {', '.join(unknown)}.\")\n\n    set_values = ensure_object(update.get(\"set\"), \"set\")\n    append_values = ensure_object(update.get(\"append\"), \"append\")\n    remove_values = ensure_object(update.get(\"remove\"), \"remove\")\n    unset_fields = ensure_list(update.get(\"unset\"), \"unset\")\n    _, _, list_fields, text_fields = field_sets(kind)\n\n    for field, value in set_values.items():\n        entry[field] = validate_field_value(kind, field, value)\n\n    for field, values in append_values.items():\n        if field not in list_fields:\n            raise