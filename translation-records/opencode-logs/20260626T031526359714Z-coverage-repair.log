5:         let firstItem = state.items[0]\n36: \n37:         @Assert(firstItem.quantity, 1)\n38:         store.incrementQuantity(firstItem)\n39:         @Assert(firstItem.quantity, 2)\n40:         store.decrementQuantity(firstItem)\n41:         @Assert(firstItem.quantity, 1)\n42:         store.decrementQuantity(firstItem)\n43:         @Assert(firstItem.quantity, 0)\n44:         store.decrementQuantity(firstItem)\n45:         @Assert(firstItem.quantity, 0)\n46:     }\n47: \n48:     @TestCase\n49:     public func cartStoreKeepsSourceDeliveryPlaceholders(): Unit {\n50:         let store = CartStore()\n51:         let state = store.loadCartState()\n52:         @Assert(state.deliveryRestaurant.name, \"Relish\")\n53:         @Assert(store.deliveryLocation(), \"Guwahati\")\n54:         @Assert(store.formatEta(state.deliveryRestaurant.etaMinutes), \"30 Min\")\n55:     }\n56: \n57:     @TestCase\n58:     public func detailStoreLoadsSelectedRestaurantAndRecommendedMenuSlice(): Unit {\n59:         let store = DetailStore()\n60:         let contentRepository = HomeContentRepository()\n61:         let restaurant = match (contentRepository.getRestaurantByName(\"Relish\")) {\n62:             case Some(found) => found\n63:             case None => contentRepository.getRestaurants()[0]\n64:         }\n65:         store.session().setSelectedRestaurant(restaurant)\n66: \n67:         let state = store.loadDetailState(true, true, true)\n68:         @Assert(state.restaurant.name, \"Relish\")\n69:         @Assert(state.recommendedItems.size, 5)\n70:         @Assert(state.recommendedItems[0].menuItem.dish, \"Masala Dosa\")\n71:     }\n72: \n73:     @TestCase\n74:     public func detailStorePreservesSectionFilteringAndCartVisibilityRules(): Unit {\n75:         let store = DetailStore()\n76:         let contentRepository = HomeContentRepository()\n77:         let restaurant = match (contentRepository.getRestaurantByName(\"George Street\")) {\n78:             case Some(found) => found\n79:             case None => contentRepository.getRestaurants()[0]\n80:         }\n81:         store.session().setSelectedRestaurant(restaurant)\n82: \n83:         let state = store.loadDetailState(true, true, true)\n84:         let nonVegItems = store.nonVegItems(state.menuItems)\n85:         let vegItems = store.vegItems(state.menuItems)\n86:         @Assert(nonVegItems.size, 4)\n87:         @Assert(vegItems.size, 4)\n88:         @Assert(store.shouldShowCartAction(state.menuItems), false)\n89: \n90:         store.incrementQuantity(state.menuItems[0])\n91:         @Assert(store.shouldShowCartAction(state.menuItems), true)\n92:         @Assert(store.totalSelectedItems(state.menuItems), 1)\n93:         store.decrementQuantity(state.menuItems[0])\n94:         @Assert(store.totalSelectedItems(state.menuItems), 0)\n95:     }\n96: \n97:     @TestCase\n98:     public func detailStoreTogglesLikedStateForSelectedRestaurant(): Unit {\n99:         let store = DetailStore()\n100:         let contentRepository = HomeContentRepository()\n101:         let restaurant = match (contentRepository.getRestaurantByName(\"Relish\")) {\n102:             case Some(found) => found\n103:             case None => contentRepository.getRestaurants()[0]\n104:         }\n105: \n106:         store.session().setRestaurantLiked(restaurant, false)\n107:         let liked = store.toggleLiked(restaurant, false)\n108:         @Assert(liked, true)\n109:         @Assert(store.session().isRestaurantLiked(restaurant), true)\n110:         let unliked = store.toggleLiked(restaurant, true)\n111:         @Assert(unliked, false)\n112:     }\n113: }\n\n(End of file - total 113 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.DetailStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.CartStore\nimport std.unitte