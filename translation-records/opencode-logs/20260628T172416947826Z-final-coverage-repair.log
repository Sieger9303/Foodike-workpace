onent\n23: class FoodikeBootstrap {\n24:     @State\n25:     var currentRoute: String = bootstrapStartRoute\n26: \n27:     @State\n28:     var isShellAtTop: Bool = true\n29: \n30:     @State\n31:     var onboardingPageIndex: Int64 = 0\n32: \n33:     @State\n34:     var loginEmail: String = \"\"\n35: \n36:     @State\n37:     var loginPassword: String = \"\"\n38: \n39:     @State\n40:     var loginErrorMessage: String = \"\"\n41: \n42:     @State\n43:     var homeSearchQuery: String = \"\"\n44: \n45:     @State\n46:     var homeSelectedFilter: String = \"\"\n47: \n48:     @State\n49:     var historySearchQuery: String = \"\"\n50: \n51:     @State\n52:     var historyTabIndex: Int64 = 0\n53: \n54:     @State\n55:     var previousRoute: String = \"home_screen\"\n56: \n57:     @State\n58:     var cartNote: String = \"\"\n59: \n60:     @State\n61:     var cartCoupon: String = \"\"\n62: \n63:     @State\n64:     var cartMutationRevision: Int64 = 0\n65: \n66:     @State\n67:     var detailRecommendedExpanded: Bool = true\n68: \n69:     @State\n70:     var detailNonVegExpanded: Bool = true\n71: \n72:     @State\n73:     var detailVegExpanded: Bool = true\n74: \n75:     @State\n76:     var detailLiked: Bool = false\n77: \n78:     @State\n79:     var detailMutationRevision: Int64 = 0\n80: \n81:     private var onboardingController: SwiperController = SwiperController()\n82:     private var routeBackStack: ArrayList<String> = ArrayList<String>([])\n83: \n84:     private func applyShellState(shellState: ShellRouteState): Unit {\n85:         this.currentRoute = shellState.currentRoute\n86:         this.isShellAtTop = shellState.isAtTop\n87:     }\n88: \n89:     private func shellState(): ShellRouteState {\n90:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n91:     }\n92: \n93:     private func applyShellCommand(command: ShellCommand): Unit {\n94:         let shellState = this.shellState()\n95:         shellState.applyCommand(command)\n96:         this.applyShellState(shellState)\n97:     }\n98: \n99:     private func navigateTo(route: String): Unit {\n100:         if (this.currentRoute != route) {\n101:             this.routeBackStack.add(this.currentRoute)\n102:         }\n103:         this.previousRoute = this.currentRoute\n104:         let shellState = this.shellState()\n105:         shellState.currentRoute = route\n106:         shellState.isAtTop = true\n107:         this.applyShellState(shellState)\n108:     }\n109: \n110:     private func navigateBack(): Unit {\n111:         if (this.routeBackStack.size == 0) {\n112:             return\n113:         }\n114:         let targetIndex = this.routeBackStack.size - 1\n115:         let targetRoute = this.routeBackStack[targetIndex]\n116:         this.routeBackStack.remove(at: targetIndex)\n117:         this.previousRoute = this.currentRoute\n118:         let shellState = this.shellState()\n119:         shellState.currentRoute = targetRoute\n120:         shellState.isAtTop = true\n121:         this.applyShellState(shellState)\n122:     }\n123: \n124:     private func handleProfileBack(): Unit {\n125:         if (!profileRouteService.canNavigateBack(this.currentRoute, this.routeBackStack)) {\n126:             return\n127:         }\n128:         this.navigateBack()\n129:     }\n130: \n131:     private func showBottomShell(route: String): Bool {\n132:         let shellState = this.shellState()\n133:         shellState.currentRoute = route\n134:         return shellState.showBottomShell()\n135:     }\n136: \n137:     private func routeTitle(route: String): ResourceStr {\n138:         routeLabelByPath(route)\n139:     }\n140: \n141:     private func showToast(message: String): Unit {\n142:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n143:     }\n144: \n145:     private func clearLoginError(): Unit {\n146:         this.loginErrorMessage = \"\"\n147:     }\n148: \n149:     private func performLogin(): Unit {\n150:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n151:             this.clearLoginError()\n152:             this.navigateTo(loginStore.successRoute())\n153:             return\n154:         }\n155: \n156:         this.loginErrorMessage = loginStore.invalidLoginMessage\n157:         this.showToast(loginStore.invalidLoginMessage)\n158:     }\n159: \n160:     private func performLogout(): Unit {\n161:         profileStore.logout(Global.abilityContext)\n162:         let transition = profileRouteService.buildLogoutTransition(profileStore.logoutRoute())\n163:         let resetState = transition.resetState\n164:         this.loginEmail = resetState.loginEmail\n165:         this.loginPassword = resetState.loginPassword\n166:         this.clearLoginError()\n167:         this.onboardingPageIndex = resetState.onboardingPageIndex\n168:         this.homeSearchQuery = resetState.homeSearchQuery\n169:         this.homeSelectedFilter = resetState.homeSelectedFilter\n170:         this.historySearchQuery = resetState.historySearchQuery\n171:         this.historyTabIndex = resetState.historyTabIndex\n172:         this.routeBackStack.clear()\n173:         this.navigateTo(transition.nextRoute)\n174:     }\n175: \n176:     private func handleProfileEdit(): Unit {\n177:         this.showToast(profileRouteService.editActionMessage())\n178:     }\n179: \n180:     private func handleProfileSectionAction(section: ProfileSection): Unit {\n181:         this.showToast(profileRouteService.sectionActionMessage(section))\n182:     }\n183: \n184:     private func handleProfileLogout(): Unit {\n185:         this.performLogout()\n186:     }\n187: \n188:     private func routeSummary(route: String): String {\n189:         match (route) {\n190:             case \"home_screen\" => \"Home now renders repository-backed discovery content, local search/filter controls, and restaurant selection before detail routing.\"\n191:             case \"history\" => \"History now preserves search plus tab-local content, reuses favourite restaurants, and saves the selected restaurant before navigation.\"\n192:             case \"cart\" => \"Cart now renders snapshot-backed items, a local note editor, a local coupon field, delivery details, and bill totals without adding new checkout persistence flows.\"\n193:             case \"restaurant_details\" => \"Restaurant detail now reads the selected restaurant, preserves local section expansion and like state, keeps menu quantity controls local to the route, and shows the cart action only when selected quantities are non-zero.\"\n194:             case _ => \"\"\n195:         }\n196:     }\n197: \n198:     private func homeHour(): Int64 {\n199:         return 9\n200:     }\n201: \n202:     private func goToProfile(): Unit {\n203:         this.navigateTo(routePath(RouteId.Profile))\n204:     }\n205: \n206:     private func goToRestaurantDetail(): Unit {\n207:         this.detailRecommendedExpanded = true\n208:         this.detailNonVegExpanded = true\n209:         this.detailVegExpanded = true\n210:         this.detailLiked = detailStore.session().isRestaurantLiked(detailStore.selectedRestaurant())\n211:         this.detailMutationRevision = 0\n212:         this.navigateTo(routePath(RouteId.RestaurantDetails))\n213:     }\n214: \n215:     private func detailState(): DetailPageState {\n216:         return detailStore.loadDetailState(\n217:             this.detailRecommendedExpanded,\n218:             this.detailNonVegExpanded,\n219:             this.detailVegExpanded\n220:         )\n221:     }\n222: \n223:     private func selectHomeRestaurant(restaurant: RestaurantData): Unit {\n224:         homeStore.selectRestaurant(restaurant, { =>\n225:             this.goToRestaurantDetail()\n226:         })\n227:     }\n228: \n229:     private func selectHistoryRestaurant(restaurant: RestaurantData): Unit {\n230:         historyStore.selectRestaurant(restaurant, { =>\n231:             this.goToRestaurantDetail()\n232:         })\n233:     }\n234: \n235:     @Builder\n236:     private func buildOnboardingRoute() {\n237:         renderOnboardingRoute(\n238:             this.onboardingPageIndex,\n239:             this.onboardingController,\n240:             { index: Int32 =>\n241:                 this.onboardingPageIndex = Int64(index)\n242:             },\n243:             { =>\n244:                 if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n245:                     this.navigateTo(routePath(RouteId.Login))\n246:                 } else {\n247:                     this.onboardingController.showNext()\n248:                 }\n249:             }\n250:         )\n251:     }\n252: \n253:     @Builder\n254:     private func buildLoginRoute() {\n255:         renderLoginRoute(\n256:             this.loginEmail,\n257:             this.loginPassword,\n258:             this.loginErrorMessage,\n259:             { value: String =>\n260:                 this.loginEmail = value\n261:                 this.clearLoginError()\n262:             },\n263:             { value: String =>\n264:                 this.loginPassword = value\n265:                 this.clearLoginError()\n266:             },\n267:             { => this.showToast(loginStore.comingSoonMessage) },\n268:             { => this.performLogin() },\n269:             { => this.showToast(loginStore.comingSoonMessage) },\n270:             { => this.showToast(loginStore.comingSoonMessage) },\n271:             { => this.showToast(loginStore.comingSoonMessage) },\n272:             { => this.clearLoginError() }\n273:         )\n274:     }\n275: \n276:     @Builder\n277:     private func buildProfileRoute() {\n278:         renderProfileRoute(\n279:             profileStore.userName,\n280:             profileStore.userEmail,\n281:             { => this.handleProfileBack() },\n282:             { => this.handleProfileEdit() },\n283:             { section: ProfileSection => this.handleProfileSectionAction(section) },\n284:             { => this.handleProfileLogout() }\n285:         )\n286:     }\n287: \n288:     @Builder\n289:     private func buildHomeRoute() {\n290:         renderHomeRoute(\n291:             homeStore.buildFilteredState(this.homeSearchQuery, this.homeSelectedFilter),\n292:             this.homeHour(),\n293:             this.homeSearchQuery,\n294:             this.homeSelectedFilter,\n295:             { value: String =>\n296:                 this.homeSearchQuery = value\n297:             },\n298:             { value: String =>\n299:                 this.homeSelectedFilter = homeStore.toggleFilter(this.homeSelectedFilter, value)\n300:             },\n301:             { => this.goToProfile() },\n302:             { restaurant: RestaurantData =>\n303:                 this.selectHomeRestaurant(restaurant)\n304:             }\n305:         )\n306:     }\n307: \n308:     @Builder\n309:     private func buildHistoryRoute() {\n310:         renderHistoryRoute(\n311:             historyStore.buildVisibleState(this.historySearchQuery),\n312:             this.historyTabIndex,\n313:             this.historySearchQuery,\n314:             { value: String =>\n315:                 this.historySearchQuery = value\n316:             },\n317:             { value: Int64 =>\n318:                 this.historyTabIndex = value\n319:             },\n320:             { restaurant: RestaurantData =>\n321:                 this.selectHistoryRestaurant(restaurant)\n322:             }\n323:         )\n324:     }\n325: \n326:     @Builder\n327:     private func buildCartRoute() {\n328:         renderCartRoute(\n329:             cartStore.loadCartState(),\n330:             this.cartNote,\n331:             this.cartCoupon,\n332:             { value: String =>\n333:                 this.cartNote = value\n334:             },\n335:             { value: String =>\n336:                 this.cartCoupon = value\n337:             },\n338:             { item: CartSnapshotItemData =>\n339:                 cartStore.decrementQuantity(item)\n340:                 this.cartMutationRevision += 1\n341:             },\n342:             { item: CartSnapshotItemData =>\n343:                 cartStore.incrementQuantity(item)\n344:                 this.cartMutationRevision += 1\n345:             },\n346:             { =>\n347:                 this.navigateBack()\n348:             }\n349:         )\n350:     }\n351: \n352:     @Builder\n353:     private func buildDetailRoute() {\n354:         renderDetailRoute(\n355:             this.detailState(),\n356:             { =>\n357:                 this.navigateBack()\n358:             },\n359:             { =>\n360:                 let restaurant = detailStore.selectedRestaurant()\n361:                 this.detailLiked = detailStore.toggleLiked(restaurant, this.detailLiked)\n362:             },\n363:             { =>\n364:                 this.showToast(loginStore.comingSoonMessage)\n365:             },\n366:             { =>\n367:                 this.detailRecommendedExpanded = !this.detailRecommendedExpanded\n368:             },\n369:             { =>\n370:                 this.detailNonVegExpanded = !this.detailNonVegExpanded\n371:             },\n372:             { =>\n373:                 this.detailVegExpanded = !this.detailVegExpanded\n374:             },\n375:             { item: DetailMenuItemData =>\n376:                 detailStore.incrementQuantity(item)\n377:                 this.detailMutationRevision += 1\n378:             },\n379:             { item: DetailMenuItemData =>\n380:                 detailStore.decrementQuantity(item)\n381:                 this.detailMutationRevision += 1\n382:             },\n383:             { =>\n384:                 this.navigateTo(routePath(RouteId.Cart))\n385:             }\n386:         )\n387:     }\n388: \n389:     @Builder\n390:     private func buildPlaceholderRoute() {\n391:         Column(space: 18) {\n392:             Text(\"Foodike\")\n393:                 .fontSize(42)\n394:                 .fontWeight(FontWeight.Bold)\n395:             Text(this.routeTitle(this.currentRoute))\n396:                 .fontSize(28)\n397:             Text(this.routeSummary(this.currentRoute))\n398:                 .fontSize(16)\n399:                 .textAlign(TextAlign.Center)\n400:                 .width(86.percent)\n401: \n402:             if (this.currentRoute == routePath(RouteId.Home) || this.currentRoute == routePath(RouteId.History)) {\n403:                 Button(if (this.isShellAtTop) { \"Simulate Scrolled Content\" } else { \"Return To Top\" })\n404:                     .onClick({ _ =>\n405:                         let shellState = this.shellState()\n406:                         shellState.setTopState(!shellState.isAtTop)\n407:                         this.applyShellState(shellState)\n408:                     })\n409:             }\n410: \n411:             Button(primaryActionLabel(this.currentRoute))\n412:                 .backgroundColor(foodikeThemePrimaryColor)\n413:                 .fontColor(Color.White)\n414:                 .onClick({ _ =>\n415:                     this.applyShellCommand(ShellCommand.PrimaryAction)\n416:                 })\n417: \n418:             if (this.showBottomShell(this.currentRoute)) {\n419:                 Row(space: 12) {\n420:                     Button(stringHome)\n421:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HomeTab) })\n422:                     Button(stringCart)\n423:                         .onClick({ _ => this.applyShellCommand(ShellCommand.CartAction) })\n424:                     Button(stringHistory)\n425:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HistoryTab) })\n426:                 }\n427:             }\n428:         }\n429:         .width(100.percent)\n430:         .height(100.percent)\n431:         .justifyContent(FlexAlign.Center)\n432:         .alignItems(HorizontalAlign.Center)\n433:         .padding(top: 24, right: 24, bottom: 24, left: 24)\n434:     }\n435: \n436:     func build() {\n437:         if (this.currentRoute == routePath(RouteId.Onboarding)) {\n438:             this.buildOnboardingRoute()\n439:         } else if (this.currentRoute == routePath(RouteId.Login)) {\n440:             this.buildLoginRoute()\n441:         } else if (this.currentRoute == routePath(RouteId.Home)) {\n442:             this.buildHomeRoute()\n443:         } else if (this.currentRoute == routePath(RouteId.History)) {\n444:             this.buildHistoryRoute()\n445:         } else if (this.currentRoute == routePath(RouteId.Cart)) {\n446:             this.buildCartRoute()\n447:         } else if (this.currentRoute == routePath(RouteId.RestaurantDetails)) {\n448:             this.buildDetailRoute()\n449:         } else if (this.currentRoute == routePath(RouteId.Profile)) {\n450:             this.buildProfileRoute()\n451:         } else {\n452:             this.buildPlaceholderRoute()\n453:         }\n454:     }\n455: }\n\n(End of file - total 455 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\nimport kit.ArkUI.*\nimport ohos.base.ResourceStr\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos.arkui.state_macro_manage.Component\nimport ohos.arkui.state_macro_manage.Entry\nimport ohos.arkui.state_macro_manage.State\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.{CartSnapshotItemData, DetailMenuItemData, DetailPageState, RestaurantData}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.{cartStore, renderCartRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.{detailStore, renderDetailRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history.{historyStore, renderHistoryRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home.{homeStore, renderHomeRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.{