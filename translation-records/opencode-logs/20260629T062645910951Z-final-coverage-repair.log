targetFallback\",\n150:     \"futureCompletionPath\",\n151:     \"notes\",\n152: }\n153: PLATFORM_UPDATE_FIELDS = PLATFORM_LIST_FIELDS | PLATFORM_TEXT_FIELDS | PLATFORM_OBJECT_FIELDS\n154: PLATFORM_ADD_FIELDS = PLATFORM_UPDATE_FIELDS | {\n155:     \"capabilityId\",\n156:     \"capabilityName\",\n157:     \"importance\",\n158:     \"sourcePaths\",\n159:     \"sourceEvidence\",\n160:     \"sourceEvidenceSummary\",\n161:     \"requiredTargetCapabilitySearch\",\n162:     \"targetStrategyHint\",\n163:     \"minimumParity\",\n164:     \"requiredTests\",\n165:     \"allowedDeferredReasons\",\n166: }\n167: PLATFORM_ADD_REQUIRED_FIELDS = {\"capabilityId\", \"capabilityName\", \"importance\", \"sourceEvidenceSummary\"}\n168: \n169: \n170: class PatchError(ValueError):\n171:     \"\"\"Raised for user-facing patch validation errors.\"\"\"\n172: \n173: \n174: @dataclass(frozen=True)\n175: class PatchContext:\n176:     target_project: Path | None = None\n177:     legal_phases: frozenset[str] | None = None\n178:     allow_missing_endpoints: bool = False\n179:     allow_unknown_phase: bool = False\n180: \n181: \n182: def parse_args() -> argparse.Namespace:\n183:     parser = argparse.ArgumentParser(\n184:         description=(\n185:             \"Apply a strict JSON patch payload to source-coverage-matrix.json or \"\n186:             \"platform-capability-check.json and optionally sync the Markdown view.\"\n187:         ),\n188:         formatter_class=HelpFormatter,\n189:     )\n190:     parser.add_argument(\n191:         \"--kind\",\n192:         choices=(\"auto\", \"matrix\", \"platform\"),\n193:         default=\"auto\",\n194:         help=\"Authority type. auto infers from the authority filename.\",\n195:     )\n196:     parser.add_argument(\"--authority\", required=True, help=\"Authority JSON path to patch.\")\n197:     parser.add_argument(\n198:         \"--patch\",\n199:         default=\"\",\n200:         help=\"Strict JSON patch payload. Omit with --validate-only to just 