onent\n23: class FoodikeBootstrap {\n24:     @State\n25:     var currentRoute: String = bootstrapStartRoute\n26: \n27:     @State\n28:     var isShellAtTop: Bool = true\n29: \n30:     @State\n31:     var onboardingPageIndex: Int64 = 0\n32: \n33:     @State\n34:     var loginEmail: String = \"\"\n35: \n36:     @State\n37:     var loginPassword: String = \"\"\n38: \n39:     @State\n40:     var loginErrorMessage: String = \"\"\n41: \n42:     @State\n43:     var homeSearchQuery: String = \"\"\n44: \n45:     @State\n46:     var homeSelectedFilter: String = \"\"\n47: \n48:     @State\n49:     var historySearchQuery: String = \"\"\n50: \n51:     @State\n52:     var historyTabIndex: Int64 = 0\n53: \n54:     @State\n55:     var previousRoute: String = \"home_screen\"\n56: \n57:     @State\n58:     var cartNote: String = \"\"\n59: \n60:     @State\n61:     var cartCoupon: String = \"\"\n62: \n63:     @State\n64:     var cartMutationRevision: Int64 = 0\n65: \n66:     @State\n67:     var detailRecommendedExpanded: Bool = true\n68: \n69:     @State\n70:     var detailNonVegExpanded: Bool = true\n71: \n72:     @State\n73:     var detailVegExpanded: Bool = true\n74: \n75:     @State\n76:     var detailLiked: Bool = false\n77: \n78:     @State\n79:     var detailMutationRevision: Int64 = 0\n80: \n81:     private var onboardingController: SwiperController = SwiperController()\n82:     private var routeBackStack: ArrayList<String> = ArrayList<String>([])\n83: \n84:     private func applyShellState(shellState: ShellRouteState): Unit {\n85:         this.currentRoute = shellState.currentRoute\n86:         this.isShellAtTop = shellState.isAtTop\n87:     }\n88: \n89:     private func shellState(): ShellRouteState {\n90:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n91:     }\n92: \n93:     private func applyShellCommand(command: ShellCommand): Unit {\n94:         let shellState = this.shellState()\n95:         shellState.applyCommand(command)\n96:         this.applyShellState(shellState)\n97:     }\n98: \n99:     private func navigateTo(route: String): Unit {\n100:         if (this.currentRoute != route) {\n101:             this.routeBackStack.add(this.currentRoute)\n102:         }\n103:         this.previousRoute = this.currentRoute\n104:         let shellState = this.shellState()\n105:         shellState.currentRoute = route\n106:         shellState.isAtTop = true\n107:         this.applyShellState(shellState)\n108:     }\n109: \n110:     private func navigateBack(): Unit {\n111:         if (this.routeBackStack.size == 0) {\n112:             return\n113:         }\n114:         let targetIndex = this.routeBackStack.size - 1\n115:         let targetRoute = this.routeBackStack[targetIndex]\n116:         this.routeBackStack.remove(at: targetIndex)\n117:         this.previousRoute = this.currentRoute\n118:         let shellState = this.shellState()\n119:         shellState.currentRoute = targetRoute\n120:         shellState.isAtTop = true\n121:         this.applyShellState(shellState)\n122:     }\n123: \n124:     private func handleProfileBack(): Unit {\n125:         if (!profileRouteService.canNavigateBack(this.currentRoute, this.routeBackStack)) {\n126:             return\n127:         }\n128:         this.navigateBack()\n129:     }\n130: \n131:     private func showBottomShell(route: String): Bool {\n132:         let shellState = this.shellState()\n133:         shellState.currentRoute = route\n134:         return shellState.showBottomShell()\n135:     }\n136: \n137:     private func routeTitle(route: String): ResourceStr {\n138:         routeLabelByPath(route)\n139:     }\n140: \n141:     private func showToast(message: String): Unit {\n142:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n143:     }\n144: \n145:     private func clearLoginError(): Unit {\n146:         this.loginErrorMessage = \"\"\n147:     }\n148: \n149:     private func performLogin(): Unit {\n150:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n151:             this.clearLoginError()\n152:             this.navigateTo(loginStore.successRoute())\n153:             return\n154:         }\n155: \n156:         this.loginErrorMessage = loginStore.invalidLoginMessage\n157:         this.showToast(loginStore.invalidLoginMessage)\n158:     }\n159: \n160:     private func performLogout(): Unit {\n161:         profileStore.logout(Global.abilityContext)\n162:         let transition = profileRouteService.buildLogoutTransition(profileStore.logoutRoute())\n163:         let resetState = transition.resetState\n164:         this.loginEmail = resetState.loginEmail\n165:         this.loginPassword = resetState.loginPassword\n166:         this.clearLoginError()\n167:         this.onboardingPageIndex = resetState.onboardingPageIndex\n168:         this.homeSearchQuery = resetState.homeSearchQuery\n169:         this.homeSelectedFilter = resetState.homeSelectedFilter\n170:         this.historySearchQuery = resetState.historySearchQuery\n171:         this.historyTabIndex = resetState.historyTabIndex\n172:         this.routeBackStack.clear()\n173:         this.navigateTo(transition.nextRoute)\n174:     }\n175: \n176:     private func handleProfileEdit(): Unit {}\n177: \n178:     private func handleProfileSectionAction(section: ProfileSection): Unit {}\n179: \n180:     private func handleProfileLogout(): Unit {\n181:         this.performLogout()\n182:     }\n183: \n184:     private func routeSummary(route: String): String {\n185:         match (route) {\n186:             case \"home_screen\" => \"Home now renders repository-backed discovery content, local search/filter controls, and restaurant selection before detail routing.\"\n187:             case \"history\" => \"History now preserves search plus tab-local content, reuses favourite restaurants, and saves the selected restaurant before navigation.\"\n188:             case \"cart\" => \"Cart now renders snapshot-backed items, a local note editor, a local coupon field, delivery details, and bill totals without adding new checkout persistence flows.\"\n189:             case \"restaurant_details\" => \"Restaurant detail now reads the selected restaurant, preserves local section expansion and like state, keeps menu quantity controls local to the route, and shows the cart action only when selected quantities are non-zero.\"\n190:             case _ => \"\"\n191:         }\n192:     }\n193: \n194:     private func homeHour(): Int64 {\n195:         return 9\n196:     }\n197: \n198:     private func goToProfile(): Unit {\n199:         this.navigateTo(routePath(RouteId.Profile))\n200:     }\n201: \n202:     private func goToRestaurantDetail(): Unit {\n203:         this.detailRecommendedExpanded = true\n204:         this.detailNonVegExpanded = true\n205:         this.detailVegExpanded = true\n206:         this.detailLiked = detailStore.session().isRestaurantLiked(detailStore.selectedRestaurant())\n207:         this.detailMutationRevision = 0\n208:         this.navigateTo(routePath(RouteId.RestaurantDetails))\n209:     }\n210: \n211:     private func detailState(): DetailPageState {\n212:         return detailStore.loadDetailState(\n213:             this.detailRecommendedExpanded,\n214:             this.detailNonVegExpanded,\n215:             this.detailVegExpanded\n216:         )\n217:     }\n218: \n219:     private func selectHomeRestaurant(restaurant: RestaurantData): Unit {\n220:         homeStore.selectRestaurant(restaurant, { =>\n221:             this.goToRestaurantDetail()\n222:         })\n223:     }\n224: \n225:     private func selectHistoryRestaurant(restaurant: RestaurantData): Unit {\n226:         historyStore.selectRestaurant(restaurant, { =>\n227:             this.goToRestaurantDetail()\n228:         })\n229:     }\n230: \n231:     @Builder\n232:     private func buildOnboardingRoute() {\n233:         renderOnboardingRoute(\n234:             this.onboardingPageIndex,\n235:             this.onboardingController,\n236:             { index: Int32 =>\n237:                 this.onboardingPageIndex = Int64(index)\n238:             },\n239:             { =>\n240:                 if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n241:                     this.navigateTo(routePath(RouteId.Login))\n242:                 } else {\n243:                     this.onboardingController.showNext()\n244:                 }\n245:             }\n246:         )\n247:     }\n248: \n249:     @Builder\n250:     private func buildLoginRoute() {\n251:         renderLoginRoute(\n252:             this.loginEmail,\n253:             this.loginPassword,\n254:             this.loginErrorMessage,\n255:             { value: String =>\n256:                 this.loginEmail = value\n257:                 this.clearLoginError()\n258:             },\n259:             { value: String =>\n260:                 this.loginPassword = value\n261:                 this.clearLoginError()\n262:             },\n263:             { => this.showToast(loginStore.comingSoonMessage) },\n264:             { => this.performLogin() },\n265:             { => this.showToast(loginStore.comingSoonMessage) },\n266:             { => this.showToast(loginStore.comingSoonMessage) },\n267:             { => this.showToast(loginStore.comingSoonMessage) },\n268:             { => this.clearLoginError() }\n269:         )\n270:     }\n271: \n272:     @Builder\n273:     private func buildProfileRoute() {\n274:         renderProfileRoute(\n275:             profileStore.userName,\n276:             profileStore.userEmail,\n277:             { => this.handleProfileBack() },\n278:             { => this.handleProfileEdit() },\n279:             { section: ProfileSection => this.handleProfileSectionAction(section) },\n280:             { => this.handleProfileLogout() }\n281:         )\n282:     }\n283: \n284:     @Builder\n285:     private func buildHomeRoute() {\n286:         renderHomeRoute(\n287:             homeStore.buildFilteredState(this.homeSearchQuery, this.homeSelectedFilter),\n288:             this.homeHour(),\n289:             this.homeSearchQuery,\n290:             this.homeSelectedFilter,\n291:             { value: String =>\n292:                 this.homeSearchQuery = value\n293:             },\n294:             { value: String =>\n295:                 this.homeSelectedFilter = homeStore.toggleFilter(this.homeSelectedFilter, value)\n296:             },\n297:             { => this.goToProfile() },\n298:             { restaurant: RestaurantData =>\n299:                 this.selectHomeRestaurant(restaurant)\n300:             }\n301:         )\n302:     }\n303: \n304:     @Builder\n305:     private func buildHistoryRoute() {\n306:         renderHistoryRoute(\n307:             historyStore.buildVisibleState(this.historySearchQuery),\n308:             this.historyTabIndex,\n309:             this.historySearchQuery,\n310:             { value: String =>\n311:                 this.historySearchQuery = value\n312:             },\n313:             { value: Int64 =>\n314:                 this.historyTabIndex = value\n315:             },\n316:             { restaurant: RestaurantData =>\n317:                 this.selectHistoryRestaurant(restaurant)\n318:             }\n319:         )\n320:     }\n321: \n322:     @Builder\n323:     private func buildCartRoute() {\n324:         renderCartRoute(\n325:             cartStore.loadCartState(),\n326:             this.cartNote,\n327:             this.cartCoupon,\n328:             { value: String =>\n329:                 this.cartNote = value\n330:             },\n331:             { value: String =>\n332:                 this.cartCoupon = value\n333:             },\n334:             { item: CartSnapshotItemData =>\n335:                 cartStore.decrementQuantity(item)\n336:                 this.cartMutationRevision += 1\n337:             },\n338:             { item: CartSnapshotItemData =>\n339:                 cartStore.incrementQuantity(item)\n340:                 this.cartMutationRevision += 1\n341:             },\n342:             { =>\n343:                 this.navigateBack()\n344:             }\n345:         )\n346:     }\n347: \n348:     @Builder\n349:     private func buildDetailRoute() {\n350:         renderDetailRoute(\n351:             this.detailState(),\n352:             { =>\n353:                 this.navigateBack()\n354:             },\n355:             { =>\n356:                 let restaurant = detailStore.selectedRestaurant()\n357:                 this.detailLiked = detailStore.toggleLiked(restaurant, this.detailLiked)\n358:             },\n359:             { =>\n360:                 this.showToast(loginStore.comingSoonMessage)\n361:             },\n362:             { =>\n363:                 this.detailRecommendedExpanded = !this.detailRecommendedExpanded\n364:             },\n365:             { =>\n366:                 this.detailNonVegExpanded = !this.detailNonVegExpanded\n367:             },\n368:             { =>\n369:                 this.detailVegExpanded = !this.detailVegExpanded\n370:             },\n371:             { item: DetailMenuItemData =>\n372:                 detailStore.incrementQuantity(item)\n373:                 this.detailMutationRevision += 1\n374:             },\n375:             { item: DetailMenuItemData =>\n376:                 detailStore.decrementQuantity(item)\n377:                 this.detailMutationRevision += 1\n378:             },\n379:             { =>\n380:                 this.navigateTo(routePath(RouteId.Cart))\n381:             }\n382:         )\n383:     }\n384: \n385:     @Builder\n386:     private func buildPlaceholderRoute() {\n387:         Column(space: 18) {\n388:             Text(\"Foodike\")\n389:                 .fontSize(42)\n390:                 .fontWeight(FontWeight.Bold)\n391:             Text(this.routeTitle(this.currentRoute))\n392:                 .fontSize(28)\n393:             Text(this.routeSummary(this.currentRoute))\n394:                 .fontSize(16)\n395:                 .textAlign(TextAlign.Center)\n396:                 .width(86.percent)\n397: \n398:             if (this.currentRoute == routePath(RouteId.Home) || this.currentRoute == routePath(RouteId.History)) {\n399:                 Button(if (this.isShellAtTop) { \"Simulate Scrolled Content\" } else { \"Return To Top\" })\n400:                     .onClick({ _ =>\n\n(Showing lines 1-400 of 451. Use offset=401 to continue.)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\nimport kit.ArkUI.*\nimport ohos.base.ResourceStr\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos.arkui.state_macro_manage.Component\nimport ohos.arkui.state_macro_manage.Entry\nimport ohos.arkui.state_macro_manage.State\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.{CartSnapshotItemData, DetailMenuItemData, DetailPageState, RestaurantData}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.{cartStore, renderCartRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.{detailStore, renderDetailRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history.{historyStore, renderHistoryRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home.{homeStore, renderHomeRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.{loginStore, renderLoginRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.{onboardingStore, renderOnboardingRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{ProfileSection, profileRouteService, profileStore, renderProfileRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.runtime.{Global, bootstrapStartRoute}\nimport std.collection.ArrayList\n","truncated":true,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\