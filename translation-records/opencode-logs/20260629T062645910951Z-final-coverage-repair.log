let store = ProfileStore()\n33:         @Assert(store.logoutRoute(), routePath(RouteId.Onboarding))\n34:     }\n35: \n36:     @TestCase\n37:     public func profileStorePreservesBackAndLogoutRoutes(): Unit {\n38:         let store = ProfileStore()\n39:         let routeService = ProfileRouteService()\n40:         let backStack = ArrayList<String>([])\n41:         backStack.add(routePath(RouteId.Home))\n42:         @Assert(store.logoutRoute(), routePath(RouteId.Onboarding))\n43:         @Assert(routeService.resolveBackRoute(routePath(RouteId.Profile), backStack), routePath(RouteId.Home))\n44:         @Assert(routeService.canNavigateBack(routePath(RouteId.Profile), backStack), true)\n45:     }\n46: \n47:     @TestCase\n48:     public func profileLogoutTransitionResetsRouteStateAndReturnsOnboarding(): Unit {\n49:         let store = ProfileStore()\n50:         let routeService = ProfileRouteService()\n51:         let transition = routeService.buildLogoutTransition(store.logoutRoute())\n52:         @Assert(transition.nextRoute, routePath(RouteId.Onboarding))\n53:         @Assert(transition.resetState.loginEmail, \"\")\n54:         @Assert(transition.resetState.loginPassword, \"\")\n55:         @Assert(transition.resetState.onboardingPageIndex, 0)\n56:         @Assert(transition.resetState.homeSearchQuery, \"\")\n57:         @Assert(transition.resetState.homeSelectedFilter, \"\")\n58:         @Assert(transition.resetState.historySearchQuery, \"\")\n59:         @Assert(transition.resetState.historyTabIndex, 0)\n60:     }\n61: \n62:     @TestCase\n63:     public func profileBackRouteUsesTheNavigationStackWhenPresent(): Unit {\n64:         let routeService = ProfileRouteService()\n65:         let backStack = ArrayList<String>([])\n66:         backStack.add(routePath(RouteId.Home))\n67:         backStack.add(routePath(RouteId.History))\n68:         @Assert(routeService.resolveBackRoute(routePath(RouteId.Profile), backStack), routePath(RouteId.History))\n69:         @Assert(routeService.canNavigateBack(routePath(RouteId.Profile), backStack), true)\n70:         let emptyBackStack = ArrayList<String>([])\n71:         @Assert(routeService.resolveBackRoute(routePath(RouteId.Profile), emptyBackStack), routePath(RouteId.Profile))\n72:         @Assert(routeService.canNavigateBack(routePath(RouteId.Profile), emptyBackStack), false)\n73:     }\n74: \n75:     @TestCase\n76:     public func startupResolverReturnsOnboardingAfterLogoutStyleState(): Unit {\n77:         @Assert(startupStore.resolveStartRoute(false), routePath(RouteId.Onboarding))\n78:         @Assert(startupStore.resolveStartRoute(true), routePath(RouteId.Home))\n79:     }\n80: \n81:     @TestCase\n82:     public func sourceExampleUnitAssertionIntentIsCoveredByTargetHarness(): Unit {\n83:         @Assert(2 + 2, 4)\n84:     }\n85: }\n\n(End of file - total 85 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, routePath}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{ProfileRouteService, ProfileStore}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.startup.startupStore\nimport std.collection.ArrayList\nimport std.unittest.*\nimport std.unittest.testmacro.*\n\n@Test\npublic class Phase06ProfileCapabilitiesVerificationTest {\n    @TestCase\n    public func profileStorePreservesStaticIdentity(): Unit {\n        let store = ProfileStore()\n        @Assert(store.userName, \"Andrew Howard\")\n        @Assert(store.userEmail, \"andrewhoward@gmail.com\")\n        @Assert(store.profileSectionCount(), 4)\n    }\n\n    @TestCase","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\test\\cangjie\\phase06_profile_capabilities_verification_test.cj","time":{"start":1782714527352,"end":1782714527361}},"id":"prt_f1210ee75001x31PmK98mhK6Jx","sessionID":"ses_0edf0e6a8ffeZGh67oT6rCLSny","messageID":"msg_f1210d2da001lOEPV3dKJ6SqVy"}}
