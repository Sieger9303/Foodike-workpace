:         case RouteId.RestaurantDetails => stringRestaurant\n45:     }\n46: }\n47: \n48: public func routeLabelText(route: RouteId): String {\n49:     match (route) {\n50:         case RouteId.Onboarding => \"Foodike\"\n51:         case RouteId.Login => \"Login\"\n52:         case RouteId.Home => \"Home\"\n53:         case RouteId.History => \"History\"\n54:         case RouteId.Cart => \"Cart\"\n55:         case RouteId.Profile => \"Profile\"\n56:         case RouteId.RestaurantDetails => \"Restaurant\"\n57:     }\n58: }\n59: \n60: public func routeLabelByPath(route: String): ResourceStr {\n61:     match (route) {\n62:         case \"onboarding\" => routeLabel(RouteId.Onboarding)\n63:         case \"login_screen\" => routeLabel(RouteId.Login)\n64:         case \"home_screen\" => routeLabel(RouteId.Home)\n65:         case \"history\" => routeLabel(RouteId.History)\n66:         case \"cart\" => routeLabel(RouteId.Cart)\n67:         case \"profile\" => routeLabel(RouteId.Profile)\n68:         case \"restaurant_details\" => routeLabel(RouteId.RestaurantDetails)\n69:         case _ => route\n70:     }\n71: }\n72: \n73: public func routeLabelTextByPath(route: String): String {\n74:     match (route) {\n75:         case \"onboarding\" => routeLabelText(RouteId.Onboarding)\n76:         case \"login_screen\" => routeLabelText(RouteId.Login)\n77:         case \"home_screen\" => routeLabelText(RouteId.Home)\n78:         case \"history\" => routeLabelText(RouteId.History)\n79:         case \"cart\" => routeLabelText(RouteId.Cart)\n80:         case \"profile\" => routeLabelText(RouteId.Profile)\n81:         case \"restaurant_details\" => routeLabelText(RouteId.RestaurantDetails)\n82:         case _ => route\n83:     }\n84: }\n85: \n86: public func routeWithArgs(route: RouteId, args: ArrayList<String>): String {\n87:     var composedRoute = routePath(route)\n88:     for (arg in args) {\n89:         composedRoute = composedRoute + \"/\" + arg\n90:     }\n91:     return composedRoute\n92: }\n93: \n94: public func primaryActionTarget(route: String): String {\n95:     match (route) {\n96:         case \"onboarding\" => routePath(RouteId.Login)\n97:         case \"login_screen\" => routePath(RouteId.Home)\n98:         case \"home_screen\" => routePath(RouteId.RestaurantDetails)\n99:         case \"history\" => routePath(RouteId.Profile)\n100:         case \"cart\" => routePath(RouteId.Home)\n101:         case \"profile\" => routePath(RouteId.Onboarding)\n102:         case \"restaurant_details\" => routePath(RouteId.Home)\n103:         case _ => routePath(RouteId.Home)\n104:     }\n105: }\n106: \n107: public func primaryActionLabel(route: String): ResourceStr {\n108:     routeLabelByPath(primaryActionTarget(route))\n109: }\n110: \n111: public func primaryActionLabelText(route: String): String {\n112:     routeLabelTextByPath(primaryActionTarget(route))\n113: }\n\n(End of file - total 113 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\nimport ohos.base.ResourceStr\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{stringAppName, stringCart, stringHistory, stringHome, stringLogin, stringProfileTitle, stringRestaurant}\nimport std.collection.ArrayList\n\npublic enum RouteId {\n    | Onboarding\n    | Login\n    | Home\n    | History\n    | Cart\n    | Profile\n    | RestaurantDetails\n}\n\npublic enum ShellCommand {\n    | HomeTab\n    | HistoryTab\n    | CartAction","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\route_registry.cj","time":{"start":1782642916722,"end":1782642916728}},"id":"prt_f0dcc3d6a001F15kvba5BbrLl6","sessionID":"ses_0f234de66ffeoXYFpTxjPoAdc8","messageID":"msg_f0dcc12060013Ob46tN4tketgJ"}}
