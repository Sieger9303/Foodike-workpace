ment = Arrangement.Center,\n79:             verticalAlignment = Alignment.CenterVertically\n80:         ) {\n81:             if (cartItem.menuItem.isVegetarian) {\n82:                 Image(\n83:                     modifier = Modifier.size(18.dp),\n84:                     painter = painterResource(id = R.drawable.ic_veg),\n85:                     contentDescription = \"Vegetarian\"\n86:                 )\n87:             } else {\n88:                 Image(\n89:                     modifier = Modifier.size(16.dp),\n90:                     painter = painterResource(id = R.drawable.ic_non_veg),\n91:                     contentDescription = \"Non-Vegetarian\"\n92:                 )\n93:             }\n94:             Spacer(modifier = Modifier.width(8.dp))\n95:             Text(text = cartItem.menuItem.dish)\n96: \n97:         }\n98: \n99: \n100:         Column(\n101: \n102:             verticalArrangement = Arrangement.Center,\n103:             horizontalAlignment = Alignment.CenterHorizontally\n104:         ) {\n105:             Surface(\n106:                 modifier = Modifier\n107:                     .border(\n108:                         BorderStroke(1.dp, Color.Black.copy(0.5f)),\n109:                         MaterialTheme.shapes.medium\n110:                     ),\n111:                 shape = MaterialTheme.shapes.medium,\n112:                 color = Color.White,\n113:                 contentColor = MaterialTheme.colors.primary\n114:             ) {\n115:                 Row(\n116:                     modifier = Modifier.padding(4.dp),\n117:                     horizontalArrangement = Arrangement.Center,\n118:                     verticalAlignment = Alignment.CenterVertically\n119:                 ) {\n120: \n121:                     Icon(\n122:                         imageVector = Icons.Default.Remove,\n123:                         contentDescription = stringResource(R.string.subtract),\n124:                         modifier = Modifier\n125:               