2) {\n40:         Text(restaurant.name)\n41:             .fontSize(26)\n42:             .fontWeight(FontWeight.Bold)\n43:         Row(space: 6) {\n44:             Image(mediaStar)\n45:                 .width(18)\n46:                 .height(18)\n47:             Text(detailStore.formatRestaurantMeta(restaurant))\n48:                 .fontSize(14)\n49:         }\n50:         Text(restaurant.variety)\n51:             .fontSize(14)\n52:             .fontColor(Color.Gray)\n53:         Text(restaurant.place)\n54:             .fontSize(14)\n55:             .fontColor(Color.Gray)\n56: \n57:         Row(space: 14) {\n58:             Image(mediaOutletCard)\n59:                 .width(42)\n60:                 .height(42)\n61:             Column(space: 4) {\n62:                 Text(stringOutlet)\n63:                     .fontWeight(FontWeight.Medium)\n64:                 Text(\"${restaurant.etaMinutes} Min\")\n65:                     .fontColor(Color.Gray)\n66:             }\n67:             Blank().layoutWeight(1)\n68:             Column(space: 4) {\n69:                 Text(restaurant.place)\n70:                     .fontColor(Color.Gray)\n71:                 Text(stringYourLocation)\n72:                     .fontColor(Color.Gray)\n73:             }\n74:         }\n75:         .width(100.percent)\n76:     }\n77:     .width(100.percent)\n78:     .padding(top: 18, right: 18, bottom: 18, left: 18)\n79:     .backgroundColor(0xFFC6FDB3)\n80:     .borderRadius(22)\n81: }\n82: \n83: @Builder\n84: func buildMenuQuantityControls(\n85:     item: DetailMenuItemData,\n86:     onAdd: () -> Unit,\n87:     onRemove: () -> Unit\n88: ) {\n89:     if (item.quantity == 0) {\n90:         Text(stringAdd)\n91:             .fontSize(15)\n92:             .fontWeight(FontWeight.Bold)\n93:             .fontColor(colorDarkGreen)\n94:             .onClick({ _ =>\n95:                 onAdd()\n96:             })\n97:     } else {\n98:         Row(space: 10) {\n99:             Text(stringSubtract)\n100:                 .fontSize(16)\n101:                 .fontWeight(FontWeight.Bold)\n102:                 .onClick({ _ =>\n103:                     onRemove()\n104:                 })\n105:             Text(\"${item.quantity}\")\n106:                 .fontSize(16)\n107:                 .fontWeight(FontWeight.Medium)\n108:             Text(\"+\")\n109:                 .fontSize(16)\n110:                 .fontWeight(FontWeight.Bold)\n111:                 .fontColor(colorDarkGreen)\n112:                 .onClick({ _ =>\n113:                     onAdd()\n114:                 })\n115:         }\n116:         .padding(top: 6, right: 10, bottom: 6, left: 10)\n117:         .borderRadius(14)\n118:         .border(width: 1.px, color: 0x55000000)\n119:     }\n120: }\n121: \n122: @Builder\n123: func buildMenuItemRow(\n124:     item: DetailMenuItemData,\n125:     onAdd: () -> Unit,\n126:     onRemove: () -> Unit\n127: ) {\n128:     Row(space: 14) {\n129:         Image(if (item.menuItem.isVegetarian) { mediaIcVeg } else { mediaIcNonVeg })\n130:             .width(18)\n131:             .height(18)\n132:         Column(space: 6) {\n133:             Text(item.menuItem.dish)\n134:                 .fontSize(16)\n135:                 .fontWeight(FontWeight.Medium)\n136:             Text(detailStore.formatPrice(item.menuItem.price))\n137:                 .fontSize(14)\n138:                 .fontColor(Color.Gray)\n139:             Row(space: 6) {\n140:                 Image(mediaStar)\n141:                     .width(16)\n142:                     .height(16)\n143:                 Text(\"${item.menuItem.rating}\")\n144:                     .fontSize(13)\n145:                 Text(detailStore.formatRatingCount(item.menuItem.ratingCount))\n146:                     .fontSize(13)\n147:                     .fontColor(Color.Gray)\n148:             }\n149:         }\n150:         .layoutWeight(1)\n151:         buildMenuQuantityControls(item, onAdd, onRemove)\n152:     }\n153:     .width(100.percent)\n154:     .alignItems(VerticalAlign.Center)\n155:     .padding(top: 12, right: 0, bottom: 12, left: 0)\n156: }\n157: \n158: @Builder\n159: func buildSectionHeader(title: ResourceStr, expanded: Bool, onToggle: () -> Unit) {\n160:     Row {\n161:         Text(title)\n162:             .fontSize(22)\n163:             .fontWeight(FontWeight.Bold)\n164:         Blank().layoutWeight(1)\n165:         Text(if (expanded) { \"v\" } else { \">\" })\n166:             .fontSize(20)\n167:             .fontColor(Color.Gray)\n168:             .onClick({ _ =>\n169:                 onToggle()\n170:             })\n171:     }\n172:     .width(100.percent)\n173:     .alignItems(VerticalAlign.Center)\n174: }\n175: \n176: @Builder\n177: func buildDetailSection(\n178:     title: ResourceStr,\n179:     expanded: Bool,\n180:     items: ArrayList<DetailMenuItemData>,\n181:     onToggle: () -> Unit,\n182:     onAdd: (DetailMenuItemData) -> Unit,\n183:     onRemove: (DetailMenuItemData) -> Unit\n184: ) {\n185:     Column(space: 8) {\n186:         buildSectionHeader(title, expanded, onToggle)\n187:         if (expanded) {\n188:             ForEach(items, itemGeneratorFunc: { item: DetailMenuItemData, _: Int64 =>\n189:                 buildMenuItemRow(\n190:                     item,\n191:                     { => onAdd(item) },\n192:                     { => onRemove(item) }\n193:                 )\n194:             })\n195:         }\n196:     }\n197:     .width(100.percent)\n198: }\n199: \n200: @Builder\n201: func buildRestaurantHeroImage(restaurant: RestaurantData) {\n202:     Image(restaurantMedia(restaurant.mediaName))\n203:         .width(100.percent)\n204:         .height(200)\n205:         .borderRadius(22)\n206: }\n207: \n208: @Builder\n209: func buildCartFab(onOpenCart: () -> Unit) {\n210:     Row {\n211:         Blank().layoutWeight(1)\n212:         Button(stringCart)\n213:             .backgroundColor(colorDarkGreen)\n214:             .fontColor(Color.White)\n215:             .onClick({ _ =>\n216:                 onOpenCart()\n217:             })\n218:     }\n219:     .width(100.percent)\n220: }\n221: \n222: @Builder\n223: public func renderDetailRoute(\n224:     state: DetailPageState,\n225:     onBack: () -> Unit,\n226:     onToggleLike: () -> Unit,\n227:     onShare: () -> Unit,\n228:     onToggleRecommended: () -> Unit,\n229:     onToggleNonVeg: () -> Unit,\n230:     onToggleVeg: () -> Unit,\n231:     onAdd: (DetailMenuItemData) -> Unit,\n232:     onRemove: (DetailMenuItemData) -> Unit,\n233:     onOpenCart: () -> Unit\n234: ) {\n235:     Scroll(Scroller()) {\n236:         Column(space: 16) {\n237:             buildDetailTopBar(state.isLiked, onBack, onToggleLike, onShare)\n238:             buildRestaurantHeroImage(state.restaurant)\n239:             buildRestaurantDetailCard(state.restaurant)\n240:             buildDetailSection(\n241:                 stringRecommended,\n242:                 state.recommendedExpanded,\n243:                 state.recommendedItems,\n244:                 onToggleRecommended,\n245:                 onAdd,\n246:                 onRemove\n247:             )\n248:             buildDetailSection(\n249:                 stringNonVegetarian,\n250:                 state.nonVegExpanded,\n251:                 detailStore.nonVegItems(state.menuItems),\n252:                 onToggleNonVeg,\n253:                 onAdd,\n254:                 onRemove\n255:             )\n256:             buildDetailSection(\n257:                 stringVegetarian,\n258:                 state.vegExpanded,\n259:                 detailStore.vegItems(state.menuItems),\n260:                 onToggleVeg,\n261:                 onAdd,\n262:                 onRemove\n263:             )\n264:             if (detailStore.shouldShowCartAction(state.menuItems)) {\n265:                 buildCartFab(onOpenCart)\n266:             }\n267:         }\n268:         .width(100.percent)\n269:         .padding(top: 14, right: 16, bottom: 24, left: 16)\n270:     }\n271:     .scrollable(ScrollDirection.Vertical)\n272:     .scrollBar(BarState.Off)\n273:     .width(100.percent)\n274:     .height(100.percent)\n275:     .backgroundColor(Color.White)\n276: }\n\n(End of file - total 276 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos.base.ResourceStr\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.restaurantMedia\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\n@Builder\nfunc buildDetailTopBar(isLiked: Bool, onBack: () -> Unit, onToggleLike: () -> Unit, onShare: () -> Unit) {\n    Row {\n        Button(\"<\")\n            .onClick({ _ =>\n                onBack()\n            })\n        Blank().layoutWeight(1)\n        Row(space: 12) {\n            Text(if (isLiked) { \"Heart\" } else { \"Like\" })","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\detail\\detail_page.cj","time":{"start":1782642916021,"end":1782642916027}},"id":"prt_f0dcc3ab0001e7SE7nVDbUa73S","sessionID":"ses_0f234de66ffeoXYFpTxjPoAdc8","messageID":"msg_f0dcc12060013Ob46tN4tketgJ"}}
