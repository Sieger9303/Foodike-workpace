ctionCodeFiles\": 38,\n273:         \"productionCodeNonblankLines\": 2783,\n274:         \"largestProductionCodeFileNonblankLines\": 368,\n275:         \"largeProductionCodeFiles\": 0,\n276:         \"endpointBearingFeatureRows\": 85,\n277:         \"endpointTargetFiles\": 36,\n278:         \"largestEndpointFileShare\": 0.2824,\n279:         \"concentratedEndpointFiles\": 0,\n280:         \"broadShellEndpointFiles\": 1,\n281:         \"uiSurfaceFiles\": 21,\n282:         \"concentratedUiSurfaceFiles\": 2,\n283:         \"uiEndpointBearingFeatureRows\": 79,\n284:         \"uiEndpointTargetFiles\": 36,\n285:         \"concentratedUiEndpointFiles\": 7,\n286:         \"entryModuleStatus\": \"PASS\",\n287:         \"entryRootPackage\": \"ohos_app_cangjie_entry\"\n288:       }\n289:     },\n290:     \"resourceCoverage\": {},\n291:     \"verification\": {\n292:       \"totalResults\": 3,\n293:       \"byType\": {\n294:         \"build\": 3\n295:       },\n296:       \"byResult\": {\n297:         \"passed\": 3\n298:       },\n299:       \"passedBuildPhases\": [\n300:         \"phase-01-project-skeleton-resources\",\n\n(Showing lines 1-300 of 6334. Use offset=301 to continue.)\n</content>","metadata":{"preview":"{\n  \"schemaVersion\": 1,\n  \"generatedAt\": \"2026-06-27T16:43:37+00:00\",\n  \"workspaceRoot\": \"D:\\\\workspace\\\\Foodike\",\n  \"outputDir\": \"D:\\\\workspace\\\\Foodike\\\\translation-inputs\",\n  \"status\": \"blocked-high\",\n  \"recommendation\": \"Repair critical/high findings first; they are the strongest evidence that translated functionality has not converged.\",\n  \"missingCoreReports\": [],\n  \"reports\": {\n    \"coverageGap\": {\n      \"path\": \"D:\\\\workspace\\\\Foodike\\\\translation-inputs\\\\coverage-gap-report.json\",\n      \"exists\": true,\n      \"parsed\": true,\n      \"error\": \"\"\n    },\n    \"sourceCoverageMatrix\": {\n      \"path\": \"D:\\\\workspace\\\\Foodike\\\\translation-inputs\\\\source-coverage-matrix-report.json\",