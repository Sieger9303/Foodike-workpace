{"type":"tool_use","timestamp":1782642930821,"sessionID":"ses_0f234de66ffeoXYFpTxjPoAdc8","part":{"type":"tool","tool":"read","callID":"call_LsUBTVKdbvho2oE9LG55TEgc","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase05_detail_cart_state_mutations_test.cj","limit":260,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase05_detail_cart_state_mutations_test.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry_test\n2: \n3: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.DetailStore\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.CartStore\n6: import std.unittest.*\n7: import std.unittest.testmacro.*\n8: \n9: @Test\n10: public class Phase05DetailCartStateMutationsTest {\n11:     private func restaurantOrFirst(repository: HomeContentRepository, name: String) {\n12:         match (repository.getRestaurantByName(name)) {\n13:             case Some(found) => found\n14:             case None => repository.getRestaurants()[0]\n15:         }\n16:     }\n17: \n18:     @TestCase\n19:     public func cartStoreFiltersZeroCountItemsAndPreservesSnapshotOrder(): Unit {\n20:         let store = CartStore()\n21:         let state = store.loadCartState()\n22:         let visibleItems = store.visibleItems(state.items)\n23:         @Assert(visibleItems.size, 2)\n24:         @Assert(visibleItems[0].menuItem.dish, \"Paw Bhaaji\")\n25:         @Assert(visibleItems[1].menuItem.dish, \"Veg Pulao\")\n26:     }\n27: \n28:     @TestCase\n29:     public func cartStoreCalculatesTotalsFromSnapshotQuantities(): Unit {\n30:         let store = CartStore()\n31:         let state = store.loadCartState()\n32:         let itemTotal = store.itemTotal(store.visibleItems(state.items))\n33:         @Assert(itemTotal, 12.0)\n34:         @Assert(store.taxAmount(itemTotal), 2.16)\n35:         @Assert(store.grandTotal(itemTotal), 14.16)\n36:     }\n37: \n38:     @TestCase\n39:     public func cartStoreMutatesLocalQuantitiesImmediately(): Unit {\n40:         let store = CartStore()\n41:         let state = store.loadCartState()\n42:         let firstItem = state.items[0]\n43: \n44:         @Assert(firstItem.quantity, 1)\n45:         store.incrementQuantity(firstItem)\n46:         @Assert(firstItem.quantity, 2)\n47:         store.decrementQuantity(firstItem)\n48:         @Assert(firstItem.quantity, 1)\n49:         store.decrementQuantity(firstItem)\n50:         @Assert(firstItem.quantity, 0)\n51:         store.decrementQuantity(firstItem)\n52:         @Assert(firstItem.quantity, 0)\n53:     }\n54: \n55:     @TestCase\n56:     public func cartStoreKeepsSourceDeliveryPlaceholders(): Unit {\n57:         let store = CartStore()\n58:         let state = store.loadCartState()\n59:         @Assert(state.deliveryRestaurant.name, \"Relish\")\n60:         @Assert(store.deliveryLocation(), \"Guwahati\")\n61:         @Assert(store.formatEta(state.deliveryRestaurant.etaMinutes), \"30 Min\")\n62:     }\n63: \n64:     @TestCase\n65:     public func detailStoreLoadsSelectedRestaurantAndRecommendedMenuSlice(): Unit {\n66:         let store = DetailStore()\n67:         let contentRepository = HomeContentRepository()\n68:         let restaurant = restaurantOrFirst(contentRepository, \"Relish\")\n69:         store.session().setSelectedRestaurant(restaurant)\n70: \n71:         let state = store.loadDetailState(true, true, true)\n72:         @Assert(state.restaurant.name, \"Relish\")\n73:         @Assert(state.recommendedItems.size, 5)\n74:         for (item in state.recommendedItems) {\n75:             @Assert(item.menuItem.isVegetarian, true)\n76:         }\n77:     }\n78: \n79:     @TestCase\n80:     public func detailStorePreservesSectionFilteringAndCartVisibilityRules(): Unit {\n81:         let store = DetailStore()\n82:         let contentRepository = HomeContentRepository()\n83:         let restaurant = restaurantOrFirst(contentRepository, \"George Street\")\n84:         store.session().setSelectedRestaurant(restaurant)\n85: \n86:         let state = store.loadDetailState(true, true, true)\n87:         let nonVegItems = store.nonVegItems(state.menuItems)\n88:         let vegItems = store.vegItems(state.menuItems)\n89:         @Assert(nonVegItems.size, 4)\n90:         @Assert(vegItems.size, 4)\n91:         @Assert(store.shouldShowCartAction(state.menuItems), false)\n92: \n93:         store.incrementQuantity(state.menuItems[0])\n94:         @Assert(store.shouldShowCartAction(state.menuItems), true)\n95:         @Assert(store.totalSelectedItems(state.menuItems), 1)\n96:         store.decrementQuantity(state.menuItems[0])\n97:         @Assert(store.totalSelectedItems(state.menuItems), 0)\n98:     }\n99: \n100:     @TestCase\n101:     public func detailStoreTogglesLikedStateForSelectedRestaurant(): Unit {\n102:         let store = DetailStore()\n103:         let contentRepository = HomeContentRepository()\n104:         let restaurant = restaurantOrFirst(contentRepository, \"Relish\")\n105: \n106:         store.session().setRestaurantLiked(restaurant, false)\n107:         let liked = store.toggleLiked(restaurant, false)\n108:         @Assert(liked, true)\n109:         @Assert(store.session().isRestaurantLiked(restaurant), true)\n110:         let unliked = store.toggleLiked(restaurant, true)\n111:         @Assert(unliked, false)\n112:     }\n113: }\n\n(End of file - total 113 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.DetailStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.CartStore\nimport std.unittest.*\nimport std.unittest.testmacro.*\n\n@Test\npublic class Phase