  ) {\n79:                 IconButton(onClick = { navController.navigateUp() }) {\n80:                     Icon(imageVector = Icons.Outlined.Close, contentDescription = stringResource(id = R.string.back))\n81:                 }\n82:             }\n83:         }\n84: \n85:         item {\n86:             ItemSection(\n87:                 list = list.list.filter {\n88:                     it.noOfItems > 0\n89:                 },\n90:                 onDecreaseClick = { },\n91:                 onIncreaseClick = { },\n92:             )\n93:         }\n94: \n95:         item {\n96:             CouponBar()\n97:         }\n98:         item {\n99:             DeliverySection(\n100:                 Restaurant(\n101:                     name = \"Relish\",\n102:                     rating = 3.9,\n103:                     noOfRatings = 258,\n104:                     timeInMillis = 1800000,\n105:                     variety = \"American, French\",\n106:                     place = \"Misamari\",\n107:                     averagePrice = 1.0,\n108:                     image = R.drawable.pizza,\n109:                     menu = menu2\n110:                 )\n111:             )\n112:         }\n113:         item {\n114:             BillSection(\n115:                 itemTotal = 6.09\n116:             )\n117:         }\n118:     }\n119: }\n120: \n121: \n122: \n123: \n124: \n125: \n126: \n127: \n128: \n\n(End of file - total 128 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following