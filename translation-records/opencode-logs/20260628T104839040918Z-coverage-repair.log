   has_replacement_api_evidence,\n94:         platform_missing_deferred_fields,\n95:     )\n96:     from .render import platform_capability_check_markdown, source_coverage_matrix_markdown\n97:     from .utils import has_text, has_text_or_list\n98: \n99: \n100: MATRIX_OBJECT_FIELDS = {COVERAGE_FACTS_KEY}\n101: MATRIX_LIST_FIELDS = {\"verificationEvidence\", \"targetEndpoints\", \"tests\"}\n102: MATRIX_TEXT_FIELDS = set(MATRIX_AGENT_FIELDS) - MATRIX_LIST_FIELDS - MATRIX_OBJECT_FIELDS\n103: MATRIX_UPDATE_FIELDS = set(MATRIX_AGENT_FIELDS)\n104: MATRIX_ADD_FIELDS = MATRIX_UPDATE_FIELDS | {\n105:     \"featureId\",\n106:     \"featureName\",\n107:     \"sourcePath\",\n108:     \"importance\",\n109:     \"category\",\n110:     \"riskTags\",\n111:     \"keyClasses\",\n112:     \"keyMethods\",\n113:     \"androidIds\",\n114:     \"dependencies\",\n115:     \"featurePoint\",\n116:     \"sourceEvidence\",\n117: }\n118: MATRIX_ADD_REQUIRED_FIELDS = {\"featureId\", \"featureName\", \"sourcePath\", \"importance\", \"sourceEvidence\"}\n119: MATRIX_REQUIRED_LIST_FIELDS = (\"verificationEvidence\", \"targetEndpoints\", \"tests\")\n120: MATRIX_REQUIRED_TEXT_FIELDS = (\n121:     \"plannedPhase\",\n122:     \"sourceBehavior\",\n123:     \"targetBehavior\",\n124:     \"notes\",\n125:     \"deferredReason\",\n126:     \"targetFallback\",\n127:     \"risk\",\n128:     \"futureCompletionPath\",\n129: )\n130: \n131: PLATFORM_OBJECT_FIELDS = {CAPABILITY_FACTS_KEY}\n132: PLATFORM_LIST_FIELDS = {\n133:     \"targetCapabilitySearch\",\n134:     \"targetEndpoints\",\n135:     \"tests\",\n136:     \"sdkDeclarationEvidence\",\n137:     \"cangjieCallableEvidence\",\n138:     \"discoveryOnlyEvidence\",\n139:     \"compileProbeEvidence\",\n140: }\n141: PLATFORM_TEXT_FIELDS = {\n142:     \"status\",\n143:     \"plannedPhase\",\n144:     \"targetApiOrLibrary\",\n145:     \"targetStrategy\",\n146:     \"preResolutionDecision\",\n147:     \"phaseCapabilityResolution\",\n148:     \"blocker\",\n149:     \"