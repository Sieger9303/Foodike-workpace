   has_replacement_api_evidence,\n94:         platform_missing_deferred_fields,\n95:     )\n96:     from .render import platform_capability_check_markdown, source_coverage_matrix_markdown\n97:     from .utils import has_text, has_text_or_list\n98: \n99: \n100: MATRIX_OBJECT_FIELDS = {COVERAGE_FACTS_KEY}\n101: MATRIX_LIST_FIELDS = {\"verificationEvidence\", \"targetEndpoints\", \"tests\"}\n102: MATRIX_TEXT_FIELDS = set(MATRIX_AGENT_FIELDS) - MATRIX_LIST_FIELDS - MATRIX_OBJECT_FIELDS\n103: MATRIX_UPDATE_FIELDS = set(MATRIX_AGENT_FIELDS)\n104: MATRIX_ADD_FIELDS = MATRIX_UPDATE_FIELDS | {\n105:     \"featureId\",\n106:     \"featureName\",\n107:     \"sourcePath\",\n108:     \"importance\",\n109:     \"category\",\n110:     \"riskTags\",\n111:     \"keyClasses\",\n112:     \"keyMethods\",\n113:     \"androidIds\",\n114:     \"dependencies\",\n115:     \"featurePoint\",\n116:     \"sourceEvidence\",\n117: }\n118: MATRIX_ADD_REQUIRED_FIELDS = {\"featureId\", \"featureName\", \"sourcePath\", \"importance\", \"sourceEvidence\"}\n119: MATRIX_REQUIRED_LIST_FIELDS = (\"verificationEvidence\", \"targetEndpoints\", \"tests\")\n120: MATRIX_REQUIRED_TEXT_FIELDS = (\n121:     \"plannedPhase\",\n122:     \"sourceBehavior\",\n123:     \"targetBehavior\",\n124:     \"notes\",\n125:     \"deferredReason\",\n126:     \"targetFallback\",\n127:     \"risk\",\n128:     \"futureCompletionPath\",\n129: )\n130: \n131: PLATFORM_OBJECT_FIELDS = {CAPABILITY_FACTS_KEY}\n132: PLATFORM_LIST_FIELDS = {\n133:     \"targetCapabilitySearch\",\n134:     \"targetEndpoints\",\n135:     \"tests\",\n136:     \"sdkDeclarationEvidence\",\n137:     \"cangjieCallableEvidence\",\n138:     \"discoveryOnlyEvidence\",\n139:     \"compileProbeEvidence\",\n140: }\n141: PLATFORM_TEXT_FIELDS = {\n142:     \"status\",\n143:     \"plannedPhase\",\n144:     \"targetApiOrLibrary\",\n145:     \"targetStrategy\",\n146:     \"preResolutionDecision\",\n147:     \"phaseCapabilityResolution\",\n148:     \"blocker\",\n149:     \"targetFallback\",\n150:     \"futureCompletionPath\",\n151:     \"notes\",\n152: }\n153: PLATFORM_UPDATE_FIELDS = PLATFORM_LIST_FIELDS | PLATFORM_TEXT_FIELDS | PLATFORM_OBJECT_FIELDS\n154: PLATFORM_ADD_FIELDS = PLATFORM_UPDATE_FIELDS | {\n155:     \"capabilityId\",\n156:     \"capabilityName\",\n157:     \"importance\",\n158:     \"sourcePaths\",\n159:     \"sourceEvidence\",\n160:     \"sourceEvidenceSummary\",\n161:     \"requiredTargetCapabilitySearch\",\n162:     \"targetStrategyHint\",\n163:     \"minimumParity\",\n164:     \"requiredTests\",\n165:     \"allowedDeferredReasons\",\n166: }\n167: PLATFORM_ADD_REQUIRED_FIELDS = {\"capabilityId\", \"capabilityName\", \"importance\", \"sourceEvidenceSummary\"}\n168: \n169: \n170: class PatchError(ValueError):\n171:     \"\"\"Raised for user-facing patch validation errors.\"\"\"\n172: \n173: \n174: @dataclass(frozen=True)\n175: class PatchContext:\n176:     target_project: Path | None = None\n177:     legal_phases: frozenset[str] | None = None\n178:     allow_missing_endpoints: bool = False\n179:     allow_unknown_phase: bool = False\n180: \n181: \n182: def parse_args() -> argparse.Namespace:\n183:     parser = argparse.ArgumentParser(\n184:         description=(\n185:             \"Apply a strict JSON patch payload to source-coverage-matrix.json or \"\n186:             \"platform-capability-check.json and optionally sync the Markdown view.\"\n187:         ),\n188:         formatter_class=HelpFormatter,\n189:     )\n190:     parser.add_argument(\n191:         \"--kind\",\n192:         choices=(\"auto\", \"matrix\", \"platform\"),\n193:         default=\"auto\",\n194:         help=\"Authority type. auto infers from the authority filename.\",\n195:     )\n196:     parser.add_argument(\"--authority\", required=True, help=\"Authority JSON path to patch.\")\n197:     parser.add_argument(\n198:         \"--patch\",\n199:         default=\"\",\n200:         help=\"Strict JSON patch payload. Omit with --validate-only to just validate the authority.\",\n201:     )\n202:     parser.add_argument(\"--validate-only\", action=\"store_true\", help=\"Validate the authority without applying a patch.\")\n203:     parser.add_argument(\"--dry-run\", action=\"store_true\", help=\"Validate and summarize without writing files.\")\n204:     parser.add_argument(\n205:         \"--markdown\",\n206:         default=\"\",\n207:         help=\"Markdown mirror path. Defaults to the authority path with .md suffix.\",\n208:     )\n209:     parser.add_argument(\"--no-markdown\", action=\"store_true\", help=\"Do not sync the Markdown mirror.\")\n210:     parser.add_argument(\"--summary-json\", default=\"\", help=\"Optional path for a machine-readable patch summary.\")\n211:     parser.add_argument(\n212:         \"--max-markdown-files\",\n213:         type=int,\n214:         default=250,\n215:         help=\"Maximum rows rendered in the Markdown mirror.\",\n216:     )\n217:     parser.add_argument(\n218:         \"--target-project\",\n219:         default=\"\",\n220:         help=(\n221:             \"Optional target project root. When set, targetEndpoints touched by this patch must point \"\n222:             \"to existing target files, with optional ::symbol checks.\"\n223:         ),\n224:     )\n225:     parser.add_argument(\n226:         \"--plan-json\",\n227:         default=\"\",\n228:         help=\"Optional strict plan.json. When set, plannedPhase values touched by this patch must exist in phases[].\",\n229:     )\n230:     parser.add_argument(\n231:         \"--allow-missing-endpoints\",\n232:         action=\"store_true\",\n233:         help=\"Skip targetEndpoints filesystem/symbol validation even when --target-project is set.\",\n234:     )\n235:     parser.add_argument(\n236:         \"--allow-unknown-phase\",\n237:         action=\"store_true\",\n238:         help=\"Skip plannedPhase validation even when --plan-json is set.\",\n239:     )\n240:     return parser.parse_args()\n241: \n242: \n243: def load_strict_json(path: Path, label: str) -> Any:\n244:     try:\n245:         return json.loads(path.read_text(encoding=\"utf-8\"))\n246:     except FileNotFoundError as exc:\n247:         raise PatchError(f\"{label} does not exist: {path}\") from exc\n248:     except json.JSONDecodeError as exc:\n249:         raise PatchError(f\"{label} is not strict JSON: {exc}\") from exc\n250:     except OSError as exc:\n251:         raise PatchError(f\"Could not read {label}: {exc}\") from exc\n252: \n253: \n254: def phase_label(raw: str) -> str:\n255:     value = str(raw).strip()\n256:     if not value:\n257:         return \"\"\n258:     if value.isdigit():\n259:         return f\"phase-{int(value):02d}\"\n260:     return value\n261: \n262: \n263: def phases_from_plan_data(data: Any) -> list[str]:\n264:     if not isinstance(data, dict):\n265:         return []\n266:     phases = data.get(\"phases\")\n267:     if not isinstance(phases, list):\n268:         return []\n269:     found: list[str] = []\n270:     for item in phases:\n271:         candidate = \"\"\n272:         if isinstance(item, dict):\n273:             candidate = str(item.get(\"id\") or item.get(\"name\") or item.get(\"phase\") or \"\").strip()\n274:         elif isinstance(item, str):\n275:             candidate = item.strip()\n276:         labeled = phase_label(candidate)\n277:         if labeled:\n278:             found.append(labeled)\n279:     return list(dict.fromkeys(found))\n280: \n281: \n282: def patch_context_from_args(args: argparse.Namespace) -> PatchContext:\n283:     target_project = expand_path(args.target_project) if args.target_project else None\n284:     if target_project is not None and not target_project.exists():\n285:         raise PatchError(f\"target project does not exist: {target_project}\")\n286:     if target_project is not None and not target_project.is_dir():\n287:         raise PatchError(f\"target project is not a directory: {target_project}\")\n288: \n289:     legal_phases: frozenset[str] | None = None\n290:     if args.plan_json and not args.allow_unknown_phase:\n291:         plan_path = expand_path(args.plan_json)\n292:         if plan_path is None:\n293:             raise PatchError(\"--plan-json was provided but did not resolve to a path.\")\n294:         plan_data = load_strict_json(plan_path, \"plan json\")\n295:         phases = phases_from_plan_data(plan_data)\n296:         if not phases:\n297:             raise PatchError(f\"plan json does not define a non-empty top-level phases array: {plan_path}\")\n298:         legal_phases = frozenset(phases)\n299: \n300:     return PatchContext(\n301:         target_project=target_project,\n302:         legal_phases=legal_phases,\n303:         allow_missing_endpoints=bool(args.allow_missing_endpoints),\n304:         allow_unknown_phase=bool(args.allow_unknown_phase),\n305:     )\n306: \n307: \n308: def infer_kind(kind: str, authority: Path) -> str:\n309:     if kind != \"auto\":\n310:         return kind\n311:     name = authority.name\n312:     if name == \"source-coverage-matrix.json\":\n313:         return \"matrix\"\n314:     if name == \"platform-capability-check.json\":\n315:         return \"platform\"\n316:     raise PatchError(\n317:         \"Could not infer authority kind from filename. Pass --kind matrix or --kind platform explicitly.\"\n318:     )\n319: \n320: \n\n(Showing lines 1-320 of 973. Use offset=321 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n\"\"\"Apply narrow, validated patches to agent-maintained coverage authorities.\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport copy\nimport json\nimport re\nimport sys\nfrom collections import Counter\nfrom dataclasses import dataclass\nfrom pathlib import Path\nfrom typing import Any\n\nif __package__ in (None, \"\"):\n    sys.path.insert(0, str(Path(__file__).resolve().parents[2]))\n    from shared.common import HelpFormatter, expand_path, now_iso, write_json, write_text  # type: