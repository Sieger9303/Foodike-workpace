 @Assert(transition.resetState.historySearchQuery, \"\")\n63:         @Assert(transition.resetState.historyTabIndex, 0)\n64:     }\n65: \n66:     @TestCase\n67:     public func profileBackRouteUsesTheNavigationStackWhenPresent(): Unit {\n68:         let routeService = ProfileRouteService()\n69:         let backStack = ArrayList<String>([])\n70:         backStack.add(routePath(RouteId.Home))\n71:         backStack.add(routePath(RouteId.History))\n72:         @Assert(routeService.resolveBackRoute(routePath(RouteId.Profile), backStack), routePath(RouteId.History))\n73:         @Assert(routeService.canNavigateBack(routePath(RouteId.Profile), backStack), true)\n74:         let emptyBackStack = ArrayList<String>([])\n75:         @Assert(routeService.resolveBackRoute(routePath(RouteId.Profile), emptyBackStack), routePath(RouteId.Profile))\n76:         @Assert(routeService.canNavigateBack(routePath(RouteId.Profile), emptyBackStack), false)\n77:     }\n78: \n79:     @TestCase\n80:     public func startupResolverReturnsOnboardingAfterLogoutStyleState(): Unit {\n81:         @Assert(resolveStartRoute(false), routePath(RouteId.Onboarding))\n82:         @Assert(resolveStartRoute(true), routePath(RouteId.Home))\n83:     }\n84: \n85:     @TestCase\n86:     public func sourceExampleUnitAssertionIntentIsCoveredByTargetHarness(): Unit {\n87:         @Assert(2 + 2, 4)\n88:     }\n89: }\n\n(End of file - total 89 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, resolveStartRoute, routePath}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{ProfileAction, ProfileRouteService, ProfileSection, ProfileStore}\nimport std.collection.ArrayList\nimport std.unittest.*\nimport std.unittest.testmacro.*\n\n@Test\npublic class Phase06ProfileCapabilitiesVerificationTest {\n    @TestCase\n    public func profileStorePreservesStaticIdentityAndPlaceholderActions(): Unit {\n        le