    @State\n26:     var isShellAtTop: Bool = true\n27: \n28:     @State\n29:     var onboardingPageIndex: Int64 = 0\n30: \n31:     @State\n32:     var loginEmail: String = \"\"\n33: \n34:     @State\n35:     var loginPassword: String = \"\"\n36: \n37:     @State\n38:     var loginErrorMessage: String = \"\"\n39: \n40:     @State\n41:     var homeSearchQuery: String = \"\"\n42: \n43:     @State\n44:     var homeSelectedFilter: String = \"\"\n45: \n46:     @State\n47:     var historySearchQuery: String = \"\"\n48: \n49:     @State\n50:     var historyTabIndex: Int64 = 0\n51: \n52:     @State\n53:     var previousRoute: String = \"home_screen\"\n54: \n55:     @State\n56:     var cartNote: String = \"\"\n57: \n58:     @State\n59:     var cartCoupon: String = \"\"\n60: \n61:     @State\n62:     var cartMutationRevision: Int64 = 0\n63: \n64:     @State\n65:     var detailRecommendedExpanded: Bool = true\n66: \n67:     @State\n68:     var detailNonVegExpanded: Bool = true\n69: \n70:     @State\n71:     var detailVegExpanded: Bool = true\n72: \n73:     @State\n74:     var detailLiked: Bool = false\n75: \n76:     @State\n77:     var detailMutationRevision: Int64 = 0\n78: \n79:     private var onboardingController: SwiperController = SwiperController()\n80: \n81:     private func applyShellState(shellState: ShellRouteState): Unit {\n82:         this.currentRoute = shellState.currentRoute\n83:         this.isShellAtTop = shellState.isAtTop\n84:     }\n85: \n86:     private func shellState(): ShellRouteState {\n87:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n88:     }\n89: \n90:     private func applyShellCommand(command: ShellCommand): Unit {\n91:         let shellState = this.shellState()\n92:         shellState.applyCommand(command)\n93:         this.applyShellState(shellState)\n94:     }\n95: \n96:     private func navigateTo(route: String): Unit {\n97:         let shellState = this.shellState()\n98:         this.previousRoute = shellState.currentRoute\n99:         shellState.currentRoute = route\n100:         shellState.isAtTop = true\n101:         this.applyShellState(shellState)\n102:     }\n103: \n104:     private func navigateBack(): Unit {\n105:         let targetRoute = this.previousRoute\n106:         this.previousRoute = this.currentRoute\n107:         this.navigateTo(targetRoute)\n108:     }\n109: \n110:     private func showBottomShell(route: String): Bool {\n111:         let shellState = this.shellState()\n112:         shellState.currentRoute = route\n113:         return shellState.showBottomShell()\n114:     }\n115: \n116:     private func routeTitle(route: String): String {\n117:         match (route) {\n118:             case \"onboarding\" => \"Onboarding\"\n119:             case \"login_screen\" => \"Login\"\n120:             case \"home_screen\" => \"Home\"\n121:             case \"history\" => \"History\"\n122:             case \"cart\" => \"Cart\"\n123:             case \"profile\" => \"Profile\"\n124:             case \"restaurant_details\" => \"Restaurant Detail\"\n125:             case _ => \"Unknown Route\"\n126:         }\n127:     }\n128: \n129:     private func showToast(message: String): Unit {\n130:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n131:     }\n132: \n133:     private func clearLoginError(): Unit {\n134:         this.loginErrorMessage = \"\"\n135:     }\n136: \n137:     private func performLogin(): Unit {\n138:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n139:             this.clearLoginError()\n140:             this.navigateTo(loginStore.successRoute())\n141:             return\n142:         }\n143: \n144:         this.loginErrorMessage = loginStore.invalidLoginMessage\n145:         this.showToast(loginStore.invalidLoginMessage)\n146:     }\n147: \n148:     private func performLogout(): Unit {\n149:         profileStore.logout(Global.abilityContext)\n150:         this.loginEmail = \"\"\n