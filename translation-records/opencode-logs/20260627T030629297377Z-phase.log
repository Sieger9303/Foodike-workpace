\Foodike\\Foodike-Harmony\\entry\\oh-package.json5\nD:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\app_ability.cj\nD:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ability_stage.cj\nD:\\workspace\\Foodike\\Foodike-Harmony\\entry\\build-profile.json5\nD:\\workspace\\Foodike\\Foodike-Harmony\\build-profile.json5\nD:\\workspace\\Foodike\\Foodike-Harmony\\AppScope\\resources\\base\\element\\string.json\nD:\\workspace\\Foodike\\Foodike-Harmony\\AppScope\\resources\\base\\element\\color.json\nD:\\workspace\\Foodike\\Foodike-Harmony\\AppScope\\app.json5\nD:\\workspace\\Foodike\\Foodike-Harmony\\.hvigor\\dependencyMap\\oh-package.json5\nD:\\workspace\\Foodike\\Foodike-Harmony\\.hvigor\\dependencyMap\\entry\\oh-package.json5\nD:\\workspace\\Foodike\\Foodike-Harmony\\.hvigor\\dependencyMap\\dependencyMap.json5\nD:\\workspace\\Foodike\\Foodike-Harmony\\.mapcir.json","metadata":{"count":98,"truncated":false},"title":"Foodike-Harmony","time":{"start":1782529614730,"end":1782529614780}},"id":"prt_f070b6380001RpfGVPQgA0XQpx","sessionID":"ses_0f8f4f9d2ffe5W14KuM6UkbyWC","messageID":"msg_f070b4d24001idUpHW5WzVqOy1"}}
