7: \n188:     private func detailState(): DetailPageState {\n189:         return detailStore.loadDetailState(\n190:             this.detailRecommendedExpanded,\n191:             this.detailNonVegExpanded,\n192:             this.detailVegExpanded\n193:         )\n194:     }\n195: \n196:     private func selectHomeRestaurant(restaurant: RestaurantData): Unit {\n197:         homeStore.selectRestaurant(restaurant, { =>\n198:             this.goToRestaurantDetail()\n199:         })\n200:     }\n201: \n202:     private func selectHistoryRestaurant(restaurant: RestaurantData): Unit {\n203:         historyStore.selectRestaurant(restaurant, { =>\n204:             this.goToRestaurantDetail()\n205:         })\n206:     }\n207: \n208:     @Builder\n209:     private func buildOnboardingRoute() {\n210:         renderOnboardingRoute(\n211:             this.onboardingPageIndex,\n212:             this.onboardingController,\n213:             { index: Int32 =>\n214:                 this.onboardingPageIndex = Int64(index)\n215:             },\n216:             { =>\n217:                 if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n218:                     this.navigateTo(routePath(RouteId.Login))\n219:                 } else {\n220:                     this.onboardingController.showNext()\n221:                 }\n222:             }\n223:         )\n224:     }\n225: \n226:     @Builder\n227:     private func buildLoginRoute() {\n228:         renderLoginRoute(\n229:             this.loginEmail,\n230:             this.loginPassword,\n231:             this.loginErrorMessage,\n232:             { value: String =>\n233:                 this.loginEmail = value\n234:                 this.clearLoginError()\n235:             },\n236:             { value: String =>\n237:                 this.loginPassword = value\n238:                 this.clearLoginError()\n239:             },\n240:             { => this.showToast(loginStore.comingSoonMessage) },\n241:             { => this.performLogin() },\n242:             { => this.showToast(loginStore.comingSoonMessage) },\n243:             { => this.showToast(loginStore.comingSoonMessage) },\n244:             { => this.showToast(loginStore.comingSoonMessage) },\n245:             { => this.clearLoginError() }\n246:         )\n247:     }\n248: \n249:     @Builder\n250:     private func buildProfileRoute() {\n251:         renderProfileRoute(\n252:             profileStore.userName,\n253:             profileStore.userEmail,\n254:             { => this.navigateTo(profileStore.backRoute()) },\n255:             { => this.showToast(profileStore.placeholderActionMessage) },\n256:             { => this.showToast(profileStore.placeholderActionMessage) },\n257:             { => this.performLogout() }\n258:         )\n259:     }\n260: \n261:     @Builder\n262:     private func buildHomeRoute() {\n263:         renderHomeRoute(\n264:             homeStore.loadHomeState(),\n265:             this.homeHour(),\n266:             this.homeSearchQuery,\n267:             this.homeSelectedFilter,\n268:             { value: String =>\n269:                 this.homeSearchQuery = value\n270:             },\n271:             { value: String =>\n272:                 this.homeSelectedFilter = homeStore.toggleFilter(this.homeSelectedFilter, value)\n273:             },\n274:             { => this.goToProfile() },\n275:             { restaurant: RestaurantData =>\n276:                 this.selectHomeRestaurant(restaurant)\n277:             }\n278:         )\n279:     }\n280: \n281:     @Builder\n282:     private func buildHistoryRoute() {\n283:         renderHistoryRoute(\n284:             historyStore.loadHistoryState(),\n285:             this.historyTabIndex,\n286:             this.historySearchQuery,\n287:             { value: String =>\n288:                 this.historySearchQuery = value\n289:             },\n290:             { value: Int64 =>\n291:                 this.historyTabIndex = value\n292:             },\n293:             { restaurant: RestaurantData =>\n294:                 this.selectHistoryRestaurant(restaurant)\n295:             }\n296:         )\n297:     }\n298: \n299:     @Builder\n300:     private func buildCartRoute() {\n301:         renderCartRoute(\n302:             cartStore.loadCartState(),\n303:             this.cartNote,\n304:             this.cartCoupon,\n305:             { value: String =>\n306:                 this.cartNote = value\n307:             },\n308:             { value: String =>\n309:                 this.cartCoupon = value\n310:             },\n311:             { item: CartSnapshotItemData =>\n312:                 cartStore.decrementQuantity(item)\n313:                 this.cartMutationRevision += 1\n314:             },\n315:             { item: CartSnapshotItemData =>\n316:                 cartStore.incrementQuantity(item)\n317:                 this.cartMutationRevision += 1\n318:             },\n319:             { =>\n320:                 this.navigateBack()\n321:             }\n322:         )\n323:     }\n324: \n325:     @Builder\n326:     private func buildDetailRoute() {\n327:         renderDetailRoute(\n328:             this.detailState(),\n329:             { =>\n330:                 this.navigateBack()\n331:             },\n332:             { =>\n333:                 let restaurant = detailStore.selectedRestaurant()\n334:                 this.detailLiked = detailStore.toggleLiked(restaurant, this.detailLiked)\n335:             },\n336:             { =>\n337:                 this.showToast(\"Share coming soon\")\n338:             },\n339:             { =>\n340:                 this.detailRecommendedExpanded = !this.detailRecommendedExpanded\n341:             },\n342:             { =>\n343:                 this.detailNonVegExpanded = !this.detailNonVegExpanded\n344:             },\n345:             { =>\n346:                 this.detailVegExpanded = !this.detailVegExpanded\n347:             },\n348:             { item: DetailMenuItemData =>\n349: 