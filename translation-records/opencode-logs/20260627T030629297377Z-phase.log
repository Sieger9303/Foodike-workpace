e { Color.White })\n42: }\n43: \n44: @Builder\n45: public func renderOnboardingRoute(\n46:     pageIndex: Int64,\n47:     controller: SwiperController,\n48:     onIndexChanged: (Int32) -> Unit,\n49:     onNext: () -> Unit\n50: ) {\n51:     Column(space: 24) {\n52:         Swiper(controller: controller) {\n53:             buildOnboardingCard(\n54:                 onboardingStore.slideAt(0).title,\n55:                 onboardingStore.slideAt(0).description,\n56:                 onboardingStore.slideAt(0).mediaName\n57:             )\n58:             buildOnboardingCard(\n59:                 onboardingStore.slideAt(1).title,\n60:                 onboardingStore.slideAt(1).description,\n61:                 onboardingStore.slideAt(1).mediaName\n62:             )\n63:             buildOnboardingCard(\n64:                 onboardingStore.slideAt(2).title,\n65:                 onboardingStore.slideAt(2).description,\n66:                 onboardingStore.slideAt(2).mediaName\n67:             )\n68:         }\n69:         .indicator(false)\n70:         .onChange({ index: Int32 =>\n71:             onIndexChanged(index)\n72:         })\n73:         .width(100.percent)\n74:         .height(78.percent)\n75: \n76:         Row {\n77:             Row(space: 12) {\n78:                 buildOnboardingIndicator(pageIndex == 0)\n79:                 buildOnboardingIndicator(pageIndex == 1)\n80:                 buildOnboardingIndicator(pageIndex == 2)\n81:             }\n82:             Button(\">\")\n83:                 .onClick({ _ =>\n84:                     onNext()\n85:                 })\n86:         }\n87:         .width(90.percent)\n88:         .justifyContent(FlexAlign.SpaceBetween)\n89:         .alignItems(VerticalAlign.Center)\n90:         .margin(bottom: 12)\n91:     }\n92:     .width(100.percent)\n93:     .height(100.percent)\n94:     .backgroundColor(colorDarkGreen)\n95:     .alignItems(HorizontalAlign.Center)\n96:     .justifyContent(FlexAlign.SpaceBetween)\n97: }\n\n(End of