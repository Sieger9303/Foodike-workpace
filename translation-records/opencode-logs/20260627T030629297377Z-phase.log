 }\n33: \n34:     public func session(): SessionRepository {\n35:         return sessionRepository\n36:     }\n37: }\n\n(End of file - total 37 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\npublic let historyStore = HistoryStore()\n\npublic class HistoryStore {\n    private let sessionRepository = sessionRepository\n    private let orderHistory = ArrayList<HistoryRecordData>([\n        HistoryRecordData(\"Fish n Rolls\", \"Tezpur\", \"13 Aug 2022, 11:12 PM\", \"$7.90\", \"Chinese Shawarma\\nCombo (1)\", false, 5, 5, \"Delivered\", \"Reorder\"),\n        HistoryRecordData(\"Fish n Rolls\", \"Tezpur\", \"13 Aug 2022, 11:12 PM\", \"$7.90\", \"Chinese Shawarma\\nCombo (1)\", false, 0, 0, \"Delivered\", \"Rate Order\")\n    ])\n\n    public init() {}\n\n    public func loadHistoryState(): HistoryPageState {\n        return HistoryPageState(sessionRepository.getLikedRestaurants(), orderHistory)\n    }","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_store.cj","time":{"start":1782529884224,"end":1782529884231}},"id":"prt_f070f7ffa001jzIHnMg3RTIrKO","sessionID":"ses_0f8f4f9d2ffe5W14KuM6UkbyWC","messageID":"msg_f070f5bf2001riepaPyljeZ09c"}}
{"type":"tool_use","timestamp":1782529884303,"sessionID":"ses_0f8f4f9d2ffe5W14KuM6UkbyWC","part":{"type":"tool","tool":"read","callID":"call_n41eXdmFN7IV2rk5jpnDrHwx","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_page.cj","limit":170},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history\n2: \n3: import kit.ArkUI.*\n4: import ohos.arkui.state_macro_manage.Builder\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaIcNonVeg, mediaIcVeg}\n6: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.{renderRestaurantCard, renderSearchBar}\n7: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n8: import std.collection.ArrayList\n9: \n10: @Builder\n11: func buildHistoryTabs(selectedTab: Int64, onTabSelect: (Int64) -> Unit) {\n12:     Row(space: 18) {\n13:         Text(historyStore.tabLabel(0))\n14:             .fontSize(18)\n15:             .fontWeight(if (selectedTab == 0) { FontWeight.Bold } else { FontWeight.Regular })\n16:             .onClick({ _ =>\n17:                 onTabSelect(0)\n18:             })\n19:         Text(historyStore.tabLabel(1))\n20:             .fontSize(18)\n21:             .fontWeight(if (selectedTab == 1) { FontWeight.Bold } else { FontWeight.Regular })\n22:             .onClick({ _ =>\n23:                 onTabSelect(1)\n24:             })\n25:     }\n26:     .width(100.percent)\n27: }\n28: \n29: @Builder\n30: func buildHistoryStatusRow(statusText: String) {\n31:     Row(space: 6) {\n32:         Text(statusText)\n33:             .fontSize(14)\n34:             .fontColor(Color.Gray)\n35:         Text(\".\")\n36:             .fontWeight(FontWeight.Bold)\n37:             .fontColor(0xFF228D39)\n38:     }\n39: }\n40: \n41: @Builder\n42: func buildHistoryRecordCard(record: HistoryRecordData) {\n43:     Column(space: 10) {\n44:         Row {\n45:             Column(space: 4) {\n46:                 Text(record.restaurantName)\n47:                     .fontWeight(FontWeight.Bold)\n48:                 Text(record.place)\n49:                     .fontSize(14)\n50:                     .fontColor(Color.Gray)\n51:                 Text(record.timestampText)\n52:                     .fontSize(14)\n53:                     .fontColor(Color.Gray)\n54:             }\n55:             .layoutWeight(1)\n56:             Text(record.totalText)\n57:                 .fontSize(16)\n58:         }\n59: \n60:         Divider().width(100.percent)\n61: \n62:         Row(space: 10) {\n63:             Image(if (record.isVeg) { mediaIcVeg } else { mediaIcNonVeg })\n64:                 .width(16)\n65:                 .height(16)\n66:             Text(record.itemSummary)\n67:                 .layoutWeight(1)\n68:                 .fontSize(14)\n69:             Button(record.actionText)\n70:         }\n71:         .alignItems(VerticalAlign.Center)\n72: \n73:         if (record.deliveryRating > 0) {\n74:             Row {\n75:                 Column(space: 4) {\n76:                     Text(\"Your rating for delivery\")\n77:                         .fontSize(14)\n78:                         .fontColor(Color.Gray)\n79:                     Text(\"Your rating for food\")\n80:                         .fontSize(14)\n81:                         .fontColor(Color.Gray)\n82:                 }\n83:                 .layoutWeight(1)\n84:                 Column(space: 4) {\n85:                     Text(\"* ${record.deliveryRating}\")\n86:                     Text(\"* ${record.foodRating}\")\n87:                 }\n88:                 buildHistoryStatusRow(record.statusText)\n89:             }\n90:             .alignItems(VerticalAlign.Center)\n91:         } else {\n92:             Row {\n93:                 Text(record.actionText)\n94:                     .fontSize(16)\n95:                     .fontWeight(FontWeight.Bold)\n96:                     .fontColor(0xFF228D39)\n97:                 Blank().layoutWeight(1)\n98:                 buildHistoryStatusRow(record.statusText)\n99:             }\n100:             .alignItems(VerticalAlign.Center)\n101:         }\n102:     }\n103:     .width(100.percent)\n104:     .padding(top: 14, right: 14, bottom: 14, left: 14)\n105:     .backgroundColor(Color.White)\n106:     .borderRadius(16)\n107: }\n108: \n109: @Builder\n110: func buildHistoryRecords(records: ArrayList<HistoryRecordData>) {\n111:     Column(space: 10) {\n112:         ForEach(records, itemGeneratorFunc: { record: HistoryRecordData, _: Int64 =>\n113:             buildHistoryRecordCard(record)\n114:         })\n115:     }\n116:     .width(100.percent)\n117: }\n118: \n119: @Builder\n120: func buildHistoryFavourites(favourites: ArrayList<RestaurantData>, onSelectRestaurant: (RestaurantData) -> Unit) {\n121:     if (favourites.size > 0) {\n122:         Column(space: 10) {\n123:             ForEach(favourites, itemGeneratorFunc: { restaurant: RestaurantData, _: Int64 =>\n124:                 renderRestaurantCard(restaurant, { =>\n125:                     onSelectRestaurant(restaurant)\n126:                 })\n127:             })\n128:         }\n129:         .width(100.percent)\n130:     } else {\n131:         Row {\n132:             Text(\"Empty\")\n133:                 .fontSize(16)\n134:         }\n135:         .width(100.percent)\n136:         .justifyContent(FlexAlign.Center)\n137:     }\n138: }\n139: \n140: @Builder\n141: public func renderHistoryRoute(\n142:     state: HistoryPageState,\n143:     selectedTab: Int64,\n144:     query: String,\n145:     onQueryChange: (String) -> Unit,\n146:     onTabSelect: (Int64) -> Unit,\n147:     onSelectRestaurant: (RestaurantData) -> Unit\n148: ) {\n149:     Scroll(Scroller()) {\n150:         Column(space: 14) {\n151:             renderSearchBar(query, onQueryChange)\n152:             buildHistoryTabs(selectedTab, onTabSelect)\n153:             if (selectedTab == 0) {\n154:                 buildHistoryRecords(state.records)\n155:             } else {\n156:                 buildHistoryFavourites(state.favourites, onSelectRestaurant)\n157:             }\n158:         }\n159:         .width(100.percent)\n160:         .padding(top: 16, right: 16, bottom: 24, left: 16)\n161:     }\n162:     .scrollable(ScrollDirection.Vertical)\n163:     .scrollBar(BarState.Off)\n164:     .width(100.percent)\n165:     .height(100.percent)\n166:     .backgroundColor(Color.White)\n167: }\n\n(End of file - total 167 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaIcNonVeg, mediaIcVeg}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.{renderRestaurantCard, renderSearchBar}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\n@Builder\nfunc buildHistoryTabs(selectedTab: Int64, onTabSelect: (Int64) -> Unit) {\n    Row(space: 18) {\n        Text(historyStore.tabLabel(0))\n            .fontSize(18)\n            .fontWeight(if (selectedTab == 0) { FontWeight.Bold } else { FontWeight.Regular })\n            .onClick({ _ =>\n                onTabSelect(0)\n            })\n        Text(historyStore.tabLabel(1))\n            .fontSize(18)","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_page.cj","time":{"start":1782529884296,"end":1782529884302}},"id":"prt_f070f80420016uxTBCiP8UAnGX","sessionID":"ses_0f8f4f9d2ffe5W14KuM6UkbyWC","messageID":"msg_f070f5bf2001riepaPyljeZ09c"}}
{"type":"tool_use","timestamp":1782529884373,"sessionID":"ses_0f8f4f9d2ffe5W14KuM6UkbyWC","part":{"type":"tool","tool":"read","callID":"call_qUgqYuTcpvgiaHb10N5Zg4UX","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\detail\\detail_page.cj","limit":280},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\detail\\detail_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail\n2: \n3: import kit.ArkUI.*\n4: import ohos.arkui.state_macro_manage.Builder\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n6: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.restaurantMedia\n7: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n8: import std.collection.ArrayList\n9: \n10: @Builder\n11: func buildDetailTopBar(isLiked: Bool, onBack: () -> Unit, onToggleLike: () -> Unit, onShare: () -> Unit) {\n12:     Row {\n13:         Button(\"<\")\n14:             .onClick({ _ =>\n15:                 onBack()\n16:             })\n17:         Blank().layoutWeight(1)\n18:         Row(space: 12) {\n19:             Text(if (isLiked) { \"Heart\" } else { \"Like\" })\n20:                 .fontColor(if (isLiked) { Color.Red } else { Color.Black })\n21:                 .fontWeight(FontWeight.Bold)\n22:                 .onClick({ _ =>\n23:                     onToggleLike()\n24:                 })\n25:             Text(\"Share\")\n26:                 .fontColor(Color.Gray)\n27:                 .onClick({ _ =>\n28:                     onShare()\n29:                 })\n30:         }\n31:     }\n32:     .width(100.percent)\n33:     .alignItems(VerticalAlign.Center)\n34: }\n35: \n36: @Builder\n37: func buildRestaurantDetailCard(restaurant: RestaurantData) {\n38:     Column(space: 12) {\n39:         Text(restaurant.name)\n40:             .fontSize(26)\n41:             .fontWeight(FontWeight.Bold)\n42:         Row(space: 6) {\n43:             Image(mediaStar)\n44:                 .width(18)\n45:                 .height(18)\n46:             Text(detailStore.formatRestaurantMeta(restaurant))\n47:                 .fontSize(14)\n48:         }\n49:         Text(restaurant.variety)\n50:             .fontSize(14)\n51:             .fontColor(Color.Gray)\n52:         Text(restaurant.place)\n53:             .fontSize(14)\n54:             .fontColor(Color.Gray)\n55: \n56:         Row(space: 14) {\n57:             Image(mediaOutletCard)\n58:                 .width(42)\n59:                 .height(42)\n60:             Column(space: 4) {\n61:                 Text(\"Outlet\")\n62:                     .fontWeight(FontWeight.Medium)\n63:                 Text(\"${restaurant.etaMinutes} Min\")\n64:                     .fontColor(Color.Gray)\n65:             }\n66:             Blank().layoutWeight(1)\n67:             Column(space: 4) {\n68:                 Text(restaurant.place)\n69:                     .fontColor(Color.Gray)\n70:                 Text(\"Your location\")\n71:                     .fontColor(Color.Gray)\n72:             }\n73:         }\n74:         .width(100.percent)\n75:     }\n76:     .width(100.percent)\n77:     .padding(top: 18, right: 18, bottom: 18, left: 18)\n78:     .backgroundColor(0xFFC6FDB3)\n79:     .borderRadius(22)\n80: }\n81: \n82: @Builder\n83: func buildMenuQuantityControls(\n84:     item: DetailMenuItemData,\n85:     onAdd: () -> Unit,\n86:     onRemove: () -> Unit\n87: ) {\n88:     if (item.quantity == 0) {\n89:         Text(\"ADD\")\n90:             .fontSize(15)\n91:             .fontWeight(FontWeight.Bold)\n92:             .fontColor(colorDarkGreen)\n93:             .onClick({ _ =>\n94:                 onAdd()\n95:             })\n96:     } else {\n97:         Row(space: 10) {\n98:             Text(\"-\")\n99:                 .fontSize(16)\n100:                 .fontWeight(FontWeight.Bold)\n101:                 .onClick({ _ =>\n102:                     onRemove()\n103:                 })\n104:             Text(\"${item.quantity}\")\n105:                 .fontSize(16)\n106:                 .fontWeight(FontWeight.Medium)\n107:             Text(\"+\")\n108:                 .fontSize(16)\n109:                 .fontWeight(FontWeight.Bold)\n110:                 .fontColor(colorDarkGreen)\n111:                 .onClick({ _ =>\n112:                     onAdd()\n113:                 })\n114:         }\n115:         .padding(top: 6, right: 10, bottom: 6, left: 10)\n116:         .borderRadius(14)\n117:         .border(width: 1.px, color: 0x55000000)\n118:     }\n119: }\n120: \n121: @Builder\n122: func buildMenuItemRow(\n123:     item: DetailMenuItemData,\n124:     onAdd: () -> Unit,\n125:     onRemove: () -> Unit\n126: ) {\n127:     Row(space: 14) {\n128:         Image(if (item.menuItem.isVegetarian) { mediaIcVeg } else { mediaIcNonVeg })\n129:             .width(18)\n130:             .height(18)\n131:         Column(space: 6) {\n132:             Text(item.menuItem.dish)\n133:                 .fontSize(16)\n134:                 .fontWeight(FontWeight.Medium)\n135:             Text(detailStore.formatPrice(item.menuItem.price))\n136:                 .fontSize(14)\n137:                 .fontColor(Color.Gray)\n138:             Row(space: 6) {\n139:                 Image(mediaStar)\n140:                     .width(16)\n141:                     .height(16)\n142:                 Text(\"${item.menuItem.rating}\")\n143:                     .fontSize(13)\n144:                 Text(detailStore.formatRatingCount(item.menuItem.ratingCount))\n145:                     .fontSize(13)\n146:                     .fontColor(Color.Gray)\n147:             }\n148:         }\n149:         .layoutWeight(1)\n150:         buildMenuQuantityControls(item, onAdd, onRemove)\n151:     }\n152:     .width(100.percent)\n153:     .alignItems(VerticalAlign.Center)\n154:     .padding(top: 12, right: 0, bottom: 12, left: 0)\n155: }\n156: \n157: @Builder\n158: func buildSectionHeader(title: String, expanded: Bool, onToggle: () -> Unit) {\n159:     Row {\n160:         Text(title)\n161:             .fontSize(22)\n162:             .fontWeight(FontWeight.Bold)\n163:         Blank().layoutWeight(1)\n164:         Text(if (expanded) { \"v\" } else { \">\" })\n165:             .fontSize(20)\n166:             .fontColor(Color.Gray)\n167:             .onClick({ _ =>\n168:                 onToggle()\n169:             })\n170:     }\n171:     .width(100.percent)\n172:     .alignItems(VerticalAlign.Center)\n173: }\n174: \n175: @Builder\n176: func buildDetailSection(\n177:     title: String,\n178:     expanded: Bool,\n179:     items: ArrayList<DetailMenuItemData>,\n180:     onToggle: () -> Unit,\n181:     onAdd: (DetailMenuItemData) -> Unit,\n182:     onRemove: (DetailMenuItemData) -> Unit\n183: ) {\n184:     Column(space: 8) {\n185:         buildSectionHeader(title, expanded, onToggle)\n186:         if (expanded) {\n187:             ForEach(items, itemGeneratorFunc: { item: DetailMenuItemData, _: Int64 =>\n188:                 buildMenuItemRow(\n189:                     item,\n190:                     { => onAdd(item) },\n191:                     { => onRemove(item) }\n192:                 )\n193:             })\n194:         }\n195:     }\n196:     .width(100.percent)\n197: }\n198: \n199: @Builder\n200: func buildRestaurantHeroImage(restaurant: RestaurantData) {\n201:     Image(restaurantMedia(restaurant.mediaName))\n202:         .width(100.percent)\n203:         .height(200)\n204:         .borderRadius(22)\n205: }\n206: \n207: @Builder\n208: func buildCartFab(onOpenCart: () -> Unit) {\n209:     Row {\n210:         Blank().layoutWeight(1)\n211:         Button(\"Cart\")\n212:             .backgroundColor(colorDarkGreen)\n213:             .fontColor(Color.White)\n214:             .onClick({ _ =>\n215:                 onOpenCart()\n216:             })\n217:     }\n218:     .width(100.percent)\n219: }\n220: \n221: @Builder\n222: public func renderDetailRoute(\n223:     state: DetailPageState,\n224:     onBack: () -> Unit,\n225:     onToggleLike: () -> Unit,\n226:     onShare: () -> Unit,\n227:     onToggleRecommended: () -> Unit,\n228:     onToggleNonVeg: () -> Unit,\n229:     onToggleVeg: () -> Unit,\n230:     onAdd: (DetailMenuItemData) -> Unit,\n231:     onRemove: (DetailMenuItemData) -> Unit,\n232:     onOpenCart: () -> Unit\n233: ) {\n234:     Scroll(Scroller()) {\n235:         Column(space: 16) {\n236:             buildDetailTopBar(state.isLiked, onBack, onToggleLike, onShare)\n237:             buildRestaurantHeroImage(state.restaurant)\n238:             buildRestaurantDetailCard(state.restaurant)\n239:             buildDetailSection(\n240:                 \"Recommended\",\n241:                 state.recommendedExpanded,\n242:                 state.recommendedItems,\n243:                 onToggleRecommended,\n244:                 onAdd,\n245:                 onRemove\n246:             )\n247:             buildDetailSection(\n248:                 \"Non Vegetarian\",\n249:                 state.nonVegExpanded,\n250:                 detailStore.nonVegItems(state.menuItems),\n251:                 onToggleNonVeg,\n252:                 onAdd,\n253:                 onRemove\n254:             )\n255:             buildDetailSection(\n256:                 \"Vegetarian\",\n257:                 state.vegExpanded,\n258:                 detailStore.vegItems(state.menuItems),\n259:                 onToggleVeg,\n260:                 onAdd,\n261:                 onRemove\n262:             )\n263:             if (detailStore.shouldShowCartAction(state.menuItems)) {\n264:                 buildCartFab(onOpenCart)\n265:             }\n266:         }\n267:         .width(100.percent)\n268:         .padding(top: 14, right: 16, bottom: 24, left: 16)\n269:     }\n270:     .scrollable(ScrollDirection.Vertical)\n271:     .scrollBar(BarState.Off)\n272:     .width(100.percent)\n273:     .height(100.percent)\n274:     .backgroundColor(Color.White)\n275: }\n\n(End of file - total 275 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.restaurantMedia\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\n@Builder\nfunc buildDetailTopBar(isLiked: Bool, onBack: () -> Unit, onToggleLike: () -> Unit, onShare: () -> Unit) {\n    Row {\n        Button(\"<\")\n            .onClick({ _ =>\n                onBack()\n            })\n        Blank().layoutWeight(1)\n        Row(space: 12) {\n            Text(if (isLiked) { \"Heart\" } else { \"Like\" })\n                .fontColor(if (isLiked) { Color.Red } else { Color.Black })","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\detail\\detail_page.cj","time":{"start":1782529884366,"end":1782529884372}},"id":"prt_f070f8089001aIgfARRJqxAcBe","sessionID":"ses_0f8f4f9d2ffe5W14KuM6UkbyWC","messageID":"msg_f070f5bf2001riepaPyljeZ09c"}}
