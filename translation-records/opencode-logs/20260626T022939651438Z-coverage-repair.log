earch\": [],\n669:         \"targetStrategyHint\": \"\",\n670:         \"minimumParity\": \"\",\n671:         \"requiredTests\": [],\n672:         \"allowedDeferredReasons\": [],\n673:         \"targetCapabilitySearch\": [],\n674:         \"targetApiOrLibrary\": \"\",\n675:         \"targetStrategy\": \"\",\n676:         \"targetEndpoints\": [],\n677:         \"tests\": [],\n678:         \"sdkDeclarationEvidence\": [],\n679:         \"cangjieCallableEvidence\": [],\n680:         \"discoveryOnlyEvidence\": [],\n681:         \"compileProbeEvidence\": [],\n682:         \"preResolutionDecision\": \"\",\n683:         \"phaseCapabilityResolution\": \"\",\n684:         \"blocker\": \"\",\n685:         \"targetFallback\": \"\",\n686:         \"futureCompletionPath\": \"\",\n687:         \"notes\": \"\",\n688:         CAPABILITY_FACTS_KEY: default_capability_facts(),\n689:     }\n690:     return {**defaults, **entry}\n691: \n692: \n693: def validate_addition(kind: str, addition: Any) -> dict[str, Any]:\n694:     if not isinstance(addition, dict):\n695:         raise PatchError(\"Every addition must be an object.\")\n696:     required = MATRIX_ADD_REQUIRED_FIELDS if kind == \"matrix\" else PLATFORM_ADD_REQUIRED_FIELDS\n697:     missing = [field for field in sorted(required) if not has_text_or_list(addition.get(field))]\n698:     if missing:\n699:         raise PatchError(f\"Addition is missing required field(s): {', '.join(missing)}.\")\n700:     normalized = {\n701:         field: validate_field_value(kind, field, value, add_entry=True)\n702:         for field, value in addition.items()\n703:     }\n704:     return matrix_defaulted_addition(normalized) if kind == \"matrix\" else platform_defaulted_addition(normalized)\n705: \n706: \n707: def matrix_parity_errors(entry: dict[str, Any]) -> list[str]:\n708:     status = effective_matrix_status(entry)\n709:     parity = parity_level(entry)\n710:     if status == \"implemented\" and parity != \"equivalent\":\n711:         return 