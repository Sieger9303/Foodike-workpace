ion.layout.fillMaxSize\n32: import androidx.compose.foundation.layout.fillMaxWidth\n33: import androidx.compose.foundation.lazy.LazyColumn\n34: import androidx.compose.material.Icon\n35: import androidx.compose.material.IconButton\n36: import androidx.compose.material.icons.Icons\n37: import androidx.compose.material.icons.outlined.Close\n38: import androidx.compose.runtime.Composable\n39: import androidx.compose.runtime.getValue\n40: import androidx.compose.ui.Alignment\n41: import androidx.compose.ui.Modifier\n42: import androidx.compose.ui.graphics.Color\n43: import androidx.compose.ui.graphics.toArgb\n44: import androidx.compose.ui.platform.LocalContext\n45: import androidx.compose.ui.res.stringResource\n46: import androidx.hilt.navigation.compose.hiltViewModel\n47: import androidx.navigation.NavHostController\n48: import com.example.foodike.R\n49: import com.example.foodike.data.data_source.menu2\n50: import com.example.foodike.domain.model.Restaurant\n51: import com.example.foodike.presentation.cart.components.BillSection\n52: import com.example.foodike.presentation.cart.components.CouponBar\n53: import com.example.foodike.presentation.cart.components.DeliverySection\n54: import com.example.foodike.presentation.cart.components.ItemSection\n55: \n56: @Composable\n57: fun Cart(\n58:     navController: NavHostController,\n59:     viewModel: CartViewModel = hiltViewModel()\n60: ) {\n61:     val list by viewModel.cartState\n62: \n63: \n64:     val context = LocalContext.current as Activity\n65: \n66:     context.window.statusBarColor = Color.Gray.toArgb()\n67:     context.window.navigationBarColor = Color.White.toArgb()\n68: \n69:     LazyColumn(\n70:         modifier = Modifier\n71:             .fillMaxSize()\n72:             .background(color = Color(0xFFE8E7E7)),\n73:         horizontalAlignment = Alignment.CenterHorizontally\n74:     ) {\n75:         item {\n76:             Row(\n77:                 modifier = Modifier.fillMaxWidth(),\n78:             ) {\n79:                 IconButton(onClick = { navController.navigateUp() }) {\n80:                     Icon(imageVector = Icons.Outlined.Close, contentDescription = stringResource(id = R.string.back))\n81:                 }\n82:             }\n83:         }\n84: \n85:         item {\n86:             ItemSection(\n87:                 list = list.list.filter {\n88:                     it.noOfItems > 0\n89:                 },\n90:                 onDecreaseClick = { },\n91:                 onIncreaseClick = { },\n92:             )\n93:         }\n94: \n95:         item {\n96:             CouponBar()\n97:         }\n98:         item {\n99:             DeliverySection(\n100:                 Restaurant(\n101:                     name = \"Relish\",\n102:                     rating = 3.9,\n103:                     noOfRatings = 258,\n104:                     timeInMillis = 1800000,\n105:                     variety = \"American, French\",\n106:                     place = \"Misamari\",\n107:                     averagePrice = 1.0,\n108:                     image = R.drawable.pizza,\n109:                     menu = menu2\n110:                 )\n111:             )\n112:         }\n113:         item {\n114:             BillSection(\n115:                 itemTotal = 6.09\n116:             )\n117:         }\n118:     }\n119: }\n120: \n121: \n122: \n123: \n124: \n125: \n126: \n127: \n128: \n\n(End of file - total 128 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions