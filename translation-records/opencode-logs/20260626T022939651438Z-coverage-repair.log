{"type":"tool_use","timestamp":1782441020231,"sessionID":"ses_0fe3d0d4cffeOX6WWdvp2z1kkk","part":{"type":"tool","tool":"read","callID":"call_KXach4V259jF4StXdEcD5j6i","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj","limit":420},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n2: \n3: import kit.ArkUI.*\n4: import ohos.arkui.state_macro_manage.Builder\n5: import ohos.arkui.state_macro_manage.Component\n6: import ohos.arkui.state_macro_manage.Entry\n7: import ohos.arkui.state_macro_manage.State\n8: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n9: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.RestaurantData\n10: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.{cartStore, renderCartRoute}\n11: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history.{historyStore, renderHistoryRoute}\n12: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home.{homeStore, renderHomeRoute}\n13: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.{loginStore, renderLoginRoute}\n14: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.{onboardingStore, renderOnboardingRoute}\n15: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{profileStore, renderProfileRoute}\n16: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.runtime.{Global, bootstrapStartRoute}\n17: \n18: @Entry\n19: @Component\n20: class FoodikeBootstrap {\n21:     @State\n22:     var currentRoute: String = bootstrapStartRoute\n23: \n24:     @State\n25:     var isShellAtTop: Bool = true\n26: \n27:     @State\n28:     var onboardingPageIndex: Int64 = 0\n29: \n30:     @State\n31:     var loginEmail: String = \"\"\n32: \n33:     @State\n34:     var loginPassword: String = \"\"\n35: \n36:     @State\n37:     var loginErrorMessage: String = \"\"\n38: \n39:     @State\n40:     var homeSearchQuery: String = \"\"\n41: \n42:     @State\n43:     var homeSelectedFilter: String = \"\"\n44: \n45:     @State\n46:     var historySearchQuery: String = \"\"\n47: \n48:     @State\n49:     var historyTabIndex: Int64 = 0\n50: \n51:     @State\n52:     var previousRoute: String = \"home_screen\"\n53: \n54:     @State\n55:     var cartNote: String = \"\"\n56: \n57:     @State\n58:     var cartCoupon: String = \"\"\n59: \n60:     private var onboardingController: SwiperController = SwiperController()\n61: \n62:     private func applyShellState(shellState: ShellRouteState): Unit {\n63:         this.currentRoute = shellState.currentRoute\n64:         this.isShellAtTop = shellState.isAtTop\n65:     }\n66: \n67:     private func shellState(): ShellRouteState {\n68:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n69:     }\n70: \n71:     private func applyShellCommand(command: ShellCommand): Unit {\n72:         let shellState = this.shellState()\n73:         shellState.applyCommand(command)\n74:         this.applyShellState(shellState)\n75:     }\n76: \n77:     private func navigateTo(route: String): Unit {\n78:         let shellState = this.shellState()\n79:         this.previousRoute = shellState.currentRoute\n80:         shellState.currentRoute = route\n81:         shellState.isAtTop = true\n82:         this.applyShellState(shellState)\n83:     }\n84: \n85:     private func navigateBack(): Unit {\n86:         let targetRoute = this.previousRoute\n87:         this.previousRoute = this.currentRoute\n88:         this.navigateTo(targetRoute)\n89:     }\n90: \n91:     private func showBottomShell(route: String): Bool {\n92:         let shellState = this.shellState()\n93:         shellState.currentRoute = route\n94:         return shellState.showBottomShell()\n95:     }\n96: \n97:     private func routeTitle(route: String): String {\n98:         match (route) {\n99:             case \"onboarding\" => \"Onboarding\"\n100:             case \"login_screen\" => \"Login\"\n101:             case \"home_screen\" => \"Home\"\n102:             case \"history\" => \"History\"\n103:             case \"cart\" => \"Cart\"\n104:             case \"profile\" => \"Profile\"\n105:             case \"restaurant_details\" => \"Restaurant Detail\"\n106:             case _ => \"Unknown Route\"\n107:         }\n108:     }\n109: \n110:     private func showToast(message: String): Unit {\n111:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n112:     }\n113: \n114:     private func clearLoginError(): Unit {\n115:         this.loginErrorMessage = \"\"\n116:     }\n117: \n118:     private func performLogin(): Unit {\n119:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n120:             this.clearLoginError()\n121:             this.navigateTo(loginStore.successRoute())\n122:             return\n123:         }\n124: \n125:         this.loginErrorMessage = loginStore.invalidLoginMessage\n126:         this.showToast(loginStore.invalidLoginMessage)\n127:     }\n128: \n129:     private func performLogout(): Unit {\n130:         profileStore.logout(Global.abilityContext)\n131:         this.loginEmail = \"\"\n132:         this.loginPassword = \"\"\n133:         this.clearLoginError()\n134:         this.onboardingPageIndex = 0\n135:         this.homeSearchQuery = \"\"\n136:         this.homeSelectedFilter = \"\"\n137:         this.historySearchQuery = \"\"\n138:         this.historyTabIndex = 0\n139:         this.navigateTo(profileStore.logoutRoute())\n140:     }\n141: \n142:     private func routeSummary(route: String): String {\n143:         match (route) {\n144:             case \"home_screen\" => \"Home now renders repository-backed discovery content, local search/filter controls, and restaurant selection before detail routing.\"\n145:             case \"history\" => \"History now preserves search plus tab-local content, reuses favourite restaurants, and saves the selected restaurant before navigation.\"\n146:             case \"cart\" => \"Cart now renders snapshot-backed items, a local note editor, a local coupon field, delivery details, and bill totals without adding new checkout persistence flows.\"\n147:             case \"restaurant_details\" => \"Restaurant detail remains in the route contract but keeps its placeholder body until later phases.\"\n148:             case _ => \"\"\n149:         }\n150:     }\n151: \n152:     private func homeHour(): Int64 {\n153:         return 9\n154:     }\n155: \n156:     private func goToProfile(): Unit {\n157:         this.navigateTo(routePath(RouteId.Profile))\n158:     }\n159: \n160:     private func goToRestaurantDetail(): Unit {\n161:         this.navigateTo(routePath(RouteId.RestaurantDetails))\n162:     }\n163: \n164:     private func selectHomeRestaurant(restaurant: RestaurantData): Unit {\n165:         homeStore.selectRestaurant(restaurant, { =>\n166:             this.goToRestaurantDetail()\n167:         })\n168:     }\n169: \n170:     private func selectHistoryRestaurant(restaurant: RestaurantData): Unit {\n171:         historyStore.selectRestaurant(restaurant, { =>\n172:             this.goToRestaurantDetail()\n173:         })\n174:     }\n175: \n176:     @Builder\n177:     private func buildOnboardingRoute() {\n178:         renderOnboardingRoute(\n179:             this.onboardingPageIndex,\n180:             this.onboardingController,\n181:             { index: Int32 =>\n182:                 this.onboardingPageIndex = Int64(index)\n183:             },\n184:             { =>\n185:                 if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n186:                     this.navigateTo(routePath(RouteId.Login))\n187:                 } else {\n188:                     this.onboardingController.showNext()\n189:                 }\n190:             }\n191:         )\n192:     }\n193: \n194:     @Builder\n195:     private func buildLoginRoute() {\n196:         renderLoginRoute(\n197:             this.loginEmail,\n198:             this.loginPassword,\n199:             this.loginErrorMessage,\n200:             { value: String =>\n201:                 this.loginEmail = value\n202:                 this.clearLoginError()\n203:             },\n204:             { value: String =>\n205:                 this.loginPassword = value\n206:                 this.clearLoginError()\n207:             },\n208:             { => this.showToast(loginStore.comingSoonMessage) },\n209:             { => this.performLogin() },\n210:             { => this.showToast(loginStore.comingSoonMessage) },\n211:             { => this.showToast(loginStore.comingSoonMessage) },\n212:             { => this.showToast(loginStore.comingSoonMessage) },\n213:             { => this.clearLoginError() }\n214:         )\n215:     }\n216: \n217:     @Builder\n218:     private func buildProfileRoute() {\n219:         renderProfileRoute(\n220:             profileStore.userName,\n221:             profileStore.userEmail,\n222:             { => this.navigateTo(profileStore.backRoute()) },\n223:             { => this.showToast(profileStore.placeholderActionMessage) },\n224:             { => this.showToast(profileStore.placeholderActionMessage) },\n225:             { => this.performLogout() }\n226:         )\n227:     }\n228: \n229:     @Builder\n230:     private func buildHomeRoute() {\n231:         renderHomeRoute(\n232:             homeStore.loadHomeState(),\n233:             this.homeHour(),\n234:             this.homeSearchQuery,\n235:             this.homeSelectedFilter,\n236:             { value: String =>\n237:                 this.homeSearchQuery = value\n238:             },\n239:             { value: String =>\n240:                 this.homeSelectedFilter = homeStore.toggleFilter(this.homeSelectedFilter, value)\n241:             },\n242:             { => this.goToProfile() },\n243:             { restaurant: RestaurantData =>\n244:                 this.selectHomeRestaurant(restaurant)\n245:             }\n246:         )\n247:     }\n248: \n249:     @Builder\n250:     private func buildHistoryRoute() {\n251:         renderHistoryRoute(\n252:             historyStore.loadHistoryState(),\n253:             this.historyTabIndex,\n254:             this.historySearchQuery,\n255:             { value: String =>\n256:                 this.historySearchQuery = value\n257:             },\n258:             { value: Int64 =>\n259:                 this.historyTabIndex = value\n260:             },\n261:             { restaurant: RestaurantData =>\n262:                 this.selectHistoryRestaurant(restaurant)\n263:             }\n264:         )\n265:     }\n266: \n267:     @Builder\n268:     private func buildCartRoute() {\n269:         renderCartRoute(\n270:             cartStore.loadCartState(),\n271:             this.cartNote,\n272:             this.cartCoupon,\n273:             { value: String =>\n274:                 this.cartNote = value\n275:             },\n276:             { value: String =>\n277:                 this.cartCoupon = value\n278:             },\n279:             { =>\n280:                 this.navigateBack()\n281:             }\n282:         )\n283:     }\n284: \n285:     @Builder\n286:     private func buildPlaceholderRoute() {\n287:         Column(space: 18) {\n288:             Text(\"Foodike\")\n289:                 .fontSize(42)\n290:                 .fontWeight(FontWeight.Bold)\n291:             Text(this.routeTitle(this.currentRoute))\n292:                 .fontSize(28)\n293:             Text(this.routeSummary(this.currentRoute))\n294:                 .fontSize(16)\n295:                 .textAlign(TextAlign.Center)\n296:                 .width(86.percent)\n297: \n298:             if (this.currentRoute == routePath(RouteId.Home) || this.currentRoute =