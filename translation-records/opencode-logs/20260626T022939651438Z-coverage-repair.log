\n47: @Builder\n48: func buildCartItemRow(item: CartSnapshotItemData, onDecrease: () -> Unit, onIncrease: () -> Unit) {\n49:     Row(space: 16) {\n50:         Text(if (item.menuItem.isVegetarian) { \"VEG\" } else { \"NON-VEG\" })\n51:             .fontSize(12)\n52:             .fontWeight(FontWeight.Bold)\n53:             .fontColor(if (item.menuItem.isVegetarian) { colorDarkGreen } else { Color.Red })\n54:         Column(space: 6) {\n55:             Text(item.menuItem.dish)\n56:                 .fontSize(16)\n57:                 .fontWeight(FontWeight.Medium)\n58:             Text(cartStore.formatPrice(item.menuItem.price))\n59:                 .fontSize(14)\n60:                 .fontColor(Color.Gray)\n61:         }\n62:         .layoutWeight(1)\n63:         buildCartQuantityPill(item.quantity, onDecrease, onIncrease)\n64:     }\n65:     .width(100.percent)\n66:     .alignItems(VerticalAlign.Center)\n67: }\n68: \n69: @Builder\n70: func buildItemSection(\n71:     items: ArrayList<CartSnapshotItemData>,\n72:     note: String,\n73:     onNoteChange: (String) -> Unit,\n74:     onDecreaseClick: (CartSnapshotItemData) -> Unit,\n75:     onIncreaseClick: (CartSnapshotItemData) -> Unit\n76: ) {\n77:     Column(space: 14) {\n78:         if (items.size > 0) {\n79:             ForEach(items, itemGeneratorFunc: { item: CartSnapshotItemData, _: Int64 =>\n80:                 buildCartItemRow(\n81:                     item,\n82:                     { =>\n83:                         onDecreaseClick(item)\n84:                     },\n85:                     { =>\n86:                         onIncreaseClick(item)\n87:                     }\n88:                 )\n89:             })\n90:         } else {\n91:             Row {\n92:                 Text(\"Empty\")\n93:                     .fontSize(16)\n94:             }\n95:             .width(100.percent)\n96:             .justifyContent(FlexAlign.Center)\n97:         }\n98: \n99:         Divider().width(100.percent)\n100: \n101:         TextInput(text: note, placeholder: \"Write instruction for restaurant...\")\n102:             .width(100.percent)\n103:             .height(52)\n104:             .fontSize(15)\n105:             .placeholderColor(Color.Gray)\n106:             .backgroundColor(Color.White)\n107:             .onChange({ value: String =>\n108:                 onNoteChange(value)\n109:             })\n110:     }\n111:     .width(100.percent)\n112:     .padding(top: 18, right: 18, bottom: 18, left: 18)\n113:     .backgroundColor(Color.White)\n114:     .borderRadius(22)\n115: }\n116: \n117: @Builder\n118: func buildCouponBar(coupon: String, onCouponChange: (String) -> Unit) {\n119:     Row(space: 12) {\n120:         TextInput(text: coupon, placeholder: \"Add a coupon code...\")\n121:             .layoutWeight(1)\n122:             .height(52)\n123:             .fontSize(15)\n124:             .placeholderColor(Color.Gray)\n125:             .backgroundColor(Color.White)\n126:             .borderRadius(26)\n127:             .onChange({ value: String =>\n128:                 onCouponChange(value)\n129:             })\n130:         Text(\"APPLY\")\n131:             .fontSize(15)\n132:             .fontWeight(FontWeight.Bold)\n133:             .fontColor(colorDarkGreen)\n134:     }\n135:     .width(100.percent)\n136:     .padding(top: 14, right: 18, bottom: 14, left: 18)\n137:     .backgroundColor(Color.White)\n138:     .borderRadius(26)\n139:     .alignItems(VerticalAlign.Center)\n140: }\n141: \n142: @Builder\n143: func buildDeliverySection(restaurant: RestaurantData) {\n144:     Column(space: 12) {\n145:         Row {\n146:             Text(\"Deliver to:\")\n147:                 .fontWeight(FontWeight.Bold)\n148:             Blank().layoutWeight(1)\n149:             Text(\"Edit\")\n150:                 .fontColor(Color.Gray)\n151:         }\n152:         .width(100.percent)\n153: \n154:         Row {\n155:             Column(space: 6) {\n156:                 Text(\"Location:\")\n157:                 Text(\"Estimated time:\")\n158:             }\n159:             .layoutWeight(1)\n160:             Column(space: 6) {\n161:                 Text(cartStore.deliveryLocation())\n162:                 Text(cartStore.formatEta(restaurant.etaMinutes))\n163:             }\n164:         }\n165:         .width(100.percent)\n166:     }\n167:     .width(100.percent)\n168:     .padding(top: 18, right: 18, bottom: 18, left: 18)\n169:     .backgroundColor(Color.White)\n170:     .borderRadius(22)\n171: }\n172: \n173: @Builder\n174: func buildBillSection(itemTotal: Float64) {\n175:     Column(space: 12) {\n176:         Text(\"Bill Details\")\n177:             .fontSize(18)\n178:             .fontWeight(FontWeight.Bold)\n179:         Row {\n180:             Column(space: 6) {\n181:                 Text(\"Item total:\")\n182:                 Text(\"Taxes and charges:\")\n183:                 Text(\"Total:\")\n184:             }\n185:             .layoutWeight(1)\n186:             Column(space: 6) {\n187:                 Text(cartStore.formatPrice(itemTotal))\n188:                 Text(cartStore.formatPrice(cartStore.taxAmount(itemTotal)))\n189:                 Text(cartStore.formatPrice(cartStore.grandTotal(itemTotal)))\n190:             }\n191:         }\n192:         .width(100.percent)\n193:         Button(\"Proceed to Pay\")\n194:             .width(220)\n195:             .height(48)\n196:     }\n197:     .width(100.percent)\n198:     .padding(top: 18, right: 18, bottom: 18, left: 18)\n199:     .backgroundColor(Color.White)\n200:     .borderRadius(22)\n201:     .alignItems(HorizontalAlign.Center)\n202: }\n203: \n204: @Builder\n205: public func renderCartRoute(\n206:     state: CartPageState,\n207:     note: String,\n208:     coupon: String,\n209:     onNoteChange: (String) -> Unit,\n210:     onCouponChange: (String) -> Unit,\n211:     onDecreaseClick: (CartSnapshotItemData) -> Unit,\n212:     onIncreaseClick: (CartSnapshotItemData) -> Unit,\n213:     onBack: () -> Unit\n214: ) {\n215:     let visibleItems = cartStore.visibleItems(state.items)\n216:     Scroll(Scroller()) {\n217:         Column(space: 16) {\n218:             buildCartTopBar(onBack)\n219:             buildItemSection(visibleItems, note, onNoteChange, onDecreaseClick, onIncreaseClick)\n220:             buildCouponBar(coupon, onCouponChange)\n221:             buildDeliverySection(state.deliveryRestaurant)\n222:             buildBillSection(cartStore.itemTotal(visibleItems))\n223:         }\n224:         .width(100.percent)\n225:         .padding(top: 14, right: 16, bottom: 24, left: 16)\n226:     }\n227:     .scrollable(ScrollDirection.Vertical)\n228:     .scrollBar(BarState.Off)\n229:     .width(100.percent)\n230:     .height(100.percent)\n231:     .backgroundColor(0xFFE8E7E7)\n232: }\n\n(End of file - total 232 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\n@Builder\nfunc buildCartTopBar(onBack: () -> Unit) {\n    Row {\n        Button(\"x\")\n            .onClick({ _ =>\n                onBack()\n            })\n        Blank().layoutWeight(1)\n    }\n    .width(100.percent)\n    .alignItems(VerticalAlign.Center)\n}","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\cart\\cart_page.cj","time":{"start":1782441164733,"end":1782441164745}},"id":"prt_f01c5bf78001r3r53D57npPqVz","sessionID":"ses_0fe3d0d4cffeOX6WWdvp2z1kkk","messageID":"msg_f01c5aa750019LMQ2ilJr01t60"}}
{"type":"tool_use","timestamp":1782441164814,"sessionID":"ses_0fe3d0d4cffeOX6WWdvp2z1kkk","part":{"type":"tool","tool":"read","callID":"call_XdAXmFVEHLlB8ETuaBQKDQAp","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\cart\\cart_store.cj","limit":180},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\cart\\cart_store.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart\n2: \n3: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n6: import std.collection.ArrayList\n7: \n8: public let cartStore = CartStore()\n9: \n10: public class CartStore {\n11:     private let sessionRepository = sessionRepository\n12:     private let contentRepository = HomeContentRepository()\n13: \n14:     public init() {}\n15: \n16:     private func cloneMenuItem(item: MenuItemData): MenuItemData {\n17:         return MenuItemData(item.dish, item.price, item.rating, item.ratingCount, item.isVegetarian)\n18:     }\n19: \n20:     private func cloneCartItems(items: ArrayList<CartSnapshotItemData>): ArrayList<CartSnapshotItemData> {\n21:         let cloned = ArrayList<CartSnapshotItemData>([])\n22:         for (item in items) {\n23:             cloned.add(CartSnapshotItemData(cloneMenuItem(item.menuItem), item.quantity))\n24:         }\n25:         return cloned\n26:     }\n27: \n28:     public func loadCartState(): CartPageState {\n29:         let deliveryRestaurant = match (contentRepository.getRestaurantByName(\"Relish\")) {\n30:             case Some(restaurant) => restaurant\n31:             case None => contentRepository.getRestaurants()[0]\n32:         }\n33:         return CartPageState(cloneCartItems(sessionRepository.getCartItems()), deliveryRestaurant)\n34:     }\n35: \n36:     public func visibleItems(items: ArrayList<CartSnapshotItemData>): ArrayList<CartSnapshotItemData> {\n37:         let filtered = ArrayList<CartSnapshotItemData>([])\n38:         for (item in items) {\n39:             if (item.quantity > 0) {\n40:                 filtered.add(item)\n41:             }\n42:         }\n43:         return filtered\n44:     }\n45: \n46:     public func itemTotal(items: ArrayList<CartSnapshotItemData>): Float64 {\n47:         var total: Float64 = 0.0\n48:         for (item in items) {\n49:             var remaining = item.quantity\n50:             while (remaining > 0) {\n51:                 total += item.menuItem.price\n52:                 remaining -= 1\n53:             }\n54:         }\n55:         return total\n56:     }\n57: \n58:     public func formatPrice(price: Float64): String {\n59:         return \"$${price}\"\n60:     }\n61: \n62:     public func formatEta(minutes: Int64): String {\n63:         let hours = minutes / 60\n64:         let remainder = minutes % 60\n65:         if (hours > 0) {\n66:             return \"${hours} Hr ${remainder} Min\"\n67:         }\n68:         return \"${remainder} Min\"\n69:     }\n70: \n71:     public func taxAmount(itemTotal: Float64): Float64 {\n72:         return itemTotal * 0.18\n73:     }\n74: \n75:     public func grandTotal(itemTotal: Float64): Float64 {\n76:         return itemTotal + taxAmount(itemTotal)\n77:     }\n78: \n79:     public func deliveryLocation(): String {\n80:         return \"Guwahati\"\n81:     }\n82:     public func session(): SessionRepository {\n83:         return sessionRepository\n84:     }\n85: }\n\n(End of file - total 85 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\npublic let cartStore = CartStore()\n\npublic class CartStore {\n    private let sessionRepository = sessionRepository\n    private let contentRepository = HomeContentRepository()\n\n    public init() {}\n\n    private func cloneMenuItem(item: MenuItemData): MenuItemData {\n        return MenuItemData(item.dish, item.price, item.rating, item.ratingCount, item.isVegetarian)\n    }\n\n    private func cloneCartItems(items: ArrayList<CartSnapshotItemData>): ArrayList<CartSnapshotItemData> {","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\cart\\cart_store.cj","time":{"start":1782441164800,"end":1782441164813}},"id":"prt_f01c5bfbf0016vhddXC3K35hF3","sessionID":"ses_0fe3d0d4cffeOX6WWdvp2z1kkk","messageID":"msg_f01c5aa750019LMQ2ilJr01t60"}}
{"type":"tool_use","timestamp":1782441164885,"sessionID":"ses_0fe3d0d4cffeOX6WWdvp2z1kkk","part":{"type":"tool","tool":"read","callID":"call_q3n4YPqnBu2JuPLA6pFrguaD","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj","offset":1,"limit":340},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n2: \n3: import kit.ArkUI.*\n4: import ohos.arkui.state_macro_manage.Builder\n5: import ohos.arkui.state_macro_manage.Component\n6: import ohos.arkui.state_macro_manage.Entry\n7: import ohos.arkui.state_macro_manage.State\n8: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n9: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.{CartPageState, CartSnapshotItemData, RestaurantData}\n10: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.{cartStore, renderCartRoute}\n11: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history.{historyStore, renderHistoryRoute}\n12: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home.{homeStore, renderHomeRoute}\n13: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.{loginStore, renderLoginRoute}\n14: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.{onboardingStore, renderOnboardingRoute}\n15: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{profileStore, renderProfileRoute}\n16: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.runtime.{Global, bootstrapStartRoute}\n17: \n18: @Entry\n19: @Component\n20: class FoodikeBootstrap {\n21:     @State\n22:     var currentRoute: String = bootstrapStartRoute\n23: \n24:     @State\n25:     var isShellAtTop: Bool = true\n26: \n27:     @State\n28:     var onboardingPageIndex: Int64 = 0\n29: \n30:     @State\n31:     var loginEmail: String = \"\"\n32: \n33:     @State\n34:     var loginPassword: String = \"\"\n35: \n36:     @State\n37:     var loginErrorMessage: String = \"\"\n38: \n39:     @State\n40:     var homeSearchQuery: String = \"\"\n41: \n42:     @State\n43:     var homeSelectedFilter: String = \"\"\n44: \n45:     @State\n46:     var historySearchQuery: String = \"\"\n47: \n48:     @State\n49:     var historyTabIndex: Int64 = 0\n50: \n51:     @State\n52:     var previousRoute: String = \"home_screen\"\n53: \n54:     @State\n55:     var cartNote: String = \"\"\n56: \n57:     @State\n58:     var cartCoupon: String = \"\"\n59: \n60:     @State\n61:     var cartRevision: Int64 = 0\n62: \n63:     private var onboardingController: SwiperController = SwiperController()\n64:     private var cartRouteState: CartPageState = cartStore.loadCartState()\n65: \n66:     private func reloadCartRouteState(): Unit {\n67:         this.cartRouteState = cartStore.loadCartState()\n68:         this.cartRevision += 1\n69:     }\n70: \n71:     private func adjustCartItemQuantity(item: CartSnapshotItemData, delta: Int64): Unit {\n72:         let nextQuantity = item.quantity + delta\n73:         if (nextQuantity < 0) {\n74:             return\n75:         }\n76:         item.quantity = nextQuantity\n77:         this.cartRevision += 1\n78:     }\n79: \n80:     private func applyShellState(shellState: ShellRouteState): Unit {\n81:         this.currentRoute = shellState.currentRoute\n82:         this.isShellAtTop = shellState.isAtTop\n83:     }\n84: \n85:     private func shellState(): ShellRouteState {\n86:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n87:     }\n88: \n89:     private func applyShellCommand(command: ShellCommand): Unit {\n90:         let shellState = this.shellState()\n91:         shellState.applyCommand(command)\n92:         this.applyShellState(shellState)\n93:     }\n94: \n95:     private func navigateTo(route: String): Unit {\n96:         let shellState = this.shellState()\n97:         this.previousRoute = shellState.currentRoute\n98:         shellState.currentRoute = route\n99:         shellState.isAtTop = true\n100:         if (route == routePath(RouteId.Cart)) {\n101:             this.reloadCartRouteState()\n102:         }\n103:         this.applyShellState(shellState)\n104:     }\n105: \n106:     private func navigateBack(): Unit {\n107:         let targetRoute = this.previousRoute\n108:         this.previousRoute = this.currentRoute\n109:         this.navigateTo(targetRoute)\n110:     }\n111: \n112:     private func showBottomShell(route: String): Bool {\n113:         let shellState = this.shellState()\n114:         shellState.currentRoute = route\n115:         return shellState.showBottomShell()\n116:     }\n117: \n118:     private func routeTitle(route: String): String {\n119:         match (route) {\n120:             case \"onboarding\" => \"Onboarding\"\n121:             case \"login_screen\" => \"Login\"\n122:             case \"home_screen\" => \"Home\"\n123:             case \"history\" => \"History\"\n124:             case \"cart\" => \"Cart\"\n125:             case \"profile\" => \"Profile\"\n126:             case \"restaurant_details\" => \"Restaurant Detail\"\n127:             case _ => \"Unknown Route\"\n128:         }\n129:     }\n130: \n131:     private func showToast(message: String): Unit {\n132:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n133:     }\n134: \n135:     private func clearLoginError(): Unit {\n136:         this.loginErrorMessage = \"\"\n137:     }\n138: \n139:     private func performLogin(): Unit {\n140:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n141:             this.clearLoginError()\n142:             this.navigateTo(loginStore.successRoute())\n143:             return\n144:         }\n145: \n146:         this.loginErrorMessage = loginStore.invalidLoginMessage\n147:         this.showToast(loginStore.invalidLoginMessage)\n148:     }\n149: \n150:     private func performLogout(): Unit {\n151:         profileStore.logout(Global.abilityContext)\n152:         this.loginEmail = \"\"\n153:         this.loginPassword = \"\"\n154:         this.clearLoginError()\n155:         this.onboardingPageIndex = 0\n156:         this.homeSearchQuery = \"\"\n157:         this.homeSelectedFilter = \"\"\n158:         this.historySearchQuery = \"\"\n159:         this.historyTabIndex = 0\n160:         this.navigateTo(profileStore.logoutRoute())\n161:     }\n162: \n163:     private func routeSummary(route: String): String {\n164:         match (route) {\n165:             case \"home_screen\" => \"Home now renders repository-backed discovery content, local search/filter controls, and restaurant selection before detail routing.\"\n166:             case \"history\" => \"History now preserves search plus tab-local content, reuses favourite restaurants, and saves the selected restaurant before navigation.\"\n167:             case \"cart\" => \"Cart now renders snapshot-backed items, a local note editor, a local coupon field, delivery details, and bill totals without adding new checkout persistence flows.\"\n168:             case \"restaurant_details\" => \"Restaurant detail remains in the route contract but keeps its placeholder body until later phases.\"\n169:             case _ => \"\"\n170:         }\n171:     }\n172: \n173:     private func homeHour(): Int64 {\n174:         return 9\n175:     }\n176: \n177:     private func goToProfile(): Unit {\n178:         this.navigateTo(routePath(RouteId.Profile))\n179:     }\n180: \n181:     private func goToRestaurantDetail(): Unit {\n182:         this.navigateTo(routePath(RouteId.RestaurantDetails))\n183:     }\n184: \n185:     private func selectHomeRestaurant(restaurant: RestaurantData): Unit {\n186:         homeStore.selectRestaurant(restaurant, { =>\n187:             this.goToRestaurantDetail()\n188:         })\n189:     }\n190: \n191:     private func selectHistoryRestaurant(restaurant: RestaurantData): Unit {\n192:         historyStore.selectRestaurant(restaurant, { =>\n193:             this.goToRestaurantDetail()\n194:         })\n195:     }\n196: \n197:     @Builder\n198:     private func buildOnboardingRoute() {\n199:         renderOnboardingRoute(\n200:             this.onboardingPageIndex,\n201:             this.onboardingController,\n202:             { index: Int32 =>\n203:                 this.onboardingPageIndex = Int64(index)\n204:             },\n205:             { =>\n206:                 if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n207:                     this.navigateTo(routePath(RouteId.Login))\n208:                 } else {\n209:                     this.onboardingController.showNext()\n210:                 }\n211:             }\n212:         )\n213:     }\n214: \n215:     @Builder\n216:     private func buildLoginRoute() {\n217:         renderLoginRoute(\n218:             this.loginEmail,\n219:             this.loginPassword,\n220:             this.loginErrorMessage,\n221:             { value: String =>\n222:                 this.loginEmail = value\n223:                 this.clearLoginError()\n224:             },\n225:             { value: String =>\n226:                 this.loginPassword = value\n227:                 this.clearLoginError()\n228:             },\n229:             { => this.showToast(loginStore.comingSoonMessage) },\n230:             { => this.performLogin() },\n231:             { => this.showToast(loginStore.comingSoonMessage) },\n232:             { => this.showToast(loginStore.comingSoonMessage) },\n233:             { => this.showToast(loginStore.comingSoonMessage) },\n234:             { => this.clearLoginError() }\n235:         )\n236:     }\n237: \n238:     @Builder\n239:     private func buildProfileRoute() {\n240:         renderProfileRoute(\n241:             profileStore.userName,\n242:             profileStore.userEmail,\n243:             { => this.navigateTo(profileStore.backRoute()) },\n244:             { => this.showToast(profileStore.placeholderActionMessage) },\n245:             { => this.showToast(profileStore.placeholderActionMessage) },\n246:             { => this.performLogout() }\n247:         )\n248:     }\n249: \n250:     @Builder\n251:     private func buildHomeRoute() {\n252:         renderHomeRoute(\n253:             homeStore.loadHomeState(),\n254:             this.homeHour(),\n255:             this.homeSearchQuery,\n256:             this.homeSelectedFilter,\n257:             { value: String =>\n258:                 this.homeSearchQuery = value\n259:             },\n260:             { value: String =>\n261:                 this.homeSelectedFilter = homeStore.toggleFilter(this.homeSelectedFilter, value)\n262:             },\n263:             { => this.goToProfile() },\n264:             { restaurant: RestaurantData =>\n265:                 this.selectHomeRestaurant(restaurant)\n266:             }\n267:         )\n268:     }\n269: \n270:     @Builder\n271:     private func buildHistoryRoute() {\n272:         renderHistoryRoute(\n273:             historyStore.loadHistoryState(),\n274:             this.historyTabIndex,\n275:             this.historySearchQuery,\n276:             { value: String =>\n277:                 this.historySearchQuery = value\n278:             },\n279:             { value: Int64 =>\n280:                 this.historyTabIndex = value\n281:             },\n282:             { restaurant: RestaurantData =>\n283:                 this.selectHistoryRestaurant(restaurant)\n284:             }\n285:         )\n286:     }\n287: \n288:     @Builder\n289:     private func buildCartRoute() {\n290:         let _ = this.cartRevision\n291:         renderCartRoute(\n292:             this.cartRouteState,\n293:             this.cartNote,\n294:             this.cartCoupon,\n295:             { value: String =>\n296:                 this.cartNote = value\n297:  