ListState\n32: import androidx.compose.foundation.lazy.rememberLazyListState\n33: import androidx.compose.material.*\n34: import androidx.compose.material.icons.Icons\n35: import androidx.compose.material.icons.filled.Home\n36: import androidx.compose.material.icons.outlined.ShoppingCart\n37: import androidx.compose.runtime.Composable\n38: import androidx.compose.runtime.derivedStateOf\n39: import androidx.compose.runtime.getValue\n40: import androidx.compose.runtime.remember\n41: import androidx.compose.ui.Alignment\n42: import androidx.compose.ui.Modifier\n43: import androidx.compose.ui.graphics.Color\n44: import androidx.compose.ui.res.painterResource\n45: import androidx.compose.ui.res.stringResource\n46: import androidx.compose.ui.unit.dp\n47: import androidx.navigation.NavGraph.Companion.findStartDestination\n48: import androidx.navigation.NavHostController\n49: import androidx.navigation.compose.NavHost\n50: import androidx.navigation.compose.composable\n51: import androidx.navigation.compose.currentBackStackEntryAsState\n52: import androidx.navigation.compose.rememberNavController\n53: import com.example.foodike.presentation.cart.Cart\n54: import com.example.foodike.presentation.details.RestaurantDetail\n55: import com.example.foodike.presentation.history.History\n56: import com.example.foodike.presentation.home.Home\n57: import com.example.foodike.presentation.home.components.FoodikeBottomNavigation\n58: import com.example.foodike.presentation.login.LoginScreen\n59: import com.example.foodike.presentation.onboarding.OnBoarding\n60: import com.example.foodike.presentation.profile.Profile\n61: import com.google.accompanist.pager.ExperimentalPagerApi\n62: \n63: \n64: @OptIn(ExperimentalPagerApi::class)\n65: @Composable\n66: fun NavigationGraph(\n67:     navController: NavHostController,\n68:     startDestination: String,\n69:     scrollState: LazyListState\n70: ) {\n71: \n72:     NavHost(\n73:         navController = navController,\n74:         startDestination = startDestination\n75:     ) {\n76:         composable(\n77:             route = Screen.Onboarding.route,\n78:         ) {\n79:             OnBoarding(navController = navController)\n80:         }\n81:         composable(\n82:             route = Screen.LoginScreen.route,\n83:         ) {\n84:             LoginScreen(navController = navController)\n85:         }\n86: \n87:         composable(\n88:             route = Screen.Home.route\n89:         ) {\n90:             Home(navController = navController, scrollState = scrollState)\n91:         }\n92:         composable(\n93:             route = Screen.History.route\n94:         ) {\n95:             History(navHostController = navController)\n96:         }\n97:         composable(\n98:             route = Screen.Cart.route\n99:         ) {\n100:             Cart(navController = navController)\n101:         }\n102:         composable(\n103:             route = Screen.Profile.route\n104:         ) {\n105:             Profile(navController = navController)\n106:         }\n107: \n108:         composable(\n109:             route = Screen.Onboarding.route,\n110:         ) {\n111:             OnBoarding(navController = navController)\n112:         }\n113:         composable(\n114:             route = Screen.RestaurantDetails.route,\n115:         ) {\n116:             RestaurantDetail(\n117:                 navController = navController\n118:             )\n119:         }\n120:     }\n121: \n122: }\n123: \n124: @SuppressLint(\"UnusedMaterialScaffoldPaddingParameter\")\n125: @Composable\n126: fun SetupNavigation(startDestination: String) {\n127: \n128:     val navController = rememberNavController()\n129: \n130: \n131:     val navBackStackEntry by navController.currentBackStackEntryAsState()\n132:     val currentRoute = navBackStackEntry?.destination?.route\n133: \n134: \n135:     val scrollState = rememberLazyListState()\n136:     val state by remember { derivedStateOf { scrollState.firstVisibleItemIndex == 0 } }\n137: \n138: \n139:     Scaffold(\n140:         bottomBar = {\n141:             if ((currentRoute == Screen.Home.route || currentRoute == Screen.History.route) && state) {\n142: \n143:                 Column(\n144:                     modifier = Modifier.padding(115.dp, 25.dp),\n145:                     horizontalAlignment = Alignment.CenterHorizontally\n146:                 ) {\n147: \n148:                     Box(\n149:                         contentAlignment = Alignment.Center\n150:                     ) {\n151:                         BottomBar(navController = navController)\n152:                         Column {\n153:                             FloatingActionButton(\n154:                                 onClick = {\n155:                                     navController.navigate(Screen.Cart.route)\n156: \n157:                                 },\n158:                                 backgroundColor = MaterialTheme.colors.primary\n159:                             ) {\n160:                                 Icon(Icons.Outlined.ShoppingCart, \"Cart\")\n161:                             }\n162:                             Spacer(modifier = Modifier.height(26.dp))\n163:                         }\n164:                     }\n165:                 }\n166:             }\n167:         }\n168:     ) {\n169:         NavigationGraph(\n170:             navController = navController,\n171:             scrollState = scrollState,\n172:             startDestination = startDestination\n173:         )\n174:     }\n175: }\n176: \n177: \n178: @Composable\n179: fun BottomBar(navController: NavHostController) {\n180:     val navBackStackEntry by navController.currentBackStackEntryAsState()\n181:     val currentRoute = navBackStackEntry?.destination?.route\n182: \n183:     FoodikeBottomNavigation(\n184:         backgroundColor = Color(0xFFE1E1E1)\n185: \n186:     ) {\n187:         BottomNavigationItem(\n188:             icon =\n189:             {\n190:                 Icon(\n191:                     imageVector = Icons.Filled.Home,\n192:                     contentDescription = stringResource(com.example.foodike.R.string.home),\n193:                 )\n194:             },\n195: \n196:             selectedContentColor = Color.Black,\n197:             unselectedContentColor = Color.White,\n198:             alwaysShowLabel = false,\n199:             selected = currentRoute == Screen.Home.route,\n200: \n201:             onClick = {\n202:                 navController.navigate(Screen.Home.route) {\n203:                     // Pop up to the start destination of the graph to\n204:                     // avoid building up a large stack of destinations\n205:                     // on the back stack as users select items\n206:                     popUpTo(navController.graph.findStartDestination().id) {\n207:                         saveState = true\n208:                     }\n209:                     // Avoid multiple copies of the same destination when\n210:                     // reselecting the same item\n211:                     launchSingleTop = true\n212:                     // Restore state when reselecting a previously selected item\n213:                     restoreState = true\n214:                 }\n215:             }\n216:         )\n217: \n218:         Row() {\n219:             Spacer(modifier = Modifier.width(56.dp))\n220:         }\n221: \n222: \n223:         BottomNavigationItem(\n224:             icon =\n225:             {\n226:                 Icon(\n227:                     painter = painterResource(com.example.foodike.R.drawable.ic_baseline_assignment_24),\n228:                     contentDescription = stringResource(com.example.foodike.R.string.history),\n229:                 )\n230:             },\n231: \n232:             selectedContentColor = Color.Black,\n233:             unselectedContentColor = Color.White,\n234:             alwaysShowLabel = false,\n235:             selected = currentRoute == Screen.History.route,\n236:             onClick = {\n237:                 navController.navigate(Screen.History.route) {\n238:                     // Pop up to the start destination of the graph to\n239:                     // avoid building up a large stack of destinations\n240:                     // on the back stack as users select items\n241:                     popUpTo(navController.graph.findStartDestination().id) {\n242:                         saveState = true\n243:                     }\n244:                     // Avoid multiple copies of the same destination when\n245:                     // reselecting the same item\n246:                     launchSingleTop = true\n247:                     // Restore state when reselecting a previously selected item\n248:                     restoreState = true\n249:                 }\n250:             }\n251:         )\n252: \n253:     }\n254: \n255: }\n\n(End of file - total 255 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER","truncated":false,"loaded":[]},"title":"..\\..\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\util\\Navigation.kt","time":{"start":1782573652013,"end":1782573652060}},"id":"prt_f09ab582b001EIdT1eE8dDsYrn","sessionID":"ses_0f65536a1ffeRAz9IKdDJHkMWy","messageID":"msg_f09ab0c370013VQZ8AIVE4gw3D"}}
{"type":"tool_use","timestamp":1782573652062,"sessionID":"ses_0f65536a1ffeRAz9IKdDJHkMWy","part":{"type":"tool","tool":"read","callID":"call_sC6NPX2FZKxXBwTxrMtGj5Bi","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj","limit":400,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n2: \n3: import kit.ArkUI.*\n4: import ohos.base.ResourceStr\n5: import ohos.arkui.state_macro_manage.Builder\n6: import ohos.arkui.state_macro_manage.Component\n7: import ohos.arkui.state_macro_manage.Entry\n8: import ohos.arkui.state_macro_manage.State\n9: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n10: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.{CartSnapshotItemData, DetailMenuItemData, DetailPageState, RestaurantData}\n11: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.{cartStore, renderCartRoute}\n12: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.{detailStore, renderDetailRoute}\n13: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history.{historyStore, renderHistoryRoute}\n14: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home.{homeStore, renderHomeRoute}\n15: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.{loginStore, renderLoginRoute}\n16: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.{onboardingStore, renderOnboardingRoute}\n17: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{profileStore, renderProfileRoute}\n18: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.runtime.{Global, bootstrapStartRoute}\n19: \n20: @Entry\n21: @Component\n22: class FoodikeBootstrap {\n23:     @State\n24:     var currentRoute: String = bootstrapStartRoute\n25: \n26:     @State\n27:     var isShellAtTop: Bool = true\n28: \n29:     @State\n30:     var onboardingPageIndex: Int64 = 0\n31: \n32:     @State\n33:     var loginEmail: String = \"\"\n34: \n35:     @State\n36:     var loginPassword: String = \"\"\n37: \n38:     @State\n39:     var loginErrorMessage: String = \"\"\n40: \n41:     @State\n42:     var homeSearchQuery: String = \"\"\n43: \n44:     @State\n45:     var homeSelectedFilter: String = \"\"\n46: \n47:     @State\n48:     var historySearchQuery: String = \"\"\n49: \n50:     @State\n51:     var historyTabIndex: Int64 = 0\n52: \n53:     @State\n54:     var previousRoute: String = \"home_screen\"\n55: \n56:     @State\n57:     var cartNote: String = \"\"\n58: \n59:     @State\n60:     var cartCoupon: String = \"\"\n61: \n62:     @State\n63:     var cartMutationRevision: Int64 = 0\n64: \n65:     @State\n66:     var detailRecommendedExpanded: Bool = true\n67: \n68:     @State\n69:     var detailNonVegExpanded: Bool = true\n70: \n71:     @State\n72:     var detailVegExpanded: Bool = true\n73: \n74:     @State\n75:     var detailLiked: Bool = false\n76: \n77:     @State\n78:     var detailMutationRevision: Int64 = 0\n79: \n80:     private var onboardingController: SwiperController = SwiperController()\n81: \n82:     private func applyShellState(shellState: ShellRouteState): Unit {\n83:         this.currentRoute = shellState.currentRoute\n84:         this.isShellAtTop = shellState.isAtTop\n85:     }\n86: \n87:     private func shellState(): ShellRouteState {\n88:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n89:     }\n90: \n91:     private func applyShellCommand(command: ShellCommand): Unit {\n92:         let shellState = this.shellState()\n93:         shellState.applyCommand(command)\n94:         this.applyShellState(shellState)\n95:     }\n96: \n97:     private func navigateTo(route: String): Unit {\n98:         let shellState = this.shellState()\n99:         this.previousRoute = shellState.currentRoute\n100:         shellState.currentRoute = route\n101:         shellState.isAtTop = true\n102:         this.applyShellState(shellState)\n103:     }\n104: \n105:     private func navigateBack(): Unit {\n106:         let targetRoute = this.previousRoute\n107:         this.previousRoute = this.currentRoute\n108:         this.navigateTo(targetRoute)\n109:     }\n110: \n111:     private func showBottomShell(route: String): Bool {\n112:         let shellState = this.shellState()\n113:         shellState.currentRoute = route\n114:         return shellState.showBottomShell()\n115:     }\n116: \n117:     private func routeTitle(route: String): ResourceStr {\n118:         routeLabelByPath(route)\n119:     }\n120: \n121:     private func showToast(message: String): Unit {\n122:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n123:     }\n124: \n125:     private func clearLoginError(): Unit {\n126:         this.loginErrorMessage = \"\"\n127:     }\n128: \n129:     private func performLogin(): Unit {\n130:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n131:             this.clearLoginError()\n132:             this.navigateTo(loginStore.successRoute())\n133:             return\n134:         }\n135: \n136:         this.loginErrorMessage = loginStore.invalidLoginMessage\n137:         this.showToast(loginStore.invalidLoginMessage)\n138:     }\n139: \n140:     private func performLogout(): Unit {\n141:         profileStore.logout(Global.abilityContext)\n142:         this.loginEmail = \"\"\n143:         this.loginPassword = \"\"\n144:         this.clearLoginError()\n145:         this.onboardingPageIndex = 0\n146:         this.homeSearchQuery = \"\"\n147:         this.homeSelectedFilter = \"\"\n148:         this.historySearchQuery = \"\"\n149:         this.historyTabIndex = 0\n150:         this.navigateTo(profileStore.logoutRoute())\n151:     }\n152: \n153:     private func routeSummary(route: String): String {\n154:         match (route) {\n155:             case \"home_screen\" => \"Home now renders repository-backed discovery content, local search/filter controls, and restaurant selection before detail routing.\"\n156:             case \"history\" => \"History now preserves search plus tab-local content, reuses favourite restaurants, and saves the selected restaurant before navigation.\"\n157:             case \"cart\" => \"Cart now renders snapshot-backed items, a local note editor, a local coupon field, delivery details, and bill totals without adding new checkout persistence flows.\"\n158:             case \"restaurant_details\" => \"Restaurant detail now reads the selected restaurant, preserves local section expansion and like state, keeps menu quantity controls local to the route, and shows the cart action only when selected quantities are non-zero.\"\n159:             case _ => \"\"\n160:         }\n161:     }\n162: \n163:     private func homeHour(): Int64 {\n164:         return 9\n165:     }\n166: \n167:     private func goToProfile(): Unit {\n168:         this.navigateTo(routePath(RouteId.Profile))\n169:     }\n170: \n171:     private func goToRestaurantDetail(): Unit {\n172:         this.detailRecommendedExpanded = true\n173:         this.detailNonVegExpanded = true\n174:         this.detailVegExpanded = true\n175:         this.detailLiked = detailStore.session().isRestaurantLiked(detailStore.selectedRestaurant())\n176:         this.detailMutationRevision = 0\n177:         this.navigateTo(routePath(RouteId.RestaurantDetails))\n178:     }\n179: \n180:     private func detailState(): DetailPageState {\n181:         return detailStore.loadDetailState(\n182:             this.detailRecommendedExpanded,\n183:             this.detailNonVegExpanded,\n184:             this.detailVegExpanded\n185:         )\n186:     }\n187: \n188:     private func selectHomeRestaurant(restaurant: RestaurantData): Unit {\n189:         homeStore.selectRestaurant(restaurant, { =>\n190:             this.goToRestaurantDetail()\n191:         })\n192:     }\n193: \n194:     private func selectHistoryRestaurant(restaurant: RestaurantData): Unit {\n195:         historyStore.selectRestaurant(restaurant, { =>\n196:             this.goToRestaurantDetail()\n197:         })\n198:     }\n199: \n200:     @Builder\n201:     private func buildOnboardingRoute() {\n202:         renderOnboardingRoute(\n203:             this.onboardingPageIndex,\n204:             this.onboardingController,\n205:             { index: Int32 =>\n206:                 this.onboardingPageIndex = Int64(index)\n207:             },\n208:             { =>\n209:                 if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n210:                     this.navigateTo(routePath(RouteId.Login))\n211:                 } else {\n212:                     this.onboardingController.showNext()\n213:                 }\n214:             }\n215:         )\n216:     }\n217: \n218:     @Builder\n219:     private func buildLoginRoute() {\n220:         renderLoginRoute(\n221:             this.loginEmail,\n222:             this.loginPassword,\n223:             this.loginErrorMessage,\n224:             { value: String =>\n225:                 this.loginEmail = value\n226:                 this.clearLoginError()\n227:             },\n228:             { value: String =>\n229:                 this.loginPassword = value\n230:                 this.clearLoginError()\n231:             },\n232:             { => this.showToast(loginStore.comingSoonMessage) },\n233:             { => this.performLogin() },\n234:             { => this.showToast(loginStore.comingSoonMessage) },\n235:             { => this.showToast(loginStore.comingSoonMessage) },\n236:             { => this.showToast(loginStore.comingSoonMessage) },\n237:             { => this.clearLoginError() }\n238:         )\n239:     }\n240: \n241:     @Builder\n242:     private func buildProfileRoute() {\n243:         renderProfileRoute(\n244:             profileStore.userName,\n245:             profileStore.userEmail,\n246:             { => this.navigateTo(profileStore.backRoute()) },\n247:             { => this.showToast(profileStore.placeholderActionMessage) },\n248:             { => this.showToast(profileStore.placeholderActionMessage) },\n249:             { => this.performLogout() }\n250:         )\n251:     }\n252: \n253:     @Builder\n254:     private func buildHomeRoute() {\n255:         renderHomeRoute(\n256:             homeStore.loadHomeState(),\n257:             this.homeHour(),\n258:             this.homeSearchQuery,\n259:             this.homeSelectedFilter,\n260:             { value: String =>\n261:                 this.homeSearchQuery = value\n262:             },\n263:             { value: String =>\n264:                 this.homeSelectedFilter = homeStore.toggleFilter(this.homeSelectedFilter, value)\n265:             },\n266:             { => this.goToProfile() },\n267:             { restaurant: RestaurantData =>\n268:                 this.selectHomeRestaurant(restaurant)\n269:             }\n270:         )\n271:     }\n272: \n273:     @Builder\n274:     private func buildHistoryRoute() {\n275:         renderHistoryRoute(\n276:             historyStore.loadHistoryState(),\n277:             this.historyTabIndex,\n278:             this.historySearchQuery,\n279:             { value: String =>\n280:                 this.historySearchQuery = value\n281:             },\n282:             { value: Int64 =>\n283:                 this.historyTabIndex = value\n284:             },\n285:             { restaurant: RestaurantData =>\n286:                 this.selectHistoryRestaurant(restaurant)\n287:             }\n288:         )\n289:     }\n290: \n291:     @Builder\n292:     private func buildCartRoute() {\n293:         renderCartRoute(\n294:             cartStore.loadCartState(),\n295:             this.cartNote,\n296:             this.cartCoupon,\n297:             { value: String =>\n298:                 this.cartNote = value\n299:             },\n300:             { value: String =>\n301:                 this.cartCoupon = value\n302:             },\n303:             { item: CartSnapshotItemData =>\n304:                 cartStore.decrementQuantity(item)\n305:                 this.cartMutationRevision += 1\n306:             },\n307:             { item: CartSnapshotItemData =>\n308:                 cartStore.incrementQuantity(item)\n309:                 this.cartMutationRevision += 1\n310:             },\n311:             { =>\n312:                 this.navigateBack()\n313:             }\n314:         )\n315:     }\n316: \n317:     @Builder\n318:     private func buildDetailRoute() {\n319:         renderDetailRoute(\n320:             this.detailState(),\n321:             { =>\n322:                 this.navigateBack()\n323:             },\n324:             { =>\n325:                 let restaurant = detailStore.selectedRestaurant()\n326:                 this.detailLiked = detailStore.toggleLiked(restaurant, this.detailLiked)\n327:             },\n328:             { =>\n329:                 this.showToast(loginStore.comingSoonMessage)\n330:             },\n331:             { =>\n332:                 this.detailRecommendedExpanded = !this.detailRecommendedExpanded\n333:             },\n334:             { =>\n335:                 this.detailNonVegExpanded = !this.detailNonVegExpanded\n336:             },\n337:             { =>\n338:                 this.detailVegExpanded = !this.detailVegExpanded\n339:             },\n340:             { item: DetailMenuItemData =>\n341:                 detailStore.incrementQuantity(item)\n342:                 this.detailMutationRevision += 1\n343:             },\n344:             { item: DetailMenuItemData =>\n345:                 detailStore.decrementQuantity(item)\n346:                 this.detailMutationRevision += 1\n347:             },\n348:             { =>\n349:                 this.navigateTo(