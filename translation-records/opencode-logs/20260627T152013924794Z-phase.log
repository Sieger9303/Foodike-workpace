rget(routePath(RouteId.Login)), routePath(RouteId.Home))\n33:         @Assert(primaryActionTarget(routePath(RouteId.Profile)), routePath(RouteId.Onboarding))\n34:     }\n35: \n36:     @TestCase\n37:     public func shellRouteStatePreservesTopFlagAcrossCommands(): Unit {\n38:         let shellState = ShellRouteState(routePath(RouteId.Home), false)\n39:         @Assert(shellState.showBottomShell(), false)\n40: \n41:         shellState.applyCommand(ShellCommand.HomeTab)\n42:         @Assert(shellState.currentRoute, routePath(RouteId.Home))\n43:         @Assert(shellState.isAtTop, false)\n44: \n45:         shellState.applyCommand(ShellCommand.HistoryTab)\n46:         @Assert(shellState.currentRoute, routePath(RouteId.History))\n47:         @Assert(shellState.isAtTop, false)\n48:         @Assert(shellState.showBottomShell(), false)\n49: \n50:         shellState.setTopState(true)\n51:         @Assert(shellState.showBottomShell(), true)\n52: \n53:         shellState.applyCommand(ShellCommand.CartAction)\n54:         @Assert(shellState.currentRoute, routePath(RouteId.Cart))\n55:         @Assert(shellState.isAtTop, true)\n56:         @Assert(shellState.showBottomShell(), false)\n57:     }\n58: \n59:     @TestCase\n60:     public func shellRouteStatePrimaryActionUsesRouteContract(): Unit {\n61:         let shellState = ShellRouteState(routePath(RouteId.Onboarding), true)\n62:         shellState.applyCommand(ShellCommand.PrimaryAction)\n63:         @Assert(shellState.currentRoute, routePath(RouteId.Login))\n64: \n65:         shellState.applyCommand(ShellCommand.PrimaryAction)\n66:         @Assert(shellState.currentRoute, routePath(RouteId.Home))\n67:     }\n68: \n69:     @TestCase\n70:     public func loginStateToggleRuleFlipsBothDirections(): Unit {\n71:         let service = LoginPreferencesService()\n72:         @Assert(service.nextLoginState(false), true)\n73:         @Assert(service.nextLoginState(true), false)\n74:     }\n75: \n76:     @TestCase\n77:     public func startupStorePublishesResolvedRouteAndClearsLoading(): Unit {\n78:         let store = StartupStore()\n79:         @Assert(store.resolveStartRoute(false), \"onboarding\")\n80:         @Assert(store.startDestination, \"onboarding\")\n81:         @Assert(store.isLoading, false)\n82: \n83:         @Assert(store.resolveStartRoute(true), \"home_screen\")\n84:         @Assert(store.startDestination, \"home_screen\")\n85:         @Assert(store.isLoading, false)\n86:     }\n87: }\n\n(End of file - total 87 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, ShellCommand, ShellRouteState, primaryActionTarget, resolveStartRoute, routePath, showsBottomShell}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.LoginPreferencesService\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.startup.StartupStore\nimport std.unittest.*\nimport std.unittest.testmacro.*\n\n@Test\npublic class Phase02StartupNavigationTest {\n    @TestCase\n    public func resolvesLoggedOutUsersToOnboarding(): Unit {\n        @Assert(resolveStartRoute(false), \"onboarding\")\n    }\n\n    @TestCase\n    public func resolvesLoggedInUsersToHome(): Unit {\n        @Assert(resolveStartRoute(true), \"home_screen\")\n    }\n","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\test\\cangjie\\phase02_startup_navigation_test.cj","time":{"start":1782573652037,"end":1782573652058}},"id":"prt_f09ab5844001Id4K20Qa143EJm","sessionID":"ses_0f65536a1ffeRAz9IKdDJHkMWy","messageID":"msg_f09ab0c370013VQZ8AIVE4gw3D"}}
{"type":"tool_use","timestamp":1782573652060,"sessionID":"ses_0f65536a1ffeRAz9IKdDJHkMWy","part":{"type":"tool","tool":"read","callID":"call_baW2hqMJconIzc7SE2q9QpEq","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\shell_route_state.cj","limit":300,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\shell_route_state.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n2: \n3: public func showsBottomShell(route: String, isAtTop: Bool): Bool {\n4:     if (!isAtTop) {\n5:         return false\n6:     }\n7: \n8:     route == routePath(RouteId.Home) || route == routePath(RouteId.History)\n9: }\n10: \n11: public class ShellRouteState {\n12:     public var currentRoute: String\n13:     public var isAtTop: Bool\n14: \n15:     public init(currentRoute: String, isAtTop: Bool) {\n16:         this.currentRoute = currentRoute\n17:         this.isAtTop = isAtTop\n18:     }\n19: \n20:     private func navigateWithoutDuplicate(route: String): Unit {\n21:         if (this.currentRoute != route) {\n22:             this.currentRoute = route\n23:         }\n24:     }\n25: \n26:     public func applyCommand(command: ShellCommand): Unit {\n27:         match (command) {\n28:             case ShellCommand.HomeTab => this.navigateWithoutDuplicate(routePath(RouteId.Home))\n29:             case ShellCommand.HistoryTab => this.navigateWithoutDuplicate(routePath(RouteId.History))\n30:             case ShellCommand.CartAction => this.navigateWithoutDuplicate(routePath(RouteId.Cart))\n31:             case ShellCommand.PrimaryAction => this.navigateWithoutDuplicate(primaryActionTarget(this.currentRoute))\n32:         }\n33:     }\n34: \n35:     public func setTopState(isAtTop: Bool): Unit {\n36:         this.isAtTop = isAtTop\n37:     }\n38: \n39:     public func showBottomShell(): Bool {\n40:         showsBottomShell(this.currentRoute, this.isAtTop)\n41:     }\n42: }\n\n(End of file - total 42 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\npublic func showsBottomShell(route: String, isAtTop: Bool): Bool {\n    if (!isAtTop) {\n        return false\n    }\n\n    route == routePath(RouteId.Home) || route == routePath(RouteId.History)\n}\n\npublic class ShellRouteState {\n    public var currentRoute: String\n    public var isAtTop: Bool\n\n    public init(currentRoute: String, isAtTop: Bool) {\n        this.currentRoute = currentRoute\n        this.isAtTop = isAtTop\n    }\n\n    private func navigateWithoutDuplicate(route: String): Unit {","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\shell_route_state.cj","time":{"start":1782573652033,"end":1782573652059}},"id":"prt_f09ab58400014j1v7ac9Bq7MqF","sessionID":"ses_0f65536a1ffeRAz9IKdDJHkMWy","messageID":"msg_f09ab0c370013VQZ8AIVE4gw3D"}}
