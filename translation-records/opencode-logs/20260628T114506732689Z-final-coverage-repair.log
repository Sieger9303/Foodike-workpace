dit: () -> Unit,\n50:     onSectionClick: () -> Unit,\n51:     onLogout: () -> Unit\n52: ) {\n53:     Column(space: 18) {\n54:         buildProfileTopBar(onBack)\n55: \n56:         Row {\n57:             Column(space: 6) {\n58:                 Text(userName)\n59:                     .fontSize(28)\n60:                     .fontWeight(FontWeight.Bold)\n61:                 Text(userEmail)\n62:                     .fontSize(15)\n63:                     .fontColor(Color.Gray)\n64:             }\n65:             .layoutWeight(1)\n66: \n67:             Column(space: 8) {\n68:                 Image(mediaProfile)\n69:                     .width(96)\n70:                     .height(96)\n71:                     .borderRadius(48)\n72:                 Text(stringEdit)\n73:                     .fontSize(15)\n74:                     .fontColor(colorDarkGreen)\n75:                     .fontWeight(FontWeight.Bold)\n76:                     .onClick({ _ =>\n77:                         onEdit()\n78:                     })\n79:             }\n80:             .alignItems(HorizontalAlign.Center)\n81:         }\n82:         .width(100.percent)\n83:         .alignItems(VerticalAlign.Center)\n84: \n85:         Divider()\n86:             .width(100.percent)\n87: \n88:         Column {\n89:             buildProfileSection(stringSavedAddresses, stringAddEditSavedAddresses, true, onSectionClick)\n90:             buildProfileSection(stringPaymentsAndRefunds, stringRefundsInformation, true, onSectionClick)\n91:             buildProfileSection(stringOnlineOrderingHelp, stringOrderingInformation, true, onSectionClick)\n92:             buildProfileSection(stringAbout, stringAboutTheApp, false, onSectionClick)\n93:         }\n94:         .width(100.percent)\n95: \n96:         Blank()\n97:             .layoutWeight(1)\n98: \n99:         Button(stringLogOut)\n100:             .width(220)\n101:             .height(50)\n102:             .onClick({ _ =>\n103:                 onLogout()\n104:             })