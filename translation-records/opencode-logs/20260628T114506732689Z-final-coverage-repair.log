{"type":"tool_use","timestamp":1782647271969,"sessionID":"ses_0f1f3cd4fffekYDWpTfD4sU38f","part":{"type":"tool","tool":"read","callID":"call_SstqElO0Ytivsem1TLCOLhyB","state":{"status":"completed","input":{"filePath":"D:\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\patch_authority.py","limit":360,"offset":320},"output":"<path>D:\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\patch_authority.py</path>\n<type>file</type>\n<content>\n320: \n321: def entry_id_field(kind: str) -> str:\n322:     return \"featureId\" if kind == \"matrix\" else \"capabilityId\"\n323: \n324: \n325: def entries_by_id(kind: str, authority: dict[str, Any]) -> tuple[dict[str, dict[str, Any]], list[str]]:\n326:     return matrix_entries_by_id(authority) if kind == \"matrix\" else capability_entries_by_id(authority)\n327: \n328: \n329: def status_counts(kind: str, authority: dict[str, Any]) -> Counter[str]:\n330:     counts: Counter[str] = Counter()\n331:     for entry in authority.get(\"entries\", []):\n332:         if not isinstance(entry, dict):\n333:             continue\n334:         if kind == \"matrix\":\n335:             status = effective_matrix_status(entry)\n336:         else:\n337:             status = effective_capability_status(entry)\n338:         counts[status] += 1\n339:     return counts\n340: \n341: \n342: def validate_authority_shape(kind: str, authority: Any) -> dict[str, dict[str, Any]]:\n343:     if not isinstance(authority, dict):\n344:         raise PatchError(\"Authority JSON must be an object.\")\n345:     entries = authority.get(\"entries\")\n346:     if not isinstance(entries, list):\n347:         raise PatchError(\"Authority JSON must contain an `entries` list.\")\n348:     id_field = entry_id_field(kind)\n349:     missing_ids = [\n350:         str(index)\n351:         for index, entry in enumerate(entries, start=1)\n352:         if not isinstance(entry, dict) or not str(entry.get(id_field) or \"\").strip()\n353:     ]\n354:     if missing_ids:\n355:         raise PatchError(f\"Authority has entries without explicit `{id_field}` at positions: {', '.join(missing_ids[:20])}.\")\n356:     by_id, problems = entries_by_id(kind, authority)\n357:     if problems:\n358:         raise PatchError(\"Authority structural problem(s): \" + \"; \".join(problems[:20]))\n359:     return by_id\n360: \n361: \n362: def split_target_endpoint(endpoint: str) -> tuple[str, str]:\n363:     raw_path, sep, raw_symbol = endpoint.partition(\"::\")\n364:     endpoint_path = raw_path.strip().strip(\"`\")\n365:     symbol = raw_symbol.strip().strip(\"`\") if sep else \"\"\n366:     # Accept common line suffixes such as foo.cj:42 without treating the line\n367:     # number as part of the path.\n368:     endpoint_path = re.sub(r\"(\\.(?:cj|json|ets|ts|js|xml|toml|yaml|yml|md|txt)):\\d+$\", r\"\\1\", endpoint_path)\n369:     return endpoint_path, symbol\n370: \n371: \n372: def endpoint_file_path(target_project: Path, endpoint_path: str) -> Path:\n373:     normalized = endpoint_path.replace(\"\\\\\", \"/\")\n374:     candidate = Path(normalized)\n375:     if candidate.is_absolute():\n376:         return candidate\n377:     return target_project / candidate\n378: \n379: \n380: def symbol_tokens(symbol: str) -> list[str]:\n381:     return [\n382:         token\n383:         for token in re.split(r\"[^A-Za-z0-9_]+\", symbol)\n384:         if token and token not in {\"self\", \"this\", \"prototype\"}\n385:     ]\n386: \n387: \n388: def validate_target_endpoint(target_project: Path, endpoint: Any) -> list[str]:\n389:     if not isinstance(endpoint, str) or not endpoint.strip():\n390:         return [\"targetEndpoint values must be non-empty strings\"]\n391:     endpoint_path, symbol = split_target_endpoint(endpoint)\n392:     if not endpoint_path:\n393:         return [f\"targetEndpoint `{endpoint}` is missing a target file path\"]\n394:     path = endpoint_file_path(target_project, endpoint_path)\n395:     if not path.exists():\n396:         return [f\"targetEndpoint `{endpoint}` file does not exist: {path}\"]\n397:     if not path.is_file():\n398:         return [f\"targetEndpoint `{endpoint}` is not a file: {path}\"]\n399:     tokens = symbol_tokens(symbol)\n400:     if tokens:\n401:         try:\n402:             text = path.read_text(encoding=\"utf-8\", errors=\"replace\")\n403:         except OSError as exc:\n404:             return [f\"targetEndpoint `{endpoint}` could not be read for symbol validation: {exc}\"]\n405:         missing = [token for token in tokens if token not in text]\n406:         if missing:\n407:             return [f\"targetEndpoint `{endpoint}` symbol token(s) not found in {path}: {', '.join(missing)}\"]\n408:     return []\n409: \n410: \n411: def contextual_validation_errors(\n412:     kind: str,\n413:     entry: dict[str, Any],\n414:     context: PatchContext,\n415: ) -> list[str]:\n416:     problems: list[str] = []\n417:     if context.legal_phases is not None and not context.allow_unknown_phase:\n418:         planned_phase = phase_label(str(entry.get(\"plannedPhase\") or \"\"))\n419:         if planned_phase and planned_phase not in context.legal_phases:\n420:             shown = \", \".join(sorted(context.legal_phases)[:20])\n421:             problems.append(f\"plannedPhase `{planned_phase}` is not present in plan phases: {shown}\")\n422: \n423:     if context.target_project is not None and not context.allow_missing_endpoints:\n424:         endpoints = coverage_target_endpoints(entry) if kind == \"matrix\" else capability_target_endpoints(entry)\n425:         if isinstance(endpoints, list):\n426:             for endpoint in endpoints:\n427:                 problems.extend(validate_target_endpoint(context.target_project, endpoint))\n428:     return problems\n429: \n430: \n431: def validate_contextual_entries(\n432:     kind: str,\n433:     entries: list[dict[str, Any]],\n434:     context: PatchContext,\n435: ) -> None:\n436:     if context.legal_phases is None and (context.target_project is None or context.allow_missing_endpoints):\n437:         return\n438:     id_field = entry_id_field(kind)\n439:     errors: list[dict[str, Any]] = []\n440:     for entry in entries:\n441:         problems = contextual_validation_errors(kind, entry, context)\n442:         if problems:\n443:             errors.append({id_field: entry.get(id_field, \"\"), \"problems\": problems})\n444:     if errors:\n445:         shown = \"; \".join(f\"{item.get(id_field)}: {', '.join(item['problems'])}\" for item in errors[:20])\n446:         raise PatchError(f\"Authority context validation failed for {len(errors)} entrie(s): {shown}\")\n447: \n448: \n449: def ensure_object(value: Any, field: str) -> dict[str, Any]:\n450:     if value is None:\n451:         return {}\n452:     if not isinstance(value, dict):\n453:         raise PatchError(f\"`{field}` must be an object.\")\n454:     return value\n455: \n456: \n457: def ensure_list(value: Any, field: str) -> list[Any]:\n458:     if value is None:\n459:         return []\n460:     if not isinstance(value, list):\n461:         raise PatchError(f\"`{field}` must be a list.\")\n462:     return value\n463: \n464: \n465: def canonical_json(value: Any) -> str:\n466:     return json.dumps(value, ensure_ascii=False, sort_keys=True, separators=(\",\", \":\"))\n467: \n468: \n469: def append_unique(existing: list[Any], values: list[Any]) -> list[Any]:\n470:     result = list(existing)\n471:     seen = {canonical_json(item) for item in result}\n472:     for value in values:\n473:         key = canonical_json(value)\n474:         if key not in seen:\n475:             result.append(value)\n476:             seen.add(key)\n477:     return result\n478: \n479: \n480: def validate_patch_payload(payload: Any) -> dict[str, Any]:\n481:     if not isinstance(payload, dict):\n482:         raise PatchError(\"Patch payload must be a JSON object.\")\n483:     allowed = {\"schemaVersion\", \"purpose\", \"updates\", \"add\", \"additions\"}\n484:     unknown = sorted(set(payload) - allowed)\n485:     if unknown:\n486:         raise PatchError(f\"Patch payload has unknown top-level field(s): {', '.join(unknown)}.\")\n487:     updates = payload.get(\"updates\", [])\n488:     additions = payload.get(\"add\", payload.get(\"additions\", []))\n489:     if not isinstance(updates, list):\n490:         raise PatchError(\"Patch payload `updates` must be a list.\")\n491:     if not isinstance(additions, list):\n492:         raise PatchError(\"Patch payload `add`/`additions` must be a list.\")\n493:     if not updates and not additions:\n494:         raise PatchError(\"Patch payload must contain at least one update or addition.\")\n495:     return {\"updates\": updates, \"additions\": additions}\n496: \n497: \n498: def field_sets(kind: str) -> tuple[set[str], set[str], set[str], set[str]]:\n499:     if kind == \"matrix\":\n500:         return MATRIX_UPDATE_FIELDS, MATRIX_ADD_FIELDS, MATRIX_LIST_FIELDS, MATRIX_TEXT_FIELDS\n501:     return PLATFORM_UPDATE_FIELDS, PLATFORM_ADD_FIELDS, PLATFORM_LIST_FIELDS, PLATFORM_TEXT_FIELDS\n502: \n503: \n504: def object_fields(kind: str) -> set[str]:\n505:     return MATRIX_OBJECT_FIELDS if kind == \"matrix\" else PLATFORM_OBJECT_FIELDS\n506: \n507: \n508: def default_object_value(kind: str, field: str) -> dict[str, Any]:\n509:     if kind == \"matrix\" and field == COVERAGE_FACTS_KEY:\n510:         return default_coverage_facts()\n511:     if kind == \"platform\" and field == CAPABILITY_FACTS_KEY:\n512:         return default_capability_facts()\n513:     return {}\n514: \n515: \n516: def validate_object_field(kind: str, field: str, value: Any) -> dict[str, Any]:\n517:     if not isinstance(value, dict):\n518:         raise PatchError(f\"Field `{field}` must be an object.\")\n519:     if field in {COVERAGE_FACTS_KEY, CAPABILITY_FACTS_KEY} and value.get(\"factsSource\") != \"agent\":\n520:         raise PatchError(f\"Field `{field}` updates must use factsSource `agent`.\")\n521:     strict = value.get(\"factsSource\") == \"agent\"\n522:     problems = (\n523:         validate_coverage_facts(value, strict=strict)\n524:         if kind == \"matrix\" and field == COVERAGE_FACTS_KEY\n525:         else validate_capability_facts(value, strict=strict)\n526:     )\n527:     if problems:\n528:         raise PatchError(f\"Field `{field}` has invalid structured facts: \" + \"; \".join(problems[:12]))\n529:     return copy.deepcopy(value)\n530: \n531: \n532: def validate_field_value(kind: str, field: str, value: Any, *, add_entry: bool = False) -> Any:\n533:     update_fields, add_fields, list_fields, text_fields = field_sets(kind)\n534:     allowed = add_fields if add_entry else update_fields\n535:     if field not in allowed:\n536:         raise PatchError(f\"Field `{field}` is not writable for {kind} authority patches.\")\n537:     if field in object_fields(kind):\n538:         return validate_object_field(kind, field, value)\n539:     if field in list_fields:\n540:         if not isinstance(value, list):\n541:             raise PatchError(f\"Field `{field}` must be a list.\")\n542:         return value\n543:     if field in text_fields:\n544:         if not isinstance(value, str):\n545:             raise PatchError(f\"Field `{field}` must be a string.\")\n546:         if field == \"status\":\n547:             return value.strip().lower()\n548:         if field == \"parityLevel\":\n549:             return value.strip().lower()\n550:         return value\n551:     if field in {\"riskTags\", \"keyClasses\", \"keyMethods\", \"androidIds\", \"dependencies\", \"sourcePaths\"}:\n552:         if not isinstance(value, list):\n553:             raise PatchError(f\"Field `{field}` must be a list.\")\n554:     elif field in {\"sourceEvidence\", \"requiredTargetCapabilitySearch\", \"requiredTests\", \"allowedDeferredReasons\"}:\n555:         if kind == \"platform\" and field != \"sourceEvidence\" and not isinstance(value, list):\n556:             raise PatchError(f\"Field `{field}` must be a list.\")\n557:         if kind == \"platform\" and field == \"sourceEvidence\" and not isinstance(value, list):\n558:             raise PatchError(\"Field `sourceEvidence` must be a list for platform additions.\")\n559:         if kind == \"matrix\" and field == \"sourceEvidence\" and not isinstance(value, str):\n560:             raise PatchError(\"Field `sourceEvidence` must be a string for matrix additions.\")\n561:     elif field in {\n562:         \"featureId\",\n563:         \"featureName\",\n564:         \"sourcePath\",\n565:         \"importance\",\n566:         \"category\",\n567:         \"featurePoint\",\n568:         \"capabilityId\",\n569:         \"capabilityName\",\n570:         \"sourceEvidenceSummary\",\n571:         \"targetStrategyHint\",\n572:         \"minimumParity\",\n573:     }:\n574:         if not isinstance(value, str):\n575:             raise PatchError(f\"Field `{field}` must be a string.\")\n576:     return value\n577: \n578: \n579: def patch_entry(kind: str, entry: dict[str, Any], update: dict[str, Any]) -> None:\n580:     allowed_ops = {\"featureId\", \"capabilityId\", \"set\", \"append\", \"remove\", \"unset\"}\n581:     unknown = sorted(set(update) - allowed_ops)\n582:     if unknown:\n583:         raise PatchError(f\"Update for `{entry.get(entry_id_field(kind), '')}` has unknown operation field(s): {', '.join(unknown)}.\")\n584: \n585:     set_values = ensure_object(update.get(\"set\"), \"set\")\n586:     append_values = ensure_object(update.get(\"append\"), \"append\")\n587:     remove_values = ensure_object(update.get(\"remove\"), \"remove\")\n588:     unset_fields = ensure_list(update.get(\"unset\"), \"unset\")\n589:     _, _, list_fields, text_fields = field_sets(kind)\n590: \n591:     for field, value in set_values.items():\n592:         entry[field] = validate_field_value(kind, field, value)\n593: \n594:     for field, values in append_values.items():\n595:         if field not in list_fields:\n596:             raise PatchError(f\"Append is allowed only for list fields; `{field}` is not appendable.\")\n597:         values = validate_field_value(kind, field, values)\n598:         existing = entry.get(field, [])\n599:         if not isinstance(existing, list):\n600:             raise PatchError(f\"Cannot append to `{field}` because the current value is not a list.\")\n601:         entry[field] = append_unique(existing, values)\n602: \n603:     for field, values in remove_values.items():\n604:         if field not in list_fields:\n605:             raise PatchError(f\"Remove is allowed only for list fields; `{field}` is not removable.\")\n606:         values = validate_field_value(kind, field, values)\n607:         existing = entry.get(field, [])\n608:         if not isinstance(existing, list):\n609:             raise PatchError(f\"Cannot remove from `{field}` because the current value is not a list.\")\n610:         remove_keys = {canonical_json(value) for value in values}\n611:         entry[field] = [value for value in existing if canonical_json(value) not in remove_keys]\n612: \n613:     update_fields, _, _, _ = field_sets(kind)\n614:     for field in unset_fields:\n615:         if not isinstance(field, str):\n616:             raise PatchError(\"Every `unset` item must be a string field name.\")\n617:         if field not in update_fields:\n618:             raise PatchError(f\"Field `{field}` is not writable for {kind} authority patches.\")\n619:         if field in list_fields:\n620:             entry[field] = []\n621:         elif field in object_fields(kind):\n622:             entry[field] = default_object_value(kind, field)\n623:         else:\n624:             entry[field] = \"\"\n625:         if field in text_fields and field == \"status\":\n626:             entry[field] = \"planned\"\n627: \n628: \n629: def matrix_defaulted_addition(entry: dict[str, Any]) -> dict[str, Any]:\n630:     defaults: dict[str, Any] = {\n631:         \"status\": \"planned\",\n632:         \"plannedPhase\": \"\",\n633:         \"sourceBehavior\": entry.get(\"featurePoint\", \"\"),\n634:         \"targetBehavior\": \"\",\n635:         \"verificationEvidence\": [],\n636:         \"parityLevel\": \"unverified\",\n637:         \"targetEndpoints\": [],\n638:         \"tests\": [],\n639:         \"notes\": \"\",\n640:         \"deferredReason\": \"\",\n641:         \"targetFallback\": \"\",\n642:         \"risk\": \"\",\n643:         \"futureCompletionPath\": \"\",\n644:         \"entryOrigin\": \"agent-curated\",\n645:         \"matrixSync\": {\n646:             \"status\": \"agent-curated\",\n647:             \"preserveActive\": True,\n648:             \"reason\": \"row was added through structured authority patch\",\n649:         },\n650:         \"riskTags\": [],\n651:         \"keyClasses\": [],\n652:         \"keyMethods\": [],\n653:         \"androidIds\": [],\n654:         \"dependencies\": [],\n655:         \"featurePoint\": \"\",\n656:         \"category\": \"\",\n657:         COVERAGE_FACTS_KEY: default_coverage_facts(),\n658:     }\n659:     return {**defaults, **entry}\n660: \n661: \n662: def platform_defaulted_addition(entry: dict[str, Any]) -> dict[str, Any]:\n663:     defaults: dict[str, Any] = {\n664:         \"status\": \"planned\",\n665:         \"plannedPhase\": \"\",\n666:         \"sourcePaths\": [],\n667:         \"sourceEvidence\": [],\n668:         \"requiredTargetCapabilitySearch\": [],\n669:         \"targetStrategyHint\": \"\",\n670:         \"minimumParity\": \"\",\n671:         \"requiredTests\": [],\n672:         \"allowedDeferredReasons\": [],\n673:         \"targetCapabilitySearch\": [],\n674:         \"targetApiOrLibrary\": \"\",\n675:         \"targetStrategy\": \"\",\n676:         \"targetEndpoints\": [],\n677:         \"tests\": [],\n678:         \"sdkDeclarationEvidence\": [],\n679:         \"cangjieCallableEvidence\": [],\n\n(Showing lines 320-679 of 973. Use offset=680 to continue.)\n</content>","metadata":{"preview":"\ndef entry_id_field(kind: str) -> str:\n    return \"featureId\" if kind == \"matrix\" else \"capabilityId\"\n\n\ndef entries_by_id(kind: str, authority: dict[str, Any]) -> tuple[dict[str, dict[str, Any]], list[str]]:\n    return matrix_entries_by_id(authority) if kind == \"matrix\" else capability_entries_by_id(authority)\n\n\ndef status_counts(kind: str, authority: dict[str, Any]) -> Counter[str]:\n    counts: Counter[str] = Counter()\n    for entry in authority.get(\"entries\", []):\n        if not isinstance(entry, dict):\n            continue\n        if kind == \"matrix\":\n            status = effective_matrix_status(entry)\n        else:\n            status = effective_capability_status(entry)\n        counts[status] += 1\n    return counts","truncated":true,"loaded":[]},"title":"..\\..\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\patch_authority.py","time":{"start":1782647271958,"end":1782647271967}},"id":"prt_f0e0eb211001C1D637xTXVLiyr","sessionID":"ses_0f1f3cd4fffekYDWpTfD4sU38f","messageID":"msg_f0e0e9546001Jkg22tzFbpm68j"}}
