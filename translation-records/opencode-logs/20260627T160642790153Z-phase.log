oreAcceptsOnlySourceCredentials(): Unit {\n31:         let store = LoginStore()\n32:         @Assert(store.isValidCredentials(\"abcxyz@gmail.com\", \"abcdef\"), true)\n33:         @Assert(store.isValidCredentials(\"\", \"\"), false)\n34:         @Assert(store.isValidCredentials(\"abcxyz@gmail.com\", \"bad\"), false)\n35:         @Assert(store.isValidCredentials(\"other@example.com\", \"abcdef\"), false)\n36:         @Assert(store.successRoute(), routePath(RouteId.Home))\n37:     }\n38: \n39:     @TestCase\n40:     public func loginStorePreservesSourceHintsAndPlaceholderMessages(): Unit {\n41:         let store = LoginStore()\n42:         @Assert(store.emailHint, \"Enter email or phone number\")\n43:         @Assert(store.passwordHint, \"Password\")\n44:         @Assert(store.invalidLoginMessage, \"Please enter correct email and password\")\n45:         @Assert(store.comingSoonMessage, \"Coming soon!\")\n46:     }\n47: \n48:     @TestCase\n49:     public func profileStoreRoutesBackAndLogoutToSourceDestinations(): Unit {\n50:         let store = ProfileStore()\n51:         @Assert(store.backRoute(), routePath(RouteId.History))\n52:         @Assert(store.logoutRoute(), routePath(RouteId.Onboarding))\n53:         @Assert(store.userName, \"Andrew Howard\")\n54:         @Assert(store.userEmail, \"andrewhoward@gmail.com\")\n55:     }\n56: }\n\n(End of file - total 56 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, routePath}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.LoginStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.OnboardingStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.ProfileStore\nimport std.unittest.*\nimport std.unittest.testmacro.*\n\n@Test\npublic class Phase03OnboardingLoginProfileTest {\n    @TestCase\n    public func onboardingStorePreservesThreePageProgression(): Unit {\n        let store = OnboardingStore()\n        @Assert(store.pageCount(), 3)\n        @Assert(store.slideAt(0).title, \"Choose your favourite food\")\n        @Assert(store.slideAt(0).description, \"Choose from a range of restaurants and hotels near you\")\n        @Assert(store.slideAt(0).mediaName, \"chinese_bowl\")\n        @Assert(store.slideAt(1).title, \"Vaccinated delivery partners\")\n        @Assert(store.slideAt(1).mediaName, \"rider\")","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\test\\cangjie\\phase03_onboarding_login_profile_test.cj","time":{"start":1782577121085,"end":1782577121092}},"id":"prt_f09e04738001pmfhlfEhwLl1tS","sessionID":"ses_0f62aa824ffeaYjaCmpYi13tcz","messageID":"msg_f09e02b98001oIRc9gyWM43oVB"}}
