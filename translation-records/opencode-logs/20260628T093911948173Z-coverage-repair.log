{"type":"tool_use","timestamp":1782639577658,"sessionID":"ses_0f2671430ffeHDH7OOuiDtjCMf","part":{"type":"tool","tool":"read","callID":"call_vgZi2sV0IKaqt3aqweUYqhfZ","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_store.cj","limit":320,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_store.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home\n2: \n3: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.homeContentRepository\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n6: import std.collection.ArrayList\n7: import std.unicode.*\n8: \n9: public let homeStore = HomeStore()\n10: \n11: public class HomeStore {\n12:     private let contentRepository = homeContentRepository\n13:     private let sessionRepository = sessionRepository\n14:     private let filters = ArrayList<String>([\n15:         \"Fast Delivery\",\n16:         \"50% Discount\",\n17:         \"Great deals\",\n18:         \"Non-Veg\"\n19:     ])\n20: \n21:     public init() {}\n22: \n23:     public func loadHomeState(): HomePageState {\n24:         return HomePageState(\n25:             contentRepository.getAds(),\n26:             contentRepository.getFoodItems(),\n27:             sessionRepository.getLikedRestaurants(),\n28:             contentRepository.getRestaurants()\n29:         )\n30:     }\n31: \n32:     public func buildVisibleState(query: String): HomePageState {\n33:         let state = loadHomeState()\n34:         if (query == \"\") {\n35:             return state\n36:         }\n37:         return HomePageState(\n38:             state.advertisements,\n39:             state.categories,\n40:             filterRestaurants(state.favourites, query),\n41:             filterRestaurants(state.restaurants, query)\n42:         )\n43:     }\n44: \n45:     public func buildFilteredState(query: String, selectedFilter: String): HomePageState {\n46:         let state = buildVisibleState(query)\n47:         if (selectedFilter == \"\") {\n48:             return state\n49:         }\n50:         return HomePageState(\n51:             state.advertisements,\n52:             state.categories,\n53:             filterByTag(state.favourites, selectedFilter),\n54:             filterByTag(state.restaurants, selectedFilter)\n55:         )\n56:     }\n57: \n58:     public func filtersList(): ArrayList<String> {\n59:         return filters\n60:     }\n61: \n62:     public func toggleFilter(currentFilter: String, tappedFilter: String): String {\n63:         if (currentFilter == tappedFilter) {\n64:             return \"\"\n65:         }\n66:         return tappedFilter\n67:     }\n68: \n69:     public func greetingForHour(hour: Int64): String {\n70:         if (hour >= 0 && hour <= 11) {\n71:             return \"Good Morning!\"\n72:         }\n73:         if (hour >= 12 && hour <= 15) {\n74:             return \"Good Afternoon!\"\n75:         }\n76:         return \"Good Evening!\"\n77:     }\n78: \n79:     public func selectRestaurant(restaurant: RestaurantData, onNavigate: () -> Unit): Unit {\n80:         sessionRepository.setSelectedRestaurant(restaurant)\n81:         onNavigate()\n82:     }\n83: \n84:     private func filterRestaurants(restaurants: ArrayList<RestaurantData>, query: String): ArrayList<RestaurantData> {\n85:         let filtered = ArrayList<RestaurantData>([])\n86:         for (restaurant in restaurants) {\n87:             if (matchesQuery(restaurant, query)) {\n88:                 filtered.add(restaurant)\n89:             }\n90:         }\n91:         return filtered\n92:     }\n93: \n94:     public func filterByTag(restaurants: ArrayList<RestaurantData>, tag: String): ArrayList<RestaurantData> {\n95:         let filtered = ArrayList<RestaurantData>([])\n96:         for (restaurant in restaurants) {\n97:             if (matchesTag(restaurant, tag)) {\n98:                 filtered.add(restaurant)\n99:             }\n100:         }\n101:         return filtered\n102:     }\n103: \n104:     private func matchesQuery(restaurant: RestaurantData, query: String): Bool {\n105:         return containsIgnoreCase(restaurant.name, query)\n106:             || containsIgnoreCase(restaurant.variety, query)\n107:             || containsIgnoreCase(restaurant.place, query)\n108:     }\n109: \n110:     public func matchesTag(restaurant: RestaurantData, tag: String): Bool {\n111:         match (tag) {\n112:             case \"Fast Delivery\" => restaurant.etaMinutes <= 30\n113:             case \"50% Discount\" => restaurant.averagePrice <= 2.5\n114:             case \"Great deals\" => restaurant.rating >= 4.5\n115:             case \"Non-Veg\" => !containsIgnoreCase(restaurant.variety, \"Vegetarian\")\n116:             case _ => true\n117:         }\n118:     }\n119: \n120:     public func containsIgnoreCase(source: String, query: String): Bool {\n121:         let normalizedSource = source.toLower()\n122:         let normalizedQuery = query.toLower()\n123:         let sourceLength = normalizedSource.size\n124:         let queryLength = normalizedQuery.size\n125:         if (queryLength == 0) {\n126:             return true\n127:         }\n128:         if (queryLength > sourceLength) {\n129:             return false\n130:         }\n131:         var start: Int64 = 0\n132:         while (start + queryLength <= sourceLength) {\n133:             if (normalizedSource[start..(start + queryLength)] == normalizedQuery) {\n134:                 return true\n135:             }\n136:             start += 1\n137:         }\n138:         return false\n139:     }\n140: \n141:     public func session(): SessionRepository {\n142:         return sessionRepository\n143:     }\n144: }\n\n(End of file - total 144 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.homeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\nimport std.unicode.*\n\npublic let homeStore = HomeStore()\n\npublic class HomeStore {\n    private let contentRepository = homeContentRepository\n    private let sessionRepository = sessionRepository\n    private let filters = ArrayList<String>([\n        \"Fast Delivery\",\n        \"50% Discount\",\n        \"Great deals\",\n        \"Non-Veg\"\n    ])\n","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_store.cj","time":{"start":1782639577643,"end":1782639577657}},"id":"prt_f0d994a29002chQ6oA6gNKIeNv","sessionID":"ses_0f2671430ffeHDH7OOuiDtjCMf","messageID":"msg_f0d9916b5001VBwCDGIG7xyMM2"}}
