95:     }\n96: \n97:     public func setRestaurantLiked(restaurant: RestaurantData, liked: Bool): Unit {\n98:         if (liked) {\n99:             if (!containsLikedRestaurant(restaurant.name)) {\n100:                 likedRestaurants.add(restaurant)\n101:             }\n102:             return\n103:         }\n104:         removeLikedRestaurant(restaurant.name)\n105:     }\n106: \n107:     public func restaurantSelectionRouteToken(): String {\n108:         return selectedRestaurantName\n109:     }\n110: \n111:     private func replaceSelectedMenu(sourceMenu: ArrayList<DetailMenuItemData>): Unit {\n112:         selectedRestaurantMenuItems.clear()\n113:         for (item in sourceMenu) {\n114:             selectedRestaurantMenuItems.add(\n115:                 DetailMenuItemData(\n116:                     MenuItemData(\n117:                         item.menuItem.dish,\n118:                         item.menuItem.price,\n119:                         item.menuItem.rating,\n120:                         item.menuItem.ratingCount,\n121:                         item.menuItem.isVegetarian\n122:                     ),\n123:                     0\n124:                 )\n125:             )\n126:         }\n127:     }\n128: \n129:     private func containsLikedRestaurant(name: String): Bool {\n130:         for (restaurant in likedRestaurants) {\n131:             if (restaurant.name == name) {\n132:                 return true\n133:             }\n134:         }\n135:         return false\n136:     }\n137: \n138:     private func removeLikedRestaurant(name: String): Unit {\n139:         var index: Int64 = 0\n140:         while (index < likedRestaurants.size) {\n141:             if (likedRestaurants[index].name == name) {\n142:                 likedRestaurants.remove(at: index)\n143:                 return\n144:             }\n145:             index += 1\n146:         }\n147:     }\n148: }\n149: \n150: public let sessionRepository = SessionRepository()\n\n(End of file - total 150