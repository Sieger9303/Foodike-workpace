le.harmonyos-6-1-8k-guide-file-management-cj-app-file-access-3more-79c9388b-md\",\r\n      \"title\": \"开发示例\",\r\n      \"score\": 100.876,\r\n      \"summary\": \"在对应用文件开始访问前，开发者需要获取应用文件路径。以从AbilityContext获取HAP级别的文件路径为例进行说明，AbilityContext的获取方式请参见[获取UIAbility的上下文信息](../application-models/cj-uiability-usage.md#获取uiability的上下文信息)。 下面介绍几种常用操作示例。\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/Guide/file-management/cj-app-file-access/应用文件访问/开发示例/开发示例_3more_79c9388b.md\"\r\n      ],\r\n      \"source\": null,\r\n      \"doc_kind\": null\r\n    },\r\n    {\r\n      \"example_id\": \"example.harmonyos-6-1-8k-guide-file-management-cj-app-file-access-abstract-md\",\r\n      \"title\": \".abstract\",\r\n      \"score\": 100.876,\r\n      \"summary\": \"本目录包含仓颉编程语言的开发示例，重点介绍文件输入输出（I/O）操作。内容涵盖如何利用流接口进行文件读写、通过 AbilityContext 获取应用文件路径以及执行文件复制等基础操作。核心知识点包括 `FileIo.createStream` 的使用、缓冲区处理、文件偏移量管理以及基于特定条件（如后缀、大小）的文件列表过滤。这些示例适合需要实现应用内数据持久化或处理文件系统的仓颉开发者参考，旨在帮助开发者掌握高效的文件处理技巧。\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/Guide/file-management/cj-app-file-access/应用文件访问/开发示例/.abstract.md\"\r\n      ],\r\n      \"source\": null,\r\n      \"doc_kind\": null\r\n    }\r\n  ],\r\n  \"docs\": [\r\n    {\r\n      \"doc_id\": \"doc.harmonyos-6-1-8k-api-arkui-cj-cj-common-types-interface-resourc-4more-9938f16a\",\r\n      \"title\": \"interface ResourceColor\",\r\n      \"score\": 106.027,\r\n      \"summary\": \"public interface ResourceColor { func toUInt32(): UInt32 } **功能：** Color、UInt32、Int64、AppResource 均实现了 ResourceColor 接口类型。 **系统能力：** SystemCapability.ArkUI.ArkUI.Full **起始版本：** 22 extend Int64 <: ResourceColor {\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/API/arkui-cj/cj-common-types/基础类型定义/interface_Resourc_4more_9938f16a.md\"\r\n      ],\r\n      \"source\": \"harmonyos-6.1-8k\",\r\n      \"doc_kind\": \"reference\"\r\n    },\r\n    {\r\n      \"doc_id\": \"doc.harmonyos-6-1-8k-api-arkui-cj-cj-common-types-class-color\",\r\n      \"title\": \"class Color\",\