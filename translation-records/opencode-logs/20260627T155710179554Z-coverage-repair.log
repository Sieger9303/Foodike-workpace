)[0]\n35:         repository.setRestaurant(restaurant)\n36: \n37:         @Assert(repository.getSavedRestaurantName(), \"George Street\")\n38:         let menuItems = repository.getMenuItems()\n39:         @Assert(menuItems.size > 0, true)\n40:         @Assert(menuItems[0].menuItem.dish, \"Fish and Chips\")\n41:         @Assert(menuItems[0].quantity, 0)\n42:     }\n43: \n44:     @TestCase\n45:     public func sessionRepositoryLikeToggleMutatesSharedFavouriteState(): Unit {\n46:         let repository = SessionRepository()\n47:         let candidate = HomeContentRepository().getRestaurants()[1]\n48: \n49:         @Assert(repository.isRestaurantLiked(candidate), false)\n50:         repository.setRestaurantLiked(candidate, true)\n51:         @Assert(repository.isRestaurantLiked(candidate), true)\n52:         @Assert(repository.getLikedRestaurants().size, 6)\n53: \n54:         repository.setRestaurantLiked(candidate, false)\n55:         @Assert(repository.isRestaurantLiked(candidate), false)\n56:         @Assert(repository.getLikedRestaurants().size, 5)\n57:     }\n58: \n59:     @TestCase\n60:     public func sessionRepositoryRetainsCartSeedItems(): Unit {\n61:         let repository = SessionRepository()\n62:         let cartItems = repository.getCartItems()\n63:         @Assert(cartItems.size, 2)\n64:         @Assert(cartItems[0].menuItem.dish, \"Paw Bhaaji\")\n65:         @Assert(cartItems[1].quantity, 2)\n66:     }\n67: }\n\n(End of file - total 67 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.SessionRepository\nimport std.unittest.*\nimport std.unittest.testmacro.*\n\n@Test\npublic class Phase02RepositoryContractTest {\n    @TestCase\n    public func contentRepositoryExposesFullRestaurantSeedSet(): Unit {\n        let repository = HomeContentRepository()\n        let restaurant