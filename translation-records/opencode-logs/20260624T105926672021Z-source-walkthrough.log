oodike.presentation.details.components.RestaurantDetailCard\n70: import com.example.foodike.presentation.util.Screen\n71: \n72: @Composable\n73: fun RestaurantDetail(\n74:     navController: NavHostController,\n75:     viewModel: RestaurantDetailViewModel = hiltViewModel()\n76: ) {\n77: \n78:     val detailScreenState by viewModel.detailScreenState\n79: \n80: \n81:     val rotationState by animateFloatAsState(\n82:         targetValue = if (detailScreenState.recommendedExpandedState) 180f else 0f\n83:     )\n84: \n85:     val rotationStateNonVeg by animateFloatAsState(\n86:         targetValue = if (detailScreenState.nonVegExpandedState) 180f else 0f\n87:     )\n88: \n89:     val rotationStateVeg by animateFloatAsState(\n90:         targetValue = if (detailScreenState.vegExpandedState) 180f else 0f\n91:     )\n92: \n93: \n94:     Box(contentAlignment = Alignment.BottomEnd) {\n95:         LazyColumn(modifier = Modifier.fillMaxSize()) {\n96:             item {\n97:                 Row(\n98:                     modifier = Modifier.fillMaxWidth(),\n99:                     horizontalArrangement = Arrangement.SpaceBetween\n100:                 ) {\n101:                     IconButton(onClick = { navController.navigateUp() }) {\n102:                         Icon(\n103:                             imageVector = Icons.Outlined.ArrowBack,\n104:                             contentDescription = stringResource(R.string.favourite)\n105:                         )\n106:                     }\n107:                     Row {\n108:                         IconToggleButton(\n109:                             checked = detailScreenState.isLiked,\n110:                             onCheckedChange = {\n111:                                 viewModel.onEvent(DetailScreenEvent.ToggleLikedStatus)\n112:                             },\n113:                         ) {\n114:                             if (detailScreenState.isLiked) {\n115:                                 Icon(\n116:                                     imageVector = Icons.Filled.Favorite,\n117:                                     contentDescription = stringResource(R.string.favourite),\n118:                                     tint = Color.Red\n119:                                 )\n120:                             } else {\n121:                                 Icon(\n122:                                     imageVector = Icons.Default.FavoriteBorder,\n123:                                     contentDescription = stringResource(R.string.favourite)\n124:                                 )\n125:                             }\n126: \n127:                         }\n128:                         IconButton(onClick = {\n129: \n130:                         }) {\n131:                             Icon(\n132:                                 imageVector = Icons.Outlined.Share,\n133:                                 contentDescription = stringResource(\n134:                                     R.string.share\n135:                                 )\n136:                             )\n137:                         }\n138: \n139:                     }\n140:                 }\n141:             }\n142:             item {\n143:                 Column(modifier = Modifier.padding(16.dp)) {\n144:                     RestaurantDetailCard(\n145:                         detailScreenState.restaurant!!\n146:                     )\n147: \n148:                 }\n149:             }\n150:             val recommendedList =\n151:                 detailScreenState.recommendedList\n152: \n153: \n154: \n155: \n156:             item {\n157:                 Row(\n158:                     modifier = Modifier\n159:                         .fillMaxWidth()\n160:                         .padding(24.dp, 0.dp),\n161:                     verticalAlignment = Alignment.CenterVertically,\n162:                     horizontalArrangement = Arrangement.Center\n163: \n164:                 ) {\n165:                     Text(\n166:                         modifier = Modifier\n167:                             .weight(6f),\n168:                         text = stringResource(R.string.recommended),\n169:                         fontSize = 24.sp,\n170:                         fontWeight = FontWeight.Bold,\n171:                         maxLines = 1,\n172:                         overflow = TextOverflow.Ellipsis\n173:                     )\n174:                     IconButton(\n175:                         modifier = Modifier\n176:                             .weight(1f)\n177:                             .alpha(ContentAlpha.medium)\n178:                             .rotate(rotationState),\n179:                         onClick = {\n180:                             viewModel.onEvent(DetailScreenEvent.ToggleRecommendedSectionExpandedState)\n181:                         }) {\n182:                         Icon(\n183:                             imageVector = Icons.Default.ArrowDropDown,\n184:                             contentDescription = stringResource(R.string.drop_down_arrow)\n185:                         )\n186:                     }\n187: \n188:                 }\n189: \n190:             }\n191:             if (detailScreenState.recommendedExpandedState) {\n192: \n193:                 items(recommendedList.size) {\n194:                     MenuItemCard(\n195:                         menuItem = recommendedList[it].menuItem,\n196: \n197: \n198:                         )\n199:                     if (it != (recommendedList.size - 1)) {\n200:                         Divider(\n201:                             modifier = Modifier\n202:                                 .fillMaxWidth()\n203:                                 .padding(24.dp, 0.dp)\n204:                         )\n205:                     }\n206:                 }\n207: \n208: \n209:             }\n210: \n211:             val nonVegList = detailScreenState.menuList.filter {\n212:                 !it.menuItem.isVegetarian\n213:             }\n214: \n215:    