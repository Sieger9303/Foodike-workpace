compose.foundation.layout.fillMaxSize\n33: import androidx.compose.foundation.layout.height\n34: import androidx.compose.foundation.layout.padding\n35: import androidx.compose.runtime.Composable\n36: import androidx.compose.runtime.getValue\n37: import androidx.compose.ui.Modifier\n38: import androidx.compose.ui.graphics.Color\n39: import androidx.compose.ui.graphics.toArgb\n40: import androidx.compose.ui.platform.LocalContext\n41: import androidx.compose.ui.unit.dp\n42: import androidx.hilt.navigation.compose.hiltViewModel\n43: import androidx.navigation.NavHostController\n44: import com.example.foodike.presentation.components.SearchBar\n45: import com.example.foodike.presentation.history.components.Tabs\n46: import com.example.foodike.presentation.history.components.TabsContent\n47: import com.example.foodike.presentation.util.Screen\n48: import com.google.accompanist.pager.ExperimentalPagerApi\n49: import com.google.accompanist.pager.rememberPagerState\n50: \n51: @ExperimentalPagerApi\n52: @Composable\n53: fun History(\n54:     viewModel: HistoryViewModel = hiltViewModel(),\n55:     navHostController: NavHostController\n56: ) {\n57: \n58:     val state by viewModel.likedRestaurants\n59: \n60: \n61:     val context = LocalContext.current as Activity\n62: \n63:     val pagerState = rememberPagerState()\n64: \n65: \n66:     context.window.statusBarColor = Color.Gray.toArgb()\n67:     context.window.navigationBarColor = Color.White.toArgb()\n68: \n69:     Column(\n70:         modifier = Modifier\n71:             .fillMaxSize()\n72:     ) {\n73:         Column(\n74:             modifier = Modifier.padding(16.dp)\n75:         ) {\n76:             SearchBar()\n77:             Spacer(modifier = Modifier.height(8.dp))\n78: \n79:             Tabs(pagerState = pagerState)\n80:         }\n81:         TabsContent(\n82:             pagerState = pagerState, state.likedRestaurantList,\n83:             onClick = {\n84:                 viewModel.onEvent(HistoryEvent.SelectRestaurant(it){\n85:                     navHostController.navigate(Screen.RestaurantDetails.route)\n86:                 })\n87:             }\n88:         )\n89: \n90:     }\n91: }\n92: \n93: \n94: \n95: \n96: \n\n(End of file - total 96 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER","truncated":false,"loaded":[]},"title":"..\\..\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\history\\History.kt","time":{"start":1782298863299,"end":1782298863306}},"id":"prt_ef94a66860010wGarJYtcKH5Ng","sessionID":"ses_106b70cc2ffeQ7z094Vd8ASez1","messageID":"msg_ef94a0579001s2cCwW1Cwm50L9"}}
