fecycle.viewModelScope\n33: import com.example.foodike.data.repository.Results\n34: import com.example.foodike.domain.repository.HomeRepository\n35: import com.example.foodike.domain.repository.UserDataRepository\n36: import dagger.hilt.android.lifecycle.HiltViewModel\n37: import kotlinx.coroutines.launch\n38: import javax.inject.Inject\n39: \n40: @HiltViewModel\n41: class HomeViewModel @Inject constructor(\n42:     private val repository: HomeRepository,\n43:     private val userDataRepository: UserDataRepository,\n44: \n45: ) : ViewModel() {\n46: \n47:     private val _homeScreenState = mutableStateOf(\n48:         HomeScreenState()\n49:     )\n50:     val homeScreenState: State<HomeScreenState> = _homeScreenState\n51: \n52:     init {\n53:         viewModelScope.launch {\n54:             when (val result = repository.getAds()) {\n55:                 is Results.Success -> _homeScreenState.value = homeScreenState.value.copy(\n56:                     adsList = result.data\n57:                 )\n58:                 is Results.Error -> {\n59:                 }\n60:             }\n61: \n62:             when (val result = repository.getFoodItems()) {\n63:                 is Results.Success -> _homeScreenState.value = homeScreenState.value.copy(\n64:                     foodList = result.data\n65:                 )\n66:                 is Results.Error -> {\n67: \n68:                 }\n69:             }\n70: \n71:             when (val result = repository.getRestaurants()) {\n72:                 is Results.Success -> _homeScreenState.value = homeScreenState.value.copy(\n73:                     restaurantList = result.data,\n74:                 )\n75:                 is Results.Error -> {\n76: \n77:                 }\n78:             }\n79: \n80:             userDataRepository.getLikedRestaurants().collect {\n81:                 _homeScreenState.value = homeScreenState.value.copy(\n82:                     likedRestaurantList = it\n83:                 )\n84: \n85:             }\n86: \n87:         }\n88: \n89: \n90:     }\n91: \n92:     fun onEvent(event: HomeScreenEvent) {\n93:         when (event) {\n94:             is HomeScreenEvent.SelectRestaurant -> {\n95:                 viewModelScope.launch {\n96:                     userDataRepository.setRestaurant(event.restaurant)\n97:                     event.onClick()\n98:                 }\n99:             }\n100:         }\n101:     }\n102: \n103: \n104: }\n\n(End of file - total 104 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER","truncated":false,"loaded":[]},"title":"..\\..\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\home\\HomeViewModel.kt","time":{"start":1782298837633,"end":1782298837639}},"id":"prt_ef94a0241002f5LNBTD9wPUAPe","sessionID":"ses_106b70cc2ffeQ7z094Vd8ASez1","messageID":"msg_ef949c80b001Jsj4EB94hy3Hb7"}}
