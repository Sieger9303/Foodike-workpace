: import com.example.foodike.domain.model.CartItem\n32: import com.example.foodike.domain.model.Restaurant\n33: import com.example.foodike.domain.repository.UserDataRepository\n34: import kotlinx.coroutines.flow.Flow\n35: import kotlinx.coroutines.flow.flow\n36: \n37: \n38: \n39: class UserDataRepositoryImpl : UserDataRepository {\n40: \n41:     private val menuList = mutableSetOf<CartItem>()\n42:     private val cartListItems = cartList.toMutableList()\n43:     private var currentRestaurant: Restaurant? = null\n44: \n45: \n46:     override suspend fun setRestaurant(restaurant: Restaurant) {\n47:         currentRestaurant = restaurant\n48:         restaurant.menu.forEach {\n49:             menuList.add(CartItem(it, 0))\n50:         }\n51:     }\n52: \n53:     override suspend fun getSavedRestaurant(): Flow<Restaurant> = flow {\n54:         if (currentRestaurant != null) {\n55:             emit(currentRestaurant!!)\n56:         }\n57:     }\n58: \n59:     override suspend fun getMenuItems(): Flow<List<CartItem>> = flow {\n60:         emit(menuList.toMutableList())\n61:     }\n62: \n63:     var list = favouriteList.toMutableList()\n64: \n65: \n66:     override suspend fun getLikedRestaurants(): Flow<List<Restaurant>> = flow {\n67:         emit(list)\n68:     }\n69: \n70:     override suspend fun isRestaurantLiked(restaurant: Restaurant): Flow<Boolean> = flow {\n71:         emit(list.contains(restaurant))\n72:     }\n73: \n74:     override suspend fun getCartItems(): Flow<List<CartItem>> = flow {\n75:         emit(cartListItems)\n76:     }\n77: }\n\n(End of file - total 77 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publ