ion.layout.*\n33: import androidx.compose.foundation.lazy.LazyColumn\n34: import androidx.compose.foundation.lazy.LazyListState\n35: import androidx.compose.foundation.lazy.LazyRow\n36: import androidx.compose.foundation.shape.CircleShape\n37: import androidx.compose.foundation.shape.RoundedCornerShape\n38: import androidx.compose.material.AppBarDefaults.ContentPadding\n39: import androidx.compose.material.BottomNavigationItem\n40: import androidx.compose.material.Card\n41: import androidx.compose.material.Icon\n42: import androidx.compose.material.Text\n43: import androidx.compose.material.icons.Icons\n44: import androidx.compose.material.icons.filled.Favorite\n45: import androidx.compose.material.icons.filled.Home\n46: import androidx.compose.material.icons.outlined.LocationOn\n47: import androidx.compose.runtime.Composable\n48: import androidx.compose.runtime.getValue\n49: import androidx.compose.runtime.remember\n50: import androidx.compose.ui.Alignment\n51: import androidx.compose.ui.Modifier\n52: import androidx.compose.ui.draw.alpha\n53: import androidx.compose.ui.draw.clip\n54: import androidx.compose.ui.draw.shadow\n55: import androidx.compose.ui.graphics.Color\n56: import androidx.compose.ui.graphics.toArgb\n57: import androidx.compose.ui.layout.ContentScale\n58: import androidx.compose.ui.platform.LocalContext\n59: import androidx.compose.ui.res.painterResource\n60: import androidx.compose.ui.res.stringResource\n61: import androidx.compose.ui.text.font.FontFamily\n62: import androidx.compose.ui.text.font.FontWeight\n63: import androidx.compose.ui.unit.dp\n64: import androidx.compose.ui.unit.sp\n65: import androidx.hilt.navigation.compose.hiltViewModel\n66: import androidx.navigation.NavGraph.Companion.findStartDestination\n67: import androidx.navigation.NavHostController\n68: import androidx.navigation.compose.currentBackStackEntryAsState\n69: import com.example.foodike.R\n70: import com.example.foodike.domain.model.Advertisement\n71: import com.example.foodike.domain.model.FoodItem\n72: import com.example.foodike.domain.model.Restaurant\n73: import com.example.foodike.presentation.components.RestaurantCard\n74: import com.example.foodike.presentation.components.SearchBar\n75: import com.example.foodike.presentation.home.components.AdSection\n76: import com.example.foodike.presentation.home.components.ChipBar\n77: import com.example.foodike.presentation.home.components.FavouriteSection\n78: import com.example.foodike.presentation.home.components.FoodikeBottomNavigation\n79: import com.example.foodike.presentation.home.components.GreetingSection\n80: import com.example.foodike.presentation.home.components.MainSection\n81: import com.example.foodike.presentation.home.components.RecommendedSection\n82: import com.example.foodike.presentation.home.components.ThankYouSection\n83: import com.example.foodike.presentation.home.components.TopSection\n84: import com.example.foodike.presentation.util.Screen\n85: import java.util.*\n86: \n87: \n88: @Composable\n89: fun Home(\n90:     scrollState: LazyListState,\n91:     navController: NavHostController,\n92:     viewModel: HomeViewModel = hiltViewModel()\n93: ) {\n94:     val context = LocalContext.current as Activity\n95: \n96:     context.window.statusBarColor = Color.Gray.toArgb()\n97:     context.window.navigationBarColor = Color.White.toArgb()\n98: \n99:     val homeScreenState by viewModel.homeScreenState\n100: \n101: \n102:     LazyColumn(\n103:         modifier =\n104:         Modifier\n105:             .fillMaxWidth(),\n106:         state = scrollState,\n107:         verticalArrangement = Arrangement.Center,\n108:         horizontalAlignment = Alignment.Start\n109:     ) {\n110:         item {\n111:             Spacer(modifier = Modifier.height(8.dp))\n112:             TopSection(navController = navController)\n113:             Spacer(modifier = Modifier.height(8.dp))\n114:         }\n115:         item {\n116:             GreetingSection()\n117:             Spacer(modifier = Modifier.height(24.dp))\n118:         }\n119:         item {\n120:             Column(\n121:                 modifier = Modifier.padding(8.dp, 0.dp)\n122:             ) {\n123:                 SearchBar()\n124:             }\n125:             Spacer(modifier = Modifier.height(16.dp))\n126:         }\n127:         item {\n128:             AdSection(homeScreenState.adsList)\n129:             Spacer(modifier = Modifier.height(16.dp))\n130:         }\n131:         item {\n132:             RecommendedSection(homeScreenState.foodList)\n133:             Spacer(modifier = Modifier.height(16.dp))\n134:         }\n135:         if (homeScreenState.likedRestaurantList.isNotEmpty()) {\n136:             item {\n137:                 FavouriteSection(homeScreenState.likedRestaurantList) {\n138:                     viewModel.onEvent(HomeScreenEvent.SelectRestaurant(it) {\n139:                         navController.navigate(Screen.RestaurantDetails.route)\n140:                     })\n141:                 }\n142:                 Spacer(modifier = Modifier.height(16.dp))\n143:             }\n144:         }\n145:         item {\n146:             Spacer(modifier = Modifier.height(8.dp))\n147:             ChipBar()\n148:         }\n149:         item {\n150:             MainSection()\n151:         }\n152:         items(homeScreenState.restaurantList.size) {\n153:             RestaurantCard(\n154:                 restaurant = homeScreenState.restaurantList[it],\n155:                 modifier = Modifier\n156:                     .clip(RoundedCornerShape(8.dp))\n157:                     .clickable {\n158:                         viewModel.onEvent(HomeScreenEvent.SelectRestaurant(homeScreenState.restaurantList[it]) {\n159:                             navController.navigate(Screen.RestaurantDetails.route)\n160:                         })\n161:                     }\n162:             )\n163:         }\n164:         item {\n165:             ThankYouSection()\n166:         }\n167: \n168:     }\n169: \n170: }\n171: \n172: \n173: \n174: \n175: \n176: \n177: \n178: \n179: \n180: \n181: \n\n(End of file - total 181 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER","truncated":false,"loaded":[]},"title":"..\\..\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\home\\HomeScreen.kt","time":{"start":1782405960864,"end":1782405960872}},"id":"prt_effac9460002II2BK9sBIZVMZQ","sessionID":"ses_10053ce1fffeJEFUjEAeuZr4YW","messageID":"msg_effac63f5001xLG0FGPCUKePoA"}}
{"type":"tool_use","timestamp":1782405960917,"sessionID":"ses_10053ce1fffeJEFUjEAeuZr4YW","part":{"type":"tool","tool":"read","callID":"call_hujz9xhXTUY3X7IkS07nlaDv","state":{"status":"completed","input":{"filePath":"D:\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\components\\RestaurantCard.kt"},"output":"<path>D:\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\components\\RestaurantCard.kt</path>\n<type>file</type>\n<content>\n1: /**\n2:  *\n3:  *\tMIT License\n4:  *\n5:  *\tCopyright (c) 2026 Gautam Hazarika\n6:  *\n7:  *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n8:  *\tof this software and associated documentation files (the \"Software\"), to deal\n9:  *\tin the Software without restriction, including without limitation the rights\n10:  *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n11:  *\tcopies of the Software, and to permit persons to whom the Software is\n12:  *\tfurnished to do so, subject to the following conditions:\n13:  *\n14:  *\tThe above copyright notice and this permission notice shall be included in all\n15:  *\tcopies or substantial portions of the Software.\n16:  *\n17:  *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n18:  *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n19:  *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n20:  *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER\n21:  *\tLIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,\n22:  *\tOUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE\n23:  *\tSOFTWARE.\n24:  *\n25:  **/\n26: \n27: package com.example.foodike.presentation.components\n28: \n29: import androidx.compose.foundation.Image\n30: import androidx.compose.foundation.clickable\n31: import androidx.compose.foundation.layout.*\n32: import androidx.compose.foundation.shape.RoundedCornerShape\n33: import androidx.compose.material.Text\n34: import androidx.compose.runtime.Composable\n35: import androidx.compose.ui.Alignment\n36: import androidx.compose.ui.Modifier\n37: import androidx.compose.ui.draw.alpha\n38: import androidx.compose.ui.draw.clip\n39: import androidx.compose.ui.draw.shadow\n40: import androidx.compose.ui.layout.ContentScale\n41: import androidx.compose.ui.res.painterResource\n42: import androidx.compose.ui.text.font.FontWeight\n43: import androidx.compose.ui.text.style.TextOverflow\n44: import androidx.compose.ui.unit.dp\n45: import androidx.compose.ui.unit.sp\n46: import com.example.foodike.R\n47: import com.example.foodike.domain.model.Restaurant\n48: import com.example.foodike.presentation.common.getTimeInMins\n49: import java.lang.StringBuilder\n50: import java.util.concurrent.TimeUnit\n51: \n52: @Composable\n53: fun RestaurantCard(\n54:     restaurant: Restaurant,\n55:     modifier: Modifier\n56: ) {\n57:     Column(\n58:         modifier = Modifier\n59:             .fillMaxWidth()\n60:             .padding(8.dp, 0.dp)\n61:     )\n62:     {\n63:         Row(\n64:             modifier = modifier\n65:                 .fillMaxWidth()\n66:                 ,\n67:             horizontalArrangement = Arrangement.Start,\n68:             verticalAlignment = Alignment.CenterVertically\n69:         ) {\n70:             Image(\n71:                 painter = painterResource(id = restaurant.image),\n72:                 contentDescription = \"Restaurant\",\n73:                 modifier = Modifier\n74:                     .size(130.dp, 170.dp)\n75:                     .shadow(elevation = 0.dp, shape = RoundedCornerShape(8.dp), clip = true),\n76:                 contentScale = ContentScale.Crop\n77:             )\n78:             Column(modifier = Modifier.padding(16.dp)) {\n79:                 Text(\n80:                     text = restaurant.name,\n81:                     fontSize = 16.sp,\n82:                     fontWeight = FontWeight.Bold,\n83:                 )\n84:                 Row(\n85:                     horizontalArrangement = Arrangement.Center,\n86:                     verticalAlignment = Alignment.CenterVertically\n87:                 ) {\n88:                     Image(\n89:                         painter = painterResource(id = R.drawable.star),\n90:                         contentDescription = \"Rating\",\n91:                         modifier = Modifier\n92:                             .size(20.dp)\n93:                     )\n94:                     Spacer(modifier = Modifier.width(2.dp))\n95: \n96:                     Text(text = \"${restaurant.rating}(${getCustomerInfo(restaurant.noOfRatings)}) \")\n97:                     Text(\n98:                         text = \"·\",\n99:                         fontSize = 16.sp,\n100:                         fontWeight = FontWeight.Bold,\n101:                     )\n102:                     Text(text = restaurant.timeInMillis.getTimeInMins())\n103:                 }\n104:                 Text(\n105:                     text = restaurant.variety,\n106:                     modifier = Modifier.alpha(0.5f),\n107:                     overflow = TextOverflow.Ellipsis,\n108:                     maxLines = 1\n109:                 )\n110:                 Text(\n111:                     text = restaurant.place,\n112:                     modifier = Modifier.alpha(0.5f),\n113:                 )\n114:             }\n115: \n116:         }\n117:         Spacer(modifier = Modifier.height(18.dp))\n118: \n119:     }\n120: \n121: \n122: }\n123: \n124: \n125: fun getCustomerInfo(noOfRatings: Int): String {\n126:     return when {\n127:         noOfRatings > 50 -> {\n128:             \"50+\"\n129:         }\n130:         noOfRatings > 100 -> {\n131:             \"100+\"\n132:         }\n133:         noOfRatings > 150 -> {\n134:             \"150+\"\n135:         }\n136:         noOfRatings > 200 -> {\n137:             \"200+\"\n138:         }\n139:         noOfRatings > 250 -> {\n140:             \"250+\"\n141:         }\n142:         noOfRatings > 300 -> {\n143:             \"300+\"\n144:         }\n145:         noOfRatings > 350 -> {\n146:             \"350+\"\n147:         }\n148:         noOfRatings > 400 -> {\n149:             \"400+\"\n150:         }\n151:         noOfRatings > 450 -> {\n152:             \"450+\"\n153:         }\n154:         noOfRatings > 500 -> {\n155:             \"500+\"\n156:         }\n157:         noOfRatings > 550 -> {\n158:             \"550+\"\n159:         }\n160:         noOfRatings > 600 -> {\n161:             \"600+\"\n162:         }\n163:         noOfRatings > 650 -> {\n164:             \"650+\"\n165:         }\n166:         noOfRatings > 700 -> {\n167:             \"700+\"\n168:         }\n169:         noOfRatings > 750 -> {\n170:             \"750+\"\n171:         }\n172:         noOfRatings > 800 -> {\n173:             \"800+\"\n174:         }\n175:         else -> {\n176:             \"1000+\"\n177:         }\n178:     }\n179: }\n180: \n181: \n182: \n\n(End of file - total 182 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER","truncated":false,"loaded":[]},"title":"..\\..\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\components\\RestaurantCard.kt","time":{"start":1782405960909,"end":1782405960916}},"id":"prt_effac94a2001I4ibrsbYTdEFQg","sessionID":"ses_10053ce1fffeJEFUjEAeuZr4YW","messageID":"msg_effac63f5001xLG0FGPCUKePoA"}}
