dx.compose.material.Tab\n32: import androidx.compose.material.TabRow\n33: import androidx.compose.material.TabRowDefaults\n34: import androidx.compose.material.Text\n35: import androidx.compose.runtime.Composable\n36: import androidx.compose.runtime.rememberCoroutineScope\n37: import androidx.compose.ui.Modifier\n38: import androidx.compose.ui.graphics.Color\n39: import androidx.compose.ui.text.font.FontWeight\n40: import androidx.compose.ui.text.style.TextAlign\n41: import androidx.compose.ui.unit.dp\n42: import androidx.compose.ui.unit.sp\n43: import com.google.accompanist.pager.ExperimentalPagerApi\n44: import com.google.accompanist.pager.PagerState\n45: import com.google.accompanist.pager.pagerTabIndicatorOffset\n46: import kotlinx.coroutines.launch\n47: \n48: @ExperimentalPagerApi\n49: @Composable\n50: fun Tabs(pagerState: PagerState) {\n51:     val list = listOf(\"History\", \"Favourites\")\n52:     val scope = rememberCoroutineScope()\n53: \n54:     TabRow(\n55:         selectedTabIndex = pagerState.currentPage,\n56:         modifier = Modifier.padding(0.dp, 0.dp, 75.dp, 0.dp),\n57:         backgroundColor = Color.White,\n58:         contentColor = Color.White,\n59:         indicator = { tabPositions ->\n60:             TabRowDefaults.Indicator(\n61:                 Modifier.pagerTabIndicatorOffset(pagerState, tabPositions),\n62:                 height = 0.dp,\n63:                 color = Color.White\n64:             )\n65:         },\n66: \n67:         ) {\n68:         list.forEachIndexed { index, _ ->\n69:             Tab(\n70:                 text = {\n71:                     Text(\n72:                         text = list[index],\n73:                         fontSize = 16.sp,\n74:                         fontWeight = if (pagerState.currentPage == index) FontWeight.Bold else FontWeight.Light,\n75:                         color = Color.Black,\n76:                         modifier = Modifier.fillMaxWidth(),\n77:                         textAlign = TextAlign.Left\n78:                     )\n79:                 },\n80:                 selected = pagerState.currentPage == index,\n81:                 onClick = {\n82:                     scope.launch {\n83:                         pagerState.animateScrollToPage(index)\n84:                     }\n85:                 }\n86: \n87: \n88:             )\n89:         }\n90:     }\n91: }\n\n(End of file - total 91 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER","truncated":false,"loaded":[]},"title":"..\\..\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\history\\components\\Tabs.kt","time":{"start":1782405960731,"end":1782405960743}},"id":"prt_effac94180016jrWZq8qMHGXM2","sessionID":"ses_10053ce1fffeJEFUjEAeuZr4YW","messageID":"msg_effac63f5001xLG0FGPCUKePoA"}}
