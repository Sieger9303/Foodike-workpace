undation.text.KeyboardOptions\n32: import androidx.compose.material.Icon\n33: import androidx.compose.material.Text\n34: import androidx.compose.material.TextField\n35: import androidx.compose.material.TextFieldDefaults\n36: import androidx.compose.material.icons.Icons\n37: import androidx.compose.material.icons.outlined.Search\n38: import androidx.compose.runtime.*\n39: import androidx.compose.ui.Modifier\n40: import androidx.compose.ui.draw.alpha\n41: import androidx.compose.ui.graphics.Color\n42: import androidx.compose.ui.text.input.ImeAction\n43: \n44: @Composable\n45: fun SearchBar() {\n46:     var text by remember { mutableStateOf(\"\") }\n47: \n48:     TextField(\n49:         value = text,\n50:         onValueChange = { text = it },\n51:         modifier = Modifier.fillMaxWidth(),\n52:         placeholder = {\n53:             Text(\n54:                 text = \"Search\",\n55:                 modifier = Modifier.alpha(0.5f)\n56:             )\n57:         },\n58:         leadingIcon = { Icon(imageVector = Icons.Outlined.Search, contentDescription = \"Search\") },\n59: \n60:         shape = CircleShape,\n61:         colors = TextFieldDefaults.textFieldColors(\n62:             backgroundColor = Color(0xFFE1E1E1),\n63:             cursorColor = Color.White,\n64: \n65:             focusedIndicatorColor = Color.Transparent,\n66:             unfocusedIndicatorColor = Color.Transparent,\n67:         ),\n68:         keyboardOptions = KeyboardOptions.Default.copy(\n69:             imeAction = ImeAction.Next\n70:         ),\n71:         singleLine = true\n72:     )\n73: }\n\n(End of file - total 73 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use,