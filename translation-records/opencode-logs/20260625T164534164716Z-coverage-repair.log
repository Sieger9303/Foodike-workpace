         }\n286:             }\n287:         }\n288:         .width(100.percent)\n289:         .height(100.percent)\n290:         .justifyContent(FlexAlign.Center)\n291:         .alignItems(HorizontalAlign.Center)\n292:         .padding(top: 24, right: 24, bottom: 24, left: 24)\n293:     }\n294: \n295:     func build() {\n296:         if (this.currentRoute == routePath(RouteId.Onboarding)) {\n297:             this.buildOnboardingRoute()\n298:         } else if (this.currentRoute == routePath(RouteId.Login)) {\n299:             this.buildLoginRoute()\n300:         } else if (this.currentRoute == routePath(RouteId.Home)) {\n301:             this.buildHomeRoute()\n302:         } else if (this.currentRoute == routePath(RouteId.History)) {\n303:             this.buildHistoryRoute()\n304:         } else if (this.currentRoute == routePath(RouteId.Profile)) {\n305:             this.buildProfileRoute()\n306:         } else {\n307:             this.buildPlaceholderRoute()\n308:         }\n309:     }\n310: }\n\n(End of file - total 310 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos.arkui.state_macro_manage.Component\nimport ohos.arkui.state_macro_manage.Entry\nimport ohos.arkui.state_macro_manage.State\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.RestaurantData\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history.{historyStore, renderHistoryRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home.{homeStore, renderHomeRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.{loginStore, renderLoginRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.{onboardingStore, renderOnboardingRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{profileStore, renderProfi