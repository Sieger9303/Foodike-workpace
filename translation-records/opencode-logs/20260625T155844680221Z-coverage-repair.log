 Spacer(modifier = Modifier.height(24.dp))\n118:         }\n119:         item {\n120:             Column(\n121:                 modifier = Modifier.padding(8.dp, 0.dp)\n122:             ) {\n123:                 SearchBar()\n124:             }\n125:             Spacer(modifier = Modifier.height(16.dp))\n126:         }\n127:         item {\n128:             AdSection(homeScreenState.adsList)\n129:             Spacer(modifier = Modifier.height(16.dp))\n130:         }\n131:         item {\n132:             RecommendedSection(homeScreenState.foodList)\n133:             Spacer(modifier = Modifier.height(16.dp))\n134:         }\n135:         if (homeScreenState.likedRestaurantList.isNotEmpty()) {\n136:             item {\n137:                 FavouriteSection(homeScreenState.likedRestaurantList) {\n138:                     viewModel.onEvent(HomeScreenEvent.SelectRestaurant(it) {\n139:                         navController.navigate(Screen.RestaurantDetails.route)\n140:                     })\n141:                 }\n142:                 Spacer(modifier = Modifier.height(16.dp))\n143:             }\n144:         }\n145:         item {\n146:             Spacer(modifier = Modifier.height(8.dp))\n147:             ChipBar()\n148:         }\n149:         item {\n150:             MainSection()\n151:         }\n152:         items(homeScreenState.restaurantList.size) {\n153:             RestaurantCard(\n154:                 restaurant = homeScreenState.restaurantList[it],\n155:                 modifier = Modifier\n156:                     .clip(RoundedCornerShape(8.dp))\n157:                     .clickable {\n158:                         viewModel.onEvent(HomeScreenEvent.SelectRestaurant(homeScreenState.restaurantList[it]) {\n159:                             navController.navigate(Screen.RestaurantDetails.route)\n160:                         })\n161:                     }\n162:             )\n163:         }\n164:         item {\n165:             ThankYouSection()\n166:         }\n1