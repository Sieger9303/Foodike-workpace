 TextAlign.Left\n78:                     )\n79:                 },\n80:                 selected = pagerState.currentPage == index,\n81:                 onClick = {\n82:                     scope.launch {\n83:                         pagerState.animateScrollToPage(index)\n84:                     }\n85:                 }\n86: \n87: \n88:             )\n89:         }\n90:     }\n91: }\n\n(End of file - total 91 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER","truncated":false,"loaded":[]},"title":"..\\..\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\history\\components\\Tabs.kt","time":{"start":1782403165509,"end":1782403165523}},"id":"prt_eff81ed41001s65sJwN4dCcZIX","sessionID":"ses_1007eac83ffeWvHUdgrrmS0V2v","messageID":"msg_eff81c04c001RMisEUxMkZemmx"}}
{"type":"tool_use","timestamp":1782403165528,"sessionID":"ses_1007eac83ffeWvHUdgrrmS0V2v","part":{"type":"tool","tool":"read","callID":"call_hy9MNR69nLvMiYxAfYboptk2","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\common\\widgets\\restaurant_card.cj","limit":260},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\common\\widgets\\restaurant_card.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets\n2: \n3: import kit.ArkUI.*\n4: import ohos.arkui.state_macro_manage.Builder\n5: import ohos.resource.AppResource\n6: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.RestaurantData\n7: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaApplePie, mediaBiryani, mediaBurger, mediaChinese, mediaDosa, mediaParatha, mediaPizza, mediaStar}\n8: \n9: public func restaurantMedia(name: String): AppResource {\n10:     match (name) {\n11:         case \"biryani\" => mediaBiryani\n12:         case \"burger\" => mediaBurger\n13:         case \"chinese\" => mediaChinese\n14:         case \"dosa\" => mediaDosa\n15:         case \"paratha\" => mediaParatha\n16:         case \"pizza\" => mediaPizza\n17:         case _ => mediaApplePie\n18:     }\n19: }\n20: \n21: public func getCustomerInfo(ratingCount: Int64): String {\n22:     return if (ratingCount > 50) {\n23:         \"50+\"\n24:     } else if (ratingCount > 100) {\n25:         \"100+\"\n26:     } else if (ratingCount > 150) {\n27:         \"150+\"\n28:     } else if (ratingCount > 200) {\n29:         \"200+\"\n30:     } else if (ratingCount > 250) {\n31:         \"250+\"\n32:     } else if (ratingCount > 300) {\n33:         \"300+\"\n34:     } else if (ratingCount > 350) {\n35:         \"350+\"\n36:     } else if (ratingCount > 400) {\n37:         \"400+\"\n38:     } else if (ratingCount > 450) {\n39:         \"450+\"\n40:     } else if (ratingCount > 500) {\n41:         \"500+\"\n42:     } else if (ratingCount > 550) {\n43:         \"550+\"\n44:     } else if (ratingCount > 600) {\n45:         \"600+\"\n46:     } else if (ratingCount > 650) {\n47:         \"650+\"\n48:     } else if (ratingCount > 700) {\n49:         \"700+\"\n50:     } else if (ratingCount > 750) {\n51:         \"750+\"\n52:     } else if (ratingCount > 800) {\n53:         \"800+\"\n54:     } else {\n55:         \"1000+\"\n56:     }\n57: }\n58: \n59: public func formatEta(minutes: Int64): String {\n60:     let hours = minutes / 60\n61:     let remainder = minutes % 60\n62:     if (hours > 0) {\n63:         return \"${hours} Hr ${remainder} Min\"\n64:     }\n65:     return \"${remainder} Min\"\n66: }\n67: \n68: @Builder\n69: public func renderRestaurantCard(restaurant: RestaurantData, onSelect: () -> Unit) {\n70:     Row(space: 14) {\n71:         Image(restaurantMedia(restaurant.mediaName))\n72:             .width(120)\n73:             .height(154)\n74:             .borderRadius(12)\n75:         Column(space: 8) {\n76:             Text(restaurant.name)\n77:                 .fontSize(18)\n78:                 .fontWeight(FontWeight.Bold)\n79:             Row(space: 6) {\n80:                 Image(mediaStar)\n81:                     .width(18)\n82:                     .height(18)\n83:                 Text(\"${restaurant.rating}(${getCustomerInfo(restaurant.ratingCount)})\")\n84:                     .fontSize(14)\n85:                 Text(\".\")\n86:                     .fontWeight(FontWeight.Bold)\n87:                 Text(formatEta(restaurant.etaMinutes))\n88:                     .fontSize(14)\n89:             }\n90:             Text(restaurant.variety)\n91:                 .fontSize(14)\n92:                 .fontColor(Color.Gray)\n93:             Text(restaurant.place)\n94:                 .fontSize(14)\n95:                 .fontColor(Color.Gray)\n96:         }\n97:         .layoutWeight(1)\n98:     }\n99:     .width(100.percent)\n100:     .padding(top: 8, right: 8, bottom: 8, left: 8)\n101:     .backgroundColor(Color.White)\n102:     .borderRadius(16)\n103:     .onClick({ _ =>\n104:         onSelect()\n105:     })\n106: }\n\n(End of file - total 106 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos.resource.AppResource\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.RestaurantData\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaApplePie, mediaBiryani, mediaBurger, mediaChinese, mediaDosa, mediaParatha, mediaPizza, mediaStar}\n\npublic func restaurantMedia(name: String): AppResource {\n    match (name) {\n        case \"biryani\" => mediaBiryani\n        case \"burger\" => mediaBurger\n        case \"chinese\" => mediaChinese\n        case \"dosa\" => mediaDosa\n        case \"paratha\" => mediaParatha\n        case \"pizza\" => mediaPizza\n        case _ => mediaApplePie\n    }\n}\n","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\common\\widgets\\restaurant_card.cj","time":{"start":1782403165515,"end":1782403165527}},"id":"prt_eff81ed46002IkfaJrTMLL6ITK","sessionID":"ses_1007eac83ffeWvHUdgrrmS0V2v","messageID":"msg_eff81c04c001RMisEUxMkZemmx"}}
