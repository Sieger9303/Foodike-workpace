compose.foundation.layout.fillMaxSize\n33: import androidx.compose.foundation.layout.height\n34: import androidx.compose.foundation.layout.padding\n35: import androidx.compose.runtime.Composable\n36: import androidx.compose.runtime.getValue\n37: import androidx.compose.ui.Modifier\n38: import androidx.compose.ui.graphics.Color\n39: import androidx.compose.ui.graphics.toArgb\n40: import androidx.compose.ui.platform.LocalContext\n41: import androidx.compose.ui.unit.dp\n42: import androidx.hilt.navigation.compose.hiltViewModel\n43: import androidx.navigation.NavHostController\n44: import com.example.foodike.presentation.components.SearchBar\n45: import com.example.foodike.presentation.history.components.Tabs\n46: import com.example.foodike.presentation.history.components.TabsContent\n47: import com.example.foodike.presentation.util.Screen\n48: import com.google.accompanist.pager.ExperimentalPagerApi\n49: import com.google.accompanist.pager.rememberPagerState\n50: \n51: @ExperimentalPagerApi\n52: @Composable\n53: fun History(\n54:     viewModel: HistoryViewModel = hiltViewModel(),\n55:     navHostController: NavHostController\n56: ) {\n57: \n58:     val state by viewModel.likedRestaurants\n59: \n60: \n61:     val context = LocalContext.current as Activity\n62: \n63:     val pagerState = rememberPagerState()\n64: \n65: \n66:     context.window.statusBarColor = Color.Gray.toArgb()\n67:     context.window.navigationBarColor = Color.White.toArgb()\n68: \n69:     Column(\n70:         modifier = Modifier\n71:             .fillMaxSize()\n72:     ) {\n73:         Column(\n74:             modifier = Modifier.padding(16.dp)\n75:         ) {\n76:             SearchBar()\n77:             Spacer(modifier = Modifier.height(8.dp))\n78: \n79:             Tabs(pagerState = pagerState)\n80:         }\n81:         TabsContent(\n82:             pagerState = pagerState, state.likedRestaurantList,\n83:             onClick = {\n84:                 viewModel.onEvent(HistoryEvent.SelectRestaurant(it){\n85:                     navHostController.navigate(Screen.RestaurantDetails.route)\n86:                 })\n87:             }\n88:         )\n89: \n90:     }\n91: }\n92: \n93: \n94: \n95: \n96: \n\n(End of file - total 96 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER","truncated":false,"loaded":[]},"title":"..\\..\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\history\\History.kt","time":{"start":1782405043818,"end":1782405043827}},"id":"prt_eff9e962c001jYjxi1ze4QC4Pd","sessionID":"ses_10061f945ffeAl9WpSa5osoNEh","messageID":"msg_eff9e5b8b001zjbxosOgZvvY6P"}}
{"type":"tool_use","timestamp":1782405043890,"sessionID":"ses_10061f945ffeAl9WpSa5osoNEh","part":{"type":"tool","tool":"read","callID":"call_nY9O8jdCOksdeeMWtRFuvzuP","state":{"status":"completed","input":{"filePath":"D:\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\history\\HistoryViewModel.kt"},"output":"<path>D:\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\history\\HistoryViewModel.kt</path>\n<type>file</type>\n<content>\n1: /**\n2:  *\n3:  *\tMIT License\n4:  *\n5:  *\tCopyright (c) 2026 Gautam Hazarika\n6:  *\n7:  *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n8:  *\tof this software and associated documentation files (the \"Software\"), to deal\n9:  *\tin the Software without restriction, including without limitation the rights\n10:  *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n11:  *\tcopies of the Software, and to permit persons to whom the Software is\n12:  *\tfurnished to do so, subject to the following conditions:\n13:  *\n14:  *\tThe above copyright notice and this permission notice shall be included in all\n15:  *\tcopies or substantial portions of the Software.\n16:  *\n17:  *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n18:  *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n19:  *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n20:  *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER\n21:  *\tLIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,\n22:  *\tOUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE\n23:  *\tSOFTWARE.\n24:  *\n25:  **/\n26: \n27: package com.example.foodike.presentation.history\n28: \n29: import androidx.compose.runtime.State\n30: import androidx.compose.runtime.mutableStateOf\n31: import androidx.lifecycle.ViewModel\n32: import androidx.lifecycle.viewModelScope\n33: import com.example.foodike.domain.model.Restaurant\n34: import com.example.foodike.domain.repository.UserDataRepository\n35: import com.example.foodike.presentation.home.HomeScreenEvent\n36: import dagger.hilt.android.lifecycle.HiltViewModel\n37: import kotlinx.coroutines.launch\n38: import javax.inject.Inject\n39: \n40: \n41: @HiltViewModel\n42: class HistoryViewModel @Inject constructor(\n43:     private val userDataRepository: UserDataRepository\n44: ) : ViewModel() {\n45: \n46:     private val _likedRestaurants = mutableStateOf(HistoryState())\n47:     val likedRestaurants: State<HistoryState> = _likedRestaurants\n48: \n49:     init {\n50:         viewModelScope.launch {\n51:             userDataRepository.getLikedRestaurants().collect {\n52:                 _likedRestaurants.value = likedRestaurants.value.copy(\n53:                     likedRestaurantList = it\n54:                 )\n55: \n56:             }\n57: \n58:         }\n59:     }\n60: \n61:     fun onEvent(event: HistoryEvent) {\n62:         when (event) {\n63:             is HistoryEvent.SelectRestaurant -> {\n64:                 viewModelScope.launch {\n65:                     userDataRepository.setRestaurant(event.restaurant)\n66:                     event.onClick()\n67:                 }\n68:             }\n69:         }\n70:     }\n71: \n72: }\n\n(End of file - total 72 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER","truncated":false,"loaded":[]},"title":"..\\..\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\history\\HistoryViewModel.kt","time":{"start":1782405043883,"end":1782405043889}},"id":"prt_eff9e966f002okQ4flJTT0YunB","sessionID":"ses_10061f945ffeAl9WpSa5osoNEh","messageID":"msg_eff9e5b8b001zjbxosOgZvvY6P"}}
