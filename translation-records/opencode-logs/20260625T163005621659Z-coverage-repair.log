    }\n39: }\n40: \n41: @Builder\n42: func buildHistoryRecordCard(record: HistoryRecordData) {\n43:     Column(space: 10) {\n44:         Row {\n45:             Column(space: 4) {\n46:                 Text(record.restaurantName)\n47:                     .fontWeight(FontWeight.Bold)\n48:                 Text(record.place)\n49:                     .fontSize(14)\n50:                     .fontColor(Color.Gray)\n51:                 Text(record.timestampText)\n52:                     .fontSize(14)\n53:                     .fontColor(Color.Gray)\n54:             }\n55:             .layoutWeight(1)\n56:             Text(record.totalText)\n57:                 .fontSize(16)\n58:         }\n59: \n60:         Divider().width(100.percent)\n61: \n62:         Row(space: 10) {\n63:             Image(if (record.isVeg) { mediaIcVeg } else { mediaIcNonVeg })\n64:                 .width(16)\n65:                 .height(16)\n66:             Text(record.itemSummary)\n67:                 .layoutWeight(1)\n68:                 .fontSize(14)\n69:             Button(record.actionText)\n70:         }\n71:         .alignItems(VerticalAlign.Center)\n72: \n73:         if (record.deliveryRating > 0) {\n74:             Row {\n75:                 Column(space: 4) {\n76:                     Text(\"Your rating for delivery\")\n77:                         .fontSize(14)\n78:                         .fontColor(Color.Gray)\n79:                     Text(\"Your rating for food\")\n80:                         .fontSize(14)\n81:                         .fontColor(Color.Gray)\n82:                 }\n83:                 .layoutWeight(1)\n84:                 Column(space: 4) {\n85:                     Text(\"* ${record.deliveryRating}\")\n86:                     Text(\"* ${record.foodRating}\")\n87:                 }\n88:                 buildHistoryStatusRow(record.statusText)\n89:             }\n90:             .alignItems(VerticalAlign.Center)\n91:         } else {\n92:             Row {\n93:                 Text(record.actionText)\n94:                     .fontSize(16)\n95:                     .fontWeight(FontWeight.Bold)\n96:                     .fontColor(0xFF228D39)\n97:                 Blank().layoutWeight(1)\n98:                 buildHistoryStatusRow(record.statusText)\n99:             }\n100:             .alignItems(VerticalAlign.Center)\n101:         }\n102:     }\n103:     .width(100.percent)\n104:     .padding(top: 14, right: 14, bottom: 14, left: 14)\n105:     .backgroundColor(Color.White)\n106:     .borderRadius(16)\n107: }\n108: \n109: @Builder\n110: func buildHistoryRecords(records: ArrayList<HistoryRecordData>) {\n111:     Column(space: 10) {\n112:         ForEach(records, itemGeneratorFunc: { record: HistoryRecordData, _: Int64 =>\n113:             buildHistoryRecordCard(record)\n114:         })\n115:     }\n116:     .width(100.percent)\n117: }\n118: \n119: @Builder\n120: func buildHistoryFavourites(favourites: ArrayList<RestaurantData>, onSelectRestaurant: (RestaurantData) -> Unit) {\n121:     if (favourites.size > 0) {\n122:         Column(space: 10) {\n123:             ForEach(favourites, itemGeneratorFunc: { restaurant: RestaurantData, _: Int64 =>\n124:                 renderRestaurantCard(restaurant, { =>\n125:                     onSelectRestaurant(restaurant)\n126:                 })\n127:             })\n128:         }\n129:         .width(100.percent)\n130:     } else {\n131:         Row {\n132:             Text(\"Empty\")\n133:                 .fontSize(16)\n134:         }\n135:         .width(100.percent)\n136:         .justifyContent(FlexAlign.Center)\n137:     }\n138: }\n139: \n140: @Builder\n141: public func renderHistoryRoute(\n142:     state: HistoryPageState,\n143:     selectedTab: Int64,\n144:     query: String,\n145:     onQueryChange: (String) -> Unit,\n146:     onTabSelect: (Int64) -> Unit,\n147:     onSelectRestaurant: (RestaurantData) -> Unit\n148: ) {\n149:     Scroll(Scroller()) {\n150:         Column(space: 14) {\n151:             renderSearchBar(query, onQueryChange)\n152:             buildHistoryTabs(selectedTab, onTabSelect)\n153:             if (selectedTab == 0) {\n154:                 buildHistoryRecords(state.records)\n155:             } else {\n156:                 buildHistoryFavourites(state.favourites, onSelectRestaurant)\n157:             }\n158:         }\n159:         .width(100.percent)\n160:         .padding(top: 16, right: 16, bottom: 24, left: 16)\n161:     }\n162:     .scrollable(ScrollDirection.Vertical)\n163:     .scrollBar(BarState.Off)\n164:     .width(100.percent)\n165:     .height(100.percent)\n166:     .backgroundColor(Color.White)\n167: }\n\n(End of file - total 167 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaIcNonVeg, mediaIcVeg}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.{renderRestaurantCard, renderSearchBar}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\n@Builder\nfunc buildHistoryTabs(selectedTab: Int64, onTabSelect: (Int64) -> Unit) {\n    Row(space: 18) {\n        Text(historyStore.tabLabel(0))\n            .fontSize(18)\n            .fontWeight(if (selectedTab == 0) { FontWeight.Bold } else { FontWeight.Regular })\n            .onClick({ _ =>\n                onTabSelect(0)\n            })\n        Text(historyStore.tabLabel(1))\n            .fontSize(18)","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_page.cj","time":{"start":1782405044447,"end":1782405044456}},"id":"prt_eff9e98d3001q4EgO0aJUZ7sns","sessionID":"ses_10061f945ffeAl9WpSa5osoNEh","messageID":"msg_eff9e5b8b001zjbxosOgZvvY6P"}}
{"type":"tool_use","timestamp":1782405044467,"sessionID":"ses_10061f945ffeAl9WpSa5osoNEh","part":{"type":"tool","tool":"read","callID":"call_GXXIps7s2frml8bzu7cdQKEa","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_page.cj"},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home\n2: \n3: import kit.ArkUI.*\n4: import ohos.arkui.state_macro_manage.Builder\n5: import ohos.resource.AppResource\n6: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaChineseBowl, mediaClock, mediaGroceries, mediaIcProfile, mediaRider, mediaUpi}\n7: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.{renderRestaurantCard, restaurantMedia, renderSearchBar}\n8: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n9: import std.collection.ArrayList\n10: \n11: private func homeMedia(name: String): AppResource {\n12:     match (name) {\n13:         case \"chinese_bowl\" => mediaChineseBowl\n14:         case \"rider\" => mediaRider\n15:         case \"groceries\" => mediaGroceries\n16:         case \"upi\" => mediaUpi\n17:         case _ => mediaClock\n18:     }\n19: }\n20: \n21: @Builder\n22: func buildHomeTopSection(onProfileClick: () -> Unit) {\n23:     Row {\n24:         Image(mediaIcProfile)\n25:             .width(36)\n26:             .height(36)\n27:             .borderRadius(18)\n28:             .onClick({ _ =>\n29:                 onProfileClick()\n30:             })\n31:         Row(space: 4) {\n32:             Text(\"Location\")\n33:                 .fontSize(14)\n34:                 .fontColor(Color.Gray)\n35:             Text(\"Guwahati\")\n36:                 .fontSize(16)\n37:                 .fontWeight(FontWeight.Medium)\n38:         }\n39:     }\n40:     .width(100.percent)\n41:     .justifyContent(FlexAlign.SpaceBetween)\n42:     .alignItems(VerticalAlign.Center)\n43: }\n44: \n45: @Builder\n46: func buildHomeGreeting(hour: Int64) {\n47:     Column(space: 2) {\n48:         Text(homeStore.greetingForHour(hour))\n49:             .fontSize(28)\n50:             .fontWeight(FontWeight.Regular)\n51:         Text(\"Andrew\")\n52:             .fontSize(28)\n53:             .fontWeight(FontWeight.Regular)\n54:     }\n55:     .width(100.percent)\n56: }\n57: \n58: @Builder\n59: func buildHomeSectionTitle(title: String) {\n60:     Text(title)\n61:         .fontSize(20)\n62:         .fontWeight(FontWeight.Regular)\n63:         .width(100.percent)\n64: }\n65: \n66: @Builder\n67: func buildHomeAdCards(advertisements: ArrayList<AdvertisementData>) {\n68:     Scroll(Scroller()) {\n69:         Row(space: 12) {\n70:             ForEach(advertisements, itemGeneratorFunc: { advertisement: AdvertisementData, _: Int64 =>\n71:                 Row(space: 12) {\n72:                     Column(space: 8) {\n73:                         Text(advertisement.title)\n74:                             .fontSize(22)\n75:                             .fontWeight(FontWeight.Bold)\n76:                         Text(advertisement.subtitle)\n77:                             .fontSize(13)\n78:                     }\n79:                     .layoutWeight(1)\n80:                     Image(homeMedia(advertisement.mediaName))\n81:                         .width(92)\n82:                         .height(92)\n83:                 }\n84:                 .width(260)\n85:                 .padding(top: 16, right: 16, bottom: 16, left: 16)\n86:                 .backgroundColor(0xFFF4F4F4)\n87:                 .borderRadius(20)\n88:             })\n89:         }\n90:     }\n91:     .scrollable(ScrollDirection.Horizontal)\n92:     .scrollBar(BarState.Off)\n93:     .width(100.percent)\n94:     .height(140)\n95: }\n96: \n97: @Builder\n98: func buildRecommendedCategories(categories: ArrayList<FoodCategoryData>) {\n99:     Scroll(Scroller()) {\n100:         Row(space: 16) {\n101:             ForEach(categories, itemGeneratorFunc: { category: FoodCategoryData, _: Int64 =>\n102:                 Column(space: 8) {\n103:                     Image(restaurantMedia(category.mediaName))\n104:                         .width(80)\n105:                         .height(80)\n106:                         .borderRadius(40)\n107:                     Text(category.name)\n108:                         .fontSize(14)\n109:                 }\n110:                 .alignItems(HorizontalAlign.Center)\n111:             })\n112:         }\n113:     }\n114:     .scrollable(ScrollDirection.Horizontal)\n115:     .scrollBar(BarState.Off)\n116:     .width(100.percent)\n117:     .height(120)\n118: }\n119: \n120: @Builder\n121: func buildFavouriteStrip(favourites: ArrayList<RestaurantData>, onSelectRestaurant: (RestaurantData) -> Unit) {\n122:     if (favourites.size > 0) {\n123:         Column(space: 10) {\n124:             buildHomeSectionTitle(\"Order from favourites\")\n125:             Scroll(Scroller()) {\n126:                 Row(space: 12) {\n127:                     ForEach(favourites, itemGeneratorFunc: { restaurant: RestaurantData, _: Int64 =>\n128:                         Column(space: 8) {\n129:                             Image(restaurantMedia(restaurant.mediaName))\n130:                                 .width(98)\n131:                                 .height(128)\n132:                                 .borderRadius(12)\n133:                             Text(restaurant.name)\n134:                                 .fontSize(14)\n135:                         }\n136:                         .width(110)\n137:                         .alignItems(HorizontalAlign.Center)\n138:                         .onClick({ _ =>\n139:                             onSelectRestaurant(restaurant)\n140:                         })\n141:                     })\n142:                 }\n143:             }\n144:             .scrollable(ScrollDirection.Horizontal)\n145:             .scrollBar(BarState.Off)\n146:             .width(100.percent)\n147:             .height(170)\n148:         }\n149:     }\n150: }\n151: \n152: @Builder\n153: func buildFilterRow(selectedFilter: String, onToggleFilter: (String) -> Unit) {\n154:     Scroll(Scroller()) {\n155:         Row(space: 8) {\n156:             ForEach(homeStore.filtersList(), itemGeneratorFunc: { filterName: String, _: Int64 =>\n157:                 Text(filterName)\n158:                     .fontSize(14)\n159:                     .fontColor(if (selectedFilter == filterName) { Color.White } else { Color.Black })\n160:                     .padding(top: 8, right: 12, bottom: 8, left: 12)\n161:                     .backgroundColor(if (selectedFilter == filterName) { 0xFF228D39 } else { Color.White })\n162:                     .borderRadius(16)\n163:                     .border(width: 1.px, color: 0x55000000)\n164:                     .onClick({ _ =>\n165:                         onToggleFilter(filterName)\n166:                     })\n167:             })\n168:         }\n169:     }\n170:     .scrollable(ScrollDirection.Horizontal)\n171:     .scrollBar(BarState.Off)\n172:     .width(100.percent)\n173:     .height(48)\n174: }\n175: \n176: @Builder\n177: func buildRestaurantList(restaurants: ArrayList<RestaurantData>, onSelectRestaurant: (RestaurantData) -> Unit) {\n178:     Column(space: 10) {\n179:         ForEach(restaurants, itemGeneratorFunc: { restaurant: RestaurantData, _: Int64 =>\n180:             renderRestaurantCard(restaurant, { =>\n181:                 onSelectRestaurant(restaurant)\n182:             })\n183:         })\n184:     }\n185:     .width(100.percent)\n186: }\n187: \n188: @Builder\n189: func buildHomeFooter() {\n190:     Row(space: 6) {\n191:         Text(\"with\")\n192:             .fontSize(24)\n193:             .fontColor(Color.Gray)\n194:         Text(\"love\")\n195:             .fontSize(24)\n196:             .fontColor(Color.Red)\n197:         Text(\"from creator\")\n198:             .fontSize(24)\n199:             .fontColor(Color.Gray)\n200:     }\n201:     .width(100.percent)\n202:     .justifyContent(FlexAlign.Center)\n203: }\n204: \n205: @Builder\n206: public func renderHomeRoute(\n207:     state: HomePageState,\n208:     hour: Int64,\n209:     query: String,\n210:     selectedFilter: String,\n211:     onQueryChange: (String) -> Unit,\n212:     onToggleFilter: (String) -> Unit,\n213:     onProfileClick: () -> Unit,\n214:     onSelectRestaurant: (RestaurantData) -> Unit\n215: ) {\n216:     Scroll(Scroller()) {\n217:         Column(space: 18) {\n218:             buildHomeTopSection(onProfileClick)\n219:             buildHomeGreeting(hour)\n220:             renderSearchBar(query, onQueryChange)\n221:             buildHomeAdCards(state.advertisements)\n222:             buildHomeSectionTitle(\"Recommended for you\")\n223:             buildRecommendedCategories(state.categories)\n224:             buildFavouriteStrip(state.favourites, onSelectRestaurant)\n225:             buildFilterRow(selectedFilter, onToggleFilter)\n226:             buildHomeSectionTitle(\"All around you\")\n227:             buildRestaurantList(state.restaurants, onSelectRestaurant)\n228:             buildHomeFooter()\n229:         }\n230:         .width(100.percent)\n231:         .padding(top: 12, right: 16, bottom: 24, left: 16)\n232:     }\n233:     .scrollable(ScrollDirection.Vertical)\n234:     .scrollBar(BarState.Off)\n235:     .width(100.percent)\n236:     .height(100.percent)\n237:     .backgroundColor(Color.White)\n238: }\n\n(End of file - total 238 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos.resource.AppResource\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaChineseBowl, mediaClock, mediaGroceries, mediaIcProfile, mediaRider, mediaUpi}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.{renderRestaurantCard, restaurantMedia, renderSearchBar}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\nprivate func homeMedia(name: String): AppResource {\n    match (name) {\n        case \"chinese_bowl\" => mediaChineseBowl\n        case \"rider\" => mediaRider\n        case \"groceries\" => mediaGroceries\n        case \"upi\" => mediaUpi\n        case _ => mediaClock\n    }\n}\n","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_page.cj","time":{"start":1782405044459,"end":1782405044467}},"id":"prt_eff9e98e0002Uba6Lfmv5UOe7m","sessionID":"ses_10061f945ffeAl9WpSa5osoNEh","messageID":"msg_eff9e5b8b001zjbxosOgZvvY6P"}}
