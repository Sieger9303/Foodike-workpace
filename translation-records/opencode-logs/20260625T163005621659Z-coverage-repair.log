1:           \"keyClasses\": [\n1552:             \"LoginRepository\"\n1553:           ],\n1554:           \"keyMethods\": [\n1555:             \"readLoginState\",\n1556:             \"toggleLoginState\"\n1557:           ],\n1558:           \"dependencies\": []\n\n(Output capped at 50 KB. Showing lines 1-1558. Use offset=1559 to continue.)\n</content>","metadata":{"preview":"{\n  \"schemaVersion\": 1,\n  \"generatedAt\": \"2026-06-25T02:01:25+00:00\",\n  \"lastUpdatedBy\": \"source_coverage/patch_authority.py\",\n  \"purpose\": \"Agent-maintained platform capability check. Update each entry after querying CangjieSkills/HarmonyOS/Cangjie API docs, HarmonyOS-Examples, or package index lookup for the detected capability. Use cjpm/project-management docs only to configure the chosen dependency in cjpm.toml. Direct API status requires Cangjie-callable evidence; ArkTS-only or native-only declarations should record the missing Cangjie binding as a blocker unless a target bridge/wrapper is implemented and verified.\",\n  \"allowedStatuses\": [\n    \"deferred\",\n    \"implemented-fallback\",\n    \"not-applicable\",\n    \"not-covered\",\n    \"planned\",\n    \"platform-replaced\",\n    \"unreviewed\",\n    \"verified-direct\"\n  ],\n  \"deferredRequiredFields\": [\n    \"targetCapabilitySearch\",\n    \"blocker\",\n    \"targetFallback\",\n    \"futureCompletionPath\"","truncated":true,"loaded":[]},"title":"translation-inputs\\platform-capability-check.json","time":{"start":1782405020800,"end":1782405020804}},"id":"prt_eff9e3c76001mes6DNZiX2cyTK","sessionID":"ses_10061f945ffeAl9WpSa5osoNEh","messageID":"msg_eff9e26b9001ddARJbG7aooAlw"}}
