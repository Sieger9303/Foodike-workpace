.slideAt(0).description,\n+                onboardingStore.slideAt(0).mediaName\n+            )\n+            buildOnboardingCard(\n+                onboardingStore.slideAt(1).title,\n+                onboardingStore.slideAt(1).description,\n+                onboardingStore.slideAt(1).mediaName\n+            )\n+            buildOnboardingCard(\n+                onboardingStore.slideAt(2).title,\n+                onboardingStore.slideAt(2).description,\n+                onboardingStore.slideAt(2).mediaName\n+            )\n+        }\n+        .indicator(false)\n+        .onChange({ index: Int32 =>\n+            onIndexChanged(index)\n+        })\n+        .width(100.percent)\n+        .height(78.percent)\n+\n+        Row {\n+            Row(space: 12) {\n+                buildOnboardingIndicator(pageIndex == 0)\n+                buildOnboardingIndicator(pageIndex == 1)\n+                buildOnboardingIndicator(pageIndex == 2)\n+            }\n+            Button(\">\")\n+                .onClick({ _ =>\n+                    onNext()\n+                })\n+        }\n+        .width(90.percent)\n+        .justifyContent(FlexAlign.SpaceBetween)\n+        .alignItems(VerticalAlign.Center)\n+        .margin(bottom: 12)\n+    }\n+    .width(100.percent)\n+    .height(100.percent)\n+    .backgroundColor(colorDarkGreen)\n+    .alignItems(HorizontalAlign.Center)\n+    .justifyContent(FlexAlign.SpaceBetween)\n+}\n","additions":97,"deletions":0},{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\login\\login_page.cj","relativePath":"Foodike-Harmony/entry/src/main/cangjie/ohos_app_cangjie_entry/features/login/login_page.cj","type":"add","patch":"Index: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\login\\login_page.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\