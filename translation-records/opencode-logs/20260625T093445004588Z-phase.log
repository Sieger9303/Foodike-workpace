xample_id\": \"example.harmonyos-6-1-8k-api-arkui-cj-cj-button-picker-slider-slider-1-abstract-md\",\r\n      \"title\": \".abstract\",\r\n      \"score\": 91.576,\r\n      \"summary\": \"本目录展示了如何在ArkUI框架中使用仓颉语言配置和自定义滑动条的基础样式。内容涵盖了OutSet（外置）、InSet（内置）以及垂直方向滑动条的实现，重点演示了气泡、刻度、滑块和滑轨的显示控制。通过style、showTips、blockColor等属性，开发者可以调整交互效果和颜色，并利用onChange回调实现状态双向绑定。该文档适合具备ArkUI基础和仓颉语法知识的开发者，用于学习UI组件的属性配置与状态管理。\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/API/arkui-cj/cj-button-picker-slider/Slider/示例代码/示例1滑动条基础样式/.abstract.md\"\r\n      ],\r\n      \"source\": null,\r\n      \"doc_kind\": null\r\n    }\r\n  ],\r\n  \"docs\": [\r\n    {\r\n      \"doc_id\": \"doc.harmonyos-6-1-8k-api-arkui-cj-cj-text-input-textinput-textinput-overview\",\r\n      \"title\": \"TextInput\",\r\n      \"score\": 133.053,\r\n      \"summary\": \"本目录包含ArkUI框架中TextInput组件的API参考文档，专为使用仓颉语言开发的HarmonyOS应用设计。内容涵盖了组件的初始化构造、控制器管理、交互事件处理以及全方位的属性配置。核心关键词包括ArkUI、TextInput、仓颉语言、API参考、事件处理和组件属性。这些文档适合需要实现单行文本输入功能、精细控制输入行为及样式的开发者阅读。 - 你想了解组件的初始化与基本用法？\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/API/arkui-cj/cj-text-input-textinput/TextInput/.overview.md\"\r\n      ],\r\n      \"source\": \"harmonyos-6.1-8k\",\r\n      \"doc_kind\": \"overview\"\r\n    },\r\n    {\r\n      \"doc_id\": \"doc.harmonyos-6-1-8k-api-arkui-cj-cj-scroll-swipe-swiper-swiper-class-dotindicator-overview\",\r\n      \"title\": \"class_DotIndicator\",\r\n      \"score\": 131.386,\r\n      \"summary\": \"本目录包含仓颉语言中 DotIndicator 类的 API 参考文档，主要用于在 ArkUI 框架下配置 Swiper 组件的圆点导航指示器。内容涵盖了指示器的构造函数、核心属性设置（如颜色、宽高、蒙版显示及最大显示数量）以及选中状态的样式配置。该文档详细说明了交互视觉效果（如按压放大）和尺寸限制，适合使用仓颉语言进行 HarmonyOS 应用开发并希望自定义轮播图导航样式的开发者查阅。\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/API/arkui-cj/cj-scroll-swipe-swiper/Swiper/基础类型定义/class_DotIndicator/.overview.md\"\r\n      ],\r\n      \"source\": \"harmonyos-6.1-8k\",\r\n      \"doc_kind\": \"overview\"\r\n    },\r\n    {\r\n      \"doc_id\": \"doc.harmonyos-6-1-8k-api-arkui-cj-cj-text-input-textinput-textinput\",\r\n      \"title\": \"组件事件\",\r\n      \"score\": 131.114,\r\n      \"summary\": \"TextInput组件的事件回调函数集合，包括onChange（内容变化）、onCopy（复制）、onCut（剪切）、onEditChange（编辑状态变化）、onPaste（粘贴）和onSubmit（提交）等。\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/API/arkui-cj/cj-text-input-textinput/TextInput/组件事件.md\"\r\n      ],\r\n      \"source\": \"harmonyos-6.1-8k\",\r\n      \"doc_kind\": \"article\"\r\n    },\r\n    {\r\n      \"doc_id\": \"doc.harmonyos-6-1-8k-api-arkui-cj-cj-text-input-textinput-textinput-overview-2\",\r\n      \"title\": \"组件属性\",\r\n      \"score\": 130.856,\r\n      \"summary\": \"本目录包含ArkUI框架中使用仓颉（Cangjie）语言开发的文本输入组件属性API参考文档。内容涵盖了文本输入的全方位配置，包括基础样式定制（如字体、颜色、对齐方式）、交互行为控制（如光标、键盘类型、焦点管理）以及输入限制规则（如长度限制、过滤规则）。所有API均支持链式调用，起始版本为API 22。这些文档适用于需要精细化管理UI组件外观与逻辑的ArkUI应用开发者，旨在帮助构建高效、美观的用户输入界面。\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/API/arkui-cj/cj-text-input-textinput/TextInput/组件属性/.overview.md\"\r\n      ],\r\n      \"source\": \"harmonyos-6.1-8k\",\r\n      \"doc_kind\": \"overview\"\r\n    },\r\n    {\r\n      \"doc_id\": \"doc.harmonyos-6-1-8k-api-arkui-cj-cj-text-input-textinput-textinput-abstract\",\r\n      \"title\": \".abstract\",\r\n      \"score\": 129.139,\r\n      \"summary\": \"本目录包含ArkUI框架中TextInput组件的API参考文档，专为使用仓颉语言开发的HarmonyOS应用设计。内容涵盖了组件的初始化构造、控制器管理、交互事件处理以及全方位的属性配置。核心关键词包括ArkUI、TextInput、仓颉语言、API参考、事件处理和组件属性。这些文档适合需要实现单行文本输入功能、精细控制输入行为及样式的开发者阅读。\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/API/arkui-cj/cj-text-input-textinput/TextInput/.abstract.md\"\r\n      ],\r\n      \"source\": \"harmonyos-6.1-8k\",\r\n      \"doc_kind\": \"abstract\"\r\n    }\r\n  ],\r\n  \"paths\": [\r\n    \"harmonyos-6.1-8k/API/arkui-cj/cj-scroll-swipe-swiper/Swiper/组件属性/.overview.md\",\r\n    \"harmonyos-6.1-8k/API/arkui-cj/cj-scroll-swipe-swiper/.abstract.md\",\r\n    \"harmonyos-6.1-8k/API/arkui-cj/cj-scroll-swipe-swiper/.overview.md\",\r\n    \"harmonyos-6.1-8k/API/arkui-cj/cj-scroll-swipe-swiper/Swiper/.overview.md\",\r\n    \"ha