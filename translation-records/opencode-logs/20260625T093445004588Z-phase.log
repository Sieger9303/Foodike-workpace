{"type":"tool_use","timestamp":1782380125827,"sessionID":"ses_101de3b79ffel3ckx0Q2nI7Wic","part":{"type":"tool","tool":"read","callID":"call_zCocAlXz5adRtLwPYkoyI8N0","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj"},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n2: \n3: import kit.ArkUI.*\n4: import kit.LocalizationKit.*\n5: import ohos.arkui.state_macro_manage.Builder\n6: import ohos.arkui.state_macro_manage.Component\n7: import ohos.arkui.state_macro_manage.Entry\n8: import ohos.arkui.state_macro_manage.State\n9: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n10: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.loginStore\n11: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.onboardingStore\n12: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.profileStore\n13: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.runtime.{Global, bootstrapStartRoute}\n14: \n15: @Entry\n16: @Component\n17: class FoodikeBootstrap {\n18:     @State\n19:     var currentRoute: String = bootstrapStartRoute\n20: \n21:     @State\n22:     var isShellAtTop: Bool = true\n23: \n24:     @State\n25:     var onboardingPageIndex: Int64 = 0\n26: \n27:     @State\n28:     var loginEmail: String = \"\"\n29: \n30:     @State\n31:     var loginPassword: String = \"\"\n32: \n33:     @State\n34:     var loginErrorMessage: String = \"\"\n35: \n36:     private var onboardingController: SwiperController = SwiperController()\n37: \n38:     private func applyShellState(shellState: ShellRouteState): Unit {\n39:         this.currentRoute = shellState.currentRoute\n40:         this.isShellAtTop = shellState.isAtTop\n41:     }\n42: \n43:     private func shellState(): ShellRouteState {\n44:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n45:     }\n46: \n47:     private func applyShellCommand(command: ShellCommand): Unit {\n48:         let shellState = this.shellState()\n49:         shellState.applyCommand(command)\n50:         this.applyShellState(shellState)\n51:     }\n52: \n53:     private func navigateTo(route: String): Unit {\n54:         let shellState = this.shellState()\n55:         shellState.currentRoute = route\n56:         shellState.isAtTop = true\n57:         this.applyShellState(shellState)\n58:     }\n59: \n60:     private func showBottomShell(route: String): Bool {\n61:         let shellState = this.shellState()\n62:         shellState.currentRoute = route\n63:         return shellState.showBottomShell()\n64:     }\n65: \n66:     private func routeTitle(route: String): String {\n67:         match (route) {\n68:             case \"onboarding\" => \"Onboarding\"\n69:             case \"login_screen\" => \"Login\"\n70:             case \"home_screen\" => \"Home\"\n71:             case \"history\" => \"History\"\n72:             case \"cart\" => \"Cart\"\n73:             case \"profile\" => \"Profile\"\n74:             case \"restaurant_details\" => \"Restaurant Detail\"\n75:             case _ => \"Unknown Route\"\n76:         }\n77:     }\n78: \n79:     private func showToast(message: String): Unit {\n80:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n81:     }\n82: \n83:     private func clearLoginError(): Unit {\n84:         this.loginErrorMessage = \"\"\n85:     }\n86: \n87:     private func performLogin(): Unit {\n88:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n89:             this.clearLoginError()\n90:             this.navigateTo(loginStore.successRoute())\n91:             return\n92:         }\n93: \n94:         this.loginErrorMessage = loginStore.invalidLoginMessage\n95:     }\n96: \n97:     private func performLogout(): Unit {\n98:         profileStore.logout(Global.abilityContext)\n99:         this.loginEmail = \"\"\n100:         this.loginPassword = \"\"\n101:         this.clearLoginError()\n102:         this.onboardingPageIndex = 0\n103:         this.navigateTo(profileStore.logoutRoute())\n104:     }\n105: \n106:     private func routeSummary(route: String): String {\n107:         match (route) {\n108:             case \"home_screen\" => \"Home remains the shared shell placeholder from phase 02 while onboarding, login, and profile now run as dedicated phase-03 routes.\"\n109:             case \"history\" => \"History remains available as a shell route so profile still has a source-consistent back destination.\"\n110:             case \"cart\" => \"Cart continues to be a shell-owned placeholder route until later phases land the real content.\"\n111:             case \"restaurant_details\" => \"Restaurant detail remains in the route contract but keeps its placeholder body until later phases.\"\n112:             case _ => \"\"\n113:         }\n114:     }\n115: \n116:     @Builder\n117:     private func buildTopBar(title: ResourceStr, backLabel: ResourceStr, onBack: () -> Unit) {\n118:         Row {\n119:             Button(backLabel)\n120:                 .onClick({ _ => onBack() })\n121:             Text(title)\n122:                 .fontSize(28)\n123:                 .fontWeight(FontWeight.Bold)\n124:                 .margin(left: 16)\n125:         }\n126:         .width(100.percent)\n127:         .justifyContent(FlexAlign.Start)\n128:         .alignItems(VerticalAlign.Center)\n129:     }\n130: \n131:     @Builder\n132:     private func buildOnboardingCard(title: String, description: String, mediaName: String) {\n133:         Column(space: 18) {\n134:             Image(\n135:                 match (mediaName) {\n136:                     case \"chinese_bowl\" => mediaChineseBowl\n137:                     case \"rider\" => mediaRider\n138:                     case _ => mediaClock\n139:                 }\n140:             )\n141:                 .width(72.percent)\n142:                 .height(280)\n143:             Text(title)\n144:                 .fontSize(30)\n145:                 .fontColor(Color.White)\n146:                 .fontWeight(FontWeight.Bold)\n147:                 .textAlign(TextAlign.Center)\n148:             Text(description)\n149:                 .fontSize(17)\n150:                 .fontColor(Color.White)\n151:                 .textAlign(TextAlign.Center)\n152:                 .width(86.percent)\n153:         }\n154:         .width(100.percent)\n155:         .height(100.percent)\n156:         .justifyContent(FlexAlign.Center)\n157:         .alignItems(HorizontalAlign.Center)\n158:     }\n159: \n160:     @Builder\n161:     private func buildOnboardingIndicator(isSelected: Bool) {\n162:         Text(\" \")\n163:             .width(if (isSelected) { 24 } else { 10 })\n164:             .height(10)\n165:             .backgroundColor(if (isSelected) { Color.White } else { Color.Gray })\n166:     }\n167: \n168:     @Builder\n169:     private func buildLoginErrorBanner() {\n170:         if (this.loginErrorMessage != \"\") {\n171:             Row(space: 12) {\n172:                 Text(this.loginErrorMessage)\n173:                     .fontSize(14)\n174:                     .fontColor(Color.White)\n175:                     .layoutWeight(1)\n176:                 Text(\"Dismiss\")\n177:                     .fontSize(13)\n178:                     .fontWeight(FontWeight.Medium)\n179:                     .fontColor(Color.White)\n180:                     .onClick({ _ =>\n181:                         this.clearLoginError()\n182:                     })\n183:             }\n184:             .width(90.percent)\n185:             .padding(top: 12, right: 14, bottom: 12, left: 14)\n186:             .backgroundColor(colorDarkGreen)\n187:         }\n188:     }\n189: \n190:     @Builder\n191:     private func buildOnboardingRoute() {\n192:         Column(space: 24) {\n193:             Swiper(controller: this.onboardingController) {\n194:                 this.buildOnboardingCard(\n195:                     onboardingStore.slideAt(0).title,\n196:                     onboardingStore.slideAt(0).description,\n197:                     onboardingStore.slideAt(0).mediaName\n198:                 )\n199:                 this.buildOnboardingCard(\n200:                     onboardingStore.slideAt(1).title,\n201:                     onboardingStore.slideAt(1).description,\n202:                     onboardingStore.slideAt(1).mediaName\n203:                 )\n204:                 this.buildOnboardingCard(\n205:                     onboardingStore.slideAt(2).title,\n206:                     onboardingStore.slideAt(2).description,\n207:                     onboardingStore.slideAt(2).mediaName\n208:                 )\n209:             }\n210:             .indicator(false)\n211:             .onChange({ index: Int32 =>\n212:                 this.onboardingPageIndex = Int64(index)\n213:              })\n214:             .width(100.percent)\n215:             .height(78.percent)\n216: \n217:             Row {\n218:                 Row(space: 12) {\n219:                     this.buildOnboardingIndicator(this.onboardingPageIndex == 0)\n220:                     this.buildOnboardingIndicator(this.onboardingPageIndex == 1)\n221:                     this.buildOnboardingIndicator(this.onboardingPageIndex == 2)\n222:                 }\n223:                 Button(\">\")\n224:                     .onClick({ _ =>\n225:                         if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n226:                             this.navigateTo(routePath(RouteId.Login))\n227:                         } else {\n228:                             this.onboardingController.showNext()\n229:                         }\n230:                     })\n231:             }\n232:             .width(90.percent)\n233:             .justifyContent(FlexAlign.SpaceBetween)\n234:             .alignItems(VerticalAlign.Center)\n235:             .margin(bottom: 12)\n236:         }\n237:         .width(100.percent)\n238:         .height(100.percent)\n239:         .backgroundColor(colorDarkGreen)\n240:         .alignItems(HorizontalAlign.Center)\n241:         .justifyContent(FlexAlign.SpaceBetween)\n242:     }\n243: \n244:     @Builder\n245:     private func buildLoginRoute() {\n246:         Column(space: 16) {\n247:             Text(stringWelcomeBack)\n248:                 .fontSize(32)\n249:                 .fontWeight(FontWeight.Bold)\n250: \n251:             this.buildLoginErrorBanner()\n252: \n253:             TextInput(text: this.loginEmail, placeholder: loginStore.emailHint)\n254:                 .width(90.percent)\n255:                 .height(52)\n256:                 .fontSize(16)\n257:                 .placeholderColor(Color.Gray)\n258:                 .onChange({ value: String =>\n259:                     this.loginEmail = value\n260:                     this.clearLoginError()\n261:                 })\n262: \n263:             TextInput(text: this.loginPassword, placeholder: loginStore.passwordHint)\n264:                 .width(90.percent)\n265:                 .height(52)\n266:                 .fontSize(16)\n267:                 .placeholderColor(Color.Gray)\n268:                 .enterKeyType(EnterKeyType.Done)\n269:                 .onChange({ value: String =>\n270:                     this.loginPassword = value\n271:                     this.clearLoginError()\n272:                 })\n273:                 .onSubmit({ _ =>\n274:                     this.performLogin()\n275:                 })\n276: \n277:             Text(stringForgotPassword)\n278:                 .fontSize(14)\n279:                 .fontColor(Color.Gray)\n280:                 .width(90.percent)\n281:                 .textAlign(TextAlign.End)\n282:                 .onClick({ _ =>\n283:                     this.showToast(loginStore.comingSoonMessage)\n284:                 })\n285: \n286:             Button(stringLogin)\n287:                 .width(220)\n288:                 .height(50)\n289:                 .onClick({ _ =>\n290:                     this.performLogin()\n291:                 })\n292: \n293:             Row {\n294:                 Text(stringOrSignInWith)\n295:                     .fontSize(16)\n296:                     .fontColor(Color.Gray)\n297:             }\n298:             .margin(top: 8)\n299: \n300:             Row(space: 20) {\n301:                 Image(mediaGoogIcon)\n302:                     .width(48)\n303:                     .height(48)\n304:                     .onClick({ _ =>\n305:                         this.showToast(loginStore.comingSoonMessage)\n306:                     })\n307:                 Image(mediaFbIcon)\n308:                     .width(48)\n309:                     .height(48)\n310:                     .onClick({ _ =>\n311:                         this.showToast(loginStore.comingSoonMessage)\n312:                     })\n313:             }\n314: \n315:             Text(stringNewToFoodike)\n316:                 .fontSize(15)\n317:                 .fontColor(Color.Gray)\n318:                 .margin(top: 8)\n319:                 .onClick({ _ =>\n320:                     this.showToast(loginStore.comingSoonMessage)\n321:                 })\n322:         }\n323:         .width(100.percent)\n324:         .height(100.percent)\n325:         .padding(top: 24, right: 24, bottom: 24, left: 24)\n326:         .justifyContent(FlexAlign.Center)\n327:         .alignItems(HorizontalAlign.Center)\n328:         .backgroundColor(Color.White)\n329:     }\n330: \n331:     @Builder\n332:     private func buildProfileRoute() {\n333:         Column(space: 18) {\n334:             this.buildTopBar(stringProfileTitle, stringBack, { =>\n335:                 this.navigateTo(profileStore.backRoute())\n336:             })\n337: \n338:    