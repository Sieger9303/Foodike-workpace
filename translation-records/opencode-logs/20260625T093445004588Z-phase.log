{"type":"tool_use","timestamp":1782380503045,"sessionID":"ses_101de3b79ffel3ckx0Q2nI7Wic","part":{"type":"tool","tool":"read","callID":"call_Zn4csnI8dM4tEMBMcK9xGd6J","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj"},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n2: \n3: import kit.ArkUI.*\n4: import kit.LocalizationKit.*\n5: import ohos.arkui.state_macro_manage.Builder\n6: import ohos.arkui.state_macro_manage.Component\n7: import ohos.arkui.state_macro_manage.Entry\n8: import ohos.arkui.state_macro_manage.State\n9: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n10: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.{loginStore, renderLoginRoute}\n11: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.{onboardingStore, renderOnboardingRoute}\n12: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{profileStore, renderProfileRoute}\n13: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.runtime.{Global, bootstrapStartRoute}\n14: \n15: @Entry\n16: @Component\n17: class FoodikeBootstrap {\n18:     @State\n19:     var currentRoute: String = bootstrapStartRoute\n20: \n21:     @State\n22:     var isShellAtTop: Bool = true\n23: \n24:     @State\n25:     var onboardingPageIndex: Int64 = 0\n26: \n27:     @State\n28:     var loginEmail: String = \"\"\n29: \n30:     @State\n31:     var loginPassword: String = \"\"\n32: \n33:     @State\n34:     var loginErrorMessage: String = \"\"\n35: \n36:     private var onboardingController: SwiperController = SwiperController()\n37: \n38:     private func applyShellState(shellState: ShellRouteState): Unit {\n39:         this.currentRoute = shellState.currentRoute\n40:         this.isShellAtTop = shellState.isAtTop\n41:     }\n42: \n43:     private func shellState(): ShellRouteState {\n44:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n45:     }\n46: \n47:     private func applyShellCommand(command: ShellCommand): Unit {\n48:         let shellState = this.shellState()\n49:         shellState.applyCommand(command)\n50:         this.applyShellState(shellState)\n51:     }\n52: \n53:     private func navigateTo(route: String): Unit {\n54:         let shellState = this.shellState()\n55:         shellState.currentRoute = route\n56:         shellState.isAtTop = true\n57:         this.applyShellState(shellState)\n58:     }\n59: \n60:     private func showBottomShell(route: String): Bool {\n61:         let shellState = this.shellState()\n62:         shellState.currentRoute = route\n63:         return shellState.showBottomShell()\n64:     }\n65: \n66:     private func routeTitle(route: String): String {\n67:         match (route) {\n68:             case \"onboarding\" => \"Onboarding\"\n69:             case \"login_screen\" => \"Login\"\n70:             case \"home_screen\" => \"Home\"\n71:             case \"history\" => \"History\"\n72:             case \"cart\" => \"Cart\"\n73:             case \"profile\" => \"Profile\"\n74:             case \"restaurant_details\" => \"Restaurant Detail\"\n75:             case _ => \"Unknown Route\"\n76:         }\n77:     }\n78: \n79:     private func showToast(message: String): Unit {\n80:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n81:     }\n82: \n83:     private func clearLoginError(): Unit {\n84:         this.loginErrorMessage = \"\"\n85:     }\n86: \n87:     private func performLogin(): Unit {\n88:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n89:             this.clearLoginError()\n90:             this.navigateTo(loginStore.successRoute())\n91:             return\n92:         }\n93: \n94:         this.loginErrorMessage = loginStore.invalidLoginMessage\n95:     }\n96: \n97:     private func performLogout(): Unit {\n98:         profileStore.logout(Global.abilityContext)\n99:         this.loginEmail = \"\"\n100:         this.loginPassword = \"\"\n101:         this.clearLoginError()\n102:         this.onboardingPageIndex = 0\n103:         this.navigateTo(profileStore.logoutRoute())\n104:     }\n105: \n106:     private func routeSummary(route: String): String {\n107:         match (route) {\n108:             case \"home_screen\" => \"Home remains the shared shell placeholder from phase 02 while onboarding, login, and profile now run as dedicated phase-03 routes.\"\n109:             case \"history\" => \"History remains available as a shell route so profile still has a source-consistent back destination.\"\n110:             case \"cart\" => \"Cart continues to be a shell-owned placeholder route until later phases land the real content.\"\n111:             case \"restaurant_details\" => \"Restaurant detail remains in the route contract but keeps its placeholder body until later phases.\"\n112:             case _ => \"\"\n113:         }\n114:     }\n115: \n116:     @Builder\n117:     private func buildTopBar(title: ResourceStr, backLabel: ResourceStr, onBack: () -> Unit) {\n118:         Row {\n119:             Button(backLabel)\n120:                 .onClick({ _ => onBack() })\n121:             Text(title)\n122:                 .fontSize(28)\n123:                 .fontWeight(FontWeight.Bold)\n124:                 .margin(left: 16)\n125:         }\n126:         .width(100.percent)\n127:         .justifyContent(FlexAlign.Start)\n128:         .alignItems(VerticalAlign.Center)\n129:     }\n130: \n131:     @Builder\n132:     private func buildOnboardingCard(title: String, description: String, mediaName: String) {\n133:         Column(space: 18) {\n134:             Image(\n135:                 match (mediaName) {\n136:                     case \"chinese_bowl\" => mediaChineseBowl\n137:                     case \"rider\" => mediaRider\n138:                     case _ => mediaClock\n139:                 }\n140:             )\n141:                 .width(72.percent)\n142:                 .height(280)\n143:             Text(title)\n144:                 .fontSize(30)\n145:                 .fontColor(Color.White)\n146:                 .fontWeight(FontWeight.Bold)\n147:                 .textAlign(TextAlign.Center)\n148:             Text(description)\n149:                 .fontSize(17)\n150:                 .fontColor(Color.White)\n151:                 .textAlign(TextAlign.Center)\n152:                 .width(86.percent)\n153:         }\n154:         .width(100.percent)\n155:         .height(100.percent)\n156:         .justifyContent(FlexAlign.Center)\n157:         .alignItems(HorizontalAlign.Center)\n158:     }\n159: \n160:     @Builder\n161:     private func buildOnboardingIndicator(isSelected: Bool) {\n162:         Text(\" \")\n163:             .width(if (isSelected) { 24 } else { 10 })\n164:             .height(10)\n165:             .backgroundColor(if (isSelected) { Color.White } else { Color.Gray })\n166:     }\n167: \n168:     @Builder\n169:     private func buildLoginErrorBanner() {\n170:         if (this.loginErrorMessage != \"\") {\n171:             Row(space: 12) {\n172:                 Text(this.loginErrorMessage)\n173:                     .fontSize(14)\n174:                     .fontColor(Color.White)\n175:                     .layoutWeight(1)\n176:                 Text(\"Dismiss\")\n177:                     .fontSize(13)\n178:                     .fontWeight(FontWeight.Medium)\n179:                     .fontColor(Color.White)\n180:                     .onClick({ _ =>\n181:                         this.clearLoginError()\n182:                     })\n183:             }\n184:             .width(90.percent)\n185:             .padding(top: 12, right: 14, bottom: 12, left: 14)\n186:             .backgroundColor(colorDarkGreen)\n187:         }\n188:     }\n189: \n190:     @Builder\n191:     private func buildOnboardingRoute() {\n192:         renderOnboardingRoute(\n193:             this.onboardingPageIndex,\n194:             this.onboardingController,\n195:             { index: Int32 =>\n196:                 this.onboardingPageIndex = Int64(index)\n197:             },\n198:             { =>\n199:                 if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n200:                     this.navigateTo(routePath(RouteId.Login))\n201:                 } else {\n202:                     this.onboardingController.showNext()\n203:                 }\n204:             }\n205:         )\n206:     }\n207: \n208:     @Builder\n209:     private func buildLoginRoute() {\n210:         renderLoginRoute(\n211:             this.loginEmail,\n212:             this.loginPassword,\n213:             this.loginErrorMessage,\n214:             { value: String =>\n215:                 this.loginEmail = value\n216:                 this.clearLoginError()\n217:             },\n218:             { value: String =>\n219:                 this.loginPassword = value\n220:                 this.clearLoginError()\n221:             },\n222:             { => this.showToast(loginStore.comingSoonMessage) },\n223:             { => this.performLogin() },\n224:             { => this.showToast(loginStore.comingSoonMessage) },\n225:             { => this.showToast(loginStore.comingSoonMessage) },\n226:             { => this.showToast(loginStore.comingSoonMessage) },\n227:             { => this.clearLoginError() }\n228:         )\n229:     }\n230: \n231:     @Builder\n232:     private func buildProfileRoute() {\n233:         renderProfileRoute(\n234:             profileStore.userName,\n235:             profileStore.userEmail,\n236:             { => this.navigateTo(profileStore.backRoute()) },\n237:             { => this.showToast(profileStore.placeholderActionMessage) },\n238:             { => this.showToast(profileStore.placeholderActionMessage) },\n239:             { => this.performLogout() }\n240:         )\n241:     }\n242: \n243:     @Builder\n244:     private func buildPlaceholderRoute() {\n245:         Column(space: 18) {\n246:             Text(\"Foodike\")\n247:                 .fontSize(42)\n248:                 .fontWeight(FontWeight.Bold)\n249:             Text(this.routeTitle(this.currentRoute))\n250:                 .fontSize(28)\n251:             Text(this.routeSummary(this.currentRoute))\n252:                 .fontSize(16)\n253:                 .textAlign(TextAlign.Center)\n254:                 .width(86.percent)\n255: \n256:             if (this.currentRoute == routePath(RouteId.Home) || this.currentRoute == routePath(RouteId.History)) {\n257:                 Button(if (this.isShellAtTop) { \"Simulate Scrolled Content\" } else { \"Return To Top\" })\n258:                     .onClick({ _ =>\n259:                         let shellState = this.shellState()\n260:                         shellState.setTopState(!shellState.isAtTop)\n261:                         this.applyShellState(shellState)\n262:                     })\n263:             }\n264: \n265:             Button(\"Primary Route Action\")\n266:                 .onClick({ _ =>\n267:                     this.applyShellCommand(ShellCommand.PrimaryAction)\n268:                 })\n269: \n270:             if (this.showBottomShell(this.currentRoute)) {\n271:                 Row(space: 12) {\n272:                     Button(\"Home Tab\")\n273:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HomeTab) })\n274:                     Button(\"Cart\")\n275:                         .onClick({ _ => this.applyShellCommand(ShellCommand.CartAction) })\n276:                     Button(\"History Tab\")\n277:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HistoryTab) })\n278:                 }\n279:             }\n280:         }\n281:         .width(100.percent)\n282:         .height(100.percent)\n283:         .justifyContent(FlexAlign.Center)\n284:         .alignItems(HorizontalAlign.Center)\n285:         .padding(top: 24, right: 24, bottom: 24, left: 24)\n286:     }\n287: \n288:     func build() {\n289:         if (this.currentRoute == routePath(RouteId.Onboarding)) {\n290:             this.buildOnboardingRoute()\n291:         } else if (this.currentRoute == routePath(RouteId.Login)) {\n292:             this.buildLoginRoute()\n293:         } else if (this.currentRoute == routePath(RouteId.Profile)) {\n294:             this.buildProfileRoute()\n295:         } else {\n296:             this.buildPlaceholderRoute()\n297:         }\n298:     }\n299: }\n\n(End of file - total 299 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\nimport kit.ArkUI.*\nimport kit.LocalizationKit.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos.arkui.state_macro_manage.Component\nimport ohos.arkui.state_macro_manage.Entry\nimport ohos.arkui.state_macro_manage.State\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.{loginStore, renderLoginRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.{onboardingStore, renderOnboardingRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{profileStore, renderProfileRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.runtime.{Global, bootstrapStartRoute}\n\n@Entry\n@Component\nclass FoodikeBootstrap {\n    @State\n    var currentRoute: String = bootstrapStartRoute\n","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj","time":{"start":1782380503036,"end":1782380503045}},"id":"prt_efe281f80001EJ6HXXhVAECT0j","sessionID":"ses_101de3b79ffel3ckx0Q2nI7Wic","messageID":"msg_efe27daf8001R7mPJ1HHSXYVok"}}
