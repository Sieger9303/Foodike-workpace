e = nextLoginState(readLoginState(context))\n39:         return writeLoginState(context, nextState)\n40:     }\n41: \n42:     public func login(context: UIAbilityContext): Bool {\n43:         return writeLoginState(context, true)\n44:     }\n45: \n46:     public func logout(context: UIAbilityContext): Bool {\n47:         return writeLoginState(context, false)\n48:     }\n49: }\n\n(End of file - total 49 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session\n\nimport kit.AbilityKit.UIAbilityContext\nimport kit.ArkData.Preferences\nimport kit.ArkData.PreferencesValueType\n\npublic class LoginPreferencesService {\n    public init() {}\n\n    public func preferenceFileName(): String {\n        return \"user_login_state_pref\"\n    }\n\n    public func preferenceKey(): String {\n        return \"user_login_state\"\n    }\n\n    public func nextLoginState(currentState: Bool): Bool {\n        return !currentState\n    }","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\data\\session\\login_preferences_service.cj","time":{"start":1782380126406,"end":1782380126422}},"id":"prt_efe2260b5001m46VUpkdqhJ233","sessionID":"ses_101de3b79ffel3ckx0Q2nI7Wic","messageID":"msg_efe22395c001vr83MtGH209Q7i"}}
