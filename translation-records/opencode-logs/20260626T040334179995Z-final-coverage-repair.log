 com.example.foodike.presentation.util.Screen\n72: import kotlinx.coroutines.flow.collectLatest\n73: \n74: @SuppressLint(\"UnusedMaterialScaffoldPaddingParameter\")\n75: @Composable\n76: fun LoginScreen(\n77:     viewModel: LoginViewModel = hiltViewModel(),\n78:     navController: NavHostController,\n79: ) {\n80: \n81:     val scaffoldState: ScaffoldState = rememberScaffoldState()\n82: \n83:     val email by viewModel.email\n84:     val password by viewModel.password\n85: \n86:     LaunchedEffect(key1 = true) {\n87:         viewModel.eventFlow.collectLatest { event ->\n88:             when (event) {\n89:                 is UiEvent.ShowSnackbar -> {\n90:                     scaffoldState.snackbarHostState.showSnackbar(\n91:                         message = event.message, duration = SnackbarDuration.Short\n92:                     )\n93:                 }\n94:             }\n95:         }\n96:     }\n97: \n98:     Scaffold(scaffoldState = scaffoldState) {\n99:         Column(\n100:             modifier = Modifier.fillMaxSize(),\n101:             verticalArrangement = Arrangement.Center,\n102:             horizontalAlignment = Alignment.CenterHorizontally\n103:         ) {\n104: \n105:             val context = LocalContext.current as Activity\n106: \n107:             context.window.statusBarColor = Color.Gray.toArgb()\n108:             context.window.navigationBarColor = Color.White.toArgb()\n109: \n110:             Text(\n111:                 text = stringResource(R.string.welcome_back), fontSize = 24.sp\n112:             )\n113: \n114:             Spacer(modifier = Modifier.height(24.dp))\n115: \n116:             Column(\n117:                 horizontalAlignment = Alignment.End\n118: \n119:             ) {\n120:                 FoodikeTextField(\n121:                     value = email.text,\n122:                     onValueChange = { viewModel.onEvent(LoginEvent.EnteredEmail(it)) },\n123:                     hint = email.hint\n124:                 )\n125: \n126: \n127:                 Spacer(modifier = Modifier.height(16.dp))\n128: \n129:                 FoodikeTextField(\n130:                     value = password.text,\n131:                     onValueChange = { viewModel.onEvent(LoginEvent.EnteredPassword(it)) },\n132:                     hint = password.hint,\n133:                     visualTransformation = PasswordVisualTransformation(),\n134:                     keyboardOptions = KeyboardOptions.Default.copy(\n135:                         imeAction = ImeAction.Done\n136:                     ),\n137:                 )\n138: \n139: \n140:                 Spacer(modifier = Modifier.height(8.dp))\n141: \n142:                 Text(\n143:                     text = stringResource(R.string.forgot_password),\n144:                     modifier = Modifier\n145:                         .alpha(0.5f)\n146:                         .clickable {\n147:                             Toast\n148:                                 .makeText(context, R.string.coming_soon, Toast.LENGTH_SHORT)\n149:                                 .show()\n150:                         },\n151:                     fontSize = 14.sp,\n152:                 )\n153:             }\n154:             Spacer(modifier = Modifier.height(16.dp))\n155:             Button(modifier = Modifier.width(200.dp), onClick = {\n156:                 viewModel.onEvent(LoginEvent.PerformLogin {\n157:                     navController.navigate(Screen.Home.route) {\n158:                         popUpTo(navController.graph.findStartDestination().id) {\n159:                             inclusive = true\n160:                         }\n161:                     }\n162:                 })\n163:             }) {\n164:                 Text(\n165:                     text = stringResource(R.string.login),\n166:                     fontSize = 16.sp,\n167:                 )\n168:             }\n169: \n170: \n171: \n172:             Row(\n173:                 modifier = Modifier\n174:                     