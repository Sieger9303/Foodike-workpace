sun.tools.javac.comp=ALL-UNNAMED \\\n  --add-opens=jdk.compiler/com.sun.tools.javac.file=ALL-UNNAMED \\\n  --add-opens=jdk.compiler/com.sun.tools.javac.parser=ALL-UNNAMED \\\n  --add-opens=jdk.compiler/com.sun.tools.javac.tree=ALL-UNNAMED \\\n  --add-opens=jdk.compiler/com.sun.tools.javac.util=ALL-UNNAMED \\\n  --add-opens=jdk.compiler/com.sun.tools.javac.api=ALL-UNNAMED\n\n# Workaround for KAPT on JDK 17+\nkotlin.daemon.jvmargs=-Xmx2048m \\","truncated":false,"loaded":[]},"title":"..\\..\\Kotlin2Cangjie\\Foodike\\gradle.properties","time":{"start":1782446938535,"end":1782446938541}},"id":"prt_f021dd9810012HdOaBY1qvbyeU","sessionID":"ses_0fde714fafferpTuzwUEMQh0gZ","messageID":"msg_f021d9325001THRtt7sWGAMR2H"}}
{"type":"tool_use","timestamp":1782446938572,"sessionID":"ses_0fde714fafferpTuzwUEMQh0gZ","part":{"type":"tool","tool":"read","callID":"call_mMzZlQcP1OVYLKPUoxG0KS9h","state":{"status":"completed","input":{"filePath":"D:\\Kotlin2Cangjie\\Foodike\\CONTRIBUTING.md","limit":180},"output":"<path>D:\\Kotlin2Cangjie\\Foodike\\CONTRIBUTING.md</path>\n<type>file</type>\n<content>\n1: # Contributing to Foodike 🍔\n2: \n3: First off, thanks for taking the time to contribute! Foodike is an open-source project and we welcome contributions from everyone.\n4: \n5: ## Getting Started\n6: \n7: ### Prerequisites\n8: \n9: - Android Studio (Beta 3 or above)\n10: - JDK 11 or higher\n11: - Git\n12: \n13: ### Setup\n14: \n15: 1. **Fork** the repository on GitHub\n16: 2. **Clone** your fork locally:\n17:    ```bash\n18:    git clone https://github.com/YOUR_USERNAME/Foodike.git\n19:    ```\n20: 3. **Open** the project in Android Studio\n21: 4. **Sync** Gradle and let dependencies download\n22: 5. **Run** the app on an emulator or physical device to verify everything works\n23: \n24: ## How to Contribute\n25: \n26: ### Reporting Bugs\n27: \n28: - Check [existing issues](https://github.com/gautam84/Foodike/issues) first to avoid duplicates\n29: - Open a new issue with a clear title and description\n30: - Include steps to reproduce, expected behavior, and actual behavior\n31: - Add screenshots or screen recordings if applicable\n32: - Mention your device, Android version, and app version\n33: \n34: ### Suggesting Features\n35: \n36: - Open an issue with the **[Feature Request]** tag in the title\n37: - Describe the feature and why it would be useful\n38: - Include mockups or references if possible\n39: \n40: ### Submitting Code\n41: \n42: 1. Create a new branch from `master`:\n43:    ```bash\n44:    git checkout -b feature/your-feature-name\n45:    ```\n46: 2. Make your changes\n47: 3. Test thoroughly on at least one device/emulator\n48: 4. Commit with clear, descriptive messages:\n49:    ```bash\n50:    git commit -m \"Add: brief description of what you added\"\n51:    ```\n52: 5. Push to your fork:\n53:    ```bash\n54:    git push origin feature/your-feature-name\n55:    ```\n56: 6. Open a **Pull Request** against `master` with:\n57:    - A clear description of what changed and why\n58:    - Screenshots/recordings for UI changes\n59:    - Reference to any related issues\n60: \n61: ## Code Style\n62: \n63: - **Language**: Kotlin (100%)\n64: - **Architecture**: MVVM — keep ViewModels, Repositories, and UI layers separate\n65: - **UI**: Jetpack Compose — no XML layouts\n66: - **DI**: Dagger-Hilt for dependency injection\n67: - **Async**: Coroutines + Flow/StateFlow — no RxJava or callbacks\n68: - **Naming**: Follow standard Kotlin conventions\n69:    - `camelCase` for functions and variables\n70:    - `PascalCase` for classes and composables\n71:    - Descriptive names over abbreviations\n72: \n73: ## Project Structure\n74: \n75: ```\n76: app/\n77: ├── data/          # Data models, repositories, data sources\n78: ├── di/            # Hilt modules and dependency injection setup\n79: ├── presentation/  # UI screens, composables, and ViewModels\n80: ├── navigation/    # Navigation graph and routes\n81: └── ui/theme/      # Theme, colors, typography\n82: ```\n83: \n84: ## What Can You Work On?\n85: \n86: Check out the **Issues** tab for open tasks. Issues labeled `good first issue` are great starting points for new contributors. If you want to work on something not listed, open an issue first so we can discuss.\n87: \n88: ## Communication\n89: \n90: - **Issues**: For bugs, features, and discussions\n91: - **Pull Requests**: For code contributions\n92: - **Email**: gautamhazarika01@gmail.com for anything else\n93: \n94: ## Code of Conduct\n95: \n96: Be respectful, constructive, and inclusive. We're all here to learn and build something cool together.\n97: \n98: ---\n99: \n100: Thanks for contributing! Every PR, issue, and suggestion makes Foodike better. 🚀\n\n(End of file - total 100 lines)\n</content>","metadata":{"preview":"# Contributing to Foodike 🍔\n\nFirst off, thanks for taking the time to contribute! Foodike is an open-source project and we welcome contributions from everyone.\n\n## Getting Started\n\n### Prerequisites\n\n- Android Studio (Beta 3 or above)\n- JDK 11 or higher\n- Git\n\n### Setup\n\n1. **Fork** the repository on GitHub\n2. **Clone** your fork locally:\n   ```bash\n   git clone https://github.com/YOUR_USERNAME/Foodike.git\n   ```\n3. **Open** the project in Android Studio","truncated":false,"loaded":[]},"title":"..\\..\\Kotlin2Cangjie\\Foodike\\CONTRIBUTING.md","time":{"start":1782446938564,"end":1782446938570}},"id":"prt_f021dd9aa001cJjkgtkvTBRm81","sessionID":"ses_0fde714fafferpTuzwUEMQh0gZ","messageID":"msg_f021d9325001THRtt7sWGAMR2H"}}
