ry in 20 minutes</string>\n34:     <string name=\"onboardingText1\">Choose from a range of restaurants and hotels near you</string>\n35:     <string name=\"onboardingText2\">Vaccinated delivery partners ensure the health and security of the customer</string>\n36:     <string name=\"onboardingText3\">Fast and easy to track delivery to ease the experience of the customer</string>\n37:     <string name=\"welcome_back\">Welcome back!</string>\n38:     <string name=\"forgot_password\">forgot password?</string>\n39:     <string name=\"coming_soon\">Coming soon!</string>\n40:     <string name=\"login\">Login</string>\n41:     <string name=\"or_sign_in_with\">or sign in with</string>\n42:     <string name=\"login_with_google\">Login with Google</string>\n43:     <string name=\"login_with_facebook\">Login with Facebook</string>\n44:     <string name=\"new_to_foodike\">New to Foodike? Sign up</string>\n45:     <string name=\"display_picture\">Display picture</string>\n46:     <string name=\"log_out\">Log Out</string>\n47:     <string name=\"saved_addresses\">Saved Addresses</string>\n48:     <string name=\"add_edit_and_delete_saved_addresses\">Add, edit and delete saved addresses</string>\n49:     <string name=\"payments_and_refunds\">\n50: <![CDATA[ Payments & Refunds ]]>\n51: </string>\n52:     <string name=\"information_about_refunds_and_payments\">Information about refunds and payments</string>\n53:     <string name=\"online_ordering_help\">Online Ordering Help</string>\n54:     <string name=\"information_about_ordering_food\">Information about ordering food</string>\n55:     <string name=\"about\">About</string>\n56:     <string name=\"about_the_app\">About the app</string>\n57:     <string name=\"with\">\\With \\</string>\n58:     <string name=\"love\">Love</string>\n59:     <string name=\"from_creator\">\\ from Gautam Hazarika\\</string>\n60:     <string name=\"location\">Location</string>\n61:     <string name=\"back\">Back</string>\n62:     <string name=\"edit\">Edit