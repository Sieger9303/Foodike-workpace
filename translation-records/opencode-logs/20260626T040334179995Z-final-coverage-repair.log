f (restaurantName != \"\") {\n38:             match (contentRepository.getRestaurantByName(restaurantName)) {\n39:                 case Some(restaurant) => return restaurant\n40:                 case None => return contentRepository.getRestaurants()[0]\n41:             }\n42:         }\n43:         return contentRepository.getRestaurants()[0]\n44:     }\n45: \n46:     public func recommendedItems(menuItems: ArrayList<DetailMenuItemData>): ArrayList<DetailMenuItemData> {\n47:         let shuffled = ArrayList<DetailMenuItemData>(menuItems)\n48:         let rng = Random()\n49:         var index: Int64 = shuffled.size - 1\n50:         while (index > 0) {\n51:             let swapIndex = rng.nextInt64(index + 1)\n52:             let current = shuffled[index]\n53:             shuffled[index] = shuffled[swapIndex]\n54:             shuffled[swapIndex] = current\n55:             index -= 1\n56:         }\n57: \n58:         let recommended = ArrayList<DetailMenuItemData>([])\n59:         var recommendedIndex: Int64 = 0\n60:         for (item in shuffled) {\n61:             if (recommendedIndex >= 5) {\n62:                 break\n63:             }\n64:             recommended.add(item)\n65:             recommendedIndex += 1\n66:         }\n67:         return recommended\n68:     }\n69: \n70:     public func nonVegItems(menuItems: ArrayList<DetailMenuItemData>): ArrayList<DetailMenuItemData> {\n71:         let filtered = ArrayList<DetailMenuItemData>([])\n72:         for (item in menuItems) {\n73:             if (!item.menuItem.isVegetarian) {\n74:                 filtered.add(item)\n75:             }\n76:         }\n77:         return filtered\n78:     }\n79: \n80:     public func vegItems(menuItems: ArrayList<DetailMenuItemData>): ArrayList<DetailMenuItemData> {\n81:         let filtered = ArrayList<DetailMenuItemData>([])\n82:         for (item in menuItems) {\n83:             if (item.menuItem.isVegetarian) {\n84:                 filtered.add(item)\n85:             }\n86:         }\n87:         return filtered\n88:     }\n89: \n90:     public func incrementQuantity(item: DetailMenuItemData): Unit {\n91:         item.quantity += 1\n92:     }\n93: \n94:     public func decrementQuantity(item: DetailMenuItemData): Unit {\n95:         if (item.quantity > 0) {\n96:             item.quantity -= 1\n97:         }\n98:     }\n99: \n100:     public func totalSelectedItems(menuItems: ArrayList<DetailMenuItemData>): Int64 {\n101:         var total: Int64 = 0\n102:         for (item in menuItems) {\n103:             total += item.quantity\n104:         }\n105:         return total\n106:     }\n107: \n108:     public func shouldShowCartAction(menuItems: ArrayList<DetailMenuItemData>): Bool {\n109:         return totalSelectedItems(menuItems) > 0\n110:     }\n111: \n112:     public func toggleLiked(restaurant: RestaurantData, currentValue: Bool): Bool {\n113:         let nextValue = !currentValue\n114:         sessionRepository.setRestaurantLiked(restaurant, nextValue)\n115:         return nextValue\n116:     }\n117: \n118:     public func formatPrice(price: Float64): String {\n119:         return \"$${price}\"\n120:     }\n121: \n122:     public func formatRatingCount(ratingCount: Int64): String {\n123:         return \"${ratingCount} ratings\"\n124:     }\n125: \n126:     public func formatRestaurantMeta(restaurant: RestaurantData): String {\n127:         return \"${restaurant.rating}(${customerCount(restaurant.ratingCount)}) · ${restaurant.etaMinutes} Min · $${restaurant.averagePrice}\"\n128:     }\n129: \n130:     public func customerCount(ratingCount: Int64): String {\n131:         if (ratingCount >= 1000) {\n132:             return \"1000+\"\n133:         }\n134:         if (ratingCount >= 100) {\n135:             return \"${ratingCount}+\"\n136:         }\n137:         return \"${ratingCount}\"\n138:     }\n139: \n140:     public func session(): SessionRepository {\n141:         return sessionRepository\n142:     }\n143: }\n\n(End of file - t