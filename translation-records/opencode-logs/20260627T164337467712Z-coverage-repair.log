apshot(): Unit {\n37:         let repository = SessionRepository()\n38:         let restaurant = HomeContentRepository().getRestaurants()[0]\n39:         repository.setRestaurant(restaurant)\n40: \n41:         @Assert(repository.getSavedRestaurantName(), \"George Street\")\n42:         let menuItems = repository.getMenuItems()\n43:         @Assert(menuItems.size > 0, true)\n44:         @Assert(menuItems[0].menuItem.dish, \"Fish and Chips\")\n45:         @Assert(menuItems[0].quantity, 0)\n46:     }\n47: \n48:     @TestCase\n49:     public func sessionRepositoryLikeToggleMutatesSharedFavouriteState(): Unit {\n50:         let repository = SessionRepository()\n51:         let candidate = HomeContentRepository().getRestaurants()[1]\n52: \n53:         @Assert(repository.isRestaurantLiked(candidate), false)\n54:         repository.setRestaurantLiked(candidate, true)\n55:         @Assert(repository.isRestaurantLiked(candidate), true)\n56:         @Assert(repository.getLikedRestaurants().size, 6)\n57: \n58:         repository.setRestaurantLiked(candidate, false)\n59:         @Assert(repository.isRestaurantLiked(candidate), false)\n60:         @Assert(repository.getLikedRestaurants().size, 5)\n61:     }\n62: \n63:     @TestCase\n64:     public func sessionRepositoryRetainsCartSeedItems(): Unit {\n65:         let repository = SessionRepository()\n66:         let cartItems = repository.getCartItems()\n67:         @Assert(cartItems.size, 2)\n68:         @Assert(cartItems[0].menuItem.dish, \"Paw Bhaaji\")\n69:         @Assert(cartItems[1].quantity, 2)\n70:     }\n71: }\n\n(End of file - total 71 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.SessionRepository\nimport std.unittest.*\nimport std.unittest.testmacro.*\n\n@Test\npublic class Phase02RepositoryContractTest {\n    private func restaur