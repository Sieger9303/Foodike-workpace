tailMenuItemData>([\n22:         DetailMenuItemData(MenuItemData(\"Fish and Chips\", 3.95, 4.7, 12, false), 0),\n23:         DetailMenuItemData(MenuItemData(\"Guacamole with Chips\", 4.50, 4.4, 15, true), 0),\n24:         DetailMenuItemData(MenuItemData(\"Chicken Biryani\", 2.55, 4.9, 22, false), 0),\n25:         DetailMenuItemData(MenuItemData(\"Kadai Paneer\", 3.55, 3.9, 52, true), 0),\n26:         DetailMenuItemData(MenuItemData(\"Veg Pulao\", 5.00, 4.2, 23, true), 0),\n27:         DetailMenuItemData(MenuItemData(\"Smoked Pork\", 3.75, 4.8, 56, false), 0),\n28:         DetailMenuItemData(MenuItemData(\"Veg Pakora\", 3.75, 2.9, 43, true), 0),\n29:         DetailMenuItemData(MenuItemData(\"Cheese Omelette\", 1.15, 3.9, 60, false), 0)\n30:     ])\n31:     private let menu2 = ArrayList<DetailMenuItemData>([\n32:         DetailMenuItemData(MenuItemData(\"Masala Dosa\", 4.50, 4.4, 73, true), 0),\n33:         DetailMenuItemData(MenuItemData(\"Papdi Chaat\", 2.55, 4.9, 33, true), 0),\n34:         DetailMenuItemData(MenuItemData(\"Chole Bhature\", 3.75, 4.8, 53, true), 0),\n35:         DetailMenuItemData(MenuItemData(\"Paw Bhaaji\", 2.00, 3.9, 67, true), 0),\n36:         DetailMenuItemData(MenuItemData(\"Amrit Peda\", 2.00, 4.6, 9, true), 0),\n37:         DetailMenuItemData(MenuItemData(\"Pani Puchka\", 3.50, 4.9, 93, true), 0),\n38:         DetailMenuItemData(MenuItemData(\"Raj Kachoori\", 3.55, 3.9, 83, true), 0),\n39:         DetailMenuItemData(MenuItemData(\"Plain Dosa\", 3.95, 4.7, 13, true), 0)\n40:     ])\n41:     private let menu3 = ArrayList<DetailMenuItemData>([\n42:         DetailMenuItemData(MenuItemData(\"Szechwan Chilli Chicken\", 6.75, 4.9, 31, false), 0),\n43:         DetailMenuItemData(MenuItemData(\"Veg Momo\", 2.00, 4.6, 13, true), 0),\n44:         DetailMenuItemData(MenuItemData(\"Chicken Momo\", 3.50, 4.9, 71, false), 0),\n45:         DetailMenuItemData(MenuItemData(\"Aloo Paratha\", 1.00, 2.9, 23, true), 0),\n46:         DetailMenuItemData(MenuItemData(\"Mutton Pulao\", 7.75, 2.9, 13, false), 0),\n47:         DetailMenuItemData(MenuItemData(\"Prawns Chilli\", 5.75, 3.5, 75, false), 0),\n48:         DetailMenuItemData(MenuItemData(\"Veg Fried Rice\", 3.75, 4.1, 73, true), 0),\n49:         DetailMenuItemData(MenuItemData(\"Masala Dosa\", 4.50, 4.4, 77, true), 0)\n50:     ])\n51: \n52:     public init() {}\n53: \n54:     public func setSelectedRestaurant(restaurant: RestaurantData): Unit {\n55:         selectedRestaurantName = restaurant.name\n56:         replaceSelectedMenu(menuItemsForRestaurant(restaurant.name))\n57:     }\n58: \n59:     public func setRestaurant(restaurant: RestaurantData): Unit {\n60:         setSelectedRestaurant(restaurant)\n61:     }\n62: \n63:     public func getSelectedRestaurantName(): String {\n64:         return selectedRestaurantName\n65:     }\n66: \n67:     public func getSavedRestaurantName(): String {\n68:         return selectedRestaurantName\n69:     }\n70: \n71:     public func getLikedRestaurants(): ArrayList<RestaurantData> {\n72:         return likedRestaurants\n73:     }\n74: \n75:     public func getCartItems(): ArrayList<CartSnapshotItemData> {\n76:         return cartItems\n77:     }\n78: \n79:     public func menuItemsForRestaurant(name: String): ArrayList<DetailMenuItemData> {\n80:         if (name == \"George Street\" || name == \"Edona\" || name == \"Hermes Kitchen\" || name == \"Naga Kitchen\" || name == \"99 Reasons to Eat\") {\n81:             return menu1\n82:         }\n83:         if (name == \"Saffron Xpress\" || name == \"KF\" || name == \"Kanha\" || name == \"Cafe Lighton\" || name == \"Rock n Rolls\") {\n84:             return menu3\n85:         }\n86:         return menu2\n87:     }\n88: \n89:     public func getMenuItems(): ArrayList<DetailMenuItemData> {\n90:         return selectedRestaurantMenuItems\n91:     }\n92: \n93:     public func isRestaurantLiked(restaurant: RestaurantData): Bool {\n94:         return containsLikedRestaurant(restaurant.name)\n95:     }\n96: \n97:     public func setRestaurantLiked(restaurant: RestaurantData, liked: Bool): Unit {\n98:         if (liked) {\n99:             if (!containsLikedRestaurant(restaurant.name)) {\n100:                 likedRestaurants.add(restaurant)\n101:             }\n102:             return\n103:         }\n104:         removeLikedRestaurant(restaurant.name)\n105:     }\n106: \n107:     public func restaurantSelectionRouteToken(): String {\n108:         return selectedRestaurantName\n109:     }\n110: \n111:     private func replaceSelectedMenu(sourceMenu: ArrayList<DetailMenuItemData>): Unit {\n112:         selectedRestaurantMenuItems.clear()\n113:         for (item in sourceMenu) {\n114:             selectedRestaurantMenuItems.add(\n115:                 DetailMenuItemData(\n116:                     MenuItemData(\n117:                         item.menuItem.dish,\n118:                         item.menuItem.price,\n119:                         item.menuItem.rating,\n120:                         item.menuItem.ratingCount,\n121:                         item.menuItem.isVegetarian\n122:                     ),\n123:                     0\n124:                 )\n125:             )\n126:         }\n127:     }\n128: \n129:     private func containsLikedRestaurant(name: String): Bool {\n130:         for (restaurant in likedRestaurants) {\n131:             if (restaurant.name == name) {\n132:                 return true\n133:             }\n134:         }\n135:         return false\n136:     }\n137: \n138:     private func removeLikedRestaurant(name: String): Unit {\n139:         var index: Int64 = 0\n140:         while (index < likedRestaurants.size) {\n141:             if (likedRestaurants[index].name == name) {\n142:                 likedRestaurants.remove(at: index)\n143:                 return\n144:             }\n145:             index += 1\n146:         }\n147:     }\n148: }\n149: \n150: public let sessionRepository = SessionRepository()\n\n(End of file - total 150 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.RestaurantData\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.{CartSnapshotItemData, DetailMenuItemData, MenuItemData}\nimport std.collection.ArrayList\n\npublic class SessionRepository {\n    private var selectedRestaurantName: String = \"\"\n    private let selectedRestaurantMenuItems = ArrayList<DetailMenuItemData>([])\n    private let likedRestaurants = ArrayList<RestaurantData>([\n        RestaurantData(\"George Street\", 4.6, 128, 59, \"Indian, American\", \"Mahabhairab\", 3.0, \"applepie\"),\n        RestaurantData(\"Saffron Xpress\", 3.6, 79, 43, \"Chinese\", \"Mission Charali\", 3.5, \"chinese\"),\n        RestaurantData(\"KF\", 4.9, 357, 55, \"North Indian, Vegetarian\", \"B.P. Tiniali\", 4.0, \"burger\"),\n        RestaurantData(\"Inaya Mughlai\", 2.6, 221, 23, \"Tandoori, American\", \"Goroimari\", 2.0, \"biryani\"),\n        RestaurantData(\"Edona\", 3.3, 207, 51, \"Italian\", \"Mission Charali\", 7.0, \"paratha\")\n    ])\n    private let cartItems = ArrayList<CartSnapshotItemData>([\n        CartSnapshotItemData(MenuItemData(\"Paw Bhaaji\", 2.00, 3.9, 23, true), 1),\n        CartSnapshotItemData(MenuItemData(\"Veg Pulao\", 5.00, 4.2, 23, true), 2)\n    ])","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\data\\session\\session_repository.cj","time":{"start":1782578657720,"end":1782578657750}},"id":"prt_f09f7b9b1001dk0FkrSA1yVg0E","sessionID":"ses_0f608ddeaffeWbGw1R7udtUrQq","messageID":"msg_f09f79166001AU1xT3C40Uc2CN"}}
