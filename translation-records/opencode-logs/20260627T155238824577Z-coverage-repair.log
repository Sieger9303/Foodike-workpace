i-appmodule-kt-30d21fc769-001-runtime-permission-request-permission-re: not-applicable has source/notes explanation\",\n51:         \"app-src-main-java-com-example-foodike-data-repository-ho-4b6d5fb3fe-001-runtime-permission-request-permission-re: not-applicable has source/notes explanation\",\n52:         \"app-src-main-java-com-example-foodike-domain-repository-583d53fd5f-002-runtime-permission-request-permission-re: not-applicable has source/notes explanation\",\n53:         \"app-src-main-java-com-example-foodike-domain-repository-f168e0eabb-001-runtime-permission-request-permission-re: not-applicable has source/notes explanation\",\n54:         \"app-src-main-java-com-example-foodike-domain-repository-451c06cddd-002-observable-state-viewmodel-flow-livedata: implemented with behavior, parity, endpoint, and verification evidence\",\n55:         \"app-src-main-java-com-example-foodike-domain-repository-937078fce8-003-data-loading-query-search-filter-or-sort: implemented with behavior, parity, endpoint, and verification evidence\",\n56:         \"app-src-main-java-com-example-foodike-domain-repository-94c665f8c2-004-authentication-account-or-session-behavi: implemented with behavior, parity, endpoint, and verification evidence\"\n57:       ],\n58:       \"contractDebt\": [],\n59:       \"sourcePaths\": [\n60:         \"app/src/main/java/com/example/foodike/data/data_source/FakeData.kt\",\n61:         \"app/src/main/java/com/example/foodike/presentation/util/Navigation.kt\",\n62:         \"app/src/main/java/com/example/foodike/data/repository/UserDataRepositoryImpl.kt\",\n63:         \"app/src/main/java/com/example/foodike/data/repository/LoginRepositoryImpl.kt\",\n64:         \"app/src/main/java/com/example/foodike/di/AppModule.kt\",\n65:         \"app/src/main/java/com/example/foodike/data/repository/HomeRepositoryImpl.kt\",\n66:         \"app/src/main/java/com/example/foodike/domain/repository/UserDataRepository.kt\",\n67:         \"app/src/main/java/com/example/foodike/domain/repository/LoginRepository.kt\"\n68:       ],\n69:       \"featureIds\": [\n70:         \"app-src-main-java-com-example-foodike-data-data-source-f-f170137f2d-001-file-document-storage-saf-mediastore-or\",\n71:         \"app-src-main-java-com-example-foodike-data-data-source-f-8d9b6c748e-002-image-viewing-bitmap-exif-handling-zoom\",\n72:         \"app-src-main-java-com-example-foodike-data-data-source-f-5dbff38a8a-003-intent-uri-bundle-deeplink-or-cross-scre\",\n73:         \"app-src-main-java-com-example-foodike-data-data-source-f-d03fbb20a2-004-navigation-surface-menu-drawer-toolbar-o\",\n74:         \"app-src-main-java-com-example-foodike-data-data-source-f-552e89ac77-005-runtime-permission-request-permission-re\",\n75:         \"app-src-main-java-com-example-foodike-presentation-util-dc524a2ddb-003-runtime-permission-request-permission-re\",\n76:         \"app-src-main-java-com-example-foodike-data-repository-us-7d28c63dc6-003-runtime-permission-request-permission-re\",\n77:         \"app-src-main-java-com-example-foodike-data-repository-lo-7e56a71166-001-runtime-permission-request-permission-re\",\n78:         \"app-src-main-java-com-example-foodike-data-repository-lo-6ca6819f0d-002-settings-preferences-option-toggles-or-c\",\n79:         \"app-src-main-java-com-example-foodike-data-repository-lo-7dc1a245fb-003-observable-state-viewmodel-flow-livedata\",\n80:         \"app-src-main-java-com-example-foodike-data-repository-lo-02b022d9dd-004-authentication-account-or-session-behavi\",\n81:         \"app-src-main-java-com-example-foodike-di-appmodule-kt-30d21fc769-001-runtime-permission-request-permission-re\",\n82:         \"app-src-main-java-com-example-foodike-data-repository-ho-4b6d5fb3fe-001-runtime-permission-request-permission-re\",\n83:         \"app-src-main-java-com-example-foodike-domain-repository-583d53fd5f-002-runtime-permission-request-permission-re\",\n84:         \"app-src-main-java-com-example-foodike-domain-repository-f168e0eabb-001-runtime-permission-request-permission-re\",\n85:         \"app-src-main-java-com-example-foodike-domain-repository-451c06cddd-002-observable-state-viewmodel-flow-livedata\",\n86:         \"app-src-main-java-com-example-foodike-domain-repository-937078fce8-003-data-loading-query-search-filter-or-sort\",\n87:         \"app-src-main-java-com-example-foodike-domain-repository-94c665f8c2-004-authentication-account-or-session-behavi\"\n88:       ],\n89:       \"resourceInputs\": [],\n90:       \"platformCapabilityIds\": [],\n91:       \"expectedTargetDomains\": [\n92:         \"ohos_app_cangjie_entry/data/content/home_content_repository.cj\",\n93:         \"ohos_app_cangjie_entry/data/session/session_repository.cj\",\n94:         \"ohos_app_cangjie_entry/domain/discovery_models.cj\",\n95:         \"ohos_app_cangjie_entry/app/app_router.cj\",\n96:         \"entry/src/main/module.json5\",\n97:         \"ohos_app_cangjie_entry/app/shell_route_state.cj\",\n98:         \"ohos_app_cangjie_entry/data/session/login_preferences_service.cj\",\n99:         \"ohos_app_cangjie_entry/features/startup/startup_launch_service.cj\",\n100:         \"ohos_app_cangjie_entry/features/login/login_store.cj\",\n101:         \"ohos_app_cangjie_entry/features/profile/profile_store.cj\"\n102:       ],\n103:       \"requiredBehaviors\": [\n104:         \"The target content/session repositories keep this phase as pure in-memory seeded data with no file, SAF, MediaStore, or import/export path.\",\n105:         \"The target repositories keep media references as simple `mediaName` strings without adding viewer or bitmap-processing logic in phase-02.\",\n106:         \"The phase-02 content/session layer keeps seeded content separate from cross-screen state; no bundle or deeplink logic is implemented in the data source file itself.\",\n107:         \"The target keeps seeded content in `home_content_repository.cj` and route behavior in feature/app modules rather than mixing navigation surfaces into the data source.\",\n108:         \"The target keeps seeded content repositories permission-free in phase-02 and adds no request-permission scaffolding.\",\n109:         \"The HarmonyOS routing shell keeps the same route/shell scope without permission prompts, and `entry/src/main/module.json5::requestPermissions` remains empty.\",\n110:         \"`session_repository.cj` preserves the same shared in-memory state responsibilities without any permission prompt or protected-access flow.\",\n111:         \"`login_preferences_service.cj` persists login state through `Preferences` without any permission prompt or protected-access flow.\",\n112:         \"`LoginPreferencesService` preserves the same single-file single-key login preference contract and exposes read/write/toggle helpers over HarmonyOS `Preferences`.\",\n113:         \"`LoginPreferencesService` preserves the same persisted login-state contract, and phase-02 startup/login/profile consumers only need immediate reads or writes at route boundaries rather than a long-lived observer subscription.\",\n114:         \"`LoginPreferencesService.toggleLoginState()` and the login/profile stores preserve the same persisted session flip behavior for startup, login success, and logout.\",\n115:         \"The target keeps repository/service wiring permission-free for phase-02 startup/session/navigation.\",\n116:         \"`home_content_repository.cj` keeps catalogue loading fully in-memory and permission-free in phase-02.\",\n117:         \"`SessionRepository` preserves the same shared state responsibilities without any permission prompt or protected-access flow.\",\n118:         \"`LoginPreferencesService` keeps login persistence inside HarmonyOS `Preferences` without adding any permission prompt or protected-access flow.\",\n119:         \"`LoginPreferencesService` preserves the same persisted login-state source of truth, and `StartupLaunchService`, `loginStore`, and `profileStore` reuse that shared state at the same startup/login/logout boundaries that the current-phase source observes throu...\",\n120:         \"`LoginPreferencesService.readLoginState(context)` reads the same persisted login flag that startup uses to choose onboarding or home.\",\n121:         \"`LoginPreferencesService.toggleLoginState()` preserves the same persisted session flip behavior reused by startup, login success, and logout flows.\"\n122:       ],\n123:       \"acceptanceEvidence\": [\n124:         \"Replace broad endpoints with precise target functions, types, resources, or tests before closing the group.\"\n125:       ],\n126:       \"riskHints\": [\n127:         \"current evidence uses broad shell/root/whole-file endpoints\"\n128:       ],\n129:       \"matrixRows\": [\n130:         {\n131:           \"kind\": \"source-feature\",\n132:           \"featureId\": \"app-src-main-java-com-example-foodike-data-data-source-f-f170137f2d-001-file-document-storage-saf-mediastore-or\",\n133:           \"featureName\": \"File, document, storage, SAF, MediaStore, or import/export behavior.\",\n134:           \"sourcePath\": \"app/src/main/java/com/example/foodike/data/data_source/FakeData.kt\",\n135:           \"importance\": \"critical\",\n136:           \"plannedPhase\": \"phase-02-startup-session-navigation\",\n137:           \"status\": \"not-applicable\",\n138:           \"parityLevel\": \"not-applicable\",\n139:           \"verdict\": \"complete\",\n140:           \"reasons\": [\n141:             \"not-applicable has source/notes explanation\"\n142:           ],\n143:           \"targetEndpoints\": [\n144:             \"entry/src/main/cangjie/ohos_app_cangjie_entry/data/content/home_content_repository.cj\",\n145:             \"entry/src/main/cangjie/ohos_app_cangjie_entry/data/session/session_repository.cj\"\n146:           ],\n147:           \"tests\": [\n148:             \"entry/src/test/cangjie/phase02_repository_contract_test.cj\",\n149:             \"blocked: cjpm test (entry/src/test/cangjie)\"\n150:           ]\n151:         },\n152:         {\n153:           \"kind\": \"source-feature\",\n154:           \"featureId\": \"app-src-main-java-com-example-foodike-data-data-source-f-8d9b6c748e-002-image-viewing-bitmap-exif-handling-zoom\",\n155:           \"featureName\": \"Image viewing, bitmap/exif handling, zoom, preview, or gallery display behavior.\",\n156:           \"sourcePath\": \"app/src/main/java/com/example/foodike/data/data_source/FakeData.kt\",\n157:           \"importance\": \"critical\",\n158:           \"plannedPhase\": \"phase-02-startup-session-navigation\",\n159:           \"status\": \"not-applicable\",\n160:           \"parityLevel\": \"not-applicable\",\n161:           \"verdict\": \"complete\",\n162:           \"reasons\": [\n163:             \"not-applicable has source/notes explanation\"\n164:           ],\n165:           \"targetEndpoints\": [\n166:             \"entry/src/main/cangjie/ohos_app_cangjie_entry/domain/discovery_models.cj::AdvertisementData\",\n167:             \"entry/src/main/cangjie/ohos_app_cangjie_entry/domain/discovery_models.cj::RestaurantData\",\n168:             \"entry/src/main/cangjie/ohos_app_cangjie_entry/data/content/home_content_repository.cj\"\n169:           ],\n170:           \"tests\": [\n171:             \"entry/src/test/cangjie/phase02_repository_contract_test.cj\",\n172:             \"blocked: cjpm test (entry/src/test/cangjie)\"\n173:           ]\n174:         },\n175:         {\n176:           \"kind\": \"source-feature\",\n177:           \"featureId\": \"app-src-main-java-com-example-foodike-data-data-source-f-5dbff38a8a-003-intent-uri-bundle-deeplink-or-cross-scre\",\n178:           \"featureName\": \"Intent, URI, bundle, deeplink, or cross-screen parameter flow.\",\n179:           \"sourcePath\": \"app/src/main/java/com/example/foodike/data/data_source/FakeData.kt\",\n180:           \"importance\": \"critical\",\n181:           \"plannedPhase\": \"phase-02-startup-session-navigation\",\n182:           \"status