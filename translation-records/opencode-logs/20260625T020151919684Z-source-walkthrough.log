out.*\n32: import androidx.compose.foundation.shape.RoundedCornerShape\n33: import androidx.compose.material.Text\n34: import androidx.compose.runtime.Composable\n35: import androidx.compose.ui.Alignment\n36: import androidx.compose.ui.Modifier\n37: import androidx.compose.ui.draw.alpha\n38: import androidx.compose.ui.draw.clip\n39: import androidx.compose.ui.draw.shadow\n40: import androidx.compose.ui.layout.ContentScale\n41: import androidx.compose.ui.res.painterResource\n42: import androidx.compose.ui.text.font.FontWeight\n43: import androidx.compose.ui.text.style.TextOverflow\n44: import androidx.compose.ui.unit.dp\n45: import androidx.compose.ui.unit.sp\n46: import com.example.foodike.R\n47: import com.example.foodike.domain.model.Restaurant\n48: import com.example.foodike.presentation.common.getTimeInMins\n49: import java.lang.StringBuilder\n50: import java.util.concurrent.TimeUnit\n51: \n52: @Composable\n53: fun RestaurantCard(\n54:     restaurant: Restaurant,\n55:     modifier: Modifier\n56: ) {\n57:     Column(\n58:         modifier = Modifier\n59:             .fillMaxWidth()\n60:             .padding(8.dp, 0.dp)\n61:     )\n62:     {\n63:         Row(\n64:             modifier = modifier\n65:                 .fillMaxWidth()\n66:                 ,\n67:             horizontalArrangement = Arrangement.Start,\n68:             verticalAlignment = Alignment.CenterVertically\n69:         ) {\n70:             Image(\n71:                 painter = painterResource(id = restaurant.image),\n72:                 contentDescription = \"Restaurant\",\n73:                 modifier = Modifier\n74:                     .size(130.dp, 170.dp)\n75:                     .shadow(elevation = 0.dp, shape = RoundedCornerShape(8.dp), clip = true),\n76:                 contentScale = ContentScale.Crop\n77:             )\n78:             Column(modifier = Modifier.padding(16.dp)) {\n79:                 Text(\n80:                     text = restaurant.name,\n81:                     fontSize = 16.sp,\n82:                     fontWeight = FontWeight.Bold,\n83:                 )\n84:                 Row(\n85:                     horizontalArrangement = Arrangement.Center,\n86:                     verticalAlignment = Alignment.CenterVertically\n87:                 ) {\n88:                     Image(\n89:                         painter = painterResource(id = R.drawable.star),\n90:                         contentDescription = \"Rating\",\n91:                         modifier = Modifier\n92:                             .size(20.dp)\n93:                     )\n94:                     Spacer(modifier = Modifier.width(2.dp))\n95: \n96:                     Text(text = \"${restaurant.rating}(${getCustomerInfo(restaurant.noOfRatings)}) \")\n97:                     Text(\n98:                         text = \"·\",\n99:                         fontSize = 16.sp,\n100:                         fontWeight = FontWeight.Bold,\n101:                     )\n102:                     Text(text = restaurant.timeInMillis.getTimeInMins())\n103:                 }\n104:                 Text(\n105:                     text = restaurant.variety,\n106:                     modifier = Modifier.alpha(0.5f),\n107:                     overflow = TextOverflow.Ellipsis,\n108:                     maxLines = 1\n109:                 )\n110:                 Text(\n111:                     text = restaurant.place,\n112:                     modifier = Modifier.alpha(0.5f),\n113:                 )\n114:             }\n115: \n116:         }\n117:         Spacer(modifier = Modifier.height(18.dp))\n118: \n119:     }\n120: \n121: \n122: }\n123: \n124: \n125: fun getCustomerInfo(noOfRatings: Int): String {\n126:     return when {\n127:         noOfRatings > 50 -> {\n128:             \"50+\"\n129:         }\n130:         noOfRatings > 100 -> {\n131:             \"100+\"\n132:         }\n133:         noOfRatings > 150 -> {\n134:             \"150+\"\n135:         }\n136:         noOfRatings > 200 -> {\n137:             \"200+\"\n138:         }\n139:         noOfRatings > 250 -> {\n140:             \"250+\"\n141:         }\n142:         noOfRatings > 300 -> {\n143:             \"300+\"\n144:         }\n145:         noOfRatings > 350 -> {\n146:             \"350+\"\n147:         }\n148:         noOfRatings > 400 -> {\n149:             \"400+\"\n150:         }\n151:         noOfRatings > 450 -> {\n152:             \"450+\"\n153:         }\n154:         noOfRatings > 500 -> {\n155:             \"500+\"\n156:         }\n157:         noOfRatings > 550 -> {\n158:             \"550+\"\n159:         }\n160:         noOfRatings > 600 -> {\n161:             \"600+\"\n162:         }\n163:         noOfRatings > 650 -> {\n164:             \"650+\"\n165:         }\n166:         noOfRatings > 700 -> {\n167:             \"700+\"\n168:         }\n169:         noOfRatings > 750 -> {\n170:             \"750+\"\n171:         }\n172:         noOfRatings > 800 -> {\n173:             \"800+\"\n174:         }\n175:         else -> {\n176:             \"1000+\"\n177:         }\n178:     }\n179: }\n180: \n181: \n182: \n\n(End of file - total 182 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRAN