ion.layout.*\n33: import androidx.compose.foundation.lazy.LazyColumn\n34: import androidx.compose.foundation.lazy.LazyListState\n35: import androidx.compose.foundation.lazy.LazyRow\n36: import androidx.compose.foundation.shape.CircleShape\n37: import androidx.compose.foundation.shape.RoundedCornerShape\n38: import androidx.compose.material.AppBarDefaults.ContentPadding\n39: import androidx.compose.material.BottomNavigationItem\n40: import androidx.compose.material.Card\n41: import androidx.compose.material.Icon\n42: import androidx.compose.material.Text\n43: import androidx.compose.material.icons.Icons\n44: import androidx.compose.material.icons.filled.Favorite\n45: import androidx.compose.material.icons.filled.Home\n46: import androidx.compose.material.icons.outlined.LocationOn\n47: import androidx.compose.runtime.Composable\n48: import androidx.compose.runtime.getValue\n49: import androidx.compose.runtime.remember\n50: import androidx.compose.ui.Alignment\n51: import androidx.compose.ui.Modifier\n52: import androidx.compose.ui.draw.alpha\n53: import androidx.compose.ui.draw.clip\n54: import androidx.compose.ui.draw.shadow\n55: import androidx.compose.ui.graphics.Color\n56: import androidx.compose.ui.graphics.toArgb\n57: import androidx.compose.ui.layout.ContentScale\n58: import androidx.compose.ui.platform.LocalContext\n59: import androidx.compose.ui.res.painterResource\n60: import androidx.compose.ui.res.stringResource\n61: import androidx.compose.ui.text.font.FontFamily\n62: import androidx.compose.ui.text.font.FontWeight\n63: import androidx.compose.ui.unit.dp\n64: import androidx.compose.ui.unit.sp\n65: import androidx.hilt.navigation.compose.hiltViewModel\n66: import androidx.navigation.NavGraph.Companion.findStartDestination\n67: import androidx.navigation.NavHostController\n68: import androidx.navigation.compose.currentBackStackEntryAsState\n69: import com.example.foodike.R\n70: import com.example.foodike.domain.model.Advertisement\n71: import com.example.foodike.domain.model.FoodItem\n72: import com.example.foodike.domain.model.Restaurant\n73: import com.example.foodike.presentation.components.RestaurantCard\n74: import com.example.foodike.presentation.components.SearchBar\n75: import com.example.foodike.presentation.home.components.AdSection\n76: import com.example.foodike.presentation.home.components.ChipBar\n77: import com.example.foodike.presentation.home.components.FavouriteSection\n78: import com.example.foodike.presentation.home.components.FoodikeBottomNavigation\n79: import com.example.foodike.presentation.home.components.GreetingSection\n80: import com.example.foodike.presentation.home.components.MainSection\n81: import com.example.foodike.presentation.home.components.RecommendedSection\n82: import com.example.foodike.presentation.home.components.ThankYouSection\n83: import com.example.foodike.presentation.home.components.TopSection\n84: import com.example.foodike.presentation.util.Screen\n85: import java.util.*\n86: \n87: \n88: @Composable\n89: fun Home(\n90:     scrollState: LazyListState,\n91:     navController: NavHostController,\n92:     viewModel: HomeViewModel = hiltViewModel()\n93: ) {\n94:     val context = LocalContext.current as Activity\n95: \n96:     context.window.statusBarColor = Color.Gray.toArgb()\n97:     context.window.navigationBarColor = Color.White.toArgb()\n98: \n99:     val homeScreenState by viewModel.homeScreenState\n100: \n101: \n102:     LazyColumn(\n103:         modifier =\n104:         Modifier\n105:             .fillMaxWidth(),\n106:         state = scrollState,\n107:         verticalArrangement = Arrangement.Center,\n108:         horizontalAlignment = Alignment.Start\n109:     ) {\n110:         item {\n111:             Spacer(modifier = Modifier.height(8.dp))\n112:             TopSection(navController = navController)\n113:             Spacer(modifier = Modifier.height(8.dp))\n114:         }\n115:         item {\n116:             GreetingSection()\n117:             Spacer(modifier = Modifier.height(24.dp))\n118:         }\n119:         item {\n120:             Column(\n121:                 modifier = Modifier.padding(8.dp, 0.dp)\n122:             ) {\n123:                 SearchBar()\n124:             }\n125:             Spacer(modifier = Modifier.height(16.dp))\n126:         }\n127:         item {\n128:             AdSection(homeScreenState.adsList)\n129:             Spacer(modifier = Modifier.height(16.dp))\n130:         }\n131:         item {\n132:             RecommendedSection(homeScreenState.foodList)\n133:             Spacer(modifier = Modifier.height(16.dp))\n134:         }\n135:         if (homeScreenState.likedRestaurantList.isNotEmpty()) {\n136:             item {\n137:                 FavouriteSection(homeScreenState.likedRestaurantList) {\n138:                     viewModel.onEvent(HomeScreenEvent.SelectRestaurant(it) {\n139:                         navController.navigate(Screen.RestaurantDetails.route)\n140:                     })\n141:                 }\n142:                 Spacer(modifier = Modifier.height(16.dp))\n143:             }\n144:         }\n145:         item {\n146:             Spacer(modifier = Modifier.height(8.dp))\n147:             ChipBar()\n148:         }\n149:         item {\n150:             MainSection()\n151:         }\n152:         items(homeScreenState.restaurantList.size) {\n153:             RestaurantCard(\n154:                 restaurant = homeScreenState.restaurantList[it],\n155:                 modifier = Modifier\n156:                     .clip(RoundedCornerShape(8.dp))\n157:                     .clickable {\n158:                         viewModel.onEvent(HomeScreenEvent.SelectRestaurant(homeScreenState.restaurantList[it]) {\n159:                             navController.navigate(Screen.RestaurantDetails.route)\n160:                         })\n161:                     }\n162:             )\n163:         }\n164:         item {\n165:             ThankYouSection()\n166:         }\n167: \n168:     }\n169: \n170: }\n171: \n172: \n173: \n174: \n175: \n176: \n177: \n178: \n179: \n180: \n181: \n\n(End of file - total 181 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER","truncated":false,"loaded":[]},"title":"..\\..\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\home\\HomeScreen.kt","time":{"start":1782353054037,"end":1782353054044}},"id":"prt_efc854916001NeNCXvtBhR7QL5","sessionID":"ses_1037cdc73ffepuj7BMO8RquXkG","messageID":"msg_efc84de7c001kqIjsNTsG6LvHr"}}
