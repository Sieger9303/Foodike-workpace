:     return matrix_defaulted_addition(normalized) if kind == \"matrix\" else platform_defaulted_addition(normalized)\n615: \n616: \n617: def matrix_parity_errors(entry: dict[str, Any]) -> list[str]:\n618:     status = str(entry.get(\"status\") or \"\").strip().lower()\n619:     parity = str(entry.get(\"parityLevel\") or \"\").strip().lower()\n620:     if status == \"implemented\" and parity != \"equivalent\":\n621:         return [\"implemented rows must use parityLevel `equivalent`.\"]\n622:     if status == \"implemented-simplified\" and parity != \"simplified\":\n623:         return [\"implemented-simplified rows must use parityLevel `simplified`.\"]\n624:     if status == \"platform-replaced\" and parity != \"platform-replaced\":\n625:         return [\"platform-replaced rows must use parityLevel `platform-replaced`.\"]\n626:     if status == \"deferred\" and parity != \"deferred\":\n627:         return [\"deferred rows must use parityLevel `deferred`.\"]\n628:     if status == \"not-applicable\" and parity not in {\"not-applicable\", \"unverified\", \"\"}:\n629:         return [\"not-applicable rows must use parityLevel `not-applicable`, `unverified`, or empty.\"]\n630:     return []\n631: \n632: \n633: def validate_matrix_entry(entry: dict[str, Any]) -> list[str]:\n634:     problems: list[str] = []\n635:     feature_id = str(entry.get(\"featureId\") or \"\").strip()\n636:     status = str(entry.get(\"status\") or \"\").strip().lower()\n637:     importance = str(entry.get(\"importance\") or \"\").strip().lower()\n638:     if not feature_id:\n639:         problems.append(\"missing featureId\")\n640:     if status not in MATRIX_STATUSES:\n641:         problems.append(f\"invalid status `{status}`\")\n642:     parity = str(entry.get(\"parityLevel\") or \"\").strip().lower()\n643:     if parity not in MATRIX_PARITY_LEVELS:\n644:         problems.append(f\"invalid parityLevel `{parity}`\")\n645:     problems.extend(matrix_parity_errors(entry))\n646: \n647:     important = importance in {\"critical\", \"high\"}\n648:     if important and status in MATRIX_IMPLEMENTED_STATUSES:\n649:         if not has_text_or_list(entry.get(\"sourceBehavior\")) and not has_text_or_list(entry.get(\"sourceEvidence\")):\n650:             problems.append(\"closed critical/high rows require sourceBehavior or sourceEvidence\")\n651:         if not has_text(entry.get(\"targetBehavior\")):\n652:             problems.append(\"closed critical/high rows require targetBehavior\")\n653:         if not has_text_or_list(entry.get(\"verificationEvidence\")) and not has_text_or_list(entry.get(\"tests\")):\n654:             problems.append(\"closed critical/high rows require verificationEvidence or tests\")\n655:         if not has_text_or_list(entry.get(\"targetEndpoints\")) and not has_text_or_list(entry.get(\"tests\")):\n656:             problems.append(\"closed critical/high rows require targetEndpoints or tests\")\n657:     if important and status == \"implemented-simplified\":\n658:         if not has_text(entry.get(\"notes\")) and not has_text(entry.get(\"targetFallback\")):\n659:             problems.append(\"implemented-simplified critical/high rows require notes or targetFallback\")\n660:     if important and status == \"deferred\":\n661:         missing = [field for field in MATRIX_DEFERRED_REQUIRED_FIELDS if not has_text_or_list(entry.get(field))]\n662:         if missing:\n663:             problems.append(\"deferred critical/high rows missing \" + \", \".join(missing))\n664:     if important and status == \"not-applicable\" and not has_text(entry.get(\"notes\")):\n665:         problems.append(\"not-applicable critical/high rows require notes\")\n666:     return problems\n667: \n668: \n669: def validate_platform_entry(entry: dict[str, Any]) -> list[str]:\n670:     problems: list[str] = []\n671:     capability_id = str(entry.get(\"capabilityId\") or \"\").strip()\n672:     status = str(entry.get(\"status\") or \"\").strip().lower()\n673:     importance = str(entry.get(\"importance\") or \"\").strip().lower()\n674:     if not capability_id:\n675:         problems.append(\"missing capabilityId\")\n676:     if status not in PLATFORM_CAPABILITY_STATUSES:\n677:         problems.append(f\"invalid status `{status}`\")\n678: \n679:     important = importance in {\"critical\", \"high\"}\n680:     if important and (status in PLATFORM_CAPABILITY_IMPLEMENTED_STATUSES or status == \"deferred\"):\n681:         if not has_text_or_list(entry.get(\"targetCapabilitySearch\")):\n682:             problems.append(\"resolved/deferred critical/high capabilities require targetCapabilitySearch\")\n683:     if important and status in PLATFORM_CAPABILITY_IMPLEMENTED_STATUSES:\n684:         if not has_text_or_list(entry.get(\"targetApiOrLibrary\")):\n685:             problems.append(\"implemented critical/high capabilities require targetApiOrLibrary\")\n686:         if not has_text(entry.get(\"targetStrategy\")):\n687:             problems.append(\"implemented critical/high capabilities require targetStrategy\")\n688:         if status in {\"verified-direct\", \"platform-replaced\"} and not has_text_or_list(entry.get(\"targetEndpoints\")):\n689:             problems.append(\"verified-direct/platform-replaced critical/high capabilities require targetEndpoints\")\n690:         if not has_text_or_list(entry.get(\"tests\")) and not has_text(entry.get(\"notes\")):\n691:             problems.append(\"implemented critical/high capabilities require tests or notes\")\n692:     if important and status == \"deferred\":\n693:         missing = [\n694:             field\n695:             for field in PLATFORM_CAPABILITY_DEFERRED_REQUIRED_FIELDS\n696:             if not has_text_or_list(entry.get(field))\n697:         ]\n698:         if missing:\n699:             problems.append(\"deferred critical/high capabilities missing \" + \", \".join(missing))\n700:     if important and status == \"not-applicable\" and not has_text(entry.get(\"notes\")):\n701:         problems.append(\"not-applicable critical/high capabilities require notes\")\n702:     return problems\n703: \n704: \n705: def validate_entry(kind: str, entry: dict[str, Any]) -> list[str]:\n706:     return validate_matrix_entry(entry) if kind == \"matrix\" else validate_platform_entry(entry)\n707: \n708: \n709: def render_markdown(kind: str, authority: dict[str, Any], max_files: int) -> str:\n710:     if kind == \"matrix\":\n711:         return source_coverage_matrix_markdown(authority, max_files)\n712:     return platform_capability_check_markdown(authority, max_files)\n713: \n714: \n715: def apply_patch_payload(\n716:     kind: str,\n717:     authority: dict[str, Any],\n718:     payload: dict[str, Any],\n719:     *,\n720:     context: PatchContext | None = None,\n721: ) -> dict[str, Any]:\n722:     normalized = validate_patch_payload(payload)\n723:     id_field = entry_id_field(kind)\n724:     before_counts = status_counts(kind, authority)\n725:     entries = authority[\"entries\"]\n726:     by_id = validate_authority_shape(kind, authority)\n727: \n728:     added_ids: list[str] = []\n729:     updated_ids: list[str] = []\n730:     touched_entries: list[dict[str, Any]] = []\n731: \n732:     for raw_addition in normalized[\"additions\"]:\n733:         addition = validate_addition(kind, raw_addition)\n734:         item_id = str(addition.get(id_field) or \"\").strip()\n735:         if item_id in by_id:\n736:             raise PatchError(f\"Cannot add duplicate {id_field} `{item_id}`.\")\n737:         problems = validate_entry(kind, addition)\n738:         if problems:\n739:             raise PatchError(f\"Addition `{item_id}` is invalid: \" + \"; \".join(problems))\n740:         entries.append(addition)\n741:         by_id[item_id] = addition\n742:         added_ids.append(item_id)\n743:         touched_entries.append(addition)\n744: \n745:     id_to_index = {str(entry.get(id_field)): index for index, entry in enumerate(entries) if isinstance(entry, dict)}\n746:     for raw_update in normalized[\"updates\"]:\n747:         if not isinstance(raw_update, dict):\n748:             raise PatchError(\"Every update must be an object.\")\n749:         item_id = str(raw_update.get(id_field) or \"\").strip()\n750:         if not item_id:\n751:             raise PatchError(f\"Every update must include `{id_field}`.\")\n752:         if item_id not in id_to_index:\n753:             raise PatchError(f\"Unknown {id_field} `{item_id}`.\")\n754:         entry = entries[id_to_index[item_id]]\n755:         if not isinstance(entry, dict):\n756:             raise PatchError(f\"Entry for `{item_id}` is not an object.\")\n757:         patch_entry(kind, entry, raw_update)\n758:         problems = validate_entry(kind, entry)\n759:         if problems:\n760:             raise PatchError(f\"Updated entry `{item_id}` is invalid: \" + \"; \".join(problems))\n761:         updated_ids.append(item_id)\n762:         touched_entries.append(entry)\n763: \n764:     validate_authority_shape(kind, authority)\n765:     if context is not None:\n766:         validate_contextual_entries(kind, touched_entries, context)\n767:     after_counts = status_counts(kind, authority)\n768:     authority[\"lastUpdatedBy\"] = \"source_coverage/patch_authority.py\"\n769:     authority[\"lastPatchedAt\"] = now_iso()\n770:     authority[\"lastPatchSummary\"] = {\n771:         \"kind\": kind,\n772:         \"updatedEntries\": len(updated_ids),\n773:         \"addedEntries\": len(added_ids),\n774:         \"updatedIds\": updated_ids,\n775:         \"addedIds\": added_ids,\n776:         \"statusCountsBefore\": dict(sorted(before_counts.items())),\n777:         \"statusCountsAfter\": dict(sorted(after_counts.items())),\n778:     }\n779:     return authority[\"lastPatchSummary\"]\n780: \n781: \n782: def validate_existing_authority(\n783:     kind: str,\n784:     authority: dict[str, Any],\n785:     *,\n786:     context: PatchContext | None = None,\n787: ) -> dict[str, Any]:\n788:     validate_authority_shape(kind, authority)\n789:     errors: list[dict[str, Any]] = []\n790:     id_field = entry_id_field(kind)\n791:     contextual_entries: list[dict[str, Any]] = []\n792:     for entry in authority.get(\"entries\", []):\n793:         if not isinstance(entry, dict):\n794:             continue\n795:         contextual_entries.append(entry)\n796:         problems = validate_entry(kind, entry)\n797:         if problems:\n798:             errors.append({id_field: entry.get(id_field, \"\"), \"problems\": problems})\n799:     if errors:\n800:         shown = \"; \".join(f\"{item.get(id_field)}: {', '.join(item['problems'])}\" for item in errors[:20])\n801:         raise PatchError(f\"Authority validation failed for {len(errors)} entrie(s): {shown}\")\n802:     if context is not None:\n803:         validate_contextual_entries(kind, contextual_entries, context)\n804:     return {\n805:         \"kind\": kind,\n806:         \"validatedEntries\": len(authority.get(\"entries\", [])),\n807:         \"statusCounts\": dict(sorted(status_counts(kind, authority).items())),\n808:     }\n809: \n810: \n811: def print_summary(summary: dict[str, Any], *, dry_run: bool, markdown_path: Path | None) -> None:\n812:     action = \"Validated\" if \"validatedEntries\" in summary else \"Patched\"\n813:     suffix = \" (dry run)\" if dry_run else \"\"\n814:     print(f\"{action} {summary.get('kind', 'authority')} authority{suffix}.\")\n815:     if \"validatedEntries\" in summary:\n816:         print(f\"Validated entries: {summary.get('validatedEntries', 0)}\")\n817:     else:\n818:         print(f\"Updated entries: {summary.get('updatedEntries', 0)}\")\n819:         print(f\"Added entries: {summary.get('addedEntries', 0)}\")\n820:         ids = list(summary.get(\"updatedIds\", [])) + list(summary.get(\"addedIds\", []))\n821:         if ids:\n822:             print(\"Touched ids: \" + \", \".join(str(item) for item in ids[:20]))\n823:     counts = summary.get(\"statusCountsAfter\") or summary.get(\"statusCounts\")\n824:     if isinstance(counts, dict):\n825:         print(\"Status counts: \" + \", \".join(f\"{key}={value}\" for key, value in sorted(counts.items())))\n826:     if markdown_path is not None and not dry_run:\n827:         print(f\"Markdown synced: {markdown_path}\")\n828: \n829: \n830: def main() -> int:\n831:     args = parse_args()\n832:     authority_path = expand_path(args.authority)\n833:     patch_path = expand_path(args.patch) if args.patch else None\n834:     summary_path = expand_path(args.summary_json) if args.summary_json else None\n835:     if authority_path is None:\n836:         raise SystemExit(\"--authority is required\")\n837:     kind = infer_kind(args.kind, authority_path)\n838:     context = patch_context_from_args(args)\n839:     authority_raw = load_strict_json(authority_path, \"authority\")\n\n(Showing lines 580-839 of 873. Use offset=840 to continue.)\n</content>","metadata":{"preview":"        \"targetStrategyHint\": \"\",\n        \"minimumParity\": \"\",\n        \"requiredTests\": [],\n        \"allowedDeferredReasons\": [],\n        \"targetCapabilitySearch\": [],\n        \"targetApiOrLibrary\": \"\",\n        \"targetStrategy\": \"\",\n        \"targetEndpoints\": [],\n        \"tests\": [],\n        \"sdkDeclarationEvidence\": [],\n        \"cangjieCallableEvidence\": [],\n        \"discoveryOnlyEvidence\": [],\n        \"compileProbeEvidence\": [],\n        \"preResolutionDecision\": \"\",\n        \"phaseCapabilityResolution\": \"\",\n        \"blocker\": \"\",\n        \"targetFallback\": \"\",\n        \"futureCompletionPath\": \"\",\n        \"notes\": \"\",\n    }","truncated":true,"loaded":[]},"title":"..\\..\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\patch_authority.py","time":{"start":1782353796944,"end":1782353796949}},"id":"prt_efc909ef50016oEOyGAJMXlHCv","sessionID":"ses_1037cdc73ffepuj7BMO8RquXkG","messageID":"msg_efc907071001g1Moq351sFvLHS"}}
