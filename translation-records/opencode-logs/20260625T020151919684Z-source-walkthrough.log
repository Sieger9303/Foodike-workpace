t/RichText/示例代码.md\"\r\n      ],\r\n      \"source\": null,\r\n      \"doc_kind\": null\r\n    },\r\n    {\r\n      \"example_id\": \"example.harmonyos-6-1-8k-api-arkui-cj-cj-text-input-span-span-md\",\r\n      \"title\": \"示例代码\",\r\n      \"score\": 199.844,\r\n      \"summary\": \"decoration、textCase、letterSpacing属性接口使用示例。 <!--run--> package ohos_app_cangjie_entry import kit.ArkUI.* import ohos.arkui.state_macro_manage.* import std.collection.* @Entry @Component\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/API/arkui-cj/cj-text-input-span/Span/示例代码.md\"\r\n      ],\r\n      \"source\": null,\r\n      \"doc_kind\": null\r\n    },\r\n    {\r\n      \"example_id\": \"example.harmonyos-6-1-8k-api-arkui-cj-cj-text-input-text-text-1-md\",\r\n      \"title\": \"示例代码\",\r\n      \"score\": 199.844,\r\n      \"summary\": \"开发者在ArkUI中使用Text组件展示文本，需要设置文本样式、管理状态、处理长按/右键/选择菜单，并在滚动布局中展示效果。\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/API/arkui-cj/cj-text-input-text/Text/示例代码/示例代码_1.md\"\r\n      ],\r\n      \"source\": null,\r\n      \"doc_kind\": null\r\n    }\r\n  ],\r\n  \"docs\": [\r\n    {\r\n      \"doc_id\": \"doc.harmonyos-6-1-8k-api-arkdata-cj-apis-preferences-ohosdatapreferences-class-preferences-func-putstring-preferen-e22bc770\",\r\n      \"title\": \"func put(String, PreferencesValueType)\",\r\n      \"score\": 182.957,\r\n      \"summary\": \"public func put(key: String, value: PreferencesValueType): Unit **功能：** 将数据写入缓存的Preferences实例中，可通过[flush](#func-flush)将Preferences实例持久化。 **系统能力：** SystemCapability.DistributedDataManager.Preferences.Core\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/API/ArkData/cj-apis-preferences/ohosdatapreferences用户首选项/class_Preferences/func_putString_Preferen_e22bc770.md\"\r\n      ],\r\n      \"source\": \"harmonyos-6.1-8k\",\r\n      \"doc_kind\": \"reference\"\r\n    },\r\n    {\r\n      \"doc_id\": \"doc.harmonyos-6-1-8k-guide-database-cj-data-persistence-by-preferences-5more-adada06c\",\r\n      \"title\": \"通过用户首选项实现数据持久化\",\r\n      \"score\": 177.383,\r\n      \"summary\": \"用户首选项为应用提供Key-Value键值型的数据处理能力，支持应用持久化轻量级数据，并对其修改和查询。当用户希望有一个全局唯一存储的地方，可以采用用户首选项来进行存储。Preferences会将该数据缓存在内存中。当用户读取时，能够快速从内存中获取数据。当需要持久化时，可以使用flush接口将内存中的数据写入持久化文件中。Preferences会随着存放的数据量越多而导致应用占用的内存\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/Guide/database/cj-data-persistence-by-preferences/通过用户首选项实现数据持久化/通过用户首选项实现数据持久化_5more_adada06c.md\"\r\n      ],\r\n      \"source\": \"harmonyos-6.1-8k\",\r\n      \"doc_kind\": \"article\"\r\n    },\r\n    {\r\n      \"doc_id\": \"doc.harmonyos-6-1-8k-api-arkdata-cj-apis-preferences-ohosdatapreferences-ohosdatapreferenc-5more-588a4e57\",\r\n      \"title\": \"ohos.data.preferences（用户首选项）\",\r\n      \"score\": 176.347,\r\n      \"summary\": \"用户首选项为应用提供Key-Value键值型的数据处理能力，支持应用持久化轻量级数据，并对其修改和查询。数据存储形式为键值对，键的类型为字符串型，值的存储数据类型包括数字型、字符型、布尔型以及这3种类型的数组类型。\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/API/ArkData/cj-apis-preferences/ohosdatapreferences用户首选项/ohosdatapreferenc_5more_588a4e57.md\"\r\n      ],\r\n      \"source\": \"harmonyos-6.1-8k\",\r\n      \"doc_kind\": \"article\"\r\n    },\r\n    {\r\n      \"doc_id\": \"doc.harmonyos-6-1-8k-guide-database-cj-data-persistence-by-preferences-overview-2\",\r\n      \"title\": \"通过用户首选项实现数据持久化\",\r\n      \"score\": 167.33,\r\n      \"summary\": \"本目录主要介绍如何利用用户首选项在HarmonyOS应用中实现轻量级数据的持久化存储。内容涵盖了Key-Value键值型存储机制、核心API使用规范、数据类型限制及并发安全风险等关键概念。此外，还提供了基于仓颉语言的完整开发教程，包括数据读写、持久化操作及监听机制。该文档适合需要保存用户个性化设置或轻量级数据的应用开发者阅读，要求具备一定的仓颉开发基础。 - 你想了解基础概念与运作机制？ → 通过用户首选项实现数据持久化_5more_a\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/Guide/database/cj-data-persistence-by-preferences/通过用户首选项实现数据持久化/.overview.md\"\r\n      ],\r\n      \"source\": \"harmonyos-6.1-8k\",\r\n      \"doc_kind\": \"overview\"\r\n    },\r\n    {\r\n      \"doc_id\": \"doc.harmonyos-6-1-8k-guide-database-cj-data-persistence-by-preferences-abstract-2\",\r\n      \"title\": \".abstract\",\r\n      \"score\": 167.202,\r\n      \"summary\":