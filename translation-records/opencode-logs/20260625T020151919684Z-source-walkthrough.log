ion.layout.*\n32: import androidx.compose.foundation.lazy.LazyRow\n33: import androidx.compose.foundation.lazy.items\n34: import androidx.compose.foundation.selection.toggleable\n35: import androidx.compose.material.MaterialTheme\n36: import androidx.compose.material.Surface\n37: import androidx.compose.material.Text\n38: import androidx.compose.runtime.Composable\n39: import androidx.compose.runtime.MutableState\n40: import androidx.compose.runtime.mutableStateOf\n41: import androidx.compose.runtime.remember\n42: import androidx.compose.ui.Modifier\n43: import androidx.compose.ui.graphics.Color\n44: import androidx.compose.ui.unit.dp\n45: import com.example.foodike.presentation.home.util.Filter\n46: import com.example.foodike.presentation.home.util.getAllTags\n47: import com.example.foodike.presentation.home.util.getTag\n48: \n49: \n50: @Composable\n51: fun ChipBar() {\n52:     val selectedFilter: MutableState<Filter?> = remember { mutableStateOf(null) }\n53: \n54:     ChipGroup(\n55:         filters = getAllTags(),\n56:         selectedFilter = selectedFilter.value,\n57:         onSelectedChanged = {\n58:             if (selectedFilter.value == getTag(it)) {\n59:                 selectedFilter.value = null\n60:             } else {\n61:                 selectedFilter.value = getTag(it)\n62:             }\n63:         }\n64:     )\n65: \n66: }\n67: \n68: \n69: @Composable\n70: fun Chip(\n71:     name: String,\n72:     isSelected: Boolean,\n73:     onSelectionChanged: (String) -> Unit,\n74: ) {\n75:     Surface(\n76:         modifier = Modifier\n77:             .border(BorderStroke(1.dp, Color.Black.copy(0.3f)), MaterialTheme.shapes.medium)\n78:             ,\n79:         shape = MaterialTheme.shapes.medium,\n80:         color = if (isSelected) MaterialTheme.colors.primary else Color.White\n81:     ) {\n82:         Row(modifier = Modifier\n83:             .toggleable(\n84:                 value = isSelected,\n85:                 onValueChange = {\n86:                     onSelectionChanged(name)\n87:                 }\n88:             )\n89:         ) {\n90:             Text(\n91:                 text = name,\n92:                 style = MaterialTheme.typography.body2,\n93:                 color = if (isSelected) Color.White else Color.Black,\n94:                 modifier = Modifier.padding(8.dp)\n95:             )\n96:         }\n97:     }\n98: }\n99: \n100: @Composable\n101: fun ChipGroup(\n102:     filters: List<Filter> = getAllTags(),\n103:     selectedFilter: Filter? = null,\n104:     onSelectedChanged: (String) -> Unit = {},\n105: ) {\n106:         LazyRow(\n107:             contentPadding = PaddingValues(\n108:                 start = 8.dp,\n109:                 end = 8.dp\n110:             ),\n111:             horizontalArrangement = Arrangement.spacedBy(8.dp)\n112:         ) {\n113:             items(filters) {\n114:                 Chip(\n115:                     name = it.value,\n116:                     isSelected = selectedFilter == it,\n117:                     onSelectionChanged = {\n118:                         onSelectedChanged(it)\n119:                     },\n120:                 )\n121:             }\n122: \n123:     }\n124: }\n125: \n\n(End of file - total 125 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS