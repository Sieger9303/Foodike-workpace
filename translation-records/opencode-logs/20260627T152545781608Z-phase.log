Preferences\n32: import androidx.datastore.preferences.core.booleanPreferencesKey\n33: import androidx.datastore.preferences.core.edit\n34: import androidx.datastore.preferences.preferencesDataStore\n35: import com.example.foodike.domain.repository.LoginRepository\n36: import kotlinx.coroutines.flow.Flow\n37: import kotlinx.coroutines.flow.map\n38: \n39: \n40: class LoginRepositoryImpl(context: Context) : PrefsDataStore(context = context, PREF_LOGIN_STATE), LoginRepository  {\n41: \n42: \n43:     companion object {\n44:         const val PREF_LOGIN_STATE = \"user_login_state_pref\"\n45:         private val LOGIN_STATE_KEY = booleanPreferencesKey(\"user_login_state\")\n46: \n47:     }\n48: \n49: \n50:     override val loginState: Flow<Boolean>\n51:         get() = mDataStore.data.map { preferences ->\n52:             val uiMode = preferences[LOGIN_STATE_KEY] ?: false\n53:             uiMode\n54:         }\n55: \n56:     override suspend fun toggleLoginState() {\n57:         mDataStore.edit { preferences ->\n58:             val loginState = preferences[LOGIN_STATE_KEY] ?: false\n59:             preferences[LOGIN_STATE_KEY] = !loginState\n60:         }\n61:     }\n62: \n63: \n64: \n65: \n66: }\n67: \n68: abstract class PrefsDataStore(context: Context, fileName: String) {\n69:     private val Context.dataStore: DataStore<Preferences> by preferencesDataStore(fileName)\n70:     val mDataStore: DataStore<Preferences> = context.dataStore\n71: }\n\n(End of file - total 71 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Softw