ze(28)\n376:             Text(this.routeSummary(this.currentRoute))\n377:                 .fontSize(16)\n378:                 .textAlign(TextAlign.Center)\n379:                 .width(86.percent)\n380: \n381:             if (this.currentRoute == routePath(RouteId.Home) || this.currentRoute == routePath(RouteId.History)) {\n382:                 Button(if (this.isShellAtTop) { \"Simulate Scrolled Content\" } else { \"Return To Top\" })\n383:                     .onClick({ _ =>\n384:                         let shellState = this.shellState()\n385:                         shellState.setTopState(!shellState.isAtTop)\n386:                         this.applyShellState(shellState)\n387:                     })\n388:             }\n389: \n390:             Button(primaryActionLabel(this.currentRoute))\n391:                 .backgroundColor(foodikeThemePrimaryColor)\n392:                 .fontColor(Color.White)\n393:                 .onClick({ _ =>\n394:                     this.applyShellCommand(ShellCommand.PrimaryAction)\n395:                 })\n396: \n397:             if (this.showBottomShell(this.currentRoute)) {\n398:                 Row(space: 12) {\n399:                     Button(stringHome)\n400:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HomeTab) })\n401:                     Button(stringCart)\n402:                         .onClick({ _ => this.applyShellCommand(ShellCommand.CartAction) })\n403:                     Button(stringHistory)\n404:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HistoryTab) })\n405:                 }\n406:             }\n407:         }\n408:         .width(100.percent)\n409:         .height(100.percent)\n410:         .justifyContent(FlexAlign.Center)\n411:         .alignItems(HorizontalAlign.Center)\n412:         .padding(top: 24, right: 24, bottom: 24, left: 24)\n413:     }\n414: \n415:     func build() {\n416:         if (this.currentRoute == routePath(RouteId.Onboarding)) {\n4