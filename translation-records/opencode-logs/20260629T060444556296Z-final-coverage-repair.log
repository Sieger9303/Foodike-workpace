{"type":"tool_use","timestamp":1782713223204,"sessionID":"ses_0ee051056ffeIDEcvyWoDfDNCb","part":{"type":"tool","tool":"read","callID":"call_cagmd7TercrvgfEwi2kHOTxe","state":{"status":"completed","input":{"filePath":"D:\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\patch_authority.py","limit":200,"offset":480},"output":"<path>D:\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\patch_authority.py</path>\n<type>file</type>\n<content>\n480: def validate_patch_payload(payload: Any) -> dict[str, Any]:\n481:     if not isinstance(payload, dict):\n482:         raise PatchError(\"Patch payload must be a JSON object.\")\n483:     allowed = {\"schemaVersion\", \"purpose\", \"updates\", \"add\", \"additions\"}\n484:     unknown = sorted(set(payload) - allowed)\n485:     if unknown:\n486:         raise PatchError(f\"Patch payload has unknown top-level field(s): {', '.join(unknown)}.\")\n487:     updates = payload.get(\"updates\", [])\n488:     additions = payload.get(\"add\", payload.get(\"additions\", []))\n489:     if not isinstance(updates, list):\n490:         raise PatchError(\"Patch payload `updates` must be a list.\")\n491:     if not isinstance(additions, list):\n492:         raise PatchError(\"Patch payload `add`/`additions` must be a list.\")\n493:     if not updates and not additions:\n494:         raise PatchError(\"Patch payload must contain at least one update or addition.\")\n495:     return {\"updates\": updates, \"additions\": additions}\n496: \n497: \n498: def field_sets(kind: str) -> tuple[set[str], set[str], set[str], set[str]]:\n499:     if kind == \"matrix\":\n500:         return MATRIX_UPDATE_FIELDS, MATRIX_ADD_FIELDS, MATRIX_LIST_FIELDS, MATRIX_TEXT_FIELDS\n501:     return PLATFORM_UPDATE_FIELDS, PLATFORM_ADD_FIELDS, PLATFORM_LIST_FIELDS, PLATFORM_TEXT_FIELDS\n502: \n503: \n504: def object_fields(kind: str) -> set[str]:\n505:     return MATRIX_OBJECT_FIELDS if kind == \"matrix\" else PLATFORM_OBJECT_FIELDS\n506: \n507: \n508: def default_object_value(kind: str, field: str) -> dict[str, Any]:\n509:     if kind == \"matrix\" and field == COVERAGE_FACTS_KEY:\n510:         return default_coverage_facts()\n511:     if kind == \"platform\" and field == CAPABILITY_FACTS_KEY:\n512:         return default_capability_facts()\n513:     return {}\n514: \n515: \n516: def validate_object_field(kind: str, field: str, value: Any) -> dict[str, Any]:\n517:     if not isinstance(value, dict):\n518:         raise PatchError(f\"Field `{field}` must be an object.\")\n519:     if field in {COVERAGE_FACTS_KEY, CAPABILITY_FACTS_KEY} and value.get(\"factsSource\") != \"agent\":\n520:         raise PatchError(f\"Field `{field}` updates must use factsSource `agent`.\")\n521:     strict = value.get(\"factsSource\") == \"agent\"\n522:     problems = (\n523:         validate_coverage_facts(value, strict=strict)\n524:         if kind == \"matrix\" and field == COVERAGE_FACTS_KEY\n525:         else validate_capability_facts(value, strict=strict)\n526:     )\n527:     if problems:\n528:         raise PatchError(f\"Field `{field}` has invalid structured facts: \" + \"; \".join(problems[:12]))\n529:     return copy.deepcopy(value)\n530: \n531: \n532: def validate_field_value(kind: str, field: str, value: Any, *, add_entry: bool = False) -> Any:\n533:     update_fields, add_fields, list_fields, text_fields = field_sets(kind)\n534:     allowed = add_fields if add_entry else update_fields\n535:     if field not in allowed:\n536:         raise PatchError(f\"Field `{field}` is not writable for {kind} authority patches.\")\n537:     if field in object_fields(kind):\n538:         return validate_object_field(kind, field, value)\n539:     if field in list_fields:\n540:         if not isinstance(value, list):\n541:             raise PatchError(f\"Field `{field}` must be a list.\")\n542:         return value\n543:     if field in text_fields:\n544:         if not isinstance(value, str):\n545:             raise PatchError(f\"Field `{field}` must be a string.\")\n546:         if field == \"status\":\n547:             return value.strip().lower()\n548:         if field == \"parityLevel\":\n549:             return value.strip().lower()\n550:         return value\n551:     if field in {\"riskTags\", \"keyClasses\", \"keyMethods\", \"androidIds\", \"dependencies\", \"sourcePaths\"}:\n552:         if not isinstance(value, list):\n553:             raise PatchError(f\"Field `{field}` must be a list.\")\n554:     elif field in {\"sourceEvidence\", \"requiredTargetCapabilitySearch\", \"requiredTests\", \"allowedDeferredReasons\"}:\n555:         if kind == \"platform\" and field != \"sourceEvidence\" and not isinstance(value, list):\n556:             raise PatchError(f\"Field `{field}` must be a list.\")\n557:         if kind == \"platform\" and field == \"sourceEvidence\" and not isinstance(value, list):\n558:             raise PatchError(\"Field `sourceEvidence` must be a list for platform additions.\")\n559:         if kind == \"matrix\" and field == \"sourceEvidence\" and not isinstance(value, str):\n560:             raise PatchError(\"Field `sourceEvidence` must be a string for matrix additions.\")\n561:     elif field in {\n562:         \"featureId\",\n563:         \"featureName\",\n564:         \"sourcePath\",\n565:         \"importance\",\n566:         \"category\",\n567:         \"featurePoint\",\n568:         \"capabilityId\",\n569:         \"capabilityName\",\n570:         \"sourceEvidenceSummary\",\n571:         \"targetStrategyHint\",\n572:         \"minimumParity\",\n573:     }:\n574:         if not isinstance(value, str):\n575:             raise PatchError(f\"Field `{field}` must be a string.\")\n576:     return value\n577: \n578: \n579: def patch_entry(kind: str, entry: dict[str, Any], update: dict[str, Any]) -> None:\n580:     allowed_ops = {\"featureId\", \"capabilityId\", \"set\", \"append\", \"remove\", \"unset\"}\n581:     unknown = sorted(set(update) - allowed_ops)\n582:     if unknown:\n583:         raise PatchError(f\"Update for `{entry.get(entry_id_field(kind), '')}` has unknown operation field(s): {', '.join(unknown)}.\")\n584: \n585:     set_values = ensure_object(update.get(\"set\"), \"set\")\n586:     append_values = ensure_object(update.get(\"append\"), \"append\")\n587:     remove_values = ensure_object(update.get(\"remove\"), \"remove\")\n588:     unset_fields = ensure_list(update.get(\"unset\"), \"unset\")\n589:     _, _, list_fields, text_fields = field_sets(kind)\n590: \n591:     for field, value in set_values.items():\n592:         entry[field] = validate_field_value(kind, field, value)\n593: \n594:     for field, values in append_values.items():\n595:         if field not in list_fields:\n596:             raise PatchError(f\"Append is allowed only for list fields; `{field}` is not appendable.\")\n597:         values = validate_field_value(kind, field, values)\n598:         existing = entry.get(field, [])\n599:         if not isinstance(existing, list):\n600:             raise PatchError(f\"Cannot append to `{field}` because the current value is not a list.\")\n601:         entry[field] = append_unique(existing, values)\n602: \n603:     for field, values in remove_values.items():\n604:         if field not in list_fields:\n605:             raise PatchError(f\"Remove is allowed only for list fields; `{field}` is not removable.\")\n606:         values = validate_field_value(kind, field, values)\n607:         existing = entry.get(field, [])\n608:         if not isinstance(existing, list):\n609:             raise PatchError(f\"Cannot remove from `{field}` because the current value is not a list.\")\n610:         remove_keys = {canonical_json(value) for value in values}\n611:         entry[field] = [value for value in existing if canonical_json(value) not in remove_keys]\n612: \n613:     update_fields, _, _, _ = field_sets(kind)\n614:     for field in unset_fields:\n615:         if not isinstance(field, str):\n616:             raise PatchError(\"Every `unset` item must be a string field name.\")\n617:         if field not in update_fields:\n618:             raise PatchError(f\"Field `{field}` is not writable for {kind} authority patches.\")\n619:         if field in list_fields:\n620:             entry[field] = []\n621:         elif field in object_fields(kind):\n622:             entry[field] = default_object_value(kind, field)\n623:         else:\n624:             entry[field] = \"\"\n625:         if field in text_fields and field == \"status\":\n626:             entry[field] = \"planned\"\n627: \n628: \n629: def matrix_defaulted_addition(entry: dict[str, Any]) -> dict[str, Any]:\n630:     defaults: dict[str, Any] = {\n631:         \"status\": \"planned\",\n632:         \"plannedPhase\": \"\",\n633:         \"sourceBehavior\": entry.get(\"featurePoint\", \"\"),\n634:         \"targetBehavior\": \"\",\n635:         \"verificationEvidence\": [],\n636:         \"parityLevel\": \"unverified\",\n637:         \"targetEndpoints\": [],\n638:         \"tests\": [],\n639:         \"notes\": \"\",\n640:         \"deferredReason\": \"\",\n641:         \"targetFallback\": \"\",\n642:         \"risk\": \"\",\n643:         \"futureCompletionPath\": \"\",\n644:         \"entryOrigin\": \"agent-curated\",\n645:         \"matrixSync\": {\n646:             \"status\": \"agent-curated\",\n647:             \"preserveActive\": True,\n648:             \"reason\": \"row was added through structured authority patch\",\n649:         },\n650:         \"riskTags\": [],\n651:         \"keyClasses\": [],\n652:         \"keyMethods\": [],\n653:         \"androidIds\": [],\n654:         \"dependencies\": [],\n655:         \"featurePoint\": \"\",\n656:         \"category\": \"\",\n657:         COVERAGE_FACTS_KEY: default_coverage_facts(),\n658:     }\n659:     return {**defaults, **entry}\n660: \n661: \n662: def platform_defaulted_addition(entry: dict[str, Any]) -> dict[str, Any]:\n663:     defaults: dict[str, Any] = {\n664:         \"status\": \"planned\",\n665:         \"plannedPhase\": \"\",\n666:         \"sourcePaths\": [],\n667:         \"sourceEvidence\": [],\n668:         \"requiredTargetCapabilitySearch\": [],\n669:         \"targetStrategyHint\": \"\",\n670:         \"minimumParity\": \"\",\n671:         \"requiredTests\": [],\n672:         \"allowedDeferredReasons\": [],\n673:         \"targetCapabilitySearch\": [],\n674:         \"targetApiOrLibrary\": \"\",\n675:         \"targetStrategy\": \"\",\n676:         \"targetEndpoints\": [],\n677:         \"tests\": [],\n678:         \"sdkDeclarationEvidence\": [],\n679:         \"cangjieCallableEvidence\": [],\n\n(Showing lines 480-679 of 973. Use offset=680 to continue.)\n</content>","metadata":{"preview":"def validate_patch_payload(payload: Any) -> dict[str, Any]:\n    if not isinstance(payload, dict):\n        raise PatchError(\"Patch payload must be a JSON object.\")\n    allowed = {\"schemaVersion\", \"purpose\", \"updates\", \"add\", \"additions\"}\n    unknown = sorted(set(payload) - allowed)\n    if unknown:\n        raise PatchError(f\"Patch payload has unknown top-level field(s): {', '.join(unknown)}.\")\n    updates = payload.get(\"updates\", [])\n    additions = payload.get(\"add\", payload.get(\"additions\", []))\n    if not isinstance(updates, list):\n        raise PatchError(\"Patch payload `updates` must be a list.\")\n    if not isinstance(additions, list):\n        raise PatchError(\"Patch payload `add`/`additions` must be a list.\")\n    if not updates and not additions:\n        raise PatchError(\"Patch payload must contain at least one update or addition.\")\n    return {\"updates\": updates, \"additions\": additions}\n\n\ndef field_sets(kind: str) -> tuple[set[str], set[str], set[str], set[str]]:\n    if kind == \"matrix\":","truncated":true,"loaded":[]},"title":"..\\..\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\patch_authority.py","time":{"start":1782713223196,"end":1782713223203}},"id":"prt_f11fd081400