load_strict_json(path: Path, label: str) -> Any:\n244:     try:\n245:         return json.loads(path.read_text(encoding=\"utf-8\"))\n246:     except FileNotFoundError as exc:\n247:         raise PatchError(f\"{label} does not exist: {path}\") from exc\n248:     except json.JSONDecodeError as exc:\n249:         raise PatchError(f\"{label} is not strict JSON: {exc}\") from exc\n250:     except OSError as exc:\n251:         raise PatchError(f\"Could not read {label}: {exc}\") from exc\n252: \n253: \n254: def phase_label(raw: str) -> str:\n255:     value = str(raw).strip()\n256:     if not value:\n257:         return \"\"\n258:     if value.isdigit():\n259:         return f\"phase-{int(value):02d}\"\n260:     return value\n\n(Showing lines 1-260 of 973. Use offset=261 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n\"\"\"Apply narrow, validated patches to agent-maintained coverage authorities.\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport copy\nimport json\nimport re\nimport sys\nfrom collections import Counter\nfrom dataclasses import dataclass\nfrom pathlib import Path\nfrom typing import Any\n\nif __package__ in (None, \"\"):\n    sys.path.insert(0, str(Path(__file__).resolve().parents[2]))\n    from shared.common import HelpFormatter, expand_path, now_iso, write_json, write_text  # type: ignore\n    from shared.source_coverage.constants import (  # type: ignore\n        MATRIX_DEFERRED_REQUIRED_FIELDS,","truncated":true,"loaded":[]},"title":"..\\..\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\patch_authority.py","time":{"start":1782713216452,"end":1782713216460}},"id":"prt_f11fcedc2001QnpJpRvodODsCp","sessionID":"ses_0ee051056ffeIDEcvyWoDfDNCb","messageID":"msg_f11fcd2e7001boPOsR5iowqL4F"}}
