{"type":"tool_use","timestamp":1782645625759,"sessionID":"ses_0f20b627effeDlfNbaYuhl9Ihz","part":{"type":"tool","tool":"read","callID":"call_NDq8ntANZPswHHn4l4B4cLZ1","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\detail\\detail_store.cj","limit":260,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\detail\\detail_store.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail\n2: \n3: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.homeContentRepository\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n6: import std.collection.ArrayList\n7: import std.random.Random\n8: \n9: public let detailStore = DetailStore()\n10: \n11: public class DetailStore {\n12:     private let contentRepository = homeContentRepository\n13:     private let sessionRepository = sessionRepository\n14: \n15:     public init() {}\n16: \n17:     public func loadDetailState(\n18:         recommendedExpanded: Bool,\n19:         nonVegExpanded: Bool,\n20:         vegExpanded: Bool\n21:     ): DetailPageState {\n22:         let restaurant = selectedRestaurant()\n23:         let menuItems = selectedMenuItems(restaurant)\n24:         return DetailPageState(\n25:             restaurant,\n26:             recommendedExpanded,\n27:             nonVegExpanded,\n28:             vegExpanded,\n29:             menuItems,\n30:             recommendedItems(menuItems),\n31:             sessionRepository.isRestaurantLiked(restaurant)\n32:         )\n33:     }\n34: \n35:     public func selectedRestaurant(): RestaurantData {\n36:         let restaurantName = sessionRepository.getSelectedRestaurantName()\n37:         if (restaurantName != \"\") {\n38:             match (contentRepository.getRestaurantByName(restaurantName)) {\n39:                 case Some(restaurant) => return restaurant\n40:                 case None => return contentRepository.getRestaurants()[0]\n41:             }\n42:         }\n43:         return contentRepository.getRestaurants()[0]\n44:     }\n45: \n46:     private func selectedMenuItems(restaurant: RestaurantData): ArrayList<DetailMenuItemData> {\n47:         let menuItems = sessionRepository.getMenuItems()\n48:         if (menuItems.size > 0) {\n49:             return menuItems\n50:         }\n51:         return sessionRepository.menuItemsForRestaurant(restaurant.name)\n52:     }\n53: \n54:     public func recommendedItems(menuItems: ArrayList<DetailMenuItemData>): ArrayList<DetailMenuItemData> {\n55:         let shuffled = ArrayList<DetailMenuItemData>(menuItems)\n56:         let rng = Random()\n57:         var index: Int64 = shuffled.size - 1\n58:         while (index > 0) {\n59:             let swapIndex = rng.nextInt64(index + 1)\n60:             let current = shuffled[index]\n61:             shuffled[index] = shuffled[swapIndex]\n62:             shuffled[swapIndex] = current\n63:             index -= 1\n64:         }\n65: \n66:         let recommended = ArrayList<DetailMenuItemData>([])\n67:         var recommendedIndex: Int64 = 0\n68:         for (item in shuffled) {\n69:             if (recommendedIndex >= 5) {\n70:                 break\n71:             }\n72:             recommended.add(item)\n73:             recommendedIndex += 1\n74:         }\n75:         return recommended\n76:     }\n77: \n78:     public func nonVegItems(menuItems: ArrayList<DetailMenuItemData>): ArrayList<DetailMenuItemData> {\n79:         let filtered = ArrayList<DetailMenuItemData>([])\n80:         for (item in menuItems) {\n81:             if (!item.menuItem.isVegetarian) {\n82:                 filtered.add(item)\n83:             }\n84:         }\n85:         return filtered\n86:     }\n87: \n88:     public func vegItems(menuItems: ArrayList<DetailMenuItemData>): ArrayList<DetailMenuItemData> {\n89:         let filtered = ArrayList<DetailMenuItemData>([])\n90:         for (item in menuItems) {\n91:             if (item.menuItem.isVegetarian) {\n92:                 filtered.add(item)\n93:             }\n94:         }\n95:         return filtered\n96:     }\n97: \n98:     public func incrementQuantity(item: DetailMenuItemData): Unit {\n99:         sessionRepository.incrementMenuItemQuantity(item.menuItem.dish)\n100:     }\n101: \n102:     public func decrementQuantity(item: DetailMenuItemData): Unit {\n103:         sessionRepository.decrementMenuItemQuantity(item.menuItem.dish)\n104:     }\n105: \n106:     public func totalSelectedItems(menuItems: ArrayList<DetailMenuItemData>): Int64 {\n107:         var total: Int64 = 0\n108:         for (item in menuItems) {\n109:             total += item.quantity\n110:         }\n111:         return total\n112:     }\n113: \n114:     public func shouldShowCartAction(menuItems: ArrayList<DetailMenuItemData>): Bool {\n115:         return totalSelectedItems(menuItems) > 0\n116:     }\n117: \n118:     public func toggleLiked(restaurant: RestaurantData, currentValue: Bool): Bool {\n119:         let nextValue = !currentValue\n120:         sessionRepository.setRestaurantLiked(restaurant, nextValue)\n121:         return nextValue\n122:     }\n123: \n124:     public func formatPrice(price: Float64): String {\n125:         return \"$${price}\"\n126:     }\n127: \n128:     public func formatRatingCount(ratingCount: Int64): String {\n129:         return \"${ratingCount} ratings\"\n130:     }\n131: \n132:     public func formatRestaurantMeta(restaurant: RestaurantData): String {\n133:         return \"${restaurant.rating}(${customerCount(restaurant.ratingCount)}) · ${restaurant.etaMinutes} Min · $${restaurant.averagePrice}\"\n134:     }\n135: \n136:     public func customerCount(ratingCount: Int64): String {\n137:         if (ratingCount >= 1000) {\n138:             return \"1000+\"\n139:         }\n140:         if (ratingCount >= 100) {\n141:             return \"${ratingCount}+\"\n142:         }\n143:         return \"${ratingCount}\"\n144:     }\n145: \n146:     public func session(): SessionRepository {\n147:         return sessionRepository\n148:     }\n149: }\n\n(End of file - total 149 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.homeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\nimport std.random.Random\n\npublic let detailStore = DetailStore()\n\npublic class DetailStore {\n    private let contentRepository = homeContentRepository\n    private let sessionRepository = sessionRepository\n\n    public init() {}\n\n    public func loadDetailState(\n        recommendedExpanded: Bool,\n        nonVegExpanded: Bool,\n        vegExpanded: Bool","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\detail\\detail_store.cj","time":{"start":1782645625742,"end":1782645625758}},"id":"prt_f0df5938c001kFlYCDnwcwWaUx","sessionID":"ses_0f20b627effeDlfNbaYuhl9Ihz","messageID":"msg_f0df5523b0013rUkjOy2zTBu16"}}
