compose.foundation.layout.Box\n32: import androidx.compose.foundation.layout.Column\n33: import androidx.compose.foundation.layout.Row\n34: import androidx.compose.foundation.layout.fillMaxSize\n35: import androidx.compose.foundation.layout.fillMaxWidth\n36: import androidx.compose.foundation.layout.padding\n37: import androidx.compose.foundation.lazy.LazyColumn\n38: import androidx.compose.material.ContentAlpha\n39: import androidx.compose.material.Divider\n40: import androidx.compose.material.FloatingActionButton\n41: import androidx.compose.material.Icon\n42: import androidx.compose.material.IconButton\n43: import androidx.compose.material.IconToggleButton\n44: import androidx.compose.material.MaterialTheme\n45: import androidx.compose.material.Text\n46: import androidx.compose.material.icons.Icons\n47: import androidx.compose.material.icons.filled.ArrowDropDown\n48: import androidx.compose.material.icons.filled.Favorite\n49: import androidx.compose.material.icons.filled.FavoriteBorder\n50: import androidx.compose.material.icons.outlined.ArrowBack\n51: import androidx.compose.material.icons.outlined.Share\n52: import androidx.compose.material.icons.outlined.ShoppingCart\n53: import androidx.compose.runtime.Composable\n54: import androidx.compose.runtime.getValue\n55: import androidx.compose.ui.Alignment\n56: import androidx.compose.ui.Modifier\n57: import androidx.compose.ui.draw.alpha\n58: import androidx.compose.ui.draw.rotate\n59: import androidx.compose.ui.graphics.Color\n60: import androidx.compose.ui.res.stringResource\n61: import androidx.compose.ui.text.font.FontWeight\n62: import androidx.compose.ui.text.style.TextOverflow\n63: import androidx.compose.ui.unit.dp\n64: import androidx.compose.ui.unit.sp\n65: import androidx.hilt.navigation.compose.hiltViewModel\n66: import androidx.navigation.NavHostController\n67: import com.example.foodike.R\n68: import com.example.foodike.presentation.details.components.MenuItemCard\n69: import com.example.foodike.presentation.details.components.RestaurantDetailCard\n70: import com.example.foodike.presentation.util.Screen\n71: \n72: @Composable\n73: fun RestaurantDetail(\n74:     navController: NavHostController,\n75:     viewModel: RestaurantDetailViewModel = hiltViewModel()\n76: ) {\n77: \n78:     val detailScreenState by viewModel.detailScreenState\n79: \n80: \n81:     val rotationState by animateFloatAsState(\n82:         targetValue = if (detailScreenState.recommendedExpandedState) 180f else 0f\n83:     )\n84: \n85:     val rotationStateNonVeg by animateFloatAsState(\n86:         targetValue = if (detailScreenState.nonVegExpandedState) 180f else 0f\n87:     )\n88: \n89:     val rotationStateVeg by animateFloatAsState(\n90:         targetValue = if (detailScreenState.vegExpandedState) 180f else 0f\n91:     )\n92: \n93: \n94:     Box(contentAlignment = Alignment.BottomEnd) {\n95:         LazyColumn(modifier = Modifier.fillMaxSize()) {\n96:             item {\n97:                 Row(\n98:                     modifier = Modifier.fillMaxWidth(),\n99:                     horizontalArrangement = Arrangement.SpaceBetween\n100:                 ) {\n101:                     IconButton(onClick = { navController.navigateUp() }) {\n102:                         Icon(\n103:                             imageVector = Icons.Outlined.ArrowBack,\n104:                             contentDescription = stringResource(R.string.favourite)\n105:                         )\n106:                     }\n107:                     Row {\n108:                         IconToggleButton(\n109:                             checked = detailScreenState.isLiked,\n110:                             onCheckedChange = {\n111:                                 viewModel.onEvent(DetailScreenEvent.ToggleLikedStatus)\n112:                             },\n113:                         ) {\n114:                             if (detailScreenState.isLiked) {\n115:                                 Icon(\n116:                                     imageVector = Icons.Filled.Favorite,\n117:                                     contentDescription = stringResource(R.string.favourite),\n118:                                     tint = Color.Red\n119:                                 )\n120:                             } else {\n121:                                 Icon(\n122:                                     imageVector = Icons.Default.FavoriteBorder,\n123:                                     contentDescription = stringResource(R.string.favourite)\n124:                                 )\n125:                             }\n126: \n127:                         }\n128:                         IconButton(onClick = {\n129: \n130:                         }) {\n131:                             Icon(\n132:                                 imageVector = Icons.Outlined.Share,\n133:                                 contentDescription = stringResource(\n134:                                     R.string.share\n135:                                 )\n136:                             )\n137:                         }\n138: \n139:                     }\n140:                 }\n141:             }\n142:             item {\n143:                 Column(modifier = Modifier.padding(16.dp)) {\n144:                     RestaurantDetailCard(\n145:                         detailScreenState.restaurant!!\n146:                     )\n147: \n148:                 }\n149:             }\n150:             val recommendedList =\n151:                 detailScreenState.recommendedList\n152: \n153: \n154: \n155: \n156:             item {\n157:                 Row(\n158:                     modifier = Modifier\n159:                         .fillMaxWidth()\n160:                         .padding(24.dp, 0.dp),\n161:                     verticalAlignment = Alignment.CenterVertically,\n162:                     horizontalArrangement = Arrangement.Center\n163: \n164:                 ) {\n165:                     Text(\n166:                         m