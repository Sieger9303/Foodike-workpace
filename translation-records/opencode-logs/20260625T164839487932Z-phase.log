ndroidx.compose.foundation.layout.Row\n31: import androidx.compose.foundation.layout.fillMaxWidth\n32: import androidx.compose.foundation.layout.padding\n33: import androidx.compose.foundation.shape.RoundedCornerShape\n34: import androidx.compose.material.Card\n35: import androidx.compose.material.Icon\n36: import androidx.compose.material.IconButton\n37: import androidx.compose.material.Text\n38: import androidx.compose.material.icons.Icons\n39: import androidx.compose.material.icons.outlined.Edit\n40: import androidx.compose.runtime.Composable\n41: import androidx.compose.ui.Alignment\n42: import androidx.compose.ui.Modifier\n43: import androidx.compose.ui.draw.alpha\n44: import androidx.compose.ui.text.font.FontWeight\n45: import androidx.compose.ui.unit.dp\n46: import com.example.foodike.domain.model.Restaurant\n47: import com.example.foodike.presentation.common.getTimeInMins\n48: \n49: @Composable\n50: fun DeliverySection(\n51:     restaurant: Restaurant\n52: ) {\n53:     Column(modifier = Modifier.padding(16.dp)) {\n54: \n55: \n56:         Card(\n57:             shape = RoundedCornerShape(24.dp),\n58:             elevation = 16.dp\n59: \n60:         ) {\n61:             Column(modifier = Modifier.padding(24.dp)) {\n62:                 Row(\n63:                     modifier = Modifier.fillMaxWidth(),\n64:                     horizontalArrangement = Arrangement.SpaceBetween,\n65:                     verticalAlignment = Alignment.CenterVertically\n66:                 ) {\n67:                     Text(text = \"Deliver to:\", fontWeight = FontWeight.Bold)\n68:                     IconButton(onClick = { }) {\n69:                         Icon(\n70:                             imageVector = Icons.Outlined.Edit,\n71:                             contentDescription = \"Back\",\n72:                             modifier = Modifier.alpha(0.5f),\n73:                         )\n74:                     }\n75:                 }\n76:                 Row(\n77:                     modifier = Modifier.fillMaxWidth(),\n78:                     horizontalArrangement = Arrangement.SpaceBetween,\n79:                 ) {\n80:                     Column {\n81:                         Text(text = \"Location:\")\n82:                         Text(text = \"Estimated time:\")\n83:                     }\n84:                     Column {\n85:                         Text(text = \"Guwahati\")\n86:                         Text(text = restaurant.timeInMillis.getTimeInMins())\n87:                     }\n88: \n89: \n90:                 }\n91: \n92:             }\n93:         }\n94:     }\n95: }\n96: \n\n(End of file - total 96 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n *\tIMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n *\tFITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n *\tAUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER","truncated":false,"loaded":[]},"title":"..\\..\\Kotlin2Cangjie\\Foodike\\app\\src\\main\\java\\com\\example\\foodike\\presentation\\cart\\components\\DeliverySection.kt","time":{"start":1782406170276,"end":1782406170282}},"id":"prt_effafc6690024zeQnLkIED1Qz7","sessionID":"ses_10050fa72ffe1d7GU3GCs1clsN","messageID"