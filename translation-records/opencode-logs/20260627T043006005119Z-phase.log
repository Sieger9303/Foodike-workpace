{"type":"tool_use","timestamp":1782534656967,"sessionID":"ses_0f8a86c83ffeImH5njw5foqGe3","part":{"type":"tool","tool":"read","callID":"call_Vu5sQBBRmGnSKX9GEcMYq0af","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\app_router.cj","limit":250,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\app_router.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n2: \n3: import ohos.base.ResourceStr\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{stringAppName, stringCart, stringHistory, stringHome, stringLogin, stringProfileTitle, stringRestaurant}\n5: import std.collection.ArrayList\n6: \n7: public enum RouteId {\n8:     | Onboarding\n9:     | Login\n10:     | Home\n11:     | History\n12:     | Cart\n13:     | Profile\n14:     | RestaurantDetails\n15: }\n16: \n17: public enum ShellCommand {\n18:     | HomeTab\n19:     | HistoryTab\n20:     | CartAction\n21:     | PrimaryAction\n22: }\n23: \n24: public func routePath(route: RouteId): String {\n25:     match (route) {\n26:         case RouteId.Onboarding => \"onboarding\"\n27:         case RouteId.Login => \"login_screen\"\n28:         case RouteId.Home => \"home_screen\"\n29:         case RouteId.History => \"history\"\n30:         case RouteId.Cart => \"cart\"\n31:         case RouteId.Profile => \"profile\"\n32:         case RouteId.RestaurantDetails => \"restaurant_details\"\n33:     }\n34: }\n35: \n36: public func routeLabel(route: RouteId): ResourceStr {\n37:     match (route) {\n38:         case RouteId.Onboarding => stringAppName\n39:         case RouteId.Login => stringLogin\n40:         case RouteId.Home => stringHome\n41:         case RouteId.History => stringHistory\n42:         case RouteId.Cart => stringCart\n43:         case RouteId.Profile => stringProfileTitle\n44:         case RouteId.RestaurantDetails => stringRestaurant\n45:     }\n46: }\n47: \n48: public func routeLabelByPath(route: String): ResourceStr {\n49:     match (route) {\n50:         case \"onboarding\" => routeLabel(RouteId.Onboarding)\n51:         case \"login_screen\" => routeLabel(RouteId.Login)\n52:         case \"home_screen\" => routeLabel(RouteId.Home)\n53:         case \"history\" => routeLabel(RouteId.History)\n54:         case \"cart\" => routeLabel(RouteId.Cart)\n55:         case \"profile\" => routeLabel(RouteId.Profile)\n56:         case \"restaurant_details\" => routeLabel(RouteId.RestaurantDetails)\n57:         case _ => route\n58:     }\n59: }\n60: \n61: public func routeWithArgs(route: RouteId, args: ArrayList<String>): String {\n62:     var composedRoute = routePath(route)\n63:     for (arg in args) {\n64:         composedRoute = composedRoute + \"/\" + arg\n65:     }\n66:     return composedRoute\n67: }\n68: \n69: public func resolveStartRoute(isLoggedIn: Bool): String {\n70:     if (isLoggedIn) {\n71:         routePath(RouteId.Home)\n72:     } else {\n73:         routePath(RouteId.Onboarding)\n74:     }\n75: }\n76: \n77: public func showsBottomShell(route: String, isAtTop: Bool): Bool {\n78:     if (!isAtTop) {\n79:         return false\n80:     }\n81: \n82:     route == routePath(RouteId.Home) || route == routePath(RouteId.History)\n83: }\n84: \n85: public func primaryActionTarget(route: String): String {\n86:     match (route) {\n87:         case \"onboarding\" => routePath(RouteId.Login)\n88:         case \"login_screen\" => routePath(RouteId.Home)\n89:         case \"home_screen\" => routePath(RouteId.RestaurantDetails)\n90:         case \"history\" => routePath(RouteId.Profile)\n91:         case \"cart\" => routePath(RouteId.Home)\n92:         case \"profile\" => routePath(RouteId.Onboarding)\n93:         case \"restaurant_details\" => routePath(RouteId.Home)\n94:         case _ => routePath(RouteId.Home)\n95:     }\n96: }\n97: \n98: public func primaryActionLabel(route: String): ResourceStr {\n99:     routeLabelByPath(primaryActionTarget(route))\n100: }\n101: \n102: public class ShellRouteState {\n103:     public var currentRoute: String\n104:     public var isAtTop: Bool\n105: \n106:     public init(currentRoute: String, isAtTop: Bool) {\n107:         this.currentRoute = currentRoute\n108:         this.isAtTop = isAtTop\n109:     }\n110: \n111:     private func navigateWithoutDuplicate(route: String): Unit {\n112:         if (this.currentRoute != route) {\n113:             this.currentRoute = route\n114:         }\n115:     }\n116: \n117:     public func applyCommand(command: ShellCommand): Unit {\n118:         match (command) {\n119:             case ShellCommand.HomeTab => this.navigateWithoutDuplicate(routePath(RouteId.Home))\n120:             case ShellCommand.HistoryTab => this.navigateWithoutDuplicate(routePath(RouteId.History))\n121:             case ShellCommand.CartAction => this.navigateWithoutDuplicate(routePath(RouteId.Cart))\n122:             case ShellCommand.PrimaryAction => this.navigateWithoutDuplicate(primaryActionTarget(this.currentRoute))\n123:         }\n124:     }\n125: \n126:     public func setTopState(isAtTop: Bool): Unit {\n127:         this.isAtTop = isAtTop\n128:     }\n129: \n130:     public func showBottomShell(): Bool {\n131:         showsBottomShell(this.currentRoute, this.isAtTop)\n132:     }\n133: }\n\n(End of file - total 133 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\nimport ohos.base.ResourceStr\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{stringAppName, stringCart, stringHistory, stringHome, stringLogin, stringProfileTitle, stringRestaurant}\nimport std.collection.ArrayList\n\npublic enum RouteId {\n    | Onboarding\n    | Login\n    | Home\n    | History\n    | Cart\n    | Profile\n    | RestaurantDetails\n}\n\npublic enum ShellCommand {\n    | HomeTab\n    | HistoryTab\n    | CartAction",