[{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\route_registry.cj","relativePath":"Foodike-Harmony/entry/src/main/cangjie/ohos_app_cangjie_entry/app/route_registry.cj","type":"add","patch":"Index: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\route_registry.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\route_registry.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\route_registry.cj\n@@ -0,0 +1,84 @@\n+package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n+\n+import ohos.base.ResourceStr\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{stringAppName, stringCart, stringHistory, stringHome, stringLogin, stringProfileTitle, stringRestaurant}\n+import std.collection.ArrayList\n+\n+public enum RouteId {\n+    | Onboarding\n+    | Login\n+    | Home\n+    | History\n+    | Cart\n+    | Profile\n+    | RestaurantDetails\n+}\n+\n+public enum ShellCommand {\n+    | HomeTab\n+    | HistoryTab\n+    | CartAction\n+    | PrimaryAction\n+}\n+\n+public func routePath(route: RouteId): String {\n+    match (route) {\n+        case RouteId.Onboarding => \"onboarding\"\n+        case RouteId.Login => \"login_screen\"\n+        case RouteId.Home => \"home_screen\"\n+        case RouteId.History => \"history\"\n+        case RouteId.Cart => \"cart\"\n+        case RouteId.Profile => \"profile\"\n+        case RouteId.RestaurantDetails => \"restaurant_details\"\n+    }\n+}\n+\n+public func routeLabel(route: RouteId): ResourceStr {\n+    match (route) {\n+        case RouteId.Onboarding => stringAppName\n+        case RouteId.Login => stringLogin\n+        case RouteId.Home => stringHome\n+        case RouteId.History => stringHistory\n+        case RouteId.Cart => stringCart\n+        case RouteId.Profile => stringProfileTitle\n+        case RouteId.RestaurantDetails => stringRestaurant\n+    }\n+}\n+\n+public func routeLabelByPath(route: String): ResourceStr {\n+    match (route) {\n+        case \"onboarding\" => routeLabel(RouteId.Onboarding)\n+        case \"login_screen\" => routeLabel(RouteId.Login)\n+        case \"home_screen\" => routeLabel(RouteId.Home)\n+        case \"history\" => routeLabel(RouteId.History)\n+        case \"cart\" => routeLabel(RouteId.Cart)\n+        case \"profile\" => routeLabel(RouteId.Profile)\n+        case \"restaurant_details\" => routeLabel(RouteId.RestaurantDetails)\n+        case _ => route\n+    }\n+}\n+\n+public func routeWithArgs(route: RouteId, args: ArrayList<String>): String {\n+    var composedRoute = routePath(route)\n+    for (arg in args) {\n+        composedRoute = composedRoute + \"/\" + arg\n+    }\n+    return composedRoute\n+}\n+\n+public func primaryActionTarget(route: String): String {\n+    match (route) {\n+        case \"onboarding\" => routePath(RouteId.Login)\n+        case \"login_screen\" => routePath(RouteId.Home)\n+        case \"home_screen\" => routePath(RouteId.RestaurantDetails)\n+        case \"history\" => routePath(RouteId.Profile)\n+        case \"cart\" => routePath(RouteId.Home)\n+        case \"profile\" => routePath(RouteId.Onboarding)\n+        case \"restaurant_details\" => routePath(RouteId.Home)\n+        case _ => routePath(RouteId.Home)\n+    }\n+}\n+\n+public func primaryActionLabel(route: String): ResourceStr {\n+    routeLabelByPath(primaryActionTarget(route))\n+}\n","additions":84,"deletions":0},{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\shell_route_state.cj","relativePath":"Foodike-Harmony/entry/src/main/cangjie/ohos_app_cangjie_entry/app/shell_route_state.cj","type":"add","patch":"Index: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\shell_route_state.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\shell_route_state.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\shell_route_state.cj\n@@ -0,0 +1,42 @@\n+package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n+\n+public func showsBottomShell(route: String, isAtTop: Bool): Bool {\n+    if (!isAtTop) {\n+        return false\n+    }\n+\n+    route == routePath(RouteId.Home) || route == routePath(RouteId.History)\n+}\n+\n+public class ShellRouteState {\n+    public var currentRoute: String\n+    public var isAtTop: Bool\n+\n+    public init(currentRoute: String, isAtTop: Bool) {\n+        this.currentRoute = currentRoute\n+        this.isAtTop = isAtTop\n+    }\n+\n+    private func navigateWithoutDuplicate(route: String): Unit {\n+        if (this.currentRoute != route) {\n+            this.currentRoute = route\n+        }\n+    }\n+\n+    public func applyCommand(command: ShellCommand): Unit {\n+        match (command) {\n+            case ShellCommand.HomeTab => this.navigateWithoutDuplicate(routePath(RouteId.Home))\n+            case ShellCommand.HistoryTab => this.navigateWithoutDuplicate(routePath(RouteId.History))\n+            case ShellCommand.CartAction => this.navigateWithoutDuplicate(routePath(RouteId.Cart))\n+            case ShellCommand.PrimaryAction => this.navigateWithoutDuplicate(primaryActionTarget(this.currentRoute))\n+        }\n+    }\n+\n+    public func setTopState(isAtTop: Bool): Unit {\n+        this.isAtTop = isAtTop\n+    }\n+\n+    public func showBottomShell(): Bool {\n+        showsBottomShell(this.currentRoute, this.isAtTop)\n+    }\n+}\n","additions":42,"deletions":0},{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\startup\\startup_launch_service.cj","relativePath":"