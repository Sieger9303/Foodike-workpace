      case \"cart\" => routePath(RouteId.Home)\n48:         case \"profile\" => routePath(RouteId.Onboarding)\n49:         case \"restaurant_details\" => routePath(RouteId.Home)\n50:         case _ => routePath(RouteId.Home)\n51:     }\n52: }\n\n(End of file - total 52 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\npublic enum RouteId {\n    | Onboarding\n    | Login\n    | Home\n    | History\n    | Cart\n    | Profile\n    | RestaurantDetails\n}\n\npublic func routePath(route: RouteId): String {\n    match (route) {\n        case RouteId.Onboarding => \"onboarding\"\n        case RouteId.Login => \"login_screen\"\n        case RouteId.Home => \"home_screen\"\n        case RouteId.History => \"history\"\n        case RouteId.Cart => \"cart\"\n        case RouteId.Profile => \"profile\"","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\app_router.cj","time":{"start":1782365425153,"end":1782365425161}},"id":"prt_efd420db2001tT3MPMN53Grb8L","sessionID":"ses_102be2c3dffeRyA4IsDHFUpioX","messageID":"msg_efd41f1a7001DiaZWkl6Z4h5TC"}}
