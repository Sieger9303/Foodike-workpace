ries\": 3,\n177:         \"missingDocSearchCriticalHighEntries\": 0,\n178:         \"implementedWeakTargetDecisionEntries\": 0,\n179:         \"implementedWeakTestEntries\": 0,\n180:         \"fallbackDespiteDirectEvidenceEntries\": 0,\n181:         \"localSimulationFallbackWithoutBlockerEntries\": 0,\n182:         \"replacementWithoutApiEvidenceEntries\": 0,\n183:         \"verifiedDirectMissingEndpointEntries\": 0,\n184:         \"implementedMissingEndpointEntries\": 0,\n185:         \"realCapabilityWithLocalFallbackEntries\": 0,\n186:         \"incompleteDeferredCriticalHighEntries\": 0,\n187:         \"genericDeferredCriticalHighEntries\": 0,\n188:         \"byStatus\": {\n189:           \"not-applicable\": 1,\n190:           \"planned\": 3,\n191:           \"platform-replaced\": 1,\n192:           \"verified-direct\": 1\n193:         },\n194:         \"allowedStatuses\": [\n195:           \"deferred\",\n196:           \"implemented-fallback\",\n197:           \"not-applicable\",\n198:           \"not-covered\",\n199:           \"planned\",\n200:           \"platform-replaced\",\n201:           \"unreviewed\",\n202:           \"verified-direct\"\n203:         ],\n204:         \"deferredRequiredFields\": [\n205:           \"targetCapabilitySearch\",\n206:           \"blocker\",\n207:           \"targetFallback\",\n208:           \"futureCompletionPath\"\n209:         ]\n210:       },\n211:       \"fromCoverageGap\": {\n212:         \"expectedEntries\": 6,\n213:         \"expectedCriticalHighEntries\": 6,\n214:         \"actualEntries\": 6,\n215:         \"missingCriticalHighEntries\": 0,\n216:         \"unresolvedCriticalHighEntries\": 3,\n217:         \"missingDocSearchCriticalHighEntries\": 0,\n218:         \"implementedWeakTargetDecisionEntries\": 0,\n219:         \"implementedWeakTestEntries\": 0,\n220:         \"fallbackDespiteDirectEvidenceEntries\": 0,\n221:         \"localSimulationFallbackWithoutBlockerEntries\": 0,\n222:         \"replacementWithoutApiE