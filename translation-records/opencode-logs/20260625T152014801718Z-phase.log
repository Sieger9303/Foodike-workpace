e = HomeStore()\n38:         @Assert(store.toggleFilter(\"\", \"Fast Delivery\"), \"Fast Delivery\")\n39:         @Assert(store.toggleFilter(\"Fast Delivery\", \"Fast Delivery\"), \"\")\n40:         @Assert(store.toggleFilter(\"Fast Delivery\", \"Non-Veg\"), \"Non-Veg\")\n41:     }\n42: \n43:     @TestCase\n44:     public func homeStorePreservesGreetingBuckets(): Unit {\n45:         let store = HomeStore()\n46:         @Assert(store.greetingForHour(9), \"Good Morning!\")\n47:         @Assert(store.greetingForHour(14), \"Good Afternoon!\")\n48:         @Assert(store.greetingForHour(19), \"Good Evening!\")\n49:     }\n50: \n51:     @TestCase\n52:     public func restaurantCardCustomerInfoMatchesSourceThresholdOrdering(): Unit {\n53:         @Assert(getCustomerInfo(51), \"50+\")\n54:         @Assert(getCustomerInfo(800), \"50+\")\n55:         @Assert(getCustomerInfo(12), \"1000+\")\n56:     }\n57: \n58:     @TestCase\n59:     public func historyStoreSelectionSavesRestaurantBeforeNavigation(): Unit {\n60:         let store = HistoryStore()\n61:         let restaurant = store.loadHistoryState().favourites[1]\n62:         let events = ArrayList<String>([])\n63:         store.selectRestaurant(restaurant, { =>\n64:             events.add(store.session().getSelectedRestaurantName())\n65:             events.add(\"navigate\")\n66:         })\n67:         @Assert(events[0], restaurant.name)\n68:         @Assert(events[1], \"navigate\")\n69:     }\n70: \n71:     @TestCase\n72:     public func historyStoreExposesSourceTabOrdering(): Unit {\n73:         let store = HistoryStore()\n74:         @Assert(store.tabLabel(0), \"History\")\n75:         @Assert(store.tabLabel(1), \"Favourites\")\n76:     }\n77: }\n\n(End of file - total 77 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home.HomeStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history.HistoryStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.getCustomerInfo\nimport std.collection.ArrayList\nimport std.unittest.*\nimport std.unittest.testmacro.*\n\n@Test\npublic class Phase04HomeHistoryDiscoveryTest {\n    @TestCase\n    public func homeStoreLoadsFixtureBackedSections(): Unit {\n        let store = HomeStore()\n        let state = store.loadHomeState()\n        @Assert(state.advertisements.size, 4)\n        @Assert(state.categories.size, 7)\n        @Assert(state.favourites.size, 5)\n        @Assert(state.restaurants.size, 8)\n    }","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\test\\cangjie\\phase04_home_history_discovery_test.cj","time":{"start":1782400849305,"end":1782400849312}},"id":"prt_eff5e9566001hqn306XNBDf9IH","sessionID":"ses_100a1eab4ffeTKCONZ3ie8fSSB","messageID":"msg_eff5e702b001b2qEyEveNkAaoL"}}
