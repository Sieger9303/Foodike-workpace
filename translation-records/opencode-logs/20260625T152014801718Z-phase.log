ents = advertisements\n108:         this.categories = categories\n109:         this.favourites = favourites\n110:         this.restaurants = restaurants\n111:     }\n112: }\n113: \n114: public class HistoryPageState {\n115:     public let favourites: ArrayList<RestaurantData>\n116:     public let records: ArrayList<HistoryRecordData>\n117: \n118:     public init(favourites: ArrayList<RestaurantData>, records: ArrayList<HistoryRecordData>) {\n119:         this.favourites = favourites\n120:         this.records = records\n121:     }\n122: }\n\n(End of file - total 122 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain\n\nimport std.collection.ArrayList\n\npublic class AdvertisementData {\n    public let title: String\n    public let subtitle: String\n    public let mediaName: String\n\n    public init(title: String, subtitle: String, mediaName: String) {\n        this.title = title\n        this.subtitle = subtitle\n        this.mediaName = mediaName\n    }\n}\n\npublic class FoodCategoryData {\n    public let name: String\n    public let mediaName: String\n","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\domain\\discovery_models.cj","time":{"start":1782400849253,"end":1782400849260}},"id":"prt_eff5e953b001e7EDbh7sOZLnpU","sessionID":"ses_100a1eab4ffeTKCONZ3ie8fSSB","messageID":"msg_eff5e702b001b2qEyEveNkAaoL"}}
