       \"500+\"\n41:     } else if (ratingCount > 550) {\n42:         \"550+\"\n43:     } else if (ratingCount > 600) {\n44:         \"600+\"\n45:     } else if (ratingCount > 650) {\n46:         \"650+\"\n47:     } else if (ratingCount > 700) {\n48:         \"700+\"\n49:     } else if (ratingCount > 750) {\n50:         \"750+\"\n51:     } else if (ratingCount > 800) {\n52:         \"800+\"\n53:     } else {\n54:         \"1000+\"\n55:     }\n56: }\n57: \n58: public func formatEta(minutes: Int64): String {\n59:     let hours = minutes / 60\n60:     let remainder = minutes % 60\n61:     if (hours > 0) {\n62:         return \"${hours} Hr ${remainder} Min\"\n63:     }\n64:     return \"${remainder} Min\"\n65: }\n66: \n67: @Builder\n68: public func renderRestaurantCard(restaurant: RestaurantData, onSelect: () -> Unit) {\n69:     Row(space: 14) {\n70:         Image(restaurantMedia(restaurant.mediaName))\n71:             .width(120)\n72:             .height(154)\n73:             .borderRadius(12)\n74:         Column(space: 8) {\n75:             Text(restaurant.name)\n76:                 .fontSize(18)\n77:                 .fontWeight(FontWeight.Bold)\n78:             Row(space: 6) {\n79:                 Image(mediaStar)\n80:                     .width(18)\n81:                     .height(18)\n82:                 Text(\"${restaurant.rating}(${getCustomerInfo(restaurant.ratingCount)})\")\n83:                     .fontSize(14)\n84:                 Text(\".\")\n85:                     .fontWeight(FontWeight.Bold)\n86:                 Text(formatEta(restaurant.etaMinutes))\n87:                     .fontSize(14)\n88:             }\n89:             Text(restaurant.variety)\n90:                 .fontSize(14)\n91:                 .fontColor(Color.Gray)\n92:             Text(restaurant.place)\n93:                 .fontSize(14)\n94:                 .fontColor(Color.Gray)\n95:         }\n96:         .layoutWeight(1)\n97:     }\n98:     .width(100.percent)\n99:     .padding(top: 8, right: 8, bottom: 8, left: 8)\n100:     .backgroundColor(Color.White)\n101:     .borderRadius(16)\n102:     .onClick({ _ =>\n103:         onSelect()\n104:     })\n105: }\n\n(End of file - total 105 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos.resource.AppResource\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.RestaurantData\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaApplePie, mediaBiryani, mediaBurger, mediaChinese, mediaDosa, mediaParatha, mediaStar}\n\npublic func restaurantMedia(name: String): AppResource {\n    match (name) {\n        case \"biryani\" => mediaBiryani\n        case \"burger\" => mediaBurger\n        case \"chinese\" => mediaChinese\n        case \"dosa\" => mediaDosa\n        case \"paratha\" => mediaParatha\n        case _ => mediaApplePie\n    }\n}\n\npublic func getCustomerInfo(ratingCount: Int64): String {","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\common\\widgets\\restaurant_card.cj","time":{"start":1782400849004,"end":1782400849012}},"id":"prt_eff5e942a0018Jv0m8Ao11BXrl","sessionID":"ses_100a1eab4ffeTKCONZ3ie8fSSB","messageID":"msg_eff5e702b001b2qEyEveNkAaoL"}}
