 class EntryView {\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/API/arkui-cj/cj-button-picker-slider/Slider/示例代码/示例1滑动条基础样式/示例1滑动条基础样式_1.md\"\r\n      ],\r\n      \"source\": null,\r\n      \"doc_kind\": null\r\n    },\r\n    {\r\n      \"example_id\": \"example.harmonyos-6-1-8k-api-arkui-cj-cj-button-picker-slider-slider-1-1-2-md\",\r\n      \"title\": \"示例1滑动条基础样式_2\",\r\n      \"score\": 44.383,\r\n      \"summary\": \"Column() { Text('vertical inset slider').fontSize(9).fontColor(0xCCCCCC).width(50.percent).margin(15) Row() { Slider( value: this.vInSetValueOne, style: SliderStyle.InSet, direction: Axis.Vertical,\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/API/arkui-cj/cj-button-picker-slider/Slider/示例代码/示例1滑动条基础样式/示例1滑动条基础样式_2.md\"\r\n      ],\r\n      \"source\": null,\r\n      \"doc_kind\": null\r\n    },\r\n    {\r\n      \"example_id\": \"example.harmonyos-6-1-8k-api-arkui-cj-cj-button-picker-slider-slider-1-abstract-md\",\r\n      \"title\": \".abstract\",\r\n      \"score\": 44.383,\r\n      \"summary\": \"本目录展示了如何在ArkUI框架中使用仓颉语言配置和自定义滑动条的基础样式。内容涵盖了OutSet（外置）、InSet（内置）以及垂直方向滑动条的实现，重点演示了气泡、刻度、滑块和滑轨的显示控制。通过style、showTips、blockColor等属性，开发者可以调整交互效果和颜色，并利用onChange回调实现状态双向绑定。该文档适合具备ArkUI基础和仓颉语法知识的开发者，用于学习UI组件的属性配置与状态管理。\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/API/arkui-cj/cj-button-picker-slider/Slider/示例代码/示例1滑动条基础样式/.abstract.md\"\r\n      ],\r\n      \"source\": null,\r\n      \"doc_kind\": null\r\n    },\r\n    {\r\n      \"example_id\": \"example.harmonyos-6-1-8k-api-arkui-cj-cj-button-picker-slider-slider-1-overview-md\",\r\n      \"title\": \"示例1滑动条基础样式\",\r\n      \"score\": 44.383,\r\n      \"summary\": \"本目录展示了如何在ArkUI框架中使用仓颉语言配置和自定义滑动条的基础样式。内容涵盖了OutSet（外置）、InSet（内置）以及垂直方向滑动条的实现，重点演示了气泡、刻度、滑块和滑轨的显示控制。通过style、showTips、blockColor等属性，开发者可以调整交互效果和颜色，并利用onChange回调实现状态双向绑定。该文档适合具备ArkUI基础和仓颉语法知识的开发者，用于学习UI组件的属性配置与状态管理。\",\r\n      \"paths\": [\r\n        \"harmonyos-6.1-8k/API/arkui-cj/cj-button-picker-slider/Slider/示例代码/示例