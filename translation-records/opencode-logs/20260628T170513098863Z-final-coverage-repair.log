.resetState = resetState\n40:     }\n41: }\n42: \n43: public class ProfileRouteService {\n44:     public init() {}\n45: \n46:     public func resolveBackRoute(currentRoute: String, routeBackStack: ArrayList<String>): String {\n47:         if (routeBackStack.size == 0) {\n48:             return currentRoute\n49:         }\n50: \n51:         return routeBackStack[routeBackStack.size - 1]\n52:     }\n53: \n54:     public func canNavigateBack(currentRoute: String, routeBackStack: ArrayList<String>): Bool {\n55:         return resolveBackRoute(currentRoute, routeBackStack) != currentRoute\n56:     }\n57: \n58:     public func resetAfterLogout(): ProfileRouteState {\n59:         return ProfileRouteState(\n60:             \"\",\n61:             \"\",\n62:             0,\n63:             \"\",\n64:             \"\",\n65:             \"\",\n66:             0\n67:         )\n68:     }\n69: \n70:     public func buildLogoutTransition(logoutRoute: String): ProfileLogoutTransition {\n71:         return ProfileLogoutTransition(logoutRoute, resetAfterLogout())\n72:     }\n73: \n74:     public func editActionMessage(): String {\n75:         return profileStore.actionFeedbackMessage(ProfileAction.Edit)\n76:     }\n77: \n78:     public func sectionActionMessage(section: ProfileSection): String {\n79:         return profileStore.sectionFeedbackMessage(section)\n80:     }\n81: }\n82: \n83: public let profileRouteService = ProfileRouteService()\n\n(End of file - total 83 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile\n\nimport std.collection.ArrayList\n\npublic class ProfileRouteState {\n    public var loginEmail: String\n    public var loginPassword: String\n    public var onboardingPageIndex: Int64\n    public var homeSearchQuery: String\n    public var homeSelectedFilter: String\n    public var historySearchQuery: String\n    public var historyTabIndex: Int64\n\n    public init(\n        loginEmail: String,\n        l