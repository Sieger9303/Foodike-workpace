ckerKinds\": list(COVERAGE_BLOCKER_KINDS),\n194:     }\n195: \n196: \n197: def allowed_capability_facts() -> dict[str, list[str]]:\n198:     \"\"\"Return machine-readable legal values for platform capability facts.\"\"\"\n199: \n200:     return {\n201:         \"resolutionKind\": list(CAPABILITY_RESOLUTION_KINDS),\n202:         \"apiEvidenceKinds\": list(CAPABILITY_API_EVIDENCE_KINDS),\n203:         \"callableApiEvidenceKinds\": list(CAPABILITY_CALLABLE_API_EVIDENCE_KINDS),\n204:         \"discoveryOnlyEvidenceKinds\": list(CAPABILITY_DISCOVERY_ONLY_EVIDENCE_KINDS),\n205:         \"compileProbeEvidenceKinds\": list(CAPABILITY_COMPILE_PROBE_EVIDENCE_KINDS),\n206:         \"fallbackKinds\": list(CAPABILITY_FALLBACK_KINDS),\n207:         \"blockerKinds\": list(CAPABILITY_BLOCKER_KINDS),\n208:         \"factsSource\": list(FACTS_SOURCES),\n209:     }\n210: \n211: \n212: def default_coverage_facts(*, facts_source: str = \"template\") -> dict[str, Any]:\n213:     \"\"\"Return a fresh default source coverage fact object.\"\"\"\n214: \n215:     facts = {\n216:         \"schemaVersion\": FACTS_SCHEMA_VERSION,\n217:         \"closureKind\": \"open\",\n218:         \"parityKind\": \"unverified\",\n219:         \"sourceBehaviorMapped\": False,\n220:         \"targetBehaviorImplemented\": False,\n221:         \"activeSimplification\": {\n222:             \"used\": False,\n223:             \"reason\": \"\",\n224:             \"preservedBehaviors\": [],\n225:             \"omittedBehaviors\": [],\n226:         },\n227:         \"activeDeferred\": {\n228:             \"used\": False,\n229:             \"blockerKind\": \"\",\n230:             \"blocker\": \"\",\n231:             \"fallbackBehavior\": \"\",\n232:             \"futureCompletionPath\": \"\",\n233:         },\n234:         \"verification\": {\n235:             \"targetEndpoints\": [],\n236:             \"testEvidence\": [],\n237:             \"buildEvidence\": [],\n238:             \"runtimeEvidence\": [],\n239:             \"manualEvidence\": [],\n240:         },\n241:         \"factsSource\": facts_source,\n242:     }\n243:     return copy.deepcopy(facts)\n244: \n245: \n246: def default_capability_facts(*, facts_source: str = \"template\") -> dict[str, Any]:\n247:     \"\"\"Return a fresh default platform capability fact object.\"\"\"\n248: \n249:     facts = {\n250:         \"schemaVersion\": FACTS_SCHEMA_VERSION,\n251:         \"resolutionKind\": \"open\",\n252:         \"activeFallback\": {\n253:             \"used\": False,\n254:             \"fallbackKind\": \"\",\n255:             \"reason\": \"\",\n256:             \"blocker\": \"\",\n257:         },\n258:         \"apiEvidence\": [],\n259:         \"discoveryOnlyEvidence\": [],\n260:         \"compileProbeEvidence\": [],\n\n(Showing lines 1-260 of 998. Use offset=261 to continue.)\n</content>","metadata":{"preview":"\"\"\"Structured fact schemas for coverage and platform authority records.\"\"\"\n\nfrom __future__ import annotations\n\nimport copy\nfrom typing import Any\n\nFACTS_SCHEMA_VERSION = 1\n\nCOVERAGE_FACTS_KEY = \"coverageFacts\"\nCAPABILITY_FACTS_KEY = \"capabilityFacts\"\n\nFACTS_SOURCES = (\"agent\", \"inferred-from-legacy\", \"template\")\n\nCOVERAGE_CLOSURE_KINDS = (\n    \"open\",\n    \"implemented\",\n    \"simplified\",\n    \"platform-replaced\",\n    \"deferred\",","truncated":true,"loaded":[]},"title":"..\\..\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\facts.py","time":{"start":1782526618758,"end":1782526618769}},"id":"prt_f06ddac46001vbaMgioJrGUM3R","sessionID":"ses_0f923eeffffeBaDzycyPMFxg4Q","messageID":"msg_f06dd8a2e00127R5JSXdVOIiNT"}}
{"type":"tool_use","timestamp":1782526618835,"sessionID":"ses_0f923eeffffeBaDzycyPMFxg4Q","part":{"type":"tool","tool":"read","callID":"call_HH2r7XT5QK4tbEFu19AkWE2U","state":{"status":"completed","input":{"filePath":"D:\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\platform.py","offset":380,"limit":120},"output":"<path>D:\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\platform.py</path>\n<type>file</type>\n<content>\n380:     \"not available\",\n381:     \"not found\",\n382:     \"without\",\n383:     \"不可用\",\n384:     \"不存在\",\n385:     \"未找到\",\n386:     \"没有\",\n387:     \"缺少\",\n388: )\n389: SDK_DECLARATION_NEGATION_SEPARATORS = (\";\", \"；\", \".\", \"。\", \"\\n\")\n390: \n391: \n392: def combined_text(*values: Any) -> str:\n393:     parts: list[str] = []\n394:     for value in values:\n395:         for item in list_value(value):\n396:             text = str(item or \"\").strip()\n397:             if text:\n398:                 parts.append(text)\n399:     return normalized_text(\" \".join(parts))\n400: \n401: \n402: CAPABILITY_RESOLUTION_TO_STATUS = {\n403:     \"open\": \"planned\",\n404:     \"direct-api\": \"verified-direct\",\n405:     \"platform-replacement\": \"platform-replaced\",\n406:     \"fallback\": \"implemented-fallback\",\n407:     \"deferred\": \"deferred\",\n408:     \"not-applicable\": \"not-applicable\",\n409: }\n410: \n411: \n412: def effective_capability_status(entry: dict[str, Any]) -> str:\n413:     \"\"\"Return gate status, allowing agent-authored capability facts to supersede stale status.\"\"\"\n414: \n415:     facts = capability_facts(entry)\n416:     status = CAPABILITY_RESOLUTION_TO_STATUS.get(str(facts.get(\"resolutionKind\") or \"\").strip().lower())\n417:     if status and facts.get(\"factsSource\") == \"agent\":\n418:         return status\n419:     raw_status = str(entry.get(\"status\") or \"\").strip().lower()\n420:     return raw_status if raw_status else \"empty\"\n421: \n422: \n423: def capability_api_evidence(entry: dict[str, Any], *, callable_only: bool = False) -> list[dict[str, Any]]:\n424:     facts = capability_facts(entry)\n425:     evidence = facts.get(\"apiEvidence\") if isinstance(facts.get(\"apiEvidence\"), list) else []\n426:     result: list[dict[str, Any]] = []\n427:     for item in evidence:\n428:         if not isinstance(item, dict):\n429:             continue\n430:         kind = str(item.get(\"kind\") or \"\").strip()\n431:         if callable_only and kind not in CAPABILITY_CALLABLE_API_EVIDENCE_KINDS:\n432:             continue\n433:         if kind:\n434:             result.append(item)\n435:     return result\n436: \n437: \n438: def capability_target_endpoints(entry: dict[str, Any]) -> list[str]:\n439:     \"\"\"Return target endpoints from legacy fields and structured capability facts.\"\"\"\n440: \n441:     endpoints: list[str] = []\n442: \n443:     def add(value: Any) -> None:\n444:         for item in list_value(value):\n445:             text = \"\"\n446:             if isinstance(item, dict):\n447:                 text = str(item.get(\"endpoint\") or item.get(\"detail\") or item.get(\"path\") or \"\").strip()\n448:             else:\n449:                 text = str(item or \"\").strip()\n450:             if text and text not in endpoints:\n451:                 endpoints.append(text)\n452: \n453:     add(entry.get(\"targetEndpoints\"))\n454:     facts = capability_facts(entry)\n455:     add(facts.get(\"targetEndpoints\"))\n456:     for item in capability_api_evidence(entry):\n457:         if item.get(\"kind\") == \"target-endpoint\":\n458:             add([item])\n459:     return endpoints\n460: \n461: \n462: def has_direct_unavailable_blocker(entry: dict[str, Any]) -> bool:\n463:     facts = capability_facts(entry)\n464:     blocker = facts.get(\"blocker\") if isinstance(facts.get(\"blocker\"), dict) else {}\n465:     if blocker.get(\"used\") and (has_text(blocker.get(\"detail\")) or has_text(blocker.get(\"kind\"))):\n466:         return True\n467:     fallback = facts.get(\"activeFallback\") if isinstance(facts.get(\"activeFallback\"), dict) else {}\n468:     if fallback.get(\"used\") and has_text(fallback.get(\"blocker\")):\n469:         return True\n470:     text = combined_text(\n471:         entry.get(\"blocker\"),\n472:         entry.get(\"targetApiOrLibrary\"),\n473:         entry.get(\"targetFallback\"),\n474:         entry.get(\"futureCompletionPath\"),\n475:         entry.get(\"notes\"),\n476:     )\n477:     return any(keyword in text for keyword in DIRECT_UNAVAILABLE_KEYWORDS)\n478: \n479: \n480: def has_structured_deferred_blocker(entry: dict[str, Any]) -> bool:\n481:     facts = capability_facts(entry)\n482:     blocker = facts.get(\"blocker\") if isinstance(facts.get(\"blocker\"), dict) else {}\n483:     return bool(\n484:         blocker.get(\"used\")\n485:         and has_text(blocker.get(\"kind\"))\n486:         and has_text(blocker.get(\"detail\"))\n487:         and has_text(blocker.get(\"futureCompletionPath\"))\n488:     )\n489: \n490: \n491: def platform_missing_deferred_fields(entry: dict[str, Any]) -> list[str]:\n492:     if has_structured_deferred_blocker(entry):\n493:         return []\n494:     return [\n495:         field\n496:         for field in PLATFORM_CAPABILITY_DEFERRED_REQUIRED_FIELDS\n497:         if not has_text_or_list(entry.get(field))\n498:     ]\n499: \n\n(Showing lines 380-499 of 1006. Use offset=500 to continue.)\n</content>","metadata":{"preview":"    \"not available\",\n    \"not found\",\n    \"without\",\n    \"不可用\",\n    \"不存在\",\n    \"未找到\",\n    \"没有\",\n    \"缺少\",\n)\nSDK_DECLARATION_NEGATION_SEPARATORS = (\";\", \"；\", \".\", \"。\", \"\\n\")\n\n\ndef combined_text(*values: Any) -> str:\n    parts: list[str] = []\n    for value in values:\n        for item in list_value(value):\n            text = str(item or \"\").strip()\n            if text:\n                parts.append(text)\n    return normalized_text(\" \".join(parts))","truncated":t