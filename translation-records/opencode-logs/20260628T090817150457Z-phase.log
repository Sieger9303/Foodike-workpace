{"type":"tool_use","timestamp":1782637775502,"sessionID":"ses_0f283616bffe00QcVZpvUWDRDJ","part":{"type":"tool","tool":"read","callID":"call_4E8y57CvYUSZtvYi7HI8SnWU","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_store.cj","limit":420,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_store.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home\n2: \n3: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.homeContentRepository\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n6: import std.collection.ArrayList\n7: \n8: public let homeStore = HomeStore()\n9: \n10: public class HomeStore {\n11:     private let contentRepository = homeContentRepository\n12:     private let sessionRepository = sessionRepository\n13:     private let filters = ArrayList<String>([\n14:         \"Fast Delivery\",\n15:         \"50% Discount\",\n16:         \"Great deals\",\n17:         \"Non-Veg\"\n18:     ])\n19: \n20:     public init() {}\n21: \n22:     public func loadHomeState(): HomePageState {\n23:         return HomePageState(\n24:             contentRepository.getAds(),\n25:             contentRepository.getFoodItems(),\n26:             sessionRepository.getLikedRestaurants(),\n27:             contentRepository.getRestaurants()\n28:         )\n29:     }\n30: \n31:     public func buildVisibleState(query: String): HomePageState {\n32:         let state = loadHomeState()\n33:         if (query == \"\") {\n34:             return state\n35:         }\n36:         return HomePageState(\n37:             state.advertisements,\n38:             state.categories,\n39:             filterRestaurants(state.favourites, query),\n40:             filterRestaurants(state.restaurants, query)\n41:         )\n42:     }\n43: \n44:     public func filtersList(): ArrayList<String> {\n45:         return filters\n46:     }\n47: \n48:     public func toggleFilter(currentFilter: String, tappedFilter: String): String {\n49:         if (currentFilter == tappedFilter) {\n50:             return \"\"\n51:         }\n52:         return tappedFilter\n53:     }\n54: \n55:     public func greetingForHour(hour: Int64): String {\n56:         if (hour >= 0 && hour <= 11) {\n57:             return \"Good Morning!\"\n58:         }\n59:         if (hour >= 12 && hour <= 15) {\n60:             return \"Good Afternoon!\"\n61:         }\n62:         return \"Good Evening!\"\n63:     }\n64: \n65:     public func selectRestaurant(restaurant: RestaurantData, onNavigate: () -> Unit): Unit {\n66:         sessionRepository.setSelectedRestaurant(restaurant)\n67:         onNavigate()\n68:     }\n69: \n70:     private func filterRestaurants(restaurants: ArrayList<RestaurantData>, query: String): ArrayList<RestaurantData> {\n71:         let filtered = ArrayList<RestaurantData>([])\n72:         for (restaurant in restaurants) {\n73:             if (matchesQuery(restaurant, query)) {\n74:                 filtered.add(restaurant)\n75:             }\n76:         }\n77:         return filtered\n78:     }\n79: \n80:     private func matchesQuery(restaurant: RestaurantData, query: String): Bool {\n81:         return containsText(restaurant.name, query)\n82:             || containsText(restaurant.variety, query)\n83:             || containsText(restaurant.place, query)\n84:     }\n85: \n86:     private func containsText(source: String, query: String): Bool {\n87:         let sourceLength = source.size\n88:         let queryLength = query.size\n89:         if (queryLength == 0) {\n90:             return true\n91:         }\n92:         if (queryLength > sourceLength) {\n93:             return false\n94:         }\n95:         var start: Int64 = 0\n96:         while (start + queryLength <= sourceLength) {\n97:             if (source.substring(start, start + queryLength) == query) {\n98:                 return true\n99:             }\n100:             start += 1\n101:         }\n102:         return false\n103:     }\n104: \n105:     public func session(): SessionRepository {\n106:         return sessionRepository\n107:     }\n108: }\n\n(End of file - total 108 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.homeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\npublic let homeStore = HomeStore()\n\npublic class HomeStore {\n    private let contentRepository = homeContentRepository\n    private let sessionRepository = sessionRepository\n    private let filters = ArrayList<String>([\n        \"Fast Delivery\",\n        \"50% Discount\",\n        \"Great deals\",\n        \"Non-Veg\"\n    ])\n\n    public init() {}","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_store.cj","time":{"start":1782637775482,"end":1782637775501}},"id":"prt_f0d7dca77001eB4UOL70vPHo1L","sessionID":"ses_0f283616bffe00QcVZpvUWDRDJ","messageID":"msg_f0d7d7f340017Mxe8AgAwIkFjw"}}
