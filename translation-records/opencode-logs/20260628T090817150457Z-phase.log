avourites(state.favourites, query), state.records)\n30:     }\n31: \n32:     public func tabLabel(index: Int64): ResourceStr {\n33:         if (index == 0) {\n34:             return stringHistory\n35:         }\n36:         return stringFavourite\n37:     }\n38: \n39:     public func tabLabelText(index: Int64): String {\n40:         if (index == 0) {\n41:             return \"History\"\n42:         }\n43:         return \"Favourites\"\n44:     }\n45: \n46:     public func selectRestaurant(restaurant: RestaurantData, onNavigate: () -> Unit): Unit {\n47:         sessionRepository.setSelectedRestaurant(restaurant)\n48:         onNavigate()\n49:     }\n50: \n51:     private func filterFavourites(favourites: ArrayList<RestaurantData>, query: String): ArrayList<RestaurantData> {\n52:         let filtered = ArrayList<RestaurantData>([])\n53:         for (restaurant in favourites) {\n54:             if (matchesQuery(restaurant, query)) {\n55:                 filtered.add(restaurant)\n56:             }\n57:         }\n58:         return filtered\n59:     }\n60: \n61:     private func matchesQuery(restaurant: RestaurantData, query: String): Bool {\n62:         return containsText(restaurant.name, query)\n63:             || containsText(restaurant.variety, query)\n64:             || containsText(restaurant.place, query)\n65:     }\n66: \n67:     private func containsText(source: String, query: String): Bool {\n68:         let sourceLength = source.size\n69:         let queryLength = query.size\n70:         if (queryLength == 0) {\n71:             return true\n72:         }\n73:         if (queryLength > sourceLength) {\n74:             return false\n75:         }\n76:         var start: Int64 = 0\n77:         while (start + queryLength <= sourceLength) {\n78:             if (source.substring(start, start + queryLength) == query) {\n79:                 return true\n80:             }\n81:             start += 1\n82:         }\n83:         return false\n84:     }\n85: \n86:     public func session(): SessionRepository {\n87:         return sessionRepository\n88:     }\n89: }\n\n(End of file - total 89 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history\n\nimport ohos.base.ResourceStr\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{stringFavourite, stringHistory}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\npublic let historyStore = HistoryStore()\n\npublic class HistoryStore {\n    private let sessionRepository = sessionRepository\n    private let orderHistory = ArrayList<HistoryRecordData>([\n        HistoryRecordData(\"Fish n Rolls\", \"Tezpur\", \"13 Aug 2022, 11:12 PM\", \"$7.90\", \"Chinese Shawarma\\nCombo (1)\", false, 5, 5, \"Delivered\", \"Reorder\"),\n        HistoryRecordData(\"Fish n Rolls\", \"Tezpur\", \"13 Aug 2022, 11:12 PM\", \"$7.90\", \"Chinese Shawarma\\nCombo (1)\", false, 0, 0, \"Delivered\", \"Rate Order\")\n    ])\n\n    public init() {}\n\n    public func loadHistoryState(): HistoryPageState {","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_store.cj","time":{"start":1782637755711,"end":1782637755738}},"id":"prt_f0d7d7d3d0014udaAqi5h8u8BK","sessionID":"ses_0f283616bffe00QcVZpvUWDRDJ","messageID":"msg_f0d7d4fd6001nBfrBwPYkMyyDs"}}
{"type":"tool_use","timestamp":1782637755745,"sessionID":"ses_0f283616bffe00QcVZpvUWDRDJ","part":{"type":"tool","tool":"read","callID":"call_CiFcaQisqi0O3OnOxxwazV0H","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_page.cj","limit":420,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history\n2: \n3: import kit.ArkUI.*\n4: import ohos.arkui.state_macro_manage.Builder\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaIcNonVeg, mediaIcVeg, stringEmpty}\n6: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.{renderRestaurantCard, renderSearchBar}\n7: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n8: import std.collection.ArrayList\n9: \n10: @Builder\n11: func buildHistoryTabs(selectedTab: Int64, onTabSelect: (Int64) -> Unit) {\n12:     Row(space: 18) {\n13:         Text(historyStore.tabLabel(0))\n14:             .fontSize(18)\n15:             .fontWeight(if (selectedTab == 0) { FontWeight.Bold } else { FontWeight.Regular })\n16:             .onClick({ _ =>\n17:                 onTabSelect(0)\n18:             })\n19:         Text(historyStore.tabLabel(1))\n20:             .fontSize(18)\n21:             .fontWeight(if (selectedTab == 1) { FontWeight.Bold } else { FontWeight.Regular })\n22:             .onClick({ _ =>\n23:                 onTabSelect(1)\n24:             })\n25:     }\n26:     .width(100.percent)\n27: }\n28: \n29: @Builder\n30: func buildHistoryStatusRow(statusText: String) {\n31:     Row(space: 6) {\n32:         Text(statusText)\n33:             .fontSize(14)\n34:             .fontColor(Color.Gray)\n35:         Text(\".\")\n36:             .fontWeight(FontWeight.Bold)\n37:             .fontColor(0xFF228D39)\n38:     }\n39: }\n40: \n41: @Builder\n42: func buildHistoryRecordCard(record: HistoryRecordData) {\n43:     Column(space: 10) {\n44:         Row {\n45:             Column(space: 4) {\n46:                 Text(record.restaurantName)\n47:                     .fontWeight(FontWeight.Bold)\n48:                 Text(record.place)\n49:                     .fontSize(14)\n50:                     .fontColor(Color.Gray)\n51:                 Text(record.timestampText)\n52:                     .fontSize(14)\n53:                     .fontColor(Color.Gray)\n54:             }\n55:             .layoutWeight(1)\n56:             Text(record.totalText)\n57:                 .fontSize(16)\n58:         }\n59: \n60:         Divider().width(100.percent)\n61: \n62:         Row(space: 10) {\n63:             Image(if (record.isVeg) { mediaIcVeg } else { mediaIcNonVeg })\n64:                 .width(16)\n65:                 .height(16)\n66:             Text(record.itemSummary)\n67:                 .layoutWeight(1)\n68:                 .fontSize(14)\n69:             Button(record.actionText)\n70:         }\n71:         .alignItems(VerticalAlign.Center)\n72: \n73:         if (record.deliveryRating > 0) {\n74:             Row {\n75:                 Column(space: 4) {\n76:                     Text(\"Your rating for delivery\")\n77:                         .fontSize(14)\n78:                         .fontColor(Color.Gray)\n79:                     Text(\"Your rating for food\")\n80:                         .fontSize(14)\n81:                         .fontColor(Color.Gray)\n82:                 }\n83:                 .layoutWeight(1)\n84:                 Column(space: 4) {\n85:                     Text(\"* ${record.deliveryRating}\")\n86:                     Text(\"* ${record.foodRating}\")\n87:                 }\n88:                 buildHistoryStatusRow(record.statusText)\n89:             }\n90:             .alignItems(VerticalAlign.Center)\n91:         } else {\n92:             Row {\n93:                 Text(record.actionText)\n94:                     .fontSize(16)\n95:                     .fontWeight(FontWeight.Bold)\n96:                     .fontColor(0xFF228D39)\n97:                 Blank().layoutWeight(1)\n98:                 buildHistoryStatusRow(record.statusText)\n99:             }\n100:             .alignItems(VerticalAlign.Center)\n101:         }\n102:     }\n103:     .width(100.percent)\n104:     .padding(top: 14, right: 14, bottom: 14, left: 14)\n105:     .backgroundColor(Color.White)\n106:     .borderRadius(16)\n107: }\n108: \n109: @Builder\n110: func buildHistoryRecords(records: ArrayList<HistoryRecordData>) {\n111:     Column(space: 10) {\n112:         ForEach(records, itemGeneratorFunc: { record: HistoryRecordData, _: Int64 =>\n113:             buildHistoryRecordCard(record)\n114:         })\n115:     }\n116:     .width(100.percent)\n117: }\n118: \n119: @Builder\n120: func buildHistoryFavourites(favourites: ArrayList<RestaurantData>, onSelectRestaurant: (RestaurantData) -> Unit) {\n121:     if (favourites.size > 0) {\n122:         Column(space: 10) {\n123:             ForEach(favourites, itemGeneratorFunc: { restaurant: RestaurantData, _: Int64 =>\n124:                 renderRestaurantCard(restaurant, { =>\n125:                     onSelectRestaurant(restaurant)\n126:                 })\n127:             })\n128:         }\n129:         .width(100.percent)\n130:     } else {\n131:         Row {\n132:             Text(stringEmpty)\n133:                 .fontSize(16)\n134:         }\n135:         .width(100.percent)\n136:         .justifyContent(FlexAlign.Center)\n137:     }\n138: }\n139: \n140: @Builder\n141: public func renderHistoryRoute(\n142:     state: HistoryPageState,\n143:     selectedTab: Int64,\n144:     query: String,\n145:     onQueryChange: (String) -> Unit,\n146:     onTabSelect: (Int64) -> Unit,\n147:     onSelectRestaurant: (RestaurantData) -> Unit\n148: ) {\n149:     Scroll(Scroller()) {\n150:         Column(space: 14) {\n151:             renderSearchBar(query, onQueryChange)\n152:             buildHistoryTabs(selectedTab, onTabSelect)\n153:             if (selectedTab == 0) {\n154:                 buildHistoryRecords(state.records)\n155:             } else {\n156:                 buildHistoryFavourites(state.favourites, onSelectRestaurant)\n157:             }\n158:         }\n159:         .width(100.percent)\n160:         .padding(top: 16, right: 16, bottom: 24, left: 16)\n161:     }\n162:     .scrollable(ScrollDirection.Vertical)\n163:     .scrollBar(BarState.Off)\n164:     .width(100.percent)\n165:     .height(100.percent)\n166:     .backgroundColor(Color.White)\n167: }\n\n(End of file - total 167 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaIcNonVeg, mediaIcVeg, stringEmpty}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.{renderRestaurantCard, renderSearchBar}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\n@Builder\nfunc buildHistoryTabs(selectedTab: Int64, onTabSelect: (Int64) -> Unit) {\n    Row(space: 18) {\n        Text(historyStore.tabLabel(0))\n            .fontSize(18)\n            .fontWeight(if (selectedTab == 0) { FontWeight.Bold } else { FontWeight.Regular })\n            .onClick({ _ =>\n                onTabSelect(0)\n            })\n        Text(historyStore.tabLabel(1))\n            .fontSize(18)","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_page.cj","time":{"start":1782637755731,"end":1782637755743}},"id":"prt_f0d7d7d51001IsRsKElH1M768C","sessionID":"ses_0f283616bffe00QcVZpvUWDRDJ","messageID":"msg_f0d7d4fd6001nBfrBwPYkMyyDs"}}
