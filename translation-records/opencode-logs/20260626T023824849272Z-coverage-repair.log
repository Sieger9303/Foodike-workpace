xpanded\n186:         )\n187:     }\n188: \n189:     private func selectHomeRestaurant(restaurant: RestaurantData): Unit {\n190:         homeStore.selectRestaurant(restaurant, { =>\n191:             this.goToRestaurantDetail()\n192:         })\n193:     }\n194: \n195:     private func selectHistoryRestaurant(restaurant: RestaurantData): Unit {\n196:         historyStore.selectRestaurant(restaurant, { =>\n197:             this.goToRestaurantDetail()\n198:         })\n199:     }\n200: \n201:     @Builder\n202:     private func buildOnboardingRoute() {\n203:         renderOnboardingRoute(\n204:             this.onboardingPageIndex,\n205:             this.onboardingController,\n206:             { index: Int32 =>\n207:                 this.onboardingPageIndex = Int64(index)\n208:             },\n209:             { =>\n210:                 if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n211:                     this.navigateTo(routePath(RouteId.Login))\n212:                 } else {\n213:                     this.onboardingController.showNext()\n214:                 }\n215:             }\n216:         )\n217:     }\n218: \n219:     @Builder\n220:     private func buildLoginRoute() {\n\n(Showing lines 1-220 of 409. Use offset=221 to continue.)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos.arkui.state_macro_manage.Component\nimport ohos.arkui.state_macro_manage.Entry\nimport ohos.arkui.state_macro_manage.State\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.RestaurantData\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.{cartStore, renderCartRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.{detailStore, renderDetailRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history.{historyStore, renderH