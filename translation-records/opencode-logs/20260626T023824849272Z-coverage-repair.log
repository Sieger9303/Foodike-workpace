{"type":"tool_use","timestamp":1782441559538,"sessionID":"ses_0fe350a51ffeC6mguZVvqFEyD1","part":{"type":"tool","tool":"read","callID":"call_G5qiaApePLDVwgxKpPZ7u5RT","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\cart\\cart_page.cj"},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\cart\\cart_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart\n2: \n3: import kit.ArkUI.*\n4: import ohos.arkui.state_macro_manage.Builder\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n6: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaIcNonVeg, mediaIcVeg}\n7: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n8: import std.collection.ArrayList\n9: \n10: @Builder\n11: func buildCartTopBar(onBack: () -> Unit) {\n12:     Row {\n13:         Button(\"x\")\n14:             .onClick({ _ =>\n15:                 onBack()\n16:             })\n17:         Blank().layoutWeight(1)\n18:     }\n19:     .width(100.percent)\n20:     .alignItems(VerticalAlign.Center)\n21: }\n22: \n23: @Builder\n24: func buildCartQuantityPill(quantity: Int64) {\n25:     Row(space: 10) {\n26:         Text(\"-\")\n27:             .fontSize(16)\n28:             .fontWeight(FontWeight.Bold)\n29:         Text(\"${quantity}\")\n30:             .fontSize(16)\n31:             .fontWeight(FontWeight.Medium)\n32:         Text(\"+\")\n33:             .fontSize(16)\n34:             .fontWeight(FontWeight.Bold)\n35:             .fontColor(colorDarkGreen)\n36:     }\n37:     .padding(top: 6, right: 10, bottom: 6, left: 10)\n38:     .borderRadius(14)\n39:     .border(width: 1.px, color: 0x55000000)\n40: }\n41: \n42: @Builder\n43: func buildCartItemRow(item: CartSnapshotItemData) {\n44:     Row(space: 16) {\n45:         Image(if (item.menuItem.isVegetarian) { mediaIcVeg } else { mediaIcNonVeg })\n46:             .width(18)\n47:             .height(18)\n48:         Column(space: 6) {\n49:             Text(item.menuItem.dish)\n50:                 .fontSize(16)\n51:                 .fontWeight(FontWeight.Medium)\n52:             Text(cartStore.formatPrice(item.menuItem.price))\n53:                 .fontSize(14)\n54:                 .fontColor(Color.Gray)\n55:         }\n56:         .layoutWeight(1)\n57:         buildCartQuantityPill(item.quantity)\n58:     }\n59:     .width(100.percent)\n60:     .alignItems(VerticalAlign.Center)\n61: }\n62: \n63: @Builder\n64: func buildItemSection(items: ArrayList<CartSnapshotItemData>, note: String, onNoteChange: (String) -> Unit) {\n65:     Column(space: 14) {\n66:         if (items.size > 0) {\n67:             ForEach(items, itemGeneratorFunc: { item: CartSnapshotItemData, _: Int64 =>\n68:                 buildCartItemRow(item)\n69:             })\n70:         } else {\n71:             Row {\n72:                 Text(\"Empty\")\n73:                     .fontSize(16)\n74:             }\n75:             .width(100.percent)\n76:             .justifyContent(FlexAlign.Center)\n77:         }\n78: \n79:         Divider().width(100.percent)\n80: \n81:         TextInput(text: note, placeholder: \"Write instruction for restaurant...\")\n82:             .width(100.percent)\n83:             .height(52)\n84:             .fontSize(15)\n85:             .placeholderColor(Color.Gray)\n86:             .backgroundColor(Color.White)\n87:             .onChange({ value: String =>\n88:                 onNoteChange(value)\n89:             })\n90:     }\n91:     .width(100.percent)\n92:     .padding(top: 18, right: 18, bottom: 18, left: 18)\n93:     .backgroundColor(Color.White)\n94:     .borderRadius(22)\n95: }\n96: \n97: @Builder\n98: func buildCouponBar(coupon: String, onCouponChange: (String) -> Unit) {\n99:     Row(space: 12) {\n100:         TextInput(text: coupon, placeholder: \"Add a coupon code...\")\n101:             .layoutWeight(1)\n102:             .height(52)\n103:             .fontSize(15)\n104:             .placeholderColor(Color.Gray)\n105:             .backgroundColor(Color.White)\n106:             .borderRadius(26)\n107:             .onChange({ value: String =>\n108:                 onCouponChange(value)\n109:             })\n110:         Text(\"APPLY\")\n111:             .fontSize(15)\n112:             .fontWeight(FontWeight.Bold)\n113:             .fontColor(colorDarkGreen)\n114:     }\n115:     .width(100.percent)\n116:     .padding(top: 14, right: 18, bottom: 14, left: 18)\n117:     .backgroundColor(Color.White)\n118:     .borderRadius(26)\n119:     .alignItems(VerticalAlign.Center)\n120: }\n121: \n122: @Builder\n123: func buildDeliverySection(restaurant: RestaurantData) {\n124:     Column(space: 12) {\n125:         Row {\n126:             Text(\"Deliver to:\")\n127:                 .fontWeight(FontWeight.Bold)\n128:             Blank().layoutWeight(1)\n129:             Text(\"Edit\")\n130:                 .fontColor(Color.Gray)\n131:         }\n132:         .width(100.percent)\n133: \n134:         Row {\n135:             Column(space: 6) {\n136:                 Text(\"Location:\")\n137:                 Text(\"Estimated time:\")\n138:             }\n139:             .layoutWeight(1)\n140:             Column(space: 6) {\n141:                 Text(cartStore.deliveryLocation())\n142:                 Text(cartStore.formatEta(restaurant.etaMinutes))\n143:             }\n144:         }\n145:         .width(100.percent)\n146:     }\n147:     .width(100.percent)\n148:     .padding(top: 18, right: 18, bottom: 18, left: 18)\n149:     .backgroundColor(Color.White)\n150:     .borderRadius(22)\n151: }\n152: \n153: @Builder\n154: func buildBillSection(itemTotal: Float64) {\n155:     Column(space: 12) {\n156:         Text(\"Bill Details\")\n157:             .fontSize(18)\n158:             .fontWeight(FontWeight.Bold)\n159:         Row {\n160:             Column(space: 6) {\n161:                 Text(\"Item total:\")\n162:                 Text(\"Taxes and charges:\")\n163:                 Text(\"Total:\")\n164:             }\n165:             .layoutWeight(1)\n166:             Column(space: 6) {\n167:                 Text(cartStore.formatPrice(itemTotal))\n168:                 Text(cartStore.formatPrice(cartStore.taxAmount(itemTotal)))\n169:                 Text(cartStore.formatPrice(cartStore.grandTotal(itemTotal)))\n170:             }\n171:         }\n172:         .width(100.percent)\n173:         Button(\"Proceed to Pay\")\n174:             .width(220)\n175:             .height(48)\n176:     }\n177:     .width(100.percent)\n178:     .padding(top: 18, right: 18, bottom: 18, left: 18)\n179:     .backgroundColor(Color.White)\n180:     .borderRadius(22)\n181:     .alignItems(HorizontalAlign.Center)\n182: }\n183: \n184: @Builder\n185: public func renderCartRoute(\n186:     state: CartPageState,\n187:     note: String,\n188:     coupon: String,\n189:     onNoteChange: (String) -> Unit,\n190:     onCouponChange: (String) -> Unit,\n191:     onBack: () -> Unit\n192: ) {\n193:     Scroll(Scroller()) {\n194:         Column(space: 16) {\n195:             buildCartTopBar(onBack)\n196:             buildItemSection(cartStore.visibleItems(state.items), note, onNoteChange)\n197:             buildCouponBar(coupon, onCouponChange)\n198:             buildDeliverySection(state.deliveryRestaurant)\n199:             buildBillSection(cartStore.itemTotal(cartStore.visibleItems(state.items)))\n200:         }\n201:         .width(100.percent)\n202:         .padding(top: 14, right: 16, bottom: 24, left: 16)\n203:     }\n204:     .scrollable(ScrollDirection.Vertical)\n205:     .scrollBar(BarState.Off)\n206:     .width(100.percent)\n207:     .height(100.percent)\n208:     .backgroundColor(0xFFE8E7E7)\n209: }\n\n(End of file - total 209 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.car