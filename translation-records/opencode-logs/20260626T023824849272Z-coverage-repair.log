contentDescription = stringResource(R.string.outlet),\n126:                 )\n127:                 Column(\n128:                     modifier = Modifier.fillMaxHeight(),\n129:                     verticalArrangement = Arrangement.SpaceBetween\n130:                 ) {\n131:                     Row {\n132:                         Text(\n133:                             text = stringResource(R.string.outlet_2),\n134:                             fontSize = 16.sp\n135:                         )\n136:                     }\n137:                     Row {\n138:                         Text(text = restaurant.timeInMillis.getTimeInMins())\n139:                     }\n140:                 }\n141:                 Spacer(modifier = Modifier.width(24.dp))\n142:                 Column(\n143:                     modifier = Modifier.fillMaxHeight(),\n144:                     verticalArrangement = Arrangement.SpaceBetween,\n145:                     horizontalAlignment = Alignment.Start\n146:                 ) {\n147:                     Row {\n148:                         Text(\n149:                             text = restaurant.place, modifier = Modifier.alpha(0.5f),\n150:                         )\n151:                     }\n152:                     Row {\n153:                         Text(\n154:                             text = stringResource(R.string.your_location),\n155:                             modifier = Modifier.alpha(0.5f),\n156:                         )\n157:                     }\n158:                 }\n159:             }\n160:         }\n161:     }\n162: }\n\n(End of file - total 162 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, 