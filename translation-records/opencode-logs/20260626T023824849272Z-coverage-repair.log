t {\n99:         let targetRoute = this.previousRoute\n100:         this.previousRoute = this.currentRoute\n101:         this.navigateTo(targetRoute)\n102:     }\n103: \n104:     private func showBottomShell(route: String): Bool {\n105:         let shellState = this.shellState()\n106:         shellState.currentRoute = route\n107:         return shellState.showBottomShell()\n108:     }\n109: \n110:     private func routeTitle(route: String): String {\n111:         match (route) {\n112:             case \"onboarding\" => \"Onboarding\"\n113:             case \"login_screen\" => \"Login\"\n114:             case \"home_screen\" => \"Home\"\n115:             case \"history\" => \"History\"\n116:             case \"cart\" => \"Cart\"\n117:             case \"profile\" => \"Profile\"\n118:             case \"restaurant_details\" => \"Restaurant Detail\"\n119:             case _ => \"Unknown Route\"\n120:         }\n121:     }\n122: \n123:     private func showToast(message: String): Unit {\n124:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n125:     }\n126: \n127:     private func clearLoginError(): Unit {\n128:         this.loginErrorMessage = \"\"\n129:     }\n130: \n131:     private func performLogin(): Unit {\n132:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n133:             this.clearLoginError()\n134:             this.navigateTo(loginStore.successRoute())\n135:             return\n136:         }\n137: \n138:         this.loginErrorMessage = loginStore.invalidLoginMessage\n139:         this.showToast(loginStore.invalidLoginMessage)\n140:     }\n141: \n142:     private func performLogout(): Unit {\n143:         profileStore.logout(Global.abilityContext)\n144:         this.loginEmail = \"\"\n145:         this.loginPassword = \"\"\n146:         this.clearLoginError()\n147:         this.onboardingPageIndex = 0\n148:         this.homeSearchQuery = \"\"\n149:         this.homeSelected