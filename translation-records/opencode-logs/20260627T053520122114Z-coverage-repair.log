{"type":"tool_use","timestamp":1782538561498,"sessionID":"ses_0f86cb423ffe1noErgvu8EkkFy","part":{"type":"tool","tool":"read","callID":"call_e56TKn7P6X1WvmUCFoKOPWx5","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\app_ability.cj","limit":250,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\app_ability.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry\n2: \n3: import kit.AbilityKit.LaunchParam\n4: import kit.AbilityKit.LaunchReason\n5: import kit.AbilityKit.UIAbility\n6: import kit.AbilityKit.Want\n7: import kit.ArkUI.WindowStage\n8: import kit.PerformanceAnalysisKit.Hilog\n9: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.startup.StartupLaunchService\n10: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.runtime.Global\n11: \n12: class EntryAbility <: UIAbility {\n13:     private let startupLaunchService = StartupLaunchService()\n14: \n15:     public init() {\n16:         super()\n17:         registerSelf()\n18:     }\n19: \n20:     public override func onCreate(want: Want, launchParam: LaunchParam): Unit {\n21:         Hilog.info(0x0000, \"Foodike\", \"EntryAbility created for ${want.abilityName}\")\n22:         match (launchParam.launchReason) {\n23:             case LaunchReason.StartAbility => Hilog.info(0x0000, \"Foodike\", \"Launcher startup request received\")\n24:             case _ => ()\n25:         }\n26: \n27:         let isLoggedIn = startupLaunchService.resolveLaunchRoute(context)\n28: \n29:         if (isLoggedIn) {\n30:             Hilog.info(0x0000, \"Foodike\", \"Startup login state resolved to home\")\n31:         } else {\n32:             Hilog.info(0x0000, \"Foodike\", \"Startup login state resolved to onboarding\")\n33:         }\n34:     }\n35: \n36:     public override func onWindowStageCreate(windowStage: WindowStage): Unit {\n37:         Hilog.info(0x0000, \"Foodike\", \"Loading Foodike bootstrap content\")\n38:         Global._abilityContext = Some(this.context)\n39:         Global._windowStage = Some(windowStage)\n40:         windowStage.loadContent(\"FoodikeBootstrap\")\n41:     }\n42: }\n\n(End of file - total 42 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry\n\nimport kit.AbilityKit.LaunchParam\nimport kit.AbilityKit.LaunchReason\nimport kit.AbilityKit.UIAbility\nimport kit.AbilityKit.Want\nimport kit.ArkUI.WindowStage\nimport kit.PerformanceAnalysisKit.Hilog\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.startup.StartupLaunchService\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.runtime.Global\n\nclass EntryAbility <: UIAbility {\n    private let startupLaunchService = StartupLaunchService()\n\n    public init() {\n        super()\n        registerSelf()\n    }\n\n    public override func onCreate(want: Want, launchParam: LaunchParam): Unit {","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\app_ability.cj","time":{"start":1782538561492,"end":1782538561497}},"id":"prt_f0793e7d3001Sy9Sc4hnYIX9Bv","sessionID":"ses_0f86cb423ffe1noErgvu8EkkFy","messageID":"msg_f0793a73e0011M44rhkVStU6hx"}}
