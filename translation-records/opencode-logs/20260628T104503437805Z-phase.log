59:                                 .fillMaxWidth()\n260:                                 .padding(24.dp, 0.dp)\n261:                         )\n262:                     }\n263:                 }\n264:             }\n265: \n266:             val vegList = detailScreenState.menuList.filter {\n267:                 it.menuItem.isVegetarian\n268:             }\n269: \n270:             item {\n271:                 Row(\n272:                     modifier = Modifier\n273:                         .fillMaxWidth()\n274:                         .padding(24.dp, 0.dp),\n275:                     verticalAlignment = Alignment.CenterVertically,\n276:                     horizontalArrangement = Arrangement.Center\n277: \n278:                 ) {\n279:                     Text(\n280:                         modifier = Modifier\n281:                             .weight(6f),\n282:                         text = stringResource(R.string.vegetarian),\n283:                         fontSize = 24.sp,\n284:                         fontWeight = FontWeight.Bold,\n285:                         maxLines = 1,\n286:                         overflow = TextOverflow.Ellipsis\n287:                     )\n288:                     IconButton(\n289:                         modifier = Modifier\n290:                             .weight(1f)\n291:                             .alpha(ContentAlpha.medium)\n292:                             .rotate(rotationStateVeg),\n293:                         onClick = {\n294:                             viewModel.onEvent(DetailScreenEvent.ToggleVegSectionExpandedState)\n295:                         }) {\n296:                         Icon(\n297:                             imageVector = Icons.Default.ArrowDropDown,\n298:                             contentDescription = stringResource(R.string.drop_down_arrow)\n299:                         )\n300:                     }\n301: \n302:                 }\n303: \n304:             }\n305:             if (detailScreenState.vegExpandedSta