                      modifier = Modifier\n167:                             .weight(6f),\n168:                         text = stringResource(R.string.recommended),\n169:                         fontSize = 24.sp,\n170:                         fontWeight = FontWeight.Bold,\n171:                         maxLines = 1,\n172:                         overflow = TextOverflow.Ellipsis\n173:                     )\n174:                     IconButton(\n175:                         modifier = Modifier\n176:                             .weight(1f)\n177:                             .alpha(ContentAlpha.medium)\n178:                             .rotate(rotationState),\n179:                         onClick = {\n180:                             viewModel.onEvent(DetailScreenEvent.ToggleRecommendedSectionExpandedState)\n181:                         }) {\n182:                         Icon(\n183:                             imageVector = Icons.Default.ArrowDropDown,\n184:                             contentDescription = stringResource(R.string.drop_down_arrow)\n185:                         )\n186:                     }\n187: \n188:                 }\n189: \n190:             }\n191:             if (detailScreenState.recommendedExpandedState) {\n192: \n193:                 items(recommendedList.size) {\n194:                     MenuItemCard(\n195:                         menuItem = recommendedList[it].menuItem,\n196: \n197: \n198:                         )\n199:                     if (it != (recommendedList.size - 1)) {\n200:                         Divider(\n201:                             modifier = Modifier\n202:                                 .fillMaxWidth()\n203:                                 .padding(24.dp, 0.dp)\n204:                         )\n205:                     }\n206:                 }\n207: \n208: \n209:             }\n210: \n211:             val nonVegList = detailScreenState.menuList.filter {\n212:                 !it.menuItem.isVegetarian\n213:             }\n214: