{"type":"tool_use","timestamp":1782365866222,"sessionID":"ses_102b9de8dffe6FNc2AwM60MJ5O","part":{"type":"tool","tool":"read","callID":"call_kg8T4ru17p9jONXZhMcvkYBz","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj","limit":120},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n2: \n3: import kit.ArkUI.*\n4: import ohos.arkui.state_macro_manage.Component\n5: import ohos.arkui.state_macro_manage.Entry\n6: import ohos.arkui.state_macro_manage.State\n7: \n8: @Entry\n9: @Component\n10: class FoodikeBootstrap {\n11:     @State\n12:     var currentRoute: String = bootstrapStartRoute\n13: \n14:     @State\n15:     var isShellAtTop: Bool = true\n16: \n17:     private func applyShellState(shellState: ShellRouteState): Unit {\n18:         this.currentRoute = shellState.currentRoute\n19:         this.isShellAtTop = shellState.isAtTop\n20:     }\n21: \n22:     private func shellState(): ShellRouteState {\n23:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n24:     }\n25: \n26:     private func applyShellCommand(command: ShellCommand): Unit {\n27:         let shellState = this.shellState()\n28:         shellState.applyCommand(command)\n29:         this.applyShellState(shellState)\n30:     }\n31: \n32:     private func navigateTo(route: String): Unit {\n33:         let shellState = this.shellState()\n34:         shellState.currentRoute = route\n35:         this.applyShellState(shellState)\n36:     }\n37: \n38:     private func showBottomShell(route: String): Bool {\n39:         let shellState = this.shellState()\n40:         shellState.currentRoute = route\n41:         shellState.showBottomShell()\n42:     }\n43: \n44:     private func routeTitle(route: String): String {\n45:         match (route) {\n46:             case \"onboarding\" => \"Onboarding\"\n47:             case \"login_screen\" => \"Login\"\n48:             case \"home_screen\" => \"Home\"\n49:             case \"history\" => \"History\"\n50:             case \"cart\" => \"Cart\"\n51:             case \"profile\" => \"Profile\"\n52:             case \"restaurant_details\" => \"Restaurant Detail\"\n53:             case _ => \"Unknown Route\"\n54:         }\n55:     }\n56: \n57:     private func routeSummary(route: String): String {\n58:         match (route) {\n59:             case \"onboarding\" => \"Logged-out startup resolves here first, and the primary action advances to login.\"\n60:             case \"login_screen\" => \"Login stays in the route host and hands off to home once the session flow succeeds.\"\n61:             case \"home_screen\" => \"Home owns the shared shell chrome, including the conditional bottom bar and cart command.\"\n62:             case \"history\" => \"History shares the same shell-owned bottom bar and floating cart command as home.\"\n63:             case \"cart\" => \"Cart is reached from the shell-owned cart action without replacing the startup route contract.\"\n64:             case \"profile\" => \"Profile remains in the phase-02 route host so logout can later hand control back to onboarding.\"\n65:             case \"restaurant_details\" => \"Restaurant detail remains part of the route host even before full content arrives in later phases.\"\n66:             case _ => \"No summary available.\"\n67:         }\n68:     }\n69: \n70:     private func primaryActionLabel(route: String): String {\n71:         match (route) {\n72:             case \"onboarding\" => \"Continue to Login\"\n73:             case \"login_screen\" => \"Enter Home\"\n74:             case \"home_screen\" => \"Open Restaurant Detail\"\n75:             case \"history\" => \"Open Profile\"\n76:             case \"cart\" => \"Return Home\"\n77:             case \"profile\" => \"Log Out to Onboarding\"\n78:             case \"restaurant_details\" => \"Back to Home\"\n79:             case _ => \"Go Home\"\n80:         }\n81:     }\n82: \n83:     private func runPrimaryAction(): Unit {\n84:         this.applyShellCommand(ShellCommand.PrimaryAction)\n85:     }\n86: \n87:     func build() {\n88:         Row {\n89:             Column {\n90:                 Text(\"Foodike\")\n91:                     .fontSize(42)\n92:                 Text(\"Startup route host\")\n93:                     .fontSize(18)\n94:                 Text(this.routeTitle(this.currentRoute))\n95:                     .fontSize(26)\n96:                     .margin(top: 18)\n97:                 Text(this.routeSummary(this.currentRoute))\n98:                     .fontSize(16)\n99:                     .margin(top: 8)\n100: \n101:                 Text(\"Current route: ${this.currentRoute}\")\n102:                     .fontSize(14)\n103:                     .margin(top: 12)\n104: \n105:                 if (this.currentRoute == routePath(RouteId.Onboarding)) {\n106:                     Text(\"The source activity composes navigation only after startup picks a first destination. This route represents the logged-out path.\")\n107:                         .fontSize(14)\n108:                         .margin(top: 18)\n109:                 }\n110: \n111:                 if (this.currentRoute == routePath(RouteId.Login)) {\n112:                     Text(\"Login remains a dedicated destination inside the shared route host, just as `SetupNavigation` keeps it in the source destination graph.\")\n113:                         .fontSize(14)\n114:                         .margin(top: 18)\n115:                 }\n116: \n117:                 if (this.currentRoute == routePath(RouteId.Home) || this.currentRoute == routePath(RouteId.History)) {\n118:                     Text(\"The shared shell reacts to both the active route and the top-of-list state before showing bottom-bar commands.\")\n119:                         .fontSize(14)\n120:                         .margin(top: 18)\n\n(Showing lines 1-120 of 182. Use offset=121 to continue.)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Component\nimport ohos.arkui.state_macro_manage.Entry\nimport ohos.arkui.state_macro_manage.State\n\n@Entry\n@Component\nclass FoodikeBootstrap {\n    @State\n    var currentRoute: String = bootstrapStartRoute\n\n    @State\n    var isShellAtTop: Bool = true\n\n    private func applyShellState(shellState: ShellRouteState): Unit {\n        this.currentRoute = shellState.currentRoute\n        this.isShellAtTop = shellState.isAtTop\n    }","truncated":true,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj","time":{"start":1782365866215,"end":1782365866221}},"id":"prt_efd48c881001kCad552uDM8jl1","sessionID":"ses_102b9de8dffe6FNc2AwM60MJ5O","messageID":"msg_efd48a67c001h4waqpyZtCg6kP"}}
