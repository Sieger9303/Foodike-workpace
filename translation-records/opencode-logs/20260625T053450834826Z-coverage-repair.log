{"type":"tool_use","timestamp":1782365715452,"sessionID":"ses_102b9de8dffe6FNc2AwM60MJ5O","part":{"type":"tool","tool":"read","callID":"call_4KBndSkt6eVByO8wI3gEUZUt","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\app_router.cj","limit":260},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\app_router.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n2: \n3: public enum RouteId {\n4:     | Onboarding\n5:     | Login\n6:     | Home\n7:     | History\n8:     | Cart\n9:     | Profile\n10:     | RestaurantDetails\n11: }\n12: \n13: public func routePath(route: RouteId): String {\n14:     match (route) {\n15:         case RouteId.Onboarding => \"onboarding\"\n16:         case RouteId.Login => \"login_screen\"\n17:         case RouteId.Home => \"home_screen\"\n18:         case RouteId.History => \"history\"\n19:         case RouteId.Cart => \"cart\"\n20:         case RouteId.Profile => \"profile\"\n21:         case RouteId.RestaurantDetails => \"restaurant_details\"\n22:     }\n23: }\n24: \n25: public func resolveStartRoute(isLoggedIn: Bool): String {\n26:     if (isLoggedIn) {\n27:         routePath(RouteId.Home)\n28:     } else {\n29:         routePath(RouteId.Onboarding)\n30:     }\n31: }\n32: \n33: public func showsBottomShell(route: String, isAtTop: Bool): Bool {\n34:     if (!isAtTop) {\n35:         return false\n36:     }\n37: \n38:     route == routePath(RouteId.Home) || route == routePath(RouteId.History)\n39: }\n40: \n41: public func primaryActionTarget(route: String): String {\n42:     match (route) {\n43:         case \"onboarding\" => routePath(RouteId.Login)\n44:         case \"login_screen\" => routePath(RouteId.Home)\n45:         case \"home_screen\" => routePath(RouteId.RestaurantDetails)\n46:         case \"history\" => routePath(RouteId.Profile)\n47:         case \"cart\" => routePath(RouteId.Home)\n48:         case \"profile\" => routePath(RouteId.Onboarding)\n49:         case \"restaurant_details\" => routePath(RouteId.Home)\n50:         case _ => routePath(RouteId.Home)\n51:     }\n52: }\n\n(End of file - total 52 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\npublic enum RouteId {\n    | Onboarding\n    | Login\n    | Home\n    | History\n    | Cart\n    | Profile\n    | RestaurantDetails\n}\n\npublic func routePath(route: RouteId): String {\n    match (route) {\n        case RouteId.Onboarding => \"onboarding\"\n        case RouteId.Login => \"login_screen\"\n        case RouteId.Home => \"home_screen\"\n        case RouteId.History => \"history\"\n        case RouteId.Cart => \"cart\"\n        case RouteId.Profile => \"profile\"","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\app_router.cj","time":{"start":1782365715445,"end":1782365715452}},"id":"prt_efd467aa70010Bh8jBwXon7pWM","sessionID":"ses_102b9de8dffe6FNc2AwM60MJ5O","messageID":"msg_efd46655a001mwLJWOeKZDBniI"}}
