me)\n52:         case \"home_screen\" => routePath(RouteId.RestaurantDetails)\n53:         case \"history\" => routePath(RouteId.Profile)\n54:         case \"cart\" => routePath(RouteId.Home)\n55:         case \"profile\" => routePath(RouteId.Onboarding)\n56:         case \"restaurant_details\" => routePath(RouteId.Home)\n57:         case _ => routePath(RouteId.Home)\n58:     }\n59: }\n60: \n61: public class ShellRouteState {\n62:     public var currentRoute: String\n63:     public var isAtTop: Bool\n64: \n65:     public init(currentRoute: String, isAtTop: Bool) {\n66:         this.currentRoute = currentRoute\n67:         this.isAtTop = isAtTop\n68:     }\n69: \n70:     private func navigateWithoutDuplicate(route: String): Unit {\n71:         if (this.currentRoute != route) {\n72:             this.currentRoute = route\n73:         }\n74:     }\n75: \n76:     public func applyCommand(command: ShellCommand): Unit {\n77:         match (command) {\n78:             case ShellCommand.HomeTab => this.navigateWithoutDuplicate(routePath(RouteId.Home))\n79:             case ShellCommand.HistoryTab => this.navigateWithoutDuplicate(routePath(RouteId.History))\n80:             case ShellCommand.CartAction => this.navigateWithoutDuplicate(routePath(RouteId.Cart))\n81:             case ShellCommand.PrimaryAction => this.navigateWithoutDuplicate(primaryActionTarget(this.currentRoute))\n82:         }\n83:     }\n84: \n85:     public func setTopState(isAtTop: Bool): Unit {\n86:         this.isAtTop = isAtTop\n87:     }\n88: \n89:     public func showBottomShell(): Bool {\n90:         showsBottomShell(this.currentRoute, this.isAtTop)\n91:     }\n92: }\n\n(End of file - total 92 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\npublic enum RouteId {\n    | Onboarding\n    | Login\n    | Home\n    | History\n    | Cart\n    | Profile\n    | RestaurantDetails\n}\n\npublic enum ShellCommand {\n    | HomeTab\n    | HistoryTab\n    | Car