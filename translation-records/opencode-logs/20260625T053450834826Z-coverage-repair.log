{"type":"tool_use","timestamp":1782365715614,"sessionID":"ses_102b9de8dffe6FNc2AwM60MJ5O","part":{"type":"tool","tool":"read","callID":"call_QQPD7OgqVEhNGuearbgZPuA4","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase02_startup_navigation_test.cj","limit":320},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase02_startup_navigation_test.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry\n2: \n3: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, primaryActionTarget, resolveStartRoute, routePath, showsBottomShell}\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.LoginPreferencesService\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.startup.StartupStore\n6: import std.unittest.*\n7: import std.unittest.testmacro.*\n8: \n9: @Test\n10: public class Phase02StartupNavigationTest {\n11:     @TestCase\n12:     public func resolvesLoggedOutUsersToOnboarding(): Unit {\n13:         @Assert(resolveStartRoute(false), \"onboarding\")\n14:     }\n15: \n16:     @TestCase\n17:     public func resolvesLoggedInUsersToHome(): Unit {\n18:         @Assert(resolveStartRoute(true), \"home_screen\")\n19:     }\n20: \n21:     @TestCase\n22:     public func bottomShellOnlyShowsOnTopLevelHomeAndHistoryRoutes(): Unit {\n23:         @Assert(showsBottomShell(routePath(RouteId.Home), true), true)\n24:         @Assert(showsBottomShell(routePath(RouteId.History), true), true)\n25:         @Assert(showsBottomShell(routePath(RouteId.Home), false), false)\n26:         @Assert(showsBottomShell(routePath(RouteId.Cart), true), false)\n27:     }\n28: \n29:     @TestCase\n30:     public func primaryActionTargetsMatchShellContract(): Unit {\n31:         @Assert(primaryActionTarget(routePath(RouteId.Onboarding)), routePath(RouteId.Login))\n32:         @Assert(primaryActionTarget(routePath(RouteId.Login)), routePath(RouteId.Home))\n33:         @Assert(primaryActionTarget(routePath(RouteId.Profile)), routePath(RouteId.Onboarding))\n34:     }\n35: \n36:     @TestCase\n37:     public func loginStateToggleRuleFlipsBothDirections(): Unit {\n38:         let service = LoginPreferencesService()\n39:         @Assert(service.nextLoginState(false), true)\n40:         @Assert(service.nextLoginState(true), false)\n41:     }\n42: \n43:     @TestCase\n44:     public func startupStorePublishesResolvedRouteAndClearsLoading(): Unit {\n45:         let store = StartupStore()\n46:         @Assert(store.resolveStartRoute(false), \"onboarding\")\n47:         @Assert(store.startDestination, \"onboarding\")\n48:         @Assert(store.isLoading, false)\n49: \n50:         @Assert(store.resolveStartRoute(true), \"home_screen\")\n51:         @Assert(store.startDestination, \"home_screen\")\n52:         @Assert(store.isLoading, false)\n53:     }\n54: }\n\n(End of file - total 54 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, primaryActionTarget, resolveStartRoute, routePath, showsBottomShell}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.LoginPreferencesService\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.startup.StartupStore\nimport std.unittest.*\nimport std.unittest.testmacro.*\n\n@Test\npublic class Phase02StartupNavigationTest {\n    @TestCase\n    public func resolvesLoggedOutUsersToOnboarding(): Unit {\n        @Assert(resolveStartRoute(false), \"onboarding\")\n    }\n\n    @TestCase\n    public func resolvesLoggedInUsersToHome(): Unit {\n        @Assert(resolveStartRoute(true), \"home_screen\")\n    }\n","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\test\\cangjie\\phase02_startup_navigation_test.cj","time":{"start":1782365715598,"end":1782365715614}},"id":"prt_efd467c8b001iODZHZCTdS3qgs","sessionID":"ses_102b9de8dffe6FNc2AwM60MJ5O","messageID":"msg