{"type":"tool_use","timestamp":1782538691294,"sessionID":"ses_0f86b033dffeEKhfxGCLxWyKsb","part":{"type":"tool","tool":"read","callID":"call_8rj6l1DdE3uFJvLDXbxGPDc0","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\data\\session\\login_preferences_service.cj","limit":260,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\data\\session\\login_preferences_service.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session\n2: \n3: import kit.AbilityKit.UIAbilityContext\n4: import kit.ArkData.Preferences\n5: import kit.ArkData.PreferencesValueType\n6: \n7: public class LoginPreferencesService {\n8:     public init() {}\n9: \n10:     public func preferenceFileName(): String {\n11:         return \"user_login_state_pref\"\n12:     }\n13: \n14:     public func preferenceKey(): String {\n15:         return \"user_login_state\"\n16:     }\n17: \n18:     public func nextLoginState(currentState: Bool): Bool {\n19:         return !currentState\n20:     }\n21: \n22:     public func readLoginState(context: UIAbilityContext): Bool {\n23:         let preferences = Preferences.getPreferences(context, preferenceFileName())\n24:         match (preferences.get(preferenceKey(), PreferencesValueType.BoolData(false))) {\n25:             case PreferencesValueType.BoolData(isLoggedIn) => isLoggedIn\n26:             case _ => false\n27:         }\n28:     }\n29: \n30:     public func writeLoginState(context: UIAbilityContext, isLoggedIn: Bool): Bool {\n31:         let preferences = Preferences.getPreferences(context, preferenceFileName())\n32:         preferences.put(preferenceKey(), PreferencesValueType.BoolData(isLoggedIn))\n33:         preferences.flush()\n34:         return isLoggedIn\n35:     }\n36: \n37:     public func toggleLoginState(context: UIAbilityContext): Bool {\n38:         let nextState = nextLoginState(readLoginState(context))\n39:         return writeLoginState(context, nextState)\n40:     }\n41: \n42:     public func login(context: UIAbilityContext): Bool {\n43:         return writeLoginState(context, true)\n44:     }\n45: \n46:     public func logout(context: UIAbilityContext): Bool {\n47:         return writeLoginState(context, false)\n48:     }\n49: }\n\n(End of file - total 49 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session\n\nimport kit.AbilityKit.UIAbilityContext\nimport kit.ArkData.Preferences\nimport kit.ArkData.PreferencesValueType\n\npublic class LoginPreferencesService {\n    public init() {}\n\n    public func preferenceFileName(): String {\n        return \"user_login_state_pref\"\n    }\n\n    public func preferenceKey(): String {\n        return \"user_login_state\"\n    }\n\n    public func nextLoginState(currentState: Bool): Bool {\n        return !currentState\n    }","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\data\\session\\login_preferences_service.cj","time":{"start":1782538691274,"end":1782538691293}},"id":"prt_f0795e2c7001jT5XozTo9tJDMu","sessionID":"ses_0f86b033dffeEKhfxGCLxWyKsb","messageID":"msg_f0795b680001nkMe7KmGuKRKJX"}}
