t):\n492:         raise PatchError(\"Patch payload `add`/`additions` must be a list.\")\n493:     if not updates and not additions:\n494:         raise PatchError(\"Patch payload must contain at least one update or addition.\")\n495:     return {\"updates\": updates, \"additions\": additions}\n496: \n497: \n498: def field_sets(kind: str) -> tuple[set[str], set[str], set[str], set[str]]:\n499:     if kind == \"matrix\":\n500:         return MATRIX_UPDATE_FIELDS, MATRIX_ADD_FIELDS, MATRIX_LIST_FIELDS, MATRIX_TEXT_FIELDS\n501:     return PLATFORM_UPDATE_FIELDS, PLATFORM_ADD_FIELDS, PLATFORM_LIST_FIELDS, PLATFORM_TEXT_FIELDS\n502: \n503: \n504: def object_fields(kind: str) -> set[str]:\n505:     return MATRIX_OBJECT_FIELDS if kind == \"matrix\" else PLATFORM_OBJECT_FIELDS\n506: \n507: \n508: def default_object_value(kind: str, field: str) -> dict[str, Any]:\n509:     if kind == \"matrix\" and field == COVERAGE_FACTS_KEY:\n510:         return default_coverage_facts()\n511:     if kind == \"platform\" and field == CAPABILITY_FACTS_KEY:\n512:         return default_capability_facts()\n513:     return {}\n514: \n515: \n516: def validate_object_field(kind: str, field: str, value: Any) -> dict[str, Any]:\n517:     if not isinstance(value, dict):\n518:         raise PatchError(f\"Field `{field}` must be an object.\")\n519:     if field in {COVERAGE_FACTS_KEY, CAPABILITY_FACTS_KEY} and value.get(\"factsSource\") != \"agent\":\n520:         raise PatchError(f\"Field `{field}` updates must use factsSource `agent`.\")\n521:     strict = value.get(\"factsSource\") == \"agent\"\n522:     problems = (\n523:         validate_coverage_facts(value, strict=strict)\n524:         if kind == \"matrix\" and field == COVERAGE_FACTS_KEY\n525:         else validate_capability_facts(value, strict=strict)\n526:     )\n527:     if problems:\n528:         raise PatchError(f\"Field `{field}` has invalid structured facts: \" + \"; \".join(problems[:12]))\n529:     return copy.deepcopy(value)\n530: \n