l(): Bool {\n40:         showsBottomShell(this.currentRoute, this.isAtTop)\n41:     }\n42: }\n\n(End of file - total 42 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\npublic func showsBottomShell(route: String, isAtTop: Bool): Bool {\n    if (!isAtTop) {\n        return false\n    }\n\n    route == routePath(RouteId.Home) || route == routePath(RouteId.History)\n}\n\npublic class ShellRouteState {\n    public var currentRoute: String\n    public var isAtTop: Bool\n\n    public init(currentRoute: String, isAtTop: Bool) {\n        this.currentRoute = currentRoute\n        this.isAtTop = isAtTop\n    }\n\n    private func navigateWithoutDuplicate(route: String): Unit {","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\shell_route_state.cj","time":{"start":1782537830456,"end":1782537830503}},"id":"prt_f0788c037001ejamqVfp85LJjV","sessionID":"ses_0f877edd7ffeeZKHsCZ5YfA2cb","messageID":"msg_f07887925001bijIXRiuSn0Kax"}}
{"type":"tool_use","timestamp":1782537830505,"sessionID":"ses_0f877edd7ffeeZKHsCZ5YfA2cb","part":{"type":"tool","tool":"read","callID":"call_AOeS4yQITsS9qW0QH7wyluFh","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\route_registry.cj","limit":260,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\route_registry.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n2: \n3: import ohos.base.ResourceStr\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{stringAppName, stringCart, stringHistory, stringHome, stringLogin, stringProfileTitle, stringRestaurant}\n5: import std.collection.ArrayList\n6: \n7: public enum RouteId {\n8:     | Onboarding\n9:     | Login\n10:     | Home\n11:     | History\n12:     | Cart\n13:     | Profile\n14:     | RestaurantDetails\n15: }\n16: \n17: public enum ShellCommand {\n18:     | HomeTab\n19:     | HistoryTab\n20:     | CartAction\n21:     | PrimaryAction\n22: }\n23: \n24: public func routePath(route: RouteId): String {\n25:     match (route) {\n26:         case RouteId.Onboarding => \"onboarding\"\n27:         case RouteId.Login => \"login_screen\"\n28:         case RouteId.Home => \"home_screen\"\n29:         case RouteId.History => \"history\"\n30:         case RouteId.Cart => \"cart\"\n31:         case RouteId.Profile => \"profile\"\n32:         case RouteId.RestaurantDetails => \"restaurant_details\"\n33:     }\n34: }\n35: \n36: public func routeLabel(route: RouteId): ResourceStr {\n37:     match (route) {\n38:         case RouteId.Onboarding => stringAppName\n39:         case RouteId.Login => stringLogin\n40:         case RouteId.Home => stringHome\n41:         case RouteId.History => stringHistory\n42:         case RouteId.Cart => stringCart\n43:         case RouteId.Profile => stringProfileTitle\n44:         case RouteId.RestaurantDetails => stringRestaurant\n45:     }\n46: }\n47: \n48: public func routeLabelByPath(route: String): ResourceStr {\n49:     match (route) {\n50:         case \"onboarding\" => routeLabel(RouteId.Onboarding)\n51:         case \"login_screen\" => routeLabel(RouteId.Login)\n52:         case \"home_screen\" => routeLabel(RouteId.Home)\n53:         case \"history\" => routeLabel(RouteId.History)\n54:         case \"cart\" => routeLabel(RouteId.Cart)\n55:         case \"profile\" => routeLabel(RouteId.Profile)\n56:         case \"restaurant_details\" => routeLabel(RouteId.RestaurantDetails)\n57:         case _ => route\n58:     }\n59: }\n60: \n61: public func routeWithArgs(route: RouteId, args: ArrayList<String>): String {\n62:     var composedRoute = routePath(route)\n63:     for (arg in args) {\n64:         composedRoute = composedRoute + \"/\" + arg\n65:     }\n66:     return composedRoute\n67: }\n68: \n69: public func primaryActionTarget(route: String): String {\n70:     match (route) {\n71:         case \"onboarding\" => routePath(RouteId.Login)\n72:         case \"login_screen\" => routePath(RouteId.Home)\n73:         case \"home_screen\" => routePath(RouteId.RestaurantDetails)\n74:         case \"history\" => routePath(RouteId.Profile)\n75:         case \"cart\" => routePath(RouteId.Home)\n76:         case \"profile\" => routePath(RouteId.Onboarding)\n77:         case \"restaurant_details\" => routePath(RouteId.Home)\n78:         case _ => routePath(RouteId.Home)\n79:     }\n80: }\n81: \n82: public func primaryActionLabel(route: String): ResourceStr {\n83:     routeLabelByPath(primaryActionTarget(route))\n84: }\n\n(End of file - total 84 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\nimport ohos.base.ResourceStr\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{stringAppName, stringCart, stringHistory, stringHome, stringLogin, stringProfileTitle, stringRestaurant}