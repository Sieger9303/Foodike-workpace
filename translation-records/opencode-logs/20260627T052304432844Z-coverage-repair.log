ility_mainability_entry.cj\",\n151:         \"module_entry_entry.cj\",\n152:         \"app_ability.cj\",\n153:         \"ability_stage.cj\",\n154:         \"ohos_app_cangjie_entry/features/startup/startup_launch_service.cj\",\n155:         \"ohos_app_cangjie_entry/features/startup/startup_store.cj\",\n156:         \"base/profile/main_pages.json\",\n157:         \"ohos_app_cangjie_entry/data/session/login_preferences_service.cj\",\n158:         \"hvigorfile.ts\",\n159:         \"ohos_app_cangjie_entry/app/route_registry.cj\",\n160:         \"ohos_app_cangjie_entry/app/shell_route_state.cj\",\n161:         \"ohos_app_cangjie_entry/app/bootstrap_page.cj\",\n162:         \"ohos_app_cangjie_entry/features/login/login_store.cj\",\n163:         \"base/element/color.json\",\n164:         \"base/element/string.json\",\n165:         \"ohos_app_cangjie_entry/app/app_router.cj\",\n166:         \"ohos_app_cangjie_entry/common/foodike_resources.cj\",\n167:         \"base/media/icon.png\",\n168:         \"ohos_app_cangjie_entry/common/foodike_theme.cj\"\n169:       ],\n170:       \"requiredBehaviors\": [\n171:         \"HarmonyOS phase-01 build configuration likewise declares no permission-specific module wiring and keeps requestPermissions empty.\",\n172:         \"HarmonyOS replaces the Android application stack with stage-mode build descriptors plus explicit EntryAbility and FoodikeAbilityStage registration creators and lifecycle classes.\",\n173:         \"HarmonyOS replaces Android splash and Compose entry wiring with EntryAbility startup resolution, the shared bootstrapStartRoute runtime variable, a focused startup launch service, FoodikeBootstrap page loading, and the registered main_pages launcher page.\",\n174:         \"HarmonyOS replaces DataStore with LoginPreferencesService-backed ArkData preferences, while StartupLaunchService consumes that persisted login-state foundation for later startup routing.\",\n175:         \"HarmonyOS keeps the root build free of permission