{"type":"tool_use","timestamp":1782444663403,"sessionID":"ses_0fe058cafffeQXWj8wzo54yLAu","part":{"type":"tool","tool":"read","callID":"call_uTyhJvFe0R7QkLtLssPokD51","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase05_detail_cart_state_mutations_test.cj"},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase05_detail_cart_state_mutations_test.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry_test\n2: \n3: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.DetailStore\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.CartStore\n6: import std.unittest.*\n7: import std.unittest.testmacro.*\n8: \n9: @Test\n10: public class Phase05DetailCartStateMutationsTest {\n11:     @TestCase\n12:     public func cartStoreFiltersZeroCountItemsAndPreservesSnapshotOrder(): Unit {\n13:         let store = CartStore()\n14:         let state = store.loadCartState()\n15:         let visibleItems = store.visibleItems(state.items)\n16:         @Assert(visibleItems.size, 2)\n17:         @Assert(visibleItems[0].menuItem.dish, \"Paw Bhaaji\")\n18:         @Assert(visibleItems[1].menuItem.dish, \"Veg Pulao\")\n19:     }\n20: \n21:     @TestCase\n22:     public func cartStoreCalculatesTotalsFromSnapshotQuantities(): Unit {\n23:         let store = CartStore()\n24:         let state = store.loadCartState()\n25:         let itemTotal = store.itemTotal(store.visibleItems(state.items))\n26:         @Assert(itemTotal, 12.0)\n27:         @Assert(store.taxAmount(itemTotal), 2.16)\n28:         @Assert(store.grandTotal(itemTotal), 14.16)\n29:     }\n30: \n31:     @TestCase\n32:     public func cartStoreMutatesLocalQuantitiesImmediately(): Unit {\n33:         let store = CartStore()\n34:         let state = store.loadCartState()\n35:         let firstItem = state.items[0]\n36: \n37:         @Assert(firstItem.quantity, 1)\n38:         store.incrementQuantity(firstItem)\n39:         @Assert(firstItem.quantity, 2)\n40:         store.decrementQuantity(firstItem)\n41:         @Assert(firstItem.quantity, 1)\n42:         store.decrementQuantity(firstItem)\n43:         @Assert(firstItem.quantity, 0)\n44:         store.decrementQuantity(firstItem)\n45:         @Assert(firstItem.quantity, 0)\n46:     }\n47: \n48:     @TestCase\n49:     public func cartStoreKeepsSourceDeliveryPlaceholders(): Unit {\n50:         let store = CartStore()\n51:         let state = store.loadCartState()\n52:         @Assert(state.deliveryRestaurant.name, \"Relish\")\n53:         @Assert(store.deliveryLocation(), \"Guwahati\")\n54:         @Assert(store.formatEta(state.deliveryRestaurant.etaMinutes), \"30 Min\")\n55:     }\n56: \n57:     @TestCase\n58:     public func detailStoreLoadsSelectedRestaurantAndRecommendedMenuSlice(): Unit {\n59:         let store = DetailStore()\n60:         let contentRepository = HomeContentRepository()\n61:         let restaurant = match (contentRepository.getRestaurantByName(\"Relish\")) {\n62:             case Some(found) => found\n63:             case None => contentRepository.getRestaurants()[0]\n64:         }\n65:         store.session().setSelectedRestaurant(restaurant)\n66: \n67:         let state = store.loadDetailState(true, true, true)\n68:         @Assert(state.restaurant.name, \"Relish\")\n69:         @Assert(state.recommendedItems.size, 5)\n70:         @Assert(state.recommendedItems[0].menuItem.dish, \"Masala Dosa\")\n71:     }\n72: \n73:     @TestCase\n74:     public func detailStorePreservesSectionFilteringAndCartVisibilityRules(): Unit {\n75:         let store = DetailStore()\n76:         let contentRepository = HomeContentRepository()\n77:         let restaurant = match (contentRepository.getRestaurantByName(\"George Street\")) {\n78:             case Some(found) => found\n79:             case None => contentRepository.getRestaurants()[0]\n80:         }\n81:         store.session().setSelectedRestaurant(restaurant)\n82: \n83:         let state = store.loadDetailState(true, true, true)\n84:         let nonVegItems = store.nonVegItems(state.menuItems)\n85:         let vegItems = store.vegItems(state.menuItems)\n86:         @Assert(nonVegItems.size, 4)\n87:         @Assert(vegItems.size, 4)\n88:         @Assert(store.shouldShowCartAction(state.menuItems), false)\n89: \n90:         store.incrementQuantity(state.menuItems[0])\n91:         @Assert(store.shouldShowCartAction(state.menuItems), true)\n92:         @Assert(store.totalSelectedItems(state.menuItems), 1)\n93:         store.decrementQuantity(state.menuItems[0])\n94:         @Assert(store.totalSelectedItems(state.menuItems), 0)\n95:     }\n96: \n97:     @TestCase\n98:     public func detailStoreTogglesLikedStateForSelectedRestaurant(): Unit {\n99:         let store = DetailStore()\n100:         let contentRepository = HomeContentRepository()\n101:         let restaurant = match (contentRepository.getRestaurantByName(\"Relish\")) {\n102:             case Some(found) => found\n103:             case None => contentRepository.getRestaurants()[0]\n104:         }\n105: \n106:         store.session().setRestaurantLiked(restaurant, false)\n107:         let liked = store.toggleLiked(restaurant, false)\n108:         @Assert(liked, true)\n109:         @Assert(store.session().isRestaurantLiked(restaurant), true)\n110:         let unliked = store.toggleLiked(restaurant, true)\n111:         @Assert(unliked, false)\n112:     }\n113: }\n\n(End of file - total 113 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.DetailStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.CartStore\nimport std.unittest.*\nimport std.unittest.testmacro.*\n\n@Test\npublic class Phase05DetailCartStateMutationsTest {\n    @TestCase\n    public func cartStoreFiltersZeroCountItemsAndPreservesSnapshotOrder(): Unit {\n        let store = CartStore()\n        let state = store.loadCartState()\n        let visibleItems = store.visibleItems(state.items)\n        @Assert(visibleItems.size, 2)\n        @Assert(visibleItems[0].menuItem.dish, \"Paw Bhaaji\")\n        @Assert(visibleItems[1].menuItem.dish, \"Veg Pulao\")\n    }\n","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\test\\cangjie\\phase05_detail_cart_state_mutations_test.cj","time":{"start":1782444663352,"end":1782444663401}},"id":"prt_f01fb2196001wNVRrmxco8MENi","sessionID":"ses_0fe058cafffeQXWj8wzo54yLAu","messageID":"msg_f01faf616001tejQoqR1mU5aCX"}}
