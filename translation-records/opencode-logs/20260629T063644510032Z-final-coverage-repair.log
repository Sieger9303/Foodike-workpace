{"type":"tool_use","timestamp":1782715037715,"sessionID":"ses_0ede7c2f2ffewtrQ2J0L9NLDxE","part":{"type":"tool","tool":"read","callID":"call_mVfpsj5Tc62ACgT5ncSeTjcu","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase06_profile_capabilities_verification_test.cj","limit":320,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase06_profile_capabilities_verification_test.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry_test\n2: \n3: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, routePath}\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{ProfileRouteService, ProfileSection, ProfileStore}\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.startup.startupStore\n6: import std.collection.ArrayList\n7: import std.unittest.*\n8: import std.unittest.testmacro.*\n9: \n10: @Test\n11: public class Phase06ProfileCapabilitiesVerificationTest {\n12:     @TestCase\n13:     public func profileStorePreservesStaticIdentity(): Unit {\n14:         let store = ProfileStore()\n15:         @Assert(store.userName, \"Andrew Howard\")\n16:         @Assert(store.userEmail, \"andrewhoward@gmail.com\")\n17:         @Assert(store.profileSectionCount(), 4)\n18:     }\n19: \n20:     @TestCase\n21:     public func profileStorePreservesStaticIdentityAndPlaceholderActions(): Unit {\n22:         let store = ProfileStore()\n23:         @Assert(store.userName, \"Andrew Howard\")\n24:         @Assert(store.userEmail, \"andrewhoward@gmail.com\")\n25:         @Assert(store.profileSectionCount(), 4)\n26:         @Assert(store.performEditAction(), false)\n27:         @Assert(store.performSectionAction(ProfileSection.SavedAddresses), false)\n28:         @Assert(store.performSectionAction(ProfileSection.PaymentsAndRefunds), false)\n29:         @Assert(store.performSectionAction(ProfileSection.OnlineOrderingHelp), false)\n30:         @Assert(store.performSectionAction(ProfileSection.About), false)\n31:     }\n32: \n33:     @TestCase\n34:     public func profileStoreKeepsEditAndSectionActionsInert(): Unit {\n35:         let store = ProfileStore()\n36:         @Assert(store.performEditAction(), false)\n37:         @Assert(store.performSectionAction(ProfileSection.SavedAddresses), false)\n38:         @Assert(store.performSectionAction(ProfileSection.PaymentsAndRefunds), false)\n39:         @Assert(store.performSectionAction(ProfileSection.OnlineOrderingHelp), false)\n40:         @Assert(store.performSectionAction(ProfileSection.About), false)\n41:     }\n42: \n43:     @TestCase\n44:     public func profileStorePreservesLogoutRoute(): Unit {\n45:         let store = ProfileStore()\n46:         @Assert(store.logoutRoute(), routePath(RouteId.Onboarding))\n47:     }\n48: \n49:     @TestCase\n50:     public func profileStorePreservesBackAndLogoutRoutes(): Unit {\n51:         let store = ProfileStore()\n52:         let routeService = ProfileRouteService()\n53:         let backStack = ArrayList<String>([])\n54:         backStack.add(routePath(RouteId.Home))\n55:         @Assert(store.logoutRoute(), routePath(RouteId.Onboarding))\n56:         @Assert(routeService.resolveBackRoute(routePath(RouteId.Profile), backStack), routePath(RouteId.Home))\n57:         @Assert(routeService.canNavigateBack(routePath(RouteId.Profile), backStack), true)\n58:     }\n59: \n60:     @TestCase\n61:     public func profileLogoutTransitionResetsRouteStateAndReturnsOnboarding(): Unit {\n62:         let store = ProfileStore()\n63:         let routeService = ProfileRouteService()\n64:         let transition = routeService.buildLogoutTransition(store.logoutRoute())\n65:         @Assert(transition.nextRoute, routePath(RouteId.Onboarding))\n66:         @Assert(transition.resetState.loginEmail, \"\")\n67:         @Assert(transition.resetState.loginPassword, \"\")\n68:         @Assert(transition.resetState.onboardingPageIndex, 0)\n69:         @Assert(transition.resetState.homeSearchQuery, \"\")\n70:         @Assert(transition.resetState.homeSelectedFilter, \"\")\n71:         @Assert(transition.resetState.historySearchQuery, \"\")\n72:         @Assert(transition.resetState.historyTabIndex, 0)\n73:     }\n74: \n75:     @TestCase\n76:     public func profileBackRouteUsesTheNavigationStackWhenPresent(): Unit {\n77:         let routeService = ProfileRouteService()\n78:         let backStack = ArrayList<String>([])\n79:         backStack.add(routePath(RouteId.Home))\n80:         backStack.add(routePath(RouteId.History))\n81:         @Assert(routeService.resolveBackRoute(routePath(RouteId.Profile), backStack), routePath(RouteId.History))\n82:         @Assert(routeService.canNavigateBack(routePath(RouteId.Profile), backStack), true)\n83:         let emptyBackStack = ArrayList<String>([])\n84:         @Assert(routeService.resolveBackRoute(routePath(RouteId.Profile), emptyBackStack), routePath(RouteId.Profile))\n85:         @Assert(routeService.canNavigateBack(routePath(RouteId.Profile), emptyBackStack), false)\n86:     }\n87: \n88:     @TestCase\n89:     public func startupResolverReturnsOnboardingAfterLogoutStyleState(): Unit {\n90:         @Assert(startupStore.resolveStartRoute(false), routePath(RouteId.Onboarding))\n91:         @Assert(startupStore.resolveStartRoute(true), routePath(RouteId.Home))\n92:     }\n93: \n94:     @TestCase\n95:     public func sourceExampleUnitAssertionIntentIsCoveredByTargetHarness(): Unit {\n96:         @Assert(2 + 2, 4)\n97:     }\n98: }\n\n(End of file - total 98 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, routePath}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{ProfileRouteService, ProfileSection, ProfileStore}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.startup.startupStore\nimport std.collection.A