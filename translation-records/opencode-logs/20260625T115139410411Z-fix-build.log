StoreRoutesBackAndLogoutToSourceDestinations(): Unit {\n34:         let store = ProfileStore()\n35:         @Assert(store.backRoute(), routePath(RouteId.History))\n36:         @Assert(store.logoutRoute(), routePath(RouteId.Onboarding))\n37:         @Assert(store.userName, \"Andrew Howard\")\n38:         @Assert(store.userEmail, \"andrewhoward@gmail.com\")\n39:     }\n40: }\n\n(End of file - total 40 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, routePath}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.LoginStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.OnboardingStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.ProfileStore\nimport std.unittest.*\nimport std.unittest.testmacro.*\n\n@Test\npublic class Phase03OnboardingLoginProfileTest {\n    @TestCase\n    public func onboardingStorePreservesThreePageProgression(): Unit {\n        let store = OnboardingStore()\n        @Assert(store.pageCount(), 3)\n        @Assert(store.slideAt(0).title, \"Choose your favourite food\")\n        @Assert(store.isLastPage(0), false)\n        @Assert(store.nextIndex(0), 1)\n        @Assert(store.isLastPage(2), true)\n        @Assert(store.nextIndex(2), 2)","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\test\\cangjie\\phase03_onboarding_login_profile_test.cj","time":{"start":1782388394535,"end":1782388394540}},"id":"prt_efea089ec001H0BF0TyiuNitUu","sessionID":"ses_10160e3e2ffe7CWzM39JBNesLy","messageID":"msg_efea06c02001TK9zXPPhEZV5Xy"}}
