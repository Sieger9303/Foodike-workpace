ext)\n93:                     .fontSize(16)\n94:                     .fontWeight(FontWeight.Bold)\n95:                     .fontColor(0xFF228D39)\n96:                 Blank().layoutWeight(1)\n97:                 buildHistoryStatusRow(record.statusText)\n98:             }\n99:             .alignItems(VerticalAlign.Center)\n100:         }\n101:     }\n102:     .width(100.percent)\n103:     .padding(top: 14, right: 14, bottom: 14, left: 14)\n104:     .backgroundColor(Color.White)\n105:     .borderRadius(16)\n106: }\n107: \n108: @Builder\n109: func buildHistoryRecords(records: std.collection.ArrayList<HistoryRecordData>) {\n110:     Column(space: 10) {\n111:         ForEach(records, itemGeneratorFunc: { record: HistoryRecordData, _: Int64 =>\n112:             buildHistoryRecordCard(record)\n113:         })\n114:     }\n115:     .width(100.percent)\n116: }\n117: \n118: @Builder\n119: func buildHistoryFavourites(favourites: std.collection.ArrayList<RestaurantData>, onSelectRestaurant: (RestaurantData) -> Unit) {\n120:     if (favourites.size > 0) {\n121:         Column(space: 10) {\n122:             ForEach(favourites, itemGeneratorFunc: { restaurant: RestaurantData, _: Int64 =>\n123:                 renderRestaurantCard(restaurant, { =>\n124:                     onSelectRestaurant(restaurant)\n125:                 })\n126:             })\n127:         }\n128:         .width(100.percent)\n129:     } else {\n130:         Row {\n131:             Text(\"Empty\")\n132:                 .fontSize(16)\n133:         }\n134:         .width(100.percent)\n135:         .justifyContent(FlexAlign.Center)\n136:     }\n137: }\n138: \n139: @Builder\n140: public func renderHistoryRoute(\n141:     state: HistoryPageState,\n142:     selectedTab: Int64,\n143:     query: String,\n144:     onQueryChange: (String) -> Unit,\n145:     onTabSelect: (Int64) -> Unit,\n146:     onSelectRestaurant: (RestaurantData) -> Unit\n147: ) {\n148:     Scroll(Scroller()) {\n149:         Column(space: 14) {\n150: