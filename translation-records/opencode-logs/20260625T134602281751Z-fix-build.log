\": [\n46:         \"entry ability\",\n47:         \"main element\",\n48:         \"startup window resources\",\n49:         \"page profile binding\"\n50:       ],\n51:       \"translationGuidelines\": [\n52:         \"Map the Android launcher activity and splash theme into HarmonyOS entry-module metadata.\"\n53:       ]\n54:     },\n55:     {\n56:       \"path\": \"entry/src/main/cangjie/ohos_app_cangjie_entry/app/app_ability.cj\",\n57:       \"kind\": \"ability-shell\",\n58:       \"sourceRefs\": [\n59:         \"app/src/main/java/com/example/foodike/presentation/MainActivity.kt\",\n60:         \"app/src/main/java/com/example/foodike/FoodikeApp.kt\"\n61:       ],\n62:       \"topLevelDefinitions\": [\n63:         \"EntryAbility\",\n64:         \"startup page handoff\"\n65:       ],\n66:       \"translationGuidelines\": [\n67:         \"Keep ability code thin and compose startup/session services instead of storing repository logic here.\"\n68:       ]\n69:     },\n70:     {\n71:       \"path\": \"entry/src/main/cangjie/ohos_app_cangjie_entry/app/app_router.cj\",\n72:       \"kind\": \"routing\",\n73:       \"sourceRefs\": [\n74:         \"app/src/main/java/com/example/foodike/presentation/util/Navigation.kt\",\n75:         \"app/src/main/java/com/example/foodike/presentation/util/Screen.kt\"\n76:       ],\n77:       \"topLevelDefinitions\": [\n78:         \"RouteId\",\n79:         \"AppRouter\",\n80:         \"shell visibility rules\"\n81:       ],\n82:       \"translationGuidelines\": [\n83:         \"Preserve startup destination selection, shared shell ownership, and conditional bottom-bar/cart-button display.\"\n84:       ]\n85:     },\n86:     {\n87:       \"path\": \"entry/src/main/cangjie/ohos_app_cangjie_entry/domain/models.cj\",\n88:       \"kind\": \"domain-model\",\n89:       \"sourceRefs\": [\n90:         \"app/src/main/java/com/example/foodike/domain/model/Advertisement.kt\",\n91:         \"app/src/main/java/com/example/foodike/domain/model/CartItem.kt\",\n92:         \"app/src/main/java/com/example/foodike/domain/model/FoodItem.kt\",\n93:         \"app/src/main/java/com/example/foodike/domain/model/MenuItem.kt\",\n94:         \"app/src/main/java/com/example/foodike/domain/model/Restaurant.kt\"\n95:       ],\n96:       \"topLevelDefinitions\": [\n97:         \"Advertisement\",\n98:         \"CartItem\",\n99:         \"FoodItem\",\n100:         \"MenuItem\",\n101:         \"Restaurant\"\n102:       ],\n103:       \"translationGuidelines\": [\n104:         \"Keep immutable business models separate from feature stores and resource adaptation helpers.\"\n105:       ]\n106:     },\n107:     {\n108:       \"path\": \"entry/src/main/cangjie/ohos_app_cangjie_entry/data/fixture/foodike_fixture_data.cj\",\n109:       \"kind\": \"fixture-data\",\n110:       \"sourceRefs\": [\n111:         \"app/src/main/java/com/example/foodike/data/data_source/FakeData.kt\"\n112:       ],\n113:       \"topLevelDefinitions\": [\n114:         \"menu fixtures\",\n115:         \"restaurant fixtures\",\n116:         \"ad fixtures\",\n117:         \"recommended fixtures\",\n118:         \"cart fixtures\",\n119:         \"favourite fixtures\"\n120:       ],\n121:       \"translationGuidelines\": [\n122:         \"Split the very large source fake-data file by target responsibility but keep the content semantics and identifiers stable enough for feature parity.\"\n123:       ]\n124:     },\n125:     {\n126:       \"path\": \"entry/src/main/cangjie/ohos_app_cangjie_entry/data/session/login_preferences_service.cj\",\n127:       \"kind\": \"persistence-service\",\n128:       \"sourceRefs\": [\n129:         \"app/src/main/java/com/example/foodike/data/repository/LoginRepositoryImpl.kt\",\n130:         \"app/src/main/java/com/example/foodike/domain/repository/LoginRepository.kt\"\n131:       ],\n132:       \"topLevelDefinitions\": [\n133:         \"LoginPreferencesService\",\n134:         \"readLoginState\",\n135:         \"toggleLoginState\"\n136:       ],\n137:       \"translationGuidelines\": [\n138:         \"This is the primary persisted state boundary and should use a HarmonyOS-direct preference API rather than in-memory fallback.\"\n139:       ]\n140:     },\n141:     {\n142:       \"path\": \"entry/src/main/cangjie/ohos_app_cangjie_entry/data/session/session_repository.cj\",\n143:       \"kind\": \"repository\",\n144:       \"sourceRefs\": [\n145:         \"app/src/main/java/com/example/foodike/data/repository/UserDataRepositoryImpl.kt\",\n146:         \"app/src/main/java/com/example/foodike/domain/repository/UserDataRepository.kt\"\n147:       ],\n148:       \"topLevelDefinitions\": [\n149:         \"SessionRepository\",\n150:         \"setSelectedRestaurant\",\n151:         \"getSelectedRestaurant\",\n152:         \"getMenuItems\",\n153:         \"getLikedRestaurants\",\n154:         \"isRestaurantLiked\",\n155:         \"getCartItems\"\n156:       ],\n157:       \"translationGuidelines\": [\n158:         \"Keep session-scoped mutable state in one repository boundary, but avoid folding it into the UI shell.\"\n159:       ]\n160:     },\n161:     {\n162:       \"path\": \"entry/src/main/cangjie/ohos_app_cangjie_entry/data/content/home_content_repository.cj\",\n163:       \"kind\": \"repository\",\n164:       \"sourceRefs\": [\n165:         \"app/src/main/java/com/example/foodike/data/repository/HomeRepositoryImpl.kt\",\n166:         \"app/src/main/java/com/example/foodike/domain/repository/HomeRepository.kt\"\n167:       ],\n168:       \"topLevelDefinitions\": [\n169:         \"HomeContentRepository\",\n170:         \"getRestaurants\",\n171:         \"getAds\",\n172:         \"getFoodItems\",\n173:         \"getRestaurantByName\"\n174:       ],\n175:       \"translationGuidelines\": [\n176:         \"Preserve repository method boundaries because multiple features depend on them for screen state composition.\"\n177:       ]\n178:     },\n179:     {\n180:       \"path\": \"entry/src/main/cangjie/ohos_app_can