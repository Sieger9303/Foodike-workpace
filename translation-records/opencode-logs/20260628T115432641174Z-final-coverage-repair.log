nce\",\n566:         \"category\",\n567:         \"featurePoint\",\n568:         \"capabilityId\",\n569:         \"capabilityName\",\n570:         \"sourceEvidenceSummary\",\n571:         \"targetStrategyHint\",\n572:         \"minimumParity\",\n573:     }:\n574:         if not isinstance(value, str):\n575:             raise PatchError(f\"Field `{field}` must be a string.\")\n576:     return value\n577: \n578: \n579: def patch_entry(kind: str, entry: dict[str, Any], update: dict[str, Any]) -> None:\n\n(Showing lines 460-579 of 973. Use offset=580 to continue.)\n</content>","metadata":{"preview":"    if not isinstance(value, list):\n        raise PatchError(f\"`{field}` must be a list.\")\n    return value\n\n\ndef canonical_json(value: Any) -> str:\n    return json.dumps(value, ensure_ascii=False, sort_keys=True, separators=(\",\", \":\"))\n\n\ndef append_unique(existing: list[Any], values: list[Any]) -> list[Any]:\n    result = list(existing)\n    seen = {canonical_json(item) for item in result}\n    for value in values:\n        key = canonical_json(value)\n        if key not in seen:\n            result.append(value)\n            seen.add(key)\n    return result\n\n","truncated":true,"loaded":[]},"title":"..\\..\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\patch_authority.py","time":{"start":1782647958313,"end":1782647958323}},"id":"prt_f0e192b270011akOfzlpF0jAhq","sessionID":"ses_0f1eb2bfbffe5S6jTtp45LGus9","messageID":"msg_f0e19195e001J6FGbPIggN80AM"}}
