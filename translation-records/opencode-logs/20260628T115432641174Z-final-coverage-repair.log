{"type":"tool_use","timestamp":1782647710497,"sessionID":"ses_0f1eb2bfbffe5S6jTtp45LGus9","part":{"type":"tool","tool":"read","callID":"call_sicIXxOSMYnmsdgAbvRzBIuk","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj","limit":400,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n2: \n3: import kit.ArkUI.*\n4: import ohos.base.ResourceStr\n5: import ohos.arkui.state_macro_manage.Builder\n6: import ohos.arkui.state_macro_manage.Component\n7: import ohos.arkui.state_macro_manage.Entry\n8: import ohos.arkui.state_macro_manage.State\n9: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n10: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.{CartSnapshotItemData, DetailMenuItemData, DetailPageState, RestaurantData}\n11: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.{cartStore, renderCartRoute}\n12: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.{detailStore, renderDetailRoute}\n13: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history.{historyStore, renderHistoryRoute}\n14: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home.{homeStore, renderHomeRoute}\n15: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.{loginStore, renderLoginRoute}\n16: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.{onboardingStore, renderOnboardingRoute}\n17: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{profileStore, renderProfileRoute}\n18: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.runtime.{Global, bootstrapStartRoute}\n19: import std.collection.ArrayList\n20: \n21: @Entry\n22: @Component\n23: class FoodikeBootstrap {\n24:     @State\n25:     var currentRoute: String = bootstrapStartRoute\n26: \n27:     @State\n28:     var isShellAtTop: Bool = true\n29: \n30:     @State\n31:     var onboardingPageIndex: Int64 = 0\n32: \n33:     @State\n34:     var loginEmail: String = \"\"\n35: \n36:     @State\n37:     var loginPassword: String = \"\"\n38: \n39:     @State\n40:     var loginErrorMessage: String = \"\"\n41: \n42:     @State\n43:     var homeSearchQuery: String = \"\"\n44: \n45:     @State\n46:     var homeSelectedFilter: String = \"\"\n47: \n48:     @State\n49:     var historySearchQuery: String = \"\"\n50: \n51:     @State\n52:     var historyTabIndex: Int64 = 0\n53: \n54:     @State\n55:     var previousRoute: String = \"home_screen\"\n56: \n57:     @State\n58:     var cartNote: String = \"\"\n59: \n60:     @State\n61:     var cartCoupon: String = \"\"\n62: \n63:     @State\n64:     var cartMutationRevision: Int64 = 0\n65: \n66:     @State\n67:     var detailRecommendedExpanded: Bool = true\n68: \n69:     @State\n70:     var detailNonVegExpanded: Bool = true\n71: \n72:     @State\n73:     var detailVegExpanded: Bool = true\n74: \n75:     @State\n76:     var detailLiked: Bool = false\n77: \n78:     @State\n79:     var detailMutationRevision: Int64 = 0\n80: \n81:     private var onboardingController: SwiperController = SwiperController()\n82:     private var routeBackStack: ArrayList<String> = ArrayList<String>([])\n83: \n84:     private func applyShellState(shellState: ShellRouteState): Unit {\n85:         this.currentRoute = shellState.currentRoute\n86:         this.isShellAtTop = shellState.isAtTop\n87:     }\n88: \n89:     private func shellState(): ShellRouteState {\n90:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n91:     }\n92: \n93:     private func applyShellCommand(command: ShellCommand): Unit {\n94:         let shellState = this.shellState()\n95:         shellState.applyCommand(command)\n96:         this.applyShellState(shellState)\n97:     }\n98: \n99:     private func navigateTo(route: String): Unit {\n100:         if (this.currentRoute != route) {\n101:             this.routeBackStack.add(this.currentRoute)\n102:         }\n103:         this.previousRoute = this.currentRoute\n104:         let shellState = this.shellState()\n105:         shellState.currentRoute = route\n106:         shellState.isAtTop = true\n107:         this.applyShellState(shellState)\n108:     }\n109: \n110:     private func navigateBack(): Unit {\n111:         if (this.routeBackStack.size == 0) {\n112:             return\n113:         }\n114:         let targetIndex = this.routeBackStack.size - 1\n115:         let targetRoute = this.routeBackStack[targetIndex]\n116:         this.routeBackStack.remove(at: targetIndex)\n117:         this.previousRoute = this.currentRoute\n118:         let shellState = this.shellState()\n119:         shellState.currentRoute = targetRoute\n120:         shellState.isAtTop = true\n121:         this.applyShellState(shellState)\n122:     }\n123: \n124:     private func profileBackRoute(): String {\n125:         resolveProfileBackRoute(this.currentRoute, this.routeBackStack)\n126:     }\n127: \n128:     private func handleProfileBack(): Unit {\n129:         let targetRoute = this.profileBackRoute()\n130:         if (targetRoute == this.currentRoute) {\n131:             return\n132:         }\n133:         this.navigateBack()\n134:     }\n135: \n136:     private func showBottomShell(route: String): Bool {\n137:         let shellState = this.shellState()\n138:         shellState.currentRoute = route\n139:         return shellState.showBottomShell()\n140:     }\n141: \n142:     private func routeTitle(route: String): ResourceStr {\n143:         routeLabelByPath(route)\n144:     }\n145: \n146:     private func showToast(message: String): Unit {\n147:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n148:     }\n149: \n150:     private func clearLoginError(): Unit {\n151:         this.loginErrorMessage = \"\"\n152:     }\n153: \n154:     private func performLogin(): Unit {\n155:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n156:             this.clearLoginError()\n157:             this.navigateTo(loginStore.successRoute())\n158:             return\n159:         }\n160: \n161:         this.loginErrorMessage = loginStore.invalidLoginMessage\n162:         this.showToast(loginStore.invalidLoginMessage)\n163:     }\n164: \n165:     private func performLogout(): Unit {\n166:         profileStore.logout(Global.abilityContext)\n167:         this.loginEmail = \"\"\n168:         this.loginPassword = \"\"\n169:         this.clearLoginError()\n170:         this.onboardingPageIndex = 0\n171:         this.homeSearchQuery = \"\"\n172:         this.homeSelectedFilter = \"\"\n173:         this.historySearchQuery = \"\"\n174:         this.historyTabIndex = 0\n175:         this.routeBackStack.clear()\n176:         this.navigateTo(profileStore.logoutRoute())\n177:     }\n178: \n179:     private func handleProfileEdit(): Unit {\n180:         this.showToast(profileStore.actionFeedbackMessage())\n181:     }\n182: \n183:     private func handleProfileSectionAction(): Unit {\n184:         this.showToast(profileStore.actionFeedbackMessage())\n185:     }\n186: \n187:     private func handleProfileLogout(): Unit {\n188:         this.performLogout()\n189:     }\n190: \n191:     private func routeSummary(route: String): String {\n192:         match (route) {\n193:             case \"home_screen\" => \"Home now renders repository-backed discovery content, local search/filter controls, and restaurant selection before detail routing.\"\n194:             case \"history\" => \"History now preserves search plus tab-local content, reuses favourite restaurants, and saves the selected restaurant before navigation.\"\n195:             case \"cart\" => \"Cart now renders snapshot-backed items, a local note editor, a local coupon field, delivery details, and bill totals without adding new checkout persistence flows.\"\n196:             case \"restaurant_details\" => \"Restaurant detail now reads the selected restaurant, preserves local section expansion and like state, keeps menu quantity controls local to the route, and shows the cart action only when selected quantities are non-zero.\"\n197:             case _ => \"\"\n198:         }\n199:     }\n200: \n201:     private func homeHour(): Int64 {\n202:         return 9\n203:     }\n204: \n205:     private func goToProfile(): Unit {\n206:         this.navigateTo(routePath(RouteId.Profile))\n207:     }\n208: \n209:     private func goToRestaurantDetail(): Unit {\n210:         this.detailRecommendedExpanded = true\n211:         this.detailNonVegExpanded = true\n212:         this.detailVegExpanded = true\n213:         this.detailLiked = detailStore.session().isRestaurantLiked(detailStore.selectedRestaurant())\n214:         this.detailMutationRevision = 0\n215:         this.navigateTo(routePath(RouteId.RestaurantDetails))\n216:     }\n217: \n218:     private func detailState(): DetailPageState {\n219:         return detailStore.loadDetailState(\n220:             this.detailRecommendedExpanded,\n221:             this.detailNonVegExpanded,\n222:             this.detailVegExpanded\n223:         )\n224:     }\n225: \n226:     private func selectHomeRestaurant(restaurant: RestaurantData): Unit {\n227:         homeStore.selectRestaurant(restaurant, { =>\n228:             this.goToRestaurantDetail()\n229:         })\n230:     }\n231: \n232:     private func selectHistoryRestaurant(restaurant: RestaurantData): Unit {\n233:         historyStore.selectRestaurant(restaurant, { =>\n234:             this.goToRestaurantDetail()\n235:         })\n236:     }\n237: \n238:     @Builder\n239:     private func buildOnboardingRoute() {\n240:         renderOnboardingRoute(\n241:             this.onboardingPageIndex,\n242:             this.onboardingController,\n243:             { index: Int32 =>\n244:                 this.onboardingPageIndex = Int64(index)\n245:             },\n246:             { =>\n247:                 if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n248:                     this.navigateTo(routePath(RouteId.Login))\n249:                 } else {\n250:                     this.onboardingController.showNext()\n251:                 }\n252:             }\n253:         )\n254:     }\n255: \n256:     @Builder\n257:     private func buildLoginRoute() {\n258:         renderLoginRoute(\n259:             this.loginEmail,\n260:             this.loginPassword,\n261:             this.loginErrorMessage,\n262:             { value: String =>\n263:                 this.loginEmail = value\n264:                 this.clearLoginError()\n265:             },\n266:             { value: String =>\n267:                 this.loginPassword = value\n268:                 this.clearLoginError()\n269:             },\n270:             { => this.showToast(loginStore.comingSoonMessage) },\n271:             { => this.performLogin() },\n272:             { => this.showToast(loginStore.comingSoonMessage) },\n273:             { => this.showToast(loginStore.comingSoonMessage) },\n274:             { => this.showToast(loginStore.comingSoonMessage) },\n275:             { => this.clearLoginError() }\n276:         )\n277:     }\n278: \n279:     @Builder\n280:     private func buildProfileRoute() {\n281:         renderProfileRoute(\n282:             profileStore.userName,\n283:             profileStore.userEmail,\n284:             { => this.handleProfileBack() },\n285:             { => this.handleProfileEdit() },\n286:             { => this.handleProfileSectionAction() },\n287:             { => this.handleProfileLogout() }\n288:         )\n289:     }\n290: \n291:     @Builder\n292:     private func buildHomeRoute() {\n293:         renderHomeRoute(\n294:             homeStore.buildFilteredState(this.homeSearchQuery, this.homeSelectedFilter),\n295:     