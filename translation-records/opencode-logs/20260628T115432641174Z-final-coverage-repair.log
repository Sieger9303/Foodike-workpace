.Column\n31: import androidx.compose.foundation.layout.Spacer\n32: import androidx.compose.foundation.layout.fillMaxWidth\n33: import androidx.compose.foundation.layout.height\n34: import androidx.compose.foundation.layout.padding\n35: import androidx.compose.material.Divider\n36: import androidx.compose.material.Text\n37: import androidx.compose.runtime.Composable\n38: import androidx.compose.ui.Modifier\n39: import androidx.compose.ui.draw.alpha\n40: import androidx.compose.ui.unit.dp\n41: import androidx.compose.ui.unit.sp\n42: \n43: @Composable\n44: fun ProfileCard(\n45:     title: String,\n46:     subtext: String,\n47:     onClick: () -> Unit,\n48:     dividerVisibility: Boolean = true\n49: ) {\n50:     Column(\n51:         modifier = Modifier\n52:             .padding(32.dp, 0.dp)\n53:             .clickable {\n54:                 onClick()\n55:             }\n56:     ) {\n57:         Text(\n58:             text = title,\n59:             fontSize = 20.sp\n60:         )\n61:         Text(\n62:             text = subtext,\n63:             modifier = Modifier.alpha(0.5f)\n64:         )\n65:         if (dividerVisibility) {\n66:             Divider(\n67:                 modifier = Modifier\n68:                     .fillMaxWidth()\n69:                     .padding(0.dp, 8.dp)\n70:             )\n71:         }\n72:         Spacer(modifier = Modifier.height(8.dp))\n73: \n74:     }\n75: }\n\n(End of file - total 75 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the foll