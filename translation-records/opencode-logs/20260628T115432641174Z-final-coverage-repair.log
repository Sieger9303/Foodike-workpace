ated\",\n645:         \"matrixSync\": {\n646:             \"status\": \"agent-curated\",\n647:             \"preserveActive\": True,\n648:             \"reason\": \"row was added through structured authority patch\",\n649:         },\n650:         \"riskTags\": [],\n651:         \"keyClasses\": [],\n652:         \"keyMethods\": [],\n653:         \"androidIds\": [],\n654:         \"dependencies\": [],\n655:         \"featurePoint\": \"\",\n656:         \"category\": \"\",\n657:         COVERAGE_FACTS_KEY: default_coverage_facts(),\n658:     }\n659:     return {**defaults, **entry}\n660: \n661: \n662: def platform_defaulted_addition(entry: dict[str, Any]) -> dict[str, Any]:\n663:     defaults: dict[str, Any] = {\n664:         \"status\": \"planned\",\n665:         \"plannedPhase\": \"\",\n666:         \"sourcePaths\": [],\n667:         \"sourceEvidence\": [],\n668:         \"requiredTargetCapabilitySearch\": [],\n669:         \"targetStrategyHint\": \"\",\n670:         \"minimumParity\": \"\",\n671:         \"requiredTests\": [],\n672:         \"allowedDeferredReasons\": [],\n673:         \"targetCapabilitySearch\": [],\n674:         \"targetApiOrLibrary\": \"\",\n675:         \"targetStrategy\": \"\",\n676:         \"targetEndpoints\": [],\n677:         \"tests\": [],\n678:         \"sdkDeclarationEvidence\": [],\n679:         \"cangjieCallableEvidence\": [],\n680:         \"discoveryOnlyEvidence\": [],\n681:         \"compileProbeEvidence\": [],\n682:         \"preResolutionDecision\": \"\",\n683:         \"phaseCapabilityResolution\": \"\",\n684:         \"blocker\": \"\",\n685:         \"targetFallback\": \"\",\n686:         \"futureCompletionPath\": \"\",\n687:         \"notes\": \"\",\n688:         CAPABILITY_FACTS_KEY: default_capability_facts(),\n689:     }\n690:     return {**defaults, **entry}\n691: \n692: \n693: def validate_addition(kind: str, addition: Any) -> dict[str, Any]:\n694:     if not isinstance(addition, dict):\n695:         raise PatchError(\"Ev