ens if token not in text]\n353:         if missing:\n354:             return [f\"targetEndpoint `{endpoint}` symbol token(s) not found in {path}: {', '.join(missing)}\"]\n355:     return []\n356: \n357: \n358: def contextual_validation_errors(\n359:     kind: str,\n360:     entry: dict[str, Any],\n361:     context: PatchContext,\n362: ) -> list[str]:\n363:     problems: list[str] = []\n364:     if context.legal_phases is not None and not context.allow_unknown_phase:\n365:         planned_phase = phase_label(str(entry.get(\"plannedPhase\") or \"\"))\n366:         if planned_phase and planned_phase not in context.legal_phases:\n367:             shown = \", \".join(sorted(context.legal_phases)[:20])\n368:             problems.append(f\"plannedPhase `{planned_phase}` is not present in plan phases: {shown}\")\n369: \n370:     if context.target_project is not None and not context.allow_missing_endpoints:\n371:         endpoints = entry.get(\"targetEndpoints\")\n372:         if isinstance(endpoints, list):\n373:             for endpoint in endpoints:\n374:                 problems.extend(validate_target_endpoint(context.target_project, endpoint))\n375:     return problems\n376: \n377: \n378: def validate_contextual_entries(\n379:     kind: str,\n380:     entries: list[dict[str, Any]],\n381:     context: PatchContext,\n382: ) -> None:\n383:     if context.legal_phases is None and (context.target_project is None or context.allow_missing_endpoints):\n384:         return\n385:     id_field = entry_id_field(kind)\n386:     errors: list[dict[str, Any]] = []\n387:     for entry in entries:\n388:         problems = contextual_validation_errors(kind, entry, context)\n389:         if problems:\n390:             errors.append({id_field: entry.get(id_field, \"\"), \"problems\": problems})\n391:     if errors:\n392:         shown = \"; \".join(f\"{item.get(id_field)}: {', '.join(item['problems'])}\" for item in errors[:20])\n393:         raise PatchError(f\"Authority context validation failed for {len(errors)} entrie(s): {shown}\")\n394: \n395: \n396: def ensure_object(value: Any, field: str) -> dict[str, Any]:\n397:     if value is None:\n398:         return {}\n399:     if not isinstance(value, dict):\n400:         raise PatchError(f\"`{field}` must be an object.\")\n401:     return value\n402: \n403: \n404: def ensure_list(value: Any, field: str) -> list[Any]:\n405:     if value is None:\n406:         return []\n407:     if not isinstance(value, list):\n408:         raise PatchError(f\"`{field}` must be a list.\")\n409:     return value\n410: \n411: \n412: def canonical_json(value: Any) -> str:\n413:     return json.dumps(value, ensure_ascii=False, sort_keys=True, separators=(\",\", \":\"))\n414: \n415: \n416: def append_unique(existing: list[Any], values: list[Any]) -> list[Any]:\n417:     result = list(existing)\n418:     seen = {canonical_json(item) for item in result}\n419:     for value in values:\n420:         key = canonical_json(value)\n421:         if key not in seen:\n422:             result.append(value)\n423:             seen.add(key)\n424:     return result\n425: \n426: \n427: def validate_patch_payload(payload: Any) -> dict[str, Any]:\n428:     if not isinstance(payload, dict):\n429:         raise PatchError(\"Patch payload must be a JSON object.\")\n430:     allowed = {\"schemaVersion\", \"purpose\", \"updates\", \"add\", \"additions\"}\n431:     unknown = sorted(set(payload) - allowed)\n432:     if unknown:\n433:         raise PatchError(f\"Patch payload has unknown top-level field(s): {', '.join(unknown)}.\")\n434:     updates = payload.get(\"updates\", [])\n435:     additions = payload.get(\"add\", payload.get(\"additions\", []))\n436:     if not isinstance(updates, list):\n437:         raise PatchError(\"Patch payload `updates` must be a list.\")\n438:     if not isinstance(additions, list):\n439:         raise PatchError(\"Patch payload `add`/`additions` must be a list.\")\n440:     if not updates and not additions:\n441:         raise PatchError(\"Patch payload must contain at least one update or addition.\")\n442:     return {\"updates\": updates, \"additions\": additions}\n443: \n444: \n445: def field_sets(kind: str) -> tuple[set[str], set[str], set[str], set[str]]:\n446:     if kind == \"matrix\":\n447:         return MATRIX_UPDATE_FIELDS, MATRIX_ADD_FIELDS, MATRIX_LIST_FIELDS, MATRIX_TEXT_FIELDS\n448:     return PLATFORM_UPDATE_FIELDS, PLATFORM_ADD_FIELDS, PLATFORM_LIST_FIELDS, PLATFORM_TEXT_FIELDS\n449: \n450: \n451: def validate_field_value(kind: str, field: str, value: Any, *, add_entry: bool = False) -> Any:\n452:     update_fields, add_fields, list_fields, text_fields = field_sets(kind)\n453:     allowed = add_fields if add_entry else update_fields\n454:     if field not in allowed:\n455:         raise PatchError(f\"Field `{field}` is not writable for {kind} authority patches.\")\n456:     if field in list_fields:\n457:         if not isinstance(value, list):\n458:             raise PatchError(f\"Field `{field}` must be a list.\")\n459:         return value\n460:     if field in text_fields:\n461:         if not isinstance(value, str):\n462:             raise PatchError(f\"Field `{field}` must be a string.\")\n463:         if field == \"status\":\n464:             return value.strip().lower()\n465:         if field == \"parityLevel\":\n466:             return value.strip().lower()\n467:         return value\n468:     if field in {\"riskTags\", \"keyClasses\", \"keyMethods\", \"androidIds\", \"dependencies\", \"sourcePaths\"}:\n469:         if not isinstance(value, list):\n470:             raise PatchError(f\"Field `{field}` must be a list.\")\n471:     elif field in {\"sourceEvidence\", \"requiredTargetCapabilitySearch\", \"requiredTests\", \"allowedDeferredReasons\"}:\n472:         if kind == \"platform\" and field != \"sourceEvidence\" and not isinstance(value, list):\n473:             raise PatchError(f\"Field `{field}` must be a list.\")\n474:         if kind == \"platform\" and field == \"sourceEvidence\" and not isinstance(value, list):\n475:             raise PatchError(\"Field `sourceEvidence` must be a list for platform additions.\")\n476:         if kind == \"matrix\" and field == \"sourceEvidence\" and not isinstance(value, str):\n477:             raise PatchError(\"Field `sourceEvidence` must be a string for matrix additions.\")\n478:     elif field in {\n479:         \"featureId\",\n480:         \"featureName\",\n481:         \"sourcePath\",\n482:         \"importance\",\n483:         \"category\",\n484:         \"featurePoint\",\n485:         \"capabilityId\",\n486:         \"capabilityName\",\n487:         \"sourceEvidenceSummary\",\n488:         \"targetStrategyHint\",\n489:         \"minimumParity\",\n490:     }:\n491:         if not isinstance(value, str):\n492:             raise PatchError(f\"Field `{field}` must be a string.\")\n493:     return value\n494: \n495: \n496: def patch_entry(kind: str, entry: dict[str, Any], update: dict[str, Any]) -> None:\n497:     allowed_ops = {\"featureId\", \"capabilityId\", \"set\", \"append\", \"remove\", \"unset\"}\n498:     unknown = sorted(set(update) - allowed_ops)\n499:     if unknown:\n500:         raise PatchError(f\"Update for `{entry.get(entry_id_field(kind), '')}` has unknown operation field(s): {', '.join(unknown)}.\")\n501: \n502:     set_values = ensure_object(update.get(\"set\"), \"set\")\n503:     append_values = ensure_object(update.get(\"append\"), \"append\")\n504:     remove_values = ensure_object(update.get(\"remove\"), \"remove\")\n505:     unset_fields = ensure_list(update.get(\"unset\"), \"unset\")\n506:     _, _, list_fields, text_fields = field_sets(kind)\n507: \n508:     for field, value in set_values.items():\n509:         entry[field] = validate_field_value(kind, field, value)\n510: \n511:     for field, values in append_values.items():\n512:         if field not in list_fields:\n513:             raise PatchError(f\"Append is allowed only for list fields; `{field}` is not appendable.\")\n514:         values = validate_field_value(kind, field, values)\n515:         existing = entry.get(field, [])\n516:         if not isinstance(existing, list):\n517:             raise PatchError(f\"Cannot append to `{field}` because the current value is not a list.\")\n518:         entry[field] = append_unique(existing, values)\n519: \n520:     for field, values in remove_values.items():\n521:         if field not in list_fields:\n522:             raise PatchError(f\"Remove is allowed only for list fields; `{field}` is not removable.\")\n523:         values = validate_field_value(kind, field, values)\n524:         existing = entry.get(field, [])\n525:         if not isinstance(existing, list):\n526:             raise PatchError(f\"Cannot remove from `{field}` because the current value is not a list.\")\n527:         remove_keys = {canonical_json(value) for value in values}\n528:         entry[field] = [value for value in existing if canonical_json(value) not in remove_keys]\n529: \n530:     update_fields, _, _, _ = field_sets(kind)\n531:     for field in unset_fields:\n532:         if not isinstance(field, str):\n533:             raise PatchError(\"Every `unset` item must be a string field name.\")\n534:         if field not in update_fields:\n535:             raise PatchError(f\"Field `{field}` is not writable for {kind} authority patches.\")\n536:         entry[field] = [] if field in list_fields else \"\"\n537:         if field in text_fields and field == \"status\":\n538:             entry[field] = \"planned\"\n539: \n540: \n541: def matrix_defaulted_addition(entry: dict[str, Any]) -> dict[str, Any]:\n542:     defaults: dict[str, Any] = {\n543:         \"status\": \"planned\",\n544:         \"plannedPhase\": \"\",\n545:         \"sourceBehavior\": entry.get(\"featurePoint\", \"\"),\n546:         \"targetBehavior\": \"\",\n547:         \"verificationEvidence\": [],\n548:         \"parityLevel\": \"unverified\",\n549:         \"t