ment\n32: import androidx.compose.foundation.layout.Column\n33: import androidx.compose.foundation.layout.Row\n34: import androidx.compose.foundation.layout.Spacer\n35: import androidx.compose.foundation.layout.fillMaxSize\n36: import androidx.compose.foundation.layout.fillMaxWidth\n37: import androidx.compose.foundation.layout.height\n38: import androidx.compose.foundation.layout.padding\n39: import androidx.compose.foundation.layout.size\n40: import androidx.compose.foundation.layout.width\n41: import androidx.compose.foundation.shape.CircleShape\n42: import androidx.compose.material.Button\n43: import androidx.compose.material.Divider\n44: import androidx.compose.material.Icon\n45: import androidx.compose.material.IconButton\n46: import androidx.compose.material.MaterialTheme\n47: import androidx.compose.material.Text\n48: import androidx.compose.material.icons.Icons\n49: import androidx.compose.material.icons.outlined.ArrowBack\n50: import androidx.compose.runtime.Composable\n51: import androidx.compose.ui.Alignment\n52: import androidx.compose.ui.Modifier\n53: import androidx.compose.ui.draw.alpha\n54: import androidx.compose.ui.draw.clip\n55: import androidx.compose.ui.graphics.Color\n56: import androidx.compose.ui.res.painterResource\n57: import androidx.compose.ui.res.stringResource\n58: import androidx.compose.ui.text.font.FontWeight\n59: import androidx.compose.ui.unit.dp\n60: import androidx.compose.ui.unit.sp\n61: import androidx.hilt.navigation.compose.hiltViewModel\n62: import androidx.navigation.NavGraph.Companion.findStartDestination\n63: import androidx.navigation.NavHostController\n64: import com.example.foodike.R\n65: import com.example.foodike.presentation.profile.components.ProfileCard\n66: import com.example.foodike.presentation.util.Screen\n67: \n68: @Composable\n69: fun Profile(\n70:     viewModel: ProfileViewModel = hiltViewModel(),\n71:     navController: NavHostController,\n72: ) {\n73:     Column(\n74:         verticalArrangement = Arrangement.Center,\n75:         horizontalAlignment = Alignment.CenterHorizontally,\n76:     ) {\n77:         Row(\n78:             modifier = Modifier.fillMaxWidth(),\n79:         ) {\n80:             IconButton(onClick = { navController.navigateUp() }) {\n81:                 Icon(imageVector = Icons.Outlined.ArrowBack, contentDescription = stringResource(R.string.back))\n82:             }\n83:         }\n84:         Row(\n85:             modifier = Modifier\n86:                 .padding(16.dp, 0.dp)\n87:                 .fillMaxWidth(),\n88:             verticalAlignment = Alignment.CenterVertically,\n89:             horizontalArrangement = Arrangement.Center\n90:         ) {\n91:             Column(\n92:                 modifier = Modifier\n93:                     .fillMaxWidth()\n94:                     .weight(0.7f)\n95:             ) {\n96:                 Text(\n97:                     text = \"Andrew Howard\",\n98:                     fontSize = 24.sp,\n99:                     fontWeight = FontWeight.Bold,\n100:                 )\n101:                 Text(\n102:                     text = \"andrewhoward@gmail.com \",\n103:                     modifier = Modifier.alpha(0.5f),\n104:                 )\n105: \n106:             }\n107:             Column(\n108:                 verticalArrangement = Arrangement.Center,\n109:                 horizontalAlignment = Alignment.End,\n110:                 modifier = Modifier\n111:                     .fillMaxWidth()\n112:                     .weight(0.3f)\n113:             ) {\n114:                 Column(\n115:                     horizontalAlignment = Alignment.CenterHorizontally,\n116: \n117:                     ) {\n118:                     Image(\n119:                         modifier = Modifier\n120:                             .size(90.dp)\n121:                             .clip(CircleShape),\n122:                         painter = painterResource(id = R.drawable.ic_profile),\n123:                         contentDescription = stringResource(R.string.display_picture)\n124:                     )\n125:                     Spacer(modifier = Modifier.height(4.dp))\n126:                     Text(\n127:                         text = stringResource(R.string.edit),\n128:                         color = MaterialTheme.colors.primary,\n129:                         modifier = Modifier.clickable {\n130: \n131:                         },\n132:                         fontWeight = FontWeight.Bold\n133:                     )\n134:                 }\n135: \n136: \n137:             }\n138: \n139: \n140:         }\n141:         Divider(\n142:             modifier = Modifier\n143:                 .fillMaxWidth()\n144:                 .padding(12.dp),\n145:             color = Color.Black\n146:         )\n147:         Column(\n148:             modifier = Modifier.fillMaxWidth()\n149:         ) {\n150:             Spacer(modifier = Modifier.height(8.dp))\n151: \n152:             ProfileCard(\n153:                 title = stringResource(R.string.saved_addresses),\n154:                 subtext = stringResource(R.string.add_edit_and_delete_saved_addresses),\n155:                 onClick = {\n156: \n157:                 }\n158:             )\n159:             ProfileCard(\n160:                 title = stringResource(R.string.payments_and_refunds),\n161:                 subtext = stringResource(R.string.information_about_refunds_and_payments),\n162:                 onClick = {\n163:                 }\n164:             )\n165:             ProfileCard(\n166:                 title = stringResource(R.string.online_ordering_help),\n167:                 subtext = stringResource(R.string.information_about_ordering_food),\n168:                 onClick = {\n169:                 }\n170:             )\n171:             ProfileCard(\n172:                 title = stringResource(R.string.about),\n173:                 subtext = stringResource(R.string.about_the_app),\n174:                 onClick = {\n175:              