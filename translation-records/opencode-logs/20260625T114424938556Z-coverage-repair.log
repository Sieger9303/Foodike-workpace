{"type":"tool_use","timestamp":1782388018159,"sessionID":"ses_1016784edffe9LVyBWMwWC7FdS","part":{"type":"tool","tool":"read","callID":"call_KUinYX66zwJBBrIOS7HJoedi","state":{"status":"completed","input":{"filePath":"D:\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\patch_authority.py","limit":320},"output":"<path>D:\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\patch_authority.py</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env python3\n2: \"\"\"Apply narrow, validated patches to agent-maintained coverage authorities.\"\"\"\n3: \n4: from __future__ import annotations\n5: \n6: import argparse\n7: import copy\n8: import json\n9: import re\n10: import sys\n11: from collections import Counter\n12: from dataclasses import dataclass\n13: from pathlib import Path\n14: from typing import Any\n15: \n16: if __package__ in (None, \"\"):\n17:     sys.path.insert(0, str(Path(__file__).resolve().parents[2]))\n18:     from shared.common import HelpFormatter, expand_path, now_iso, write_json, write_text  # type: ignore\n19:     from shared.source_coverage.constants import (  # type: ignore\n20:         MATRIX_DEFERRED_REQUIRED_FIELDS,\n21:         MATRIX_IMPLEMENTED_STATUSES,\n22:         MATRIX_PARITY_LEVELS,\n23:         MATRIX_STATUSES,\n24:         PLATFORM_CAPABILITY_DEFERRED_REQUIRED_FIELDS,\n25:         PLATFORM_CAPABILITY_IMPLEMENTED_STATUSES,\n26:         PLATFORM_CAPABILITY_STATUSES,\n27:     )\n28:     from shared.source_coverage.matrix import MATRIX_AGENT_FIELDS, matrix_entries_by_id  # type: ignore\n29:     from shared.source_coverage.platform import capability_entries_by_id  # type: ignore\n30:     from shared.source_coverage.render import (  # type: ignore\n31:         platform_capability_check_markdown,\n32:         source_coverage_matrix_markdown,\n33:     )\n34:     from shared.source_coverage.utils import has_text, has_text_or_list  # type: ignore\n35: else:\n36:     from ..common import HelpFormatter, expand_path, now_iso, write_json, write_text\n37:     from .constants import (\n38:         MATRIX_DEFERRED_REQUIRED_FIELDS,\n39:         MATRIX_IMPLEMENTED_STATUSES,\n40:         MATRIX_PARITY_LEVELS,\n41:         MATRIX_STATUSES,\n42:         PLATFORM_CAPABILITY_DEFERRED_REQUIRED_FIELDS,\n43:         PLATFORM_CAPABILITY_IMPLEMENTED_STATUSES,\n44:         PLATFORM_CAPABILITY_STATUSES,\n45:     )\n46:     from .matrix import MATRIX_AGENT_FIELDS, matrix_entries_by_id\n47:     from .platform import capability_entries_by_id\n48:     from .render import platform_capability_check_markdown, source_coverage_matrix_markdown\n49:     from .utils import has_text, has_text_or_list\n50: \n51: \n52: MATRIX_LIST_FIELDS = {\"verificationEvidence\", \"targetEndpoints\", \"tests\"}\n53: MATRIX_TEXT_FIELDS = set(MATRIX_AGENT_FIELDS) - MATRIX_LIST_FIELDS\n54: MATRIX_UPDATE_FIELDS = set(MATRIX_AGENT_FIELDS)\n55: MATRIX_ADD_FIELDS = MATRIX_UPDATE_FIELDS | {\n56:     \"featureId\",\n57:     \"featureName\",\n58:     \"sourcePath\",\n59:     \"importance\",\n60:     \"category\",\n61:     \"riskTags\",\n62:     \"keyClasses\",\n63:     \"keyMethods\",\n64:     \"androidIds\",\n65:     \"dependencies\",\n66:     \"featurePoint\",\n67:     \"sourceEvidence\",\n68: }\n69: MATRIX_ADD_REQUIRED_FIELDS = {\"featureId\", \"featureName\", \"sourcePath\", \"importance\", \"sourceEvidence\"}\n70: MATRIX_REQUIRED_LIST_FIELDS = (\"verificationEvidence\", \"targetEndpoints\", \"tests\")\n71: MATRIX_REQUIRED_TEXT_FIELDS = (\n72:     \"plannedPhase\",\n73:     \"sourceBehavior\",\n74:     \"targetBehavior\",\n75:     \"notes\",\n76:     \"deferredReason\",\n77:     \"targetFallback\",\n78:     \"risk\",\n79:     \"futureCompletionPath\",\n80: )\n81: \n82: PLATFORM_LIST_FIELDS = {\n83:     \"targetCapabilitySearch\",\n84:     \"targetEndpoints\",\n85:     \"tests\",\n86:     \"sdkDeclarationEvidence\",\n87:     \"cangjieCallableEvidence\",\n88:     \"discoveryOnlyEvidence\",\n89:     \"compileProbeEvidence\",\n90: }\n91: PLATFORM_TEXT_FIELDS = {\n92:     \"status\",\n93:     \"plannedPhase\",\n94:     \"targetApiOrLibrary\",\n95:     \"targetStrategy\",\n96:     \"preResolutionDecision\",\n97:     \"phaseCapabilityResolution\",\n98:     \"blocker\",\n99:     \"targetFallback\",\n100:     \"futureCompletionPath\",\n101:     \"notes\",\n102: }\n103: PLATFORM_UPDATE_FIELDS = PLATFORM_LIST_FIELDS | PLATFORM_TEXT_FIELDS\n104: PLATFORM_ADD_FIELDS = PLATFORM_UPDATE_FIELDS | {\n105:     \"capabilityId\",\n106:     \"capabilityName\",\n107:     \"importance\",\n108:     \"sourcePaths\",\n109:     \"sourceEvidence\",\n110:     \"sourceEvidenceSummary\",\n111:     \"requiredTargetCapabilitySearch\",\n112:     \"targetStrategyHint\",\n113:     \"minimumParity\",\n114:     \"requiredTests\",\n115:     \"allowedDeferredReasons\",\n116: }\n117: PLATFORM_ADD_REQUIRED_FIELDS = {\"capabilityId\", \"capabilityName\", \"importance\", \"sourceEvidenceSummary\"}\n118: \n119: \n120: class PatchError(ValueError):\n121:     \"\"\"Raised for user-facing patch validation errors.\"\"\"\n122: \n123: \n124: @dataclass(frozen=True)\n125: class PatchContext:\n126:     target_project: Path | None = None\n127:     legal_phases: frozenset[str] | None = None\n128:     allow_missing_endpoints: bool = False\n129:     allow_unknown_phase: bool = False\n130: \n131: \n132: def parse_args() -> argparse.Namespace:\n133:     parser = argparse.ArgumentParser(\n134:         description=(\n135:             \"Apply a strict JSON patch payload to source-coverage-matrix.json or \"\n136:             \"platform-capability-check.json and optionally sync the Markdown view.\"\n137:         ),\n138:         formatter_class=HelpFormatter,\n139:     )\n140:     parser.add_argument(\n141:         \"--kind\",\n142:         choices=(\"auto\", \"matrix\", \"platform\"),\n143:         default=\"auto\",\n144:         help=\"Authority type. auto infers from the authority filename.\",\n145:     )\n146:     parser.add_argument(\"--authority\", required=True, help=\"Authority JSON path to patch.\")\n147:     parser.add_argument(\n148:         \"--patch\",\n149:         default=\"\",\n150:         help=\"Strict JSON patch payload. Omit with --validate-only to just validate the authority.\",\n151:     )\n152:     parser.add_argument(\"--validate-only\", action=\"store_true\", help=\"Validate the authority without applying a patch.\")\n153:     parser.add_argument(\"--dry-run\", action=\"store_true\", help=\"Validate and summarize without writing files.\")\n154:     parser.add_argument(\n155:         \"--markdown\",\n156:         default=\"\",\n157:         help=\"Markdown mirror path. Defaults to the authority path with .md suffix.\",\n158:     )\n159:     parser.add_argument(\"--no-markdown\", action=\"store_true\", help=\"Do not sync the Markdown mirror.\")\n160:     parser.add_argument(\"--summary-json\", default=\"\", help=\"Optional path for a machine-readable patch summary.\")\n161:     parser.add_argument(\n162:         \"--max-markdown-files\",\n163:         type=int,\n164:         default=250,\n165:         help=\"Maximum rows rendered in the Markdown mirror.\",\n166:     )\n167:     parser.add_argument(\n168:         \"--target-project\",\n169:         default=\"\",\n170:         help=(\n171:             \"Optional target project root. When set, targetEndpoints touched by this patch must point \"\n172:             \"to existing target files, with optional ::symbol checks.\"\n173:         ),\n174:     )\n175:     parser.add_argument(\n176:         \"--plan-json\",\n177:         default=\"\",\n178:         help=\"Optional strict plan.json. When set, plannedPhase values touched by this patch must exist in phases[].\",\n179:     )\n180:     parser.add_argument(\n181:         \"--allow-missing-endpoints\",\n182:         action=\"store_true\",\n183:         help=\"Skip targetEndpoints filesystem/symbol validation even when --target-project is set.\",\n184:     )\n185:     parser.add_argument(\n186:         \"--allow-unknown-phase\",\n187:         action=\"store_true\",\n188:         help=\"Skip plannedPhase validation even when --plan-json is set.\",\n189:     )\n190:     return parser.parse_args()\n191: \n192: \n193: def load_strict_json(path: Path, label: str) -> Any:\n194:     try:\n195:         return json.loads(path.read_text(encoding=\"utf-8\"))\n196:     except FileNotFoundError as exc:\n197:         raise PatchError(f\"{label} does not exist: {path}\") from exc\n198:     except json.JSONDecodeError as exc:\n199:         raise PatchError(f\"{label} is not strict JSON: {exc}\") from exc\n200:     except OSError as exc:\n201:         raise PatchError(f\"Could not read {label}: {exc}\") from exc\n202: \n203: \n204: def phase_label(raw: str) -> str:\n205:     value = str(raw).strip()\n206:     if not value:\n207:         return \"\"\n208:     if value.isdigit():\n209:         return f\"phase-{int(value):02d}\"\n210:     return value\n211: \n212: \n213: def phases_from_plan_data(data: Any) -> list[str]:\n214:     if not isinstance(data, dict):\n215:         return []\n216:     phases = data.get(\"phases\")\n217:     if not isinstance(phases, list):\n218:         return []\n219:     found: list[str] = []\n220:     for item in phases:\n221:         candidate = \"\"\n222:         if isinstance(item, dict):\n223:             candidate = str(item.get(\"id\") or item.get(\"name\") or item.get(\"phase\") or \"\").strip()\n224:         elif isinstance(item, str):\n225:             candidate = item.strip()\n226:         labeled = phase_label(candidate)\n227:         if labeled:\n228:             found.append(labeled)\n229:     return list(dict.fromkeys(found))\n230: \n231: \n232: def patch_context_from_args(args: argparse.Namespace) -> PatchContext:\n233:     target_project = expand_path(args.target_project) if args.target_project else None\n234:     if target_project is not None and not target_project.exists():\n235:         raise PatchError(f\"target project does not exist: {target_project}\")\n236:     if target_project is not None and not target_project.is_dir():\n237:         raise PatchError(f\"target project is not a directory: {target_project}\")\n238: \n239:     legal_phases: frozenset[str] | None = None\n240:     if args.plan_json and not args.allow_unknown_phase:\n241:         plan_path = expand_path(args.plan_json)\n242:         if plan_path is None:\n243:             raise PatchError(\"--plan-json was provided but did not resolve to a path.\")\n244:         plan_data = load_strict_json(plan_path, \"plan json\")\n245:         phases = phases_from_plan_data(plan_data)\n246:         if not phases:\n247:             raise PatchError(f\"plan json does not define a non-empty top-level phases array: {plan_path}\")\n248:         legal_phases = frozenset(phases)\n249: \n250:     return PatchContext(\n251:         target_project=target_project,\n252:         legal_phases=legal_phases,\n253:         allow_missing_endpoints=bool(args.allow_missing_endpoints),\n254:         allow_unknown_phase=bool(args.allow_unknown_phase),\n255:     )\n256: \n257: \n258: def infer_kind(kind: str, authority: Path) -> str:\n259:     if kind != \"auto\":\n260:         return kind\n261:     name = authority.name\n262:     if name == \"source-coverage-matrix.json\":\n263:         return \"matrix\"\n264:     if name == \"platform-capability-check.json\":\n265:         return \"platform\"\n266:     raise PatchError(\n267:         \"Could not infer authority kind from filename. Pass --kind matrix or --kind platform explicitly.\"\n268:     )\n269: \n270: \n271: def entry_id_field(kind: str) -> str:\n272:     return \"featureId\" if kind == \"matrix\" else \"capabilityId\"\n273: \n274: \n275: def entries_by_id(kind: str, authority: dict[str, Any]) -> tuple[dict[str, dict[str, Any]], list[str]]:\n276:     return matrix_entries_by_id(authority) if kind == \"matrix\" else capability_entries_by_id(authority)\n277: \n278: \n279: def status_counts(kind: str, authority: dict[str, Any]) -> Counter[str]:\n280:     counts: Counter[str] = Counter()\n281:     for entry in authority.get(\"entries\", []):\n282:         if not isinstance(entry, dict):\n283:             continue\n284:         status = str(entry.get(\"status\") or \"\").strip().lower() or \"empty\"\n285:         counts[status] += 1\n286:     return counts\n287: \n288: \n289: def validate_authority_shape(kind: str, authority: Any) -> dict[str, dict[str, Any]]:\n290:     if not isinstance(authority, dict):\n291:         raise PatchError(\"Authority JSON must be an object.\")\n292:     entries = authority.get(\"entries\")\n293:     if not isinstance(entries, list):\n294:         raise PatchError(\"Authority JSON must contain an `entries` list.\")\n295:     id_field = entry_id_field(kind)\n296:     missing_ids = [\n297:         str(index)\n298:         for index, entry in enumerate(entries, start=1)\n299:         if not isinstance(entry, dict) or not str(entry.get(id_field) or \"\").strip()\n300:     ]\n301:     if missing_ids:\n302:         raise PatchError(f\"Authority has entries without explicit `{id_field}` at positions: {', '.join(missing_ids[:20])}.\")\n303:     by_id, problems = entries_by_id(kind, authority)\n304:     if problems:\n305:         raise PatchError(\"Authority structural problem(s): \" + \"; \".join(problems[:20]))\n306:     return by_id\n307: \n308: \n309: def split_target_endpoint(endpoint: str) -> tuple[str, str]:\n310:     raw_path, sep, raw_symbol = endpoint.partition(\"::\")\n311:     endpoint_path = raw_path.strip().strip(\"`\")\n312:     symbol = raw_symbol.strip().strip(\"`\") if sep else \"\"\n313:     # Accept common line suffixes such as foo.cj:42 without treating the line\n314:     # number as part of the path.\n315:     endpoint_path = re.sub(r\"(\\.(?:cj|json|ets|ts|js|xml|toml|yaml|yml|md|txt)):\\d+$\", r\"\\1\", endpoint_path)\n316:     return endpoint_path, symbol\n317: \n318: \n319: def endpoint_file_path(target_project: Path, endpoint_path: str) -> Path:\n320:     normalized = endpoint_path.replace(\"\\\\\", \"/\")\n\n(Showing lines 1-320 of 873. Use offset=321 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n\"\"\"Apply narrow, validated patches to agent-maintained coverage authorities.\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport copy\nimport json\nimport re\nimport sys\nfrom collections import Counter\nfrom dataclasses import dataclass\nfrom pathlib import Path\nfrom typing import Any\n\nif __package__ in (None, \"\"):\n    sys.path.insert(0, str(Path(__file__).resolve().parents[2]))\n    from shared.common import HelpFormatter, expand_path, now_iso, write_json, write_text  # type: ignore\n    from shared.source_coverage.constants import (  # type: ignore\n        MATRIX_DEFERRED_REQUIRED_FIELDS,","truncated":true,"loaded":[]},"title":"..\\..\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\patch_authority.py","time":{"start":1782388018147,"end":1782388018158}},"id":"prt_efe9acbb7001woseDR8DTQMlS3","sessionID":"ses_1016784edffe9LVyBWMwWC7FdS","messageID":"msg_efe9a3775001BhWExEt20LO43c"}}
