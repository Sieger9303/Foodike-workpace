tTop = shellState.isAtTop\n40:     }\n41: \n42:     private func shellState(): ShellRouteState {\n43:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n44:     }\n45: \n46:     private func applyShellCommand(command: ShellCommand): Unit {\n47:         let shellState = this.shellState()\n48:         shellState.applyCommand(command)\n49:         this.applyShellState(shellState)\n50:     }\n51: \n52:     private func navigateTo(route: String): Unit {\n53:         let shellState = this.shellState()\n54:         shellState.currentRoute = route\n55:         shellState.isAtTop = true\n56:         this.applyShellState(shellState)\n57:     }\n58: \n59:     private func showBottomShell(route: String): Bool {\n60:         let shellState = this.shellState()\n61:         shellState.currentRoute = route\n62:         return shellState.showBottomShell()\n63:     }\n64: \n65:     private func routeTitle(route: String): String {\n66:         match (route) {\n67:             case \"onboarding\" => \"Onboarding\"\n68:             case \"login_screen\" => \"Login\"\n69:             case \"home_screen\" => \"Home\"\n70:             case \"history\" => \"History\"\n71:             case \"cart\" => \"Cart\"\n72:             case \"profile\" => \"Profile\"\n73:             case \"restaurant_details\" => \"Restaurant Detail\"\n74:             case _ => \"Unknown Route\"\n75:         }\n76:     }\n77: \n78:     private func showToast(message: String): Unit {\n79:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n80:     }\n81: \n82:     private func clearLoginError(): Unit {\n83:         this.loginErrorMessage = \"\"\n84:     }\n85: \n86:     private func performLogin(): Unit {\n87:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n88:             this.clearLoginError()\n89:             this.navigateTo(loginStore.successRoute())\n90:             return\n91:         }\n92: \n93:         this.loginErrorMessage = loginStore.invalidLoginMessage\n94:         this.showToast(loginStore.invalidLoginMessage)\n95:     }\n96: \n97:     private func performLogout(): Unit {\n98:         profileStore.logout(Global.abilityContext)\n99:         this.loginEmail = \"\"\n100:         this.loginPassword = \"\"\n101:         this.clearLoginError()\n102:         this.onboardingPageIndex = 0\n103:         this.navigateTo(profileStore.logoutRoute())\n104:     }\n105: \n106:     private func routeSummary(route: String): String {\n107:         match (route) {\n108:             case \"home_screen\" => \"Home remains the shared shell placeholder from phase 02 while onboarding, login, and profile now run as dedicated phase-03 routes.\"\n109:             case \"history\" => \"History remains available as a shell route so profile still has a source-consistent back destination.\"\n110:             case \"cart\" => \"Cart continues to be a shell-owned placeholder route until later phases land the real content.\"\n111:             case \"restaurant_details\" => \"Restaurant detail remains in the route contract but keeps its placeholder body until later phases.\"\n112:             case _ => \"\"\n113:         }\n114:     }\n115: \n116:     @Builder\n117:     private func buildOnboardingRoute() {\n118:         renderOnboardingRoute(\n119:             this.onboardingPageIndex,\n120:             this.onboardingController,\n121:             { index: Int32 =>\n122:                 this.onboardingPageIndex = Int64(index)\n123:             },\n124:             { =>\n125:                 if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n126:                     this.navigateTo(routePath(RouteId.Login))\n127:                 } else {\n128:                     this.onboardingController.showNext()\n129:                 }\n130:             }\n131:         )\n132:     }\n133: \n134:     @Builder\n135:     private func buildLoginRoute() {\n136:         renderLoginRoute(\n137:             this.loginEmail,\n138:             this.loginPassword,\n139:             this.loginErrorMessage,\n140:             { value: String =>\n141:                 this.loginEmail = value\n142:                 this.clearLoginError()\n143:             },\n144:             { value: String =>\n145:                 this.loginPassword = value\n146:                 this.clearLoginError()\n147:             },\n148:             { => this.showToast(loginStore.comingSoonMessage) },\n149:             { => this.performLogin() },\n150:             { => this.showToast(loginStore.comingSoonMessage) },\n151:             { => this.showToast(loginStore.comingSoonMessage) },\n152:             { => this.showToast(loginStore.comingSoonMessage) },\n153:             { => this.clearLoginError() }\n154:         )\n155:     }\n156: \n157:     @Builder\n158:     private func buildProfileRoute() {\n159:         renderProfileRoute(\n160:             profileStore.userName,\n161:             profileStore.userEmail,\n162:             { => this.navigateTo(profileStore.backRoute()) },\n163:             { => this.showToast(profileStore.placeholderActionMessage) },\n164:             { => this.showToast(profileStore.placeholderActionMessage) },\n165:             { => this.performLogout() }\n166:         )\n167:     }\n168: \n169:     @Builder\n170:     private func buildPlaceholderRoute() {\n171:         Column(space: 18) {\n172:             Text(\"Foodike\")\n173:                 .fontSize(42)\n174:                 .fontWeight(FontWeight.Bold)\n175:             Text(this.routeTitle(this.currentRoute))\n176:                 .fontSize(28)\n177:             Text(this.routeSummary(this.currentRoute))\n178:                 .fontSize(16)\n179:                 .textAlign(TextAlign.Center)\n180:                 .width(86.percent)\n181: \n182:             if (this.currentRoute == routePath(RouteId.Home) || this.currentRoute == routePath(RouteId.History)) {\n183:                 Button(if (this.isShellAtTop) { \"Simulate Scrolled Content\" } else { \"Return To Top\" })\n184:                     .onClick({ _ =>\n185:                         let shellState = this.shellState()\n186:                         shellState.setTopState(!shellState.isAtTop)\n187:                         this.applyShellState(shellState)\n188:                     })\n189:             }\n190: \n191:             Button(\"Primary Route Action\")\n192:                 .onClick({ _ =>\n193:                     this.applyShellCommand(ShellCommand.PrimaryAction)\n194:                 })\n195: \n196:             if (this.showBottomShell(this.currentRoute)) {\n197:                 Row(space: 12) {\n198:                     Button(\"Home Tab\")\n199:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HomeTab) })\n200:                     Button(\"Cart\")\n201:                         .onClick({ _ => this.applyShellCommand(ShellCommand.CartAction) })\n202:                     Button(\"History Tab\")\n203:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HistoryTab) })\n204:                 }\n205:             }\n206:         }\n207:         .width(100.percent)\n208:         .height(100.percent)\n209:         .justifyContent(FlexAlign.Center)\n210:         .alignItems(HorizontalAlign.Center)\n211:         .padding(top: 24, right: 24, bottom: 24, left: 24)\n212:     }\n213: \n214:     func build() {\n215:         if (this.currentRoute == routePath(RouteId.Onboarding)) {\n216:             this.buildOnboardingRoute()\n217:         } else if (this.currentRoute == routePath(RouteId.Login)) {\n218:             this.buildLoginRoute()\n219:         } else if (this.currentRoute == routePath(RouteId.Profile)) {\n220:             this.buildProfileRoute()\n221:         } else {\n222:             this.buildPlaceholderRoute()\n223:         }\n224:     }\n225: }\n\n(End of file - total 225 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\nim