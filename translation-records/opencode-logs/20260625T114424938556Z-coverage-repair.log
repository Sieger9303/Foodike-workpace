tePath(RouteId.Login)), routePath(RouteId.Home))\n33:         @Assert(primaryActionTarget(routePath(RouteId.Profile)), routePath(RouteId.Onboarding))\n34:     }\n35: \n36:     @TestCase\n37:     public func shellRouteStatePreservesTopFlagAcrossCommands(): Unit {\n38:         let shellState = ShellRouteState(routePath(RouteId.Home), false)\n39:         @Assert(shellState.showBottomShell(), false)\n40: \n41:         shellState.applyCommand(ShellCommand.HomeTab)\n42:         @Assert(shellState.currentRoute, routePath(RouteId.Home))\n43:         @Assert(shellState.isAtTop, false)\n44: \n45:         shellState.applyCommand(ShellCommand.HistoryTab)\n46:         @Assert(shellState.currentRoute, routePath(RouteId.History))\n47:         @Assert(shellState.isAtTop, false)\n48:         @Assert(shellState.showBottomShell(), false)\n49: \n50:         shellState.setTopState(true)\n51:         @Assert(shellState.showBottomShell(), true)\n52: \n53:         shellState.applyCommand(ShellCommand.CartAction)\n54:         @Assert(shellState.currentRoute, routePath(RouteId.Cart))\n55:         @Assert(shellState.isAtTop, true)\n56:         @Assert(shellState.showBottomShell(), false)\n57:     }\n58: \n59:     @TestCase\n60:     public func shellRouteStatePrimaryActionUsesRouteContract(): Unit {\n61:         let shellState = ShellRouteState(routePath(RouteId.Onboarding), true)\n62:         shellState.applyCommand(ShellCommand.PrimaryAction)\n63:         @Assert(shellState.currentRoute, routePath(RouteId.Login))\n64: \n65:         shellState.applyCommand(ShellCommand.PrimaryAction)\n66:         @Assert(shellState.currentRoute, routePath(RouteId.Home))\n67:     }\n68: \n69:     @TestCase\n70:     public func loginStateToggleRuleFlipsBothDirections(): Unit {\n71:         let service = LoginPreferencesService()\n72:         @Assert(service.nextLoginState(false), true)\n73:         @Assert(service.nextLoginState(true), false)\n74:     }\n75: \n76:     @TestCase\n77:     public func startupStore