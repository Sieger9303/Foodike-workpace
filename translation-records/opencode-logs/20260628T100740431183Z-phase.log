chen\" || name == \"99 Reasons to Eat\") {\n110:             return menu1\n111:         }\n112:         if (name == \"Saffron Xpress\" || name == \"KF\" || name == \"Kanha\" || name == \"Cafe Lighton\" || name == \"Rock n Rolls\") {\n113:             return menu3\n114:         }\n115:         return menu2\n116:     }\n117: \n118:     public func getMenuItems(): ArrayList<DetailMenuItemData> {\n119:         return selectedRestaurantMenuItems\n120:     }\n121: \n122:     public func isRestaurantLiked(restaurant: RestaurantData): Bool {\n123:         return containsLikedRestaurant(restaurant.name)\n124:     }\n125: \n126:     public func setRestaurantLiked(restaurant: RestaurantData, liked: Bool): Unit {\n127:         if (liked) {\n128:             if (!containsLikedRestaurant(restaurant.name)) {\n129:                 likedRestaurants.add(restaurant)\n130:             }\n131:             return\n132:         }\n133:         removeLikedRestaurant(restaurant.name)\n134:     }\n135: \n136:     public func restaurantSelectionRouteToken(): String {\n137:         return selectedRestaurantName\n138:     }\n139: \n140:     private func replaceSelectedMenu(sourceMenu: ArrayList<DetailMenuItemData>): Unit {\n141:         selectedRestaurantMenuItems.clear()\n142:         for (item in sourceMenu) {\n143:             selectedRestaurantMenuItems.add(\n144:                 DetailMenuItemData(\n145:                     MenuItemData(\n146:                         item.menuItem.dish,\n147:                         item.menuItem.price,\n148:                         item.menuItem.rating,\n149:                         item.menuItem.ratingCount,\n150:                         item.menuItem.isVegetarian\n151:                     ),\n152:                     0\n153:                 )\n154:             )\n155:         }\n156:     }\n157: \n158:     private func containsLikedRestaurant(name: String): Bool {\n159:         for (restaurant in likedRestaurants) {\n160:             if (restaurant.name