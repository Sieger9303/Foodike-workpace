apshot(): Unit {\n37:         let repository = SessionRepository()\n38:         let restaurant = HomeContentRepository().getRestaurants()[0]\n39:         repository.setRestaurant(restaurant)\n40: \n41:         @Assert(repository.getSavedRestaurantName(), \"George Street\")\n42:         let menuItems = repository.getMenuItems()\n43:         @Assert(menuItems.size, 17)\n44:         @Assert(menuItems[0].menuItem.dish, \"Fish and Chips\")\n45:         @Assert(menuItems[16].menuItem.dish, \"Prawn Fried Rice\")\n46:         @Assert(menuItems[0].quantity, 0)\n47:     }\n48: \n49:     @TestCase\n50:     public func sessionRepositorySelectionPreservesExactSeededMenuPerRestaurant(): Unit {\n51:         let repository = SessionRepository()\n52:         let restaurant = HomeContentRepository().getRestaurants()[1]\n53:         repository.setSelectedRestaurant(restaurant)\n54: \n55:         let menuItems = repository.getMenuItems()\n56:         @Assert(repository.getSelectedRestaurantName(), \"Magnolia\")\n57:         @Assert(menuItems.size, 17)\n58:         @Assert(menuItems[0].menuItem.dish, \"Masala Dosa\")\n59:         @Assert(menuItems[16].menuItem.dish, \"Butter Masala Dosa\")\n60:     }\n61: \n62:     @TestCase\n63:     public func sessionRepositoryLikeToggleMutatesSharedFavouriteState(): Unit {\n64:         let repository = SessionRepository()\n65:         let candidate = HomeContentRepository().getRestaurants()[1]\n66: \n67:         @Assert(repository.isRestaurantLiked(candidate), false)\n68:         repository.setRestaurantLiked(candidate, true)\n69:         @Assert(repository.isRestaurantLiked(candidate), true)\n70:         @Assert(repository.getLikedRestaurants().size, 6)\n71: \n72:         repository.setRestaurantLiked(candidate, false)\n73:         @Assert(repository.isRestaurantLiked(candidate), false)\n74:         @Assert(repository.getLikedRestaurants().size, 5)\n75:     }\n76: \n77:     @TestCase\n78:     public func sessionRepositoryRetainsCartSeedItems(): Unit {\n79:         let repository = SessionRepository()\n80:         let cartItems = repository.getCartItems()\n81:         @Assert(cartItems.size, 2)\n82:         @Assert(cartItems[0].menuItem.dish, \"Paw Bhaaji\")\n83:         @Assert(cartItems[1].quantity, 2)\n84:     }\n85: }\n\n(End of file - total 85 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.SessionRepository\nimport std.unittest.*\nimport std.unittest.testmacro.*\n\n@Test\npublic class Phase02RepositoryContractTest {\n    private func restaurantOrFirst(repository: HomeContentRepository, name: String) {\n        match (repository.getRestaurantFromName(name)) {\n            case Some(foundRestaurant) => foundRestaurant\n            case None => repository.getRestaurants()[0]\n        }\n    }\n\n    @TestCase\n    public func contentRepositoryExposesFullRestaurantSeedSet(): Unit {\n        let repository = HomeContentRepository()\n        let restaurants = repository.getRestaurants()","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\test\\cangjie\\phase02_repository_contract_test.cj","time":{"start":1782641317555,"end":1782641317586}},"id":"prt_f0db3d6b0001iYc2dgVz11M93Y","sessionID":"ses_0f24d02caffeu51C27PF0bgjYX","messageID":"msg_f0db37a4d001DkC4BPDt9LdFX1"}}
