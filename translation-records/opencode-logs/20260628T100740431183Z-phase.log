4 {\n35:         var total: Float64 = 0.0\n36:         for (item in items) {\n37:             var remaining = item.quantity\n38:             while (remaining > 0) {\n39:                 total += item.menuItem.price\n40:                 remaining -= 1\n41:             }\n42:         }\n43:         return total\n44:     }\n45: \n46:     public func incrementQuantity(item: CartSnapshotItemData): Unit {\n47:         item.quantity += 1\n48:     }\n49: \n50:     public func decrementQuantity(item: CartSnapshotItemData): Unit {\n51:         if (item.quantity > 0) {\n52:             item.quantity -= 1\n53:         }\n54:     }\n55: \n56:     public func formatPrice(price: Float64): String {\n57:         return \"$${price}\"\n58:     }\n59: \n60:     public func formatEta(minutes: Int64): String {\n61:         let hours = minutes / 60\n62:         let remainder = minutes % 60\n63:         if (hours > 0) {\n64:             return \"${hours} Hr ${remainder} Min\"\n65:         }\n66:         return \"${remainder} Min\"\n67:     }\n68: \n69:     public func taxAmount(itemTotal: Float64): Float64 {\n70:         return itemTotal * 0.18\n71:     }\n72: \n73:     public func grandTotal(itemTotal: Float64): Float64 {\n74:         return itemTotal + taxAmount(itemTotal)\n75:     }\n76: \n77:     public func deliveryLocation(): String {\n78:         return \"Guwahati\"\n79:     }\n80:     public func session(): SessionRepository {\n81:         return sessionRepository\n82:     }\n83: }\n\n(End of file - total 83 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.homeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\npublic let cartStore = CartStore()\n\npublic class CartStore {\n    private