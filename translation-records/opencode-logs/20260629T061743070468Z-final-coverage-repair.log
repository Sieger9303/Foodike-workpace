            case _ => \"\"\n191:         }\n192:     }\n193: \n194:     private func homeHour(): Int64 {\n195:         return 9\n196:     }\n197: \n198:     private func goToProfile(): Unit {\n199:         this.navigateTo(routePath(RouteId.Profile))\n200:     }\n201: \n202:     private func goToRestaurantDetail(): Unit {\n203:         this.detailRecommendedExpanded = true\n204:         this.detailNonVegExpanded = true\n205:         this.detailVegExpanded = true\n206:         this.detailLiked = detailStore.session().isRestaurantLiked(detailStore.selectedRestaurant())\n207:         this.detailMutationRevision = 0\n208:         this.navigateTo(routePath(RouteId.RestaurantDetails))\n209:     }\n210: \n211:     private func detailState(): DetailPageState {\n212:         return detailStore.loadDetailState(\n213:             this.detailRecommendedExpanded,\n214:             this.detailNonVegExpanded,\n215:             this.detailVegExpanded\n216:         )\n217:     }\n218: \n219:     private func selectHomeRestaurant(restaurant: RestaurantData): Unit {\n220:         homeStore.selectRestaurant(restaurant, { =>\n221:             this.goToRestaurantDetail()\n222:         })\n223:     }\n224: \n225:     private func selectHistoryRestaurant(restaurant: RestaurantData): Unit {\n226:         historyStore.selectRestaurant(restaurant, { =>\n227:             this.goToRestaurantDetail()\n228:         })\n229:     }\n230: \n231:     @Builder\n232:     private func buildOnboardingRoute() {\n233:         renderOnboardingRoute(\n234:             this.onboardingPageIndex,\n235:             this.onboardingController,\n236:             { index: Int32 =>\n237:                 this.onboardingPageIndex = Int64(index)\n238:             },\n239:             { =>\n240:                 if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n241:                     this.navigateTo(routePath(RouteId.Login))\n242:                 } else {\n243:                     this.onboardingController.showNext()\n244:                 }\n245:             }\n246:         )\n247:     }\n248: \n249:     @Builder\n250:     private func buildLoginRoute() {\n251:         renderLoginRoute(\n252:             this.loginEmail,\n253:             this.loginPassword,\n254:             this.loginErrorMessage,\n255:             { value: String =>\n256:                 this.loginEmail = value\n257:                 this.clearLoginError()\n258:             },\n259:             { value: String =>\n260:                 this.loginPassword = value\n261:                 this.clearLoginError()\n262:             },\n263:             { => this.showToast(loginStore.comingSoonMessage) },\n264:             { => this.performLogin() },\n265:             { => this.showToast(loginStore.comingSoonMessage) },\n266:             { => this.showToast(loginStore.comingSoonMessage) },\n267:             { => this.showToast(loginStore.comingSoonMessage) },\n268:             { => this.clearLoginError() }\n269:         )\n270:     }\n271: \n272:     @Builder\n273:     private func buildProfileRoute() {\n274:         renderProfileRoute(\n275:             profileStore.userName,\n276:             profileStore.userEmail,\n277:             { => this.handleProfileBack() },\n278:             { => this.handleProfileEdit() },\n279:             { section: ProfileSection => this.handleProfileSectionAction(section) },\n280:             { => this.handleProfileLogout() }\n281:         )\n282:     }\n283: \n284:     @Builder\n285:     private func buildHomeRoute() {\n286:         renderHomeRoute(\n287:             homeStore.buildFilteredState(this.homeSearchQuery, this.homeSelectedFilter),\n288:             this.homeHour(),\n289:             this.homeSearchQuery,\n290:             this.homeSelectedFilter,\n291:             { value: String =>\n292:                 this.homeSearchQuery = value\n293:             },\n294:             { value: String =>\n295:                 this.homeSelectedFilter = homeStore.toggleFilter(this.ho