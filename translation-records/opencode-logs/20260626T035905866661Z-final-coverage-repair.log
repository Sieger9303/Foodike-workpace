Login)), routePath(RouteId.Home))\n33:         @Assert(primaryActionTarget(routePath(RouteId.Profile)), routePath(RouteId.Onboarding))\n34:     }\n35: \n36:     @TestCase\n37:     public func shellRouteStatePreservesTopFlagAcrossCommands(): Unit {\n38:         let shellState = ShellRouteState(routePath(RouteId.Home), false)\n39:         @Assert(shellState.showBottomShell(), false)\n40: \n41:         shellState.applyCommand(ShellCommand.HomeTab)\n42:         @Assert(shellState.currentRoute, routePath(RouteId.Home))\n43:         @Assert(shellState.isAtTop, false)\n44: \n45:         shellState.applyCommand(ShellCommand.HistoryTab)\n46:         @Assert(shellState.currentRoute, routePath(RouteId.History))\n47:         @Assert(shellState.isAtTop, false)\n48:         @Assert(shellState.showBottomShell(), false)\n49: \n50:         shellState.setTopState(true)\n51:         @Assert(shellState.showBottomShell(), true)\n52: \n53:         shellState.applyCommand(ShellCommand.CartAction)\n54:         @Assert(shellState.currentRoute, routePath(RouteId.Cart))\n55:         @Assert(shellState.isAtTop, true)\n56:         @Assert(shellState.showBottomShell(), false)\n57:     }\n58: \n59:     @TestCase\n60:     public func shellRouteStatePrimaryActionUsesRouteContract(): Unit {\n61:         let shellState = ShellRouteState(routePath(RouteId.Onboarding), true)\n62:         shellState.applyCommand(ShellCommand.PrimaryAction)\n63:         @Assert(shellState.currentRoute, routePath(RouteId.Login))\n64: \n65:         shellState.applyCommand(ShellCommand.PrimaryAction)\n66:         @Assert(shellState.currentRoute, routePath(RouteId.Home))\n67:     }\n68: \n69:     @TestCase\n70:     public func loginStateToggleRuleFlipsBothDirections(): Unit {\n71:         let service = LoginPreferencesService()\n72:         @Assert(service.nextLoginState(false), true)\n73:         @Assert(service.nextLoginState(true), false)\n74:     }\n75: \n76:     @TestCase\n77:     public func startupStorePublishesResolvedRouteAndClearsLoading(): Unit {\n78:         let store = StartupStore()\n79:         @Assert(store.resolveStartRoute(false), \"onboarding\")\n80:         @Assert(store.startDestination, \"onboarding\")\n81:         @Assert(store.isLoading, false)\n82: \n83:         @Assert(store.resolveStartRoute(true), \"home_screen\")\n84:         @Assert(store.startDestination, \"home_screen\")\n85:         @Assert(store.isLoading, false)\n86:     }\n87: }\n\n(End of file - total 87 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, ShellCommand, ShellRouteState, primaryActionTarget, resolveStartRoute, routePath, showsBottomShell}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.LoginPreferencesService\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.startup.StartupStore\nimport std.unittest.*\nimport std.unittest.testmacro.*\n\n@Test\npublic class Phase02StartupNavigationTest {\n    @TestCase\n    public func resolvesLoggedOutUsersToOnboarding(): Unit {\n        @Assert(resolveStartRoute(false), \"onboarding\")\n    }\n\n    @TestCase\n    public func resolvesLoggedInUsersToHome(): Unit {\n        @Assert(resolveStartRoute(true), \"home_screen\")\n    }\n","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\test\\cangjie\\phase02_startup_navigation_test.cj","time":{"start":1782446369103,"end":1782446369110}},"id":"prt_f0215291b001T9usPg5Y1f1CqW","sessionID":"ses_0fdeb2bd9ffe2a5Z2QNdYaTYGn","messageID":"msg_f02150898001QbgPag9NWn6EhD"}}
