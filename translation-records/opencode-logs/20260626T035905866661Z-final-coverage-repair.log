et firstItem = state.items[0]\n36: \n37:         @Assert(firstItem.quantity, 1)\n38:         store.incrementQuantity(firstItem)\n39:         @Assert(firstItem.quantity, 2)\n40:         store.decrementQuantity(firstItem)\n41:         @Assert(firstItem.quantity, 1)\n42:         store.decrementQuantity(firstItem)\n43:         @Assert(firstItem.quantity, 0)\n44:         store.decrementQuantity(firstItem)\n45:         @Assert(firstItem.quantity, 0)\n46:     }\n47: \n48:     @TestCase\n49:     public func cartStoreKeepsSourceDeliveryPlaceholders(): Unit {\n50:         let store = CartStore()\n51:         let state = store.loadCartState()\n52:         @Assert(state.deliveryRestaurant.name, \"Relish\")\n53:         @Assert(store.deliveryLocation(), \"Guwahati\")\n54:         @Assert(store.formatEta(state.deliveryRestaurant.etaMinutes), \"30 Min\")\n55:     }\n56: \n57:     @TestCase\n58:     public func detailStoreLoadsSelectedRestaurantAndRecommendedMenuSlice(): Unit {\n59:         let store = DetailStore()\n60:         let contentRepository = HomeContentRepository()\n61:         let restaurant = match (contentRepository.getRestaurantByName(\"Relish\")) {\n62:             case Some(found) => found\n63:             case None => contentRepository.getRestaurants()[0]\n64:         }\n65:         store.session().setSelectedRestaurant(restaurant)\n66: \n67:         let state = store.loadDetailState(true, true, true)\n68:         @Assert(state.restaurant.name, \"Relish\")\n69:         @Assert(state.recommendedItems.size, 5)\n70:         for (item in state.recommendedItems) {\n71:             @Assert(item.menuItem.isVegetarian, true)\n72:         }\n73:     }\n74: \n75:     @TestCase\n76:     public func detailStorePreservesSectionFilteringAndCartVisibilityRules(): Unit {\n77:         let store = DetailStore()\n78:         let contentRepository = HomeContentRepository()\n79:         let restaurant = match (contentRepository.getRestaurantByName(\"George Street\")) {\n80:             case Some(found) => found\n81:             case None => contentRepository.getRestaurants()[0]\n82:         }\n83:         store.session().setSelectedRestaurant(restaurant)\n84: \n85:         let state = store.loadDetailState(true, true, true)\n86:         let nonVegItems = store.nonVegItems(state.menuItems)\n87:         let vegItems = store.vegItems(state.menuItems)\n88:         @Assert(nonVegItems.size, 4)\n89:         @Assert(vegItems.size, 4)\n90:         @Assert(store.shouldShowCartAction(state.menuItems), false)\n91: \n92:         store.incrementQuantity(state.menuItems[0])\n93:         @Assert(store.shouldShowCartAction(state.menuItems), true)\n94:         @Assert(store.totalSelectedItems(state.menuItems), 1)\n95:         store.decrementQuantity(state.menuItems[0])\n96:         @Assert(store.totalSelectedItems(state.menuItems), 0)\n97:     }\n98: \n99:     @TestCase\n100:     public func detailStoreTogglesLikedStateForSelectedRestaurant(): Unit {\n101:         let store = DetailStore()\n102:         let contentRepository = HomeContentRepository()\n103:         let restaurant = match (contentRepository.getRestaurantByName(\"Relish\")) {\n104:             case Some(found) => found\n105:             case None => contentRepository.getRestaurants()[0]\n106:         }\n107: \n108:         store.session().setRestaurantLiked(restaurant, false)\n109:         let liked = store.toggleLiked(restaurant, false)\n110:         @Assert(liked, true)\n111:         @Assert(store.session().isRestaurantLiked(restaurant), true)\n112:         let unliked = store.toggleLiked(restaurant, true)\n113:         @Assert(unliked, false)\n114:     }\n115: }\n\n(End of file - total 115 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.HomeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.DetailStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.featu