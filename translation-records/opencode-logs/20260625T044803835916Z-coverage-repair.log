com.example.foodike\"\n40:         minSdk = 24\n41:         targetSdk = 33\n42:         versionCode = 1\n43:         versionName = \"1.0.0-alpha\"\n44: \n45:         testInstrumentationRunner = \"androidx.test.runner.AndroidJUnitRunner\"\n46:         vectorDrawables {\n47:             useSupportLibrary = true\n48:         }\n49:     }\n50: \n51:     buildTypes {\n52:         release {\n53:             isMinifyEnabled = false\n54:             proguardFiles(getDefaultProguardFile(\"proguard-android-optimize.txt\"), \"proguard-rules.pro\")\n55:         }\n56:     }\n57:     compileOptions {\n58:         sourceCompatibility = JavaVersion.VERSION_1_8\n59:         targetCompatibility = JavaVersion.VERSION_1_8\n60:     }\n61:     kotlinOptions {\n62:         jvmTarget = \"1.8\"\n63:     }\n64:     buildFeatures {\n65:         compose = true\n66:     }\n67:     composeOptions {\n68:         kotlinCompilerExtensionVersion = libs.versions.compose.compiler.get()\n69:     }\n70:     packaging {\n71:         resources {\n72:             excludes += \"/META-INF/{AL2.0,LGPL2.1}\"\n73:         }\n74:     }\n75: }\n76: \n77: dependencies {\n78: \n79:     implementation(libs.core.ktx)\n80:     implementation(libs.lifecycle.runtime.ktx)\n81:     implementation(libs.activity.compose)\n82:     implementation(libs.compose.ui)\n83:     implementation(libs.compose.ui.tooling.preview)\n84:     implementation(libs.compose.material)\n85:     testImplementation(libs.junit)\n86:     androidTestImplementation(libs.androidx.test.ext.junit)\n87:     androidTestImplementation(libs.espresso.core)\n88:     androidTestImplementation(libs.compose.ui.test.junit4)\n89:     debugImplementation(libs.compose.ui.tooling)\n90:     debugImplementation(libs.compose.ui.test.manifest)\n91: \n92:     implementation(libs.compose.material.icons.extended)\n93: \n94:     // Dagger - Hilt\n95:     implementation(libs.hilt.android)\n96:     kapt(libs.hilt.android.compiler)\n97:     kapt(libs.hilt.compiler)\n98:     impl