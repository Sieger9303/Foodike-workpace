FIELDS = {\n92:     \"status\",\n93:     \"plannedPhase\",\n94:     \"targetApiOrLibrary\",\n95:     \"targetStrategy\",\n96:     \"preResolutionDecision\",\n97:     \"phaseCapabilityResolution\",\n98:     \"blocker\",\n99:     \"targetFallback\",\n100:     \"futureCompletionPath\",\n101:     \"notes\",\n102: }\n103: PLATFORM_UPDATE_FIELDS = PLATFORM_LIST_FIELDS | PLATFORM_TEXT_FIELDS\n104: PLATFORM_ADD_FIELDS = PLATFORM_UPDATE_FIELDS | {\n105:     \"capabilityId\",\n106:     \"capabilityName\",\n107:     \"importance\",\n108:     \"sourcePaths\",\n109:     \"sourceEvidence\",\n110:     \"sourceEvidenceSummary\",\n111:     \"requiredTargetCapabilitySearch\",\n112:     \"targetStrategyHint\",\n113:     \"minimumParity\",\n114:     \"requiredTests\",\n115:     \"allowedDeferredReasons\",\n116: }\n117: PLATFORM_ADD_REQUIRED_FIELDS = {\"capabilityId\", \"capabilityName\", \"importance\", \"sourceEvidenceSummary\"}\n118: \n119: \n120: class PatchError(ValueError):\n121:     \"\"\"Raised for user-facing patch validation errors.\"\"\"\n122: \n123: \n124: @dataclass(frozen=True)\n125: class PatchContext:\n126:     target_project: Path | None = None\n127:     legal_phases: frozenset[str] | None = None\n128:     allow_missing_endpoints: bool = False\n129:     allow_unknown_phase: bool = False\n130: \n131: \n132: def parse_args() -> argparse.Namespace:\n133:     parser = argparse.ArgumentParser(\n134:         description=(\n135:             \"Apply a strict JSON patch payload to source-coverage-matrix.json or \"\n136:             \"platform-capability-check.json and optionally sync the Markdown view.\"\n137:         ),\n138:         formatter_class=HelpFormatter,\n139:     )\n140:     parser.add_argument(\n141:         \"--kind\",\n142:         choices=(\"auto\", \"matrix\", \"platform\"),\n143:         default=\"auto\",\n144:         help=\"Authority type. auto infers from the authority filename.\",\n145:     )\n146:     parser.add_argument(\"--authority\", required=True, help=\"Authority JSON path to patch.\")\n147:     parser.add_argument(\n148:         \"--patch\",\n149:         default=\"\",\n150:         help=\"Strict JSON patch payload. Omit with --validate-only to just validate the authority.\",\n151:     )\n152:     parser.add_argument(\"--validate-only\", action=\"store_true\", help=\"Validate the authority without applying a patch.\")\n153:     parser.add_argument(\"--dry-run\", action=\"store_true\", help=\"Validate and summarize without writing files.\")\n154:     parser.add_argument(\n155:         \"--markdown\",\n156:         default=\"\",\n157:         help=\"Markdown mirror path. Defaults to the authority path with .md suffix.\",\n158:     )\n159:     parser.add_argument(\"--no-markdown\", action=\"store_true\", help=\"Do not sync the Markdown mirror.\")\n160:     parser.add_argument(\"--summary-json\", default=\"\", help=\"Optional path for a machine-readable patch summary.\")\n161:     parser.add_argument(\n162:         \"--max-markdown-files\",\n163:         type=int,\n164:         default=250,\n165:         help=\"Maximum rows rendered in the Markdown mirror.\",\n166:     )\n167:     parser.add_argument(\n168:         \"--target-project\",\n169:         default=\"\",\n170:         help=(\n171:             \"Optional target project root. When set, targetEndpoints touched by this patch must point \"\n172:             \"to existing target files, with optional ::symbol checks.\"\n173:         ),\n174:     )\n175:     parser.add_argument(\n176:         \"--plan-json\",\n177:         default=\"\",\n178:         help=\"Optional strict plan.json. When set, plannedPhase values touched by this patch must exist in phases[].\",\n179:     )\n180:     parser.add_argument(\n181:         \"--allow-missing-endpoints\",\n182:         action=\"store_true\",\n183:         help=\"Skip targetEndpoints filesystem/symbol validation even when --target-project is set.\",\n184:     )\n185:     parser.add_argument(\n186:         \"--allow-unknown-phase\",\n187:         action=\"store_true\",\n188:         help=\"Skip plannedPhase validation even when --plan-json is set.\",\n189:     )\n190:     return parser.parse_args()\n191: \n192: \n193: def load_strict_json(path: Path, label: str) -> Any:\n194:     try:\n195:         return json.loads(path.read_text(encoding=\"utf-8\"))\n196:     except FileNotFoundError as exc:\n197:         raise PatchError(f\"{label} does not exist: {path}\") from exc\n198:     except json.JSONDecodeError as exc:\n199:         raise PatchError(f\"{label} is not strict JSON: {exc}\") from exc\n200:     except OSError as exc:\n201:         raise PatchError(f\"Could not read {label}: {exc}\") from exc\n202: \n203: \n204: def phase_label(raw: str) -> str:\n205:     value = str(raw).strip()\n206:     if not value:\n207:         return \"\"\n208:     if value.isdigit():\n209:         return f\"phase-{int(value):02d}\"\n210:     return value\n211: \n212: \n213: def phases_from_plan_data(data: Any) -> list[str]:\n214:     if not isinstance(data, dict):\n215:         return []\n216:     phases = data.get(\"phases\")\n217:     if not isinstance(phases, list):\n218:         return []\n219:     found: list[str] = []\n220:     for item in phases:\n221:         candidate = \"\"\n222:         if isinstance(item, dict):\n223:             candidate = str(item.get(\"id\") or item.get(\"name\") or item.get(\"phase\") or \"\").strip()\n224:         elif isinstance(item, str):\n225:             candidate = item.strip()\n226:         labeled = phase_label(candidate)\n227:         if labeled:\n228:             found.append(labeled)\n229:     return list(dict.fromkeys(found))\n230: \n231: \n232: def patch_context_from_args(args: argparse.Namespace) -> PatchContext:\n233:     target_project = expand_path(args.target_project) if args.target_project else None\n234:     if target_project is not None and not target_project.exists():\n235:         raise PatchError(f\"target project does not exist: {target_project}\")\n236:     if target_project is not None and not target_project.is_dir():\n237:         raise PatchError(f\"target project is not a directory: {target_project}\")\n238: \n239:     legal_phases: frozenset[str] | None = None\n240:     if args.plan_json and not args.allow_unknown_phase:\n241:         plan_path = expand_path(args.plan_json)\n242:         if plan_path is None:\n243:             raise PatchError(\"--plan-json was provided but did not resolve to a path.\")\n244:         plan_data = load_strict_json(plan_path, \"plan json\")\n245:         phases = phases_from_plan_data(plan_data)\n246:         if not phases:\n247:             raise PatchError(f\"plan json does not define a non-empty top-level phases array: {plan_path}\")\n248:         legal_phases = frozenset(phases)\n249: \n250:     return PatchContext(\n251:         target_project=target_project,\n252:         legal_phases=legal_phases,\n253:         allow_missing_endpoints=bool(args.allow_missing_endpoints),\n254:         allow_unknown_phase=bool(args.allow_unknown_phase),\n255:     )\n256: \n257: \n258: def infer_kind(kind: str, authority: Path) -> str:\n259:     if kind != \"auto\":\n260:         return kind\n\n(Showing lines 1-260 of 873. Use offset=261 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n\"\"\"Apply narrow, validated patches to agent-maintained coverage authorities.\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport copy\nimport json\nimport re\nimport sys\nfrom collections import Counter\nfrom dataclasses import dataclass\nfrom pathlib import Path\nfrom typing import Any\n\nif __package__ in (None, \"\"):\n    sys.path.insert(0, str(Path(__file__).resolve().parents[2]))\n    from shared.common import HelpFormatter, expand_path, now_iso, write_json, write_text  # type: ignore\n    from shared.source_coverage.constants import (  # type: ignore\n        MATRIX_DEFERRED_REQUIRED_FIELDS,","truncated":true,"loaded":[]},"title":"..\\..\\X2Cang