ment = Arrangement.Center,\n79:             verticalAlignment = Alignment.CenterVertically\n80:         ) {\n81:             if (cartItem.menuItem.isVegetarian) {\n82:                 Image(\n83:                     modifier = Modifier.size(18.dp),\n84:                     painter = painterResource(id = R.drawable.ic_veg),\n85:                     contentDescription = \"Vegetarian\"\n86:                 )\n87:             } else {\n88:                 Image(\n89:                     modifier = Modifier.size(16.dp),\n90:                     painter = painterResource(id = R.drawable.ic_non_veg),\n91:                     contentDescription = \"Non-Vegetarian\"\n92:                 )\n93:             }\n94:             Spacer(modifier = Modifier.width(8.dp))\n95:             Text(text = cartItem.menuItem.dish)\n96: \n97:         }\n98: \n99: \n100:         Column(\n101: \n102:             verticalArrangement = Arrangement.Center,\n103:             horizontalAlignment = Alignment.CenterHorizontally\n104:         ) {\n105:             Surface(\n106:                 modifier = Modifier\n107:                     .border(\n108:                         BorderStroke(1.dp, Color.Black.copy(0.5f)),\n109:                         MaterialTheme.shapes.medium\n110:                     ),\n111:                 shape = MaterialTheme.shapes.medium,\n112:                 color = Color.White,\n113:                 contentColor = MaterialTheme.colors.primary\n114:             ) {\n115:                 Row(\n116:                     modifier = Modifier.padding(4.dp),\n117:                     horizontalArrangement = Arrangement.Center,\n118:                     verticalAlignment = Alignment.CenterVertically\n119:                 ) {\n120: \n121:                     Icon(\n122:                         imageVector = Icons.Default.Remove,\n123:                         contentDescription = stringResource(R.string.subtract),\n124:                         modifier = Modifier\n125:                             .padding(3.dp, 0.dp)\n126:                             .size(20.dp)\n127:                             .clickable {\n128:                                 if (state != 0) {\n129:                                     state--\n130:                                 }\n131:                             }\n132:                     )\n133: \n134:                     Text(text = state.toString())\n135: \n136:                     Icon(\n137:                         imageVector = Icons.Filled.Add,\n138:                         contentDescription = stringResource(R.string.add),\n139:                         modifier = Modifier\n140:                             .padding(3.dp, 0.dp)\n141:                             .size(20.dp)\n142:                             .clickable {\n143:                                 state++\n144:                             }\n145:                     )\n146: \n147: \n148:                 }\n149: \n150:             }\n151:         }\n152: \n153: \n154:         Text(text = \"  $  ${cartItem.menuItem.price}\", overflow = TextOverflow.Ellipsis)\n155: \n156: \n157:     }\n158: }\n\n(End of file - total 158 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be included in all\n *\tcopies or substantial portions of the Software.\n *\n *\tTHE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n *\tIMPLIED, INCLUDING BUT NOT LIMITED TO TH