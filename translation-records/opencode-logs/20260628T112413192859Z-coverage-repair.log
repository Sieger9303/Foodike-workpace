24:     @State\n25:     var currentRoute: String = bootstrapStartRoute\n26: \n27:     @State\n28:     var isShellAtTop: Bool = true\n29: \n30:     @State\n31:     var onboardingPageIndex: Int64 = 0\n32: \n33:     @State\n34:     var loginEmail: String = \"\"\n35: \n36:     @State\n37:     var loginPassword: String = \"\"\n38: \n39:     @State\n40:     var loginErrorMessage: String = \"\"\n41: \n42:     @State\n43:     var homeSearchQuery: String = \"\"\n44: \n45:     @State\n46:     var homeSelectedFilter: String = \"\"\n47: \n48:     @State\n49:     var historySearchQuery: String = \"\"\n50: \n51:     @State\n52:     var historyTabIndex: Int64 = 0\n53: \n54:     @State\n55:     var previousRoute: String = \"home_screen\"\n56: \n57:     @State\n58:     var cartNote: String = \"\"\n59: \n60:     @State\n61:     var cartCoupon: String = \"\"\n62: \n63:     @State\n64:     var cartMutationRevision: Int64 = 0\n65: \n66:     @State\n67:     var detailRecommendedExpanded: Bool = true\n68: \n69:     @State\n70:     var detailNonVegExpanded: Bool = true\n71: \n72:     @State\n73:     var detailVegExpanded: Bool = true\n74: \n75:     @State\n76:     var detailLiked: Bool = false\n77: \n78:     @State\n79:     var detailMutationRevision: Int64 = 0\n80: \n81:     private var onboardingController: SwiperController = SwiperController()\n82:     private var routeBackStack: ArrayList<String> = ArrayList<String>([])\n83: \n84:     private func applyShellState(shellState: ShellRouteState): Unit {\n85:         this.currentRoute = shellState.currentRoute\n86:         this.isShellAtTop = shellState.isAtTop\n87:     }\n88: \n89:     private func shellState(): ShellRouteState {\n90:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n91:     }\n92: \n93:     private func applyShellCommand(command: ShellCommand): Unit {\n94:         let shellState = this.shellState()\n95:         shellState.applyCommand(command)\n96:         this.applyShellState(shellState)\n97:     }\n98: \n99:     private func navigateTo(route: String): Unit {\n100:         if (this.currentRoute != route) {\n101:             this.routeBackStack.add(this.currentRoute)\n102:         }\n103:         this.previousRoute = this.currentRoute\n104:         let shellState = this.shellState()\n105:         shellState.currentRoute = route\n106:         shellState.isAtTop = true\n107:         this.applyShellState(shellState)\n108:     }\n109: \n110:     private func navigateBack(): Unit {\n111:         if (this.routeBackStack.size == 0) {\n112:             return\n113:         }\n114:         let targetIndex = this.routeBackStack.size - 1\n115:         let targetRoute = this.routeBackStack[targetIndex]\n116:         this.routeBackStack.remove(at: targetIndex)\n117:         this.previousRoute = this.currentRoute\n118:         let shellState = this.shellState()\n119:         shellState.currentRoute = targetRoute\n120:         shellState.isAtTop = true\n121:         this.applyShellState(shellState)\n122:     }\n123: \n124:     private func showBottomShell(route: String): Bool {\n125:         let shellState = this.shellState()\n126:         shellState.currentRoute = route\n127:         return shellState.showBottomShell()\n128:     }\n129: \n130:     private func routeTitle(route: String): ResourceStr {\n131:         routeLabelByPath(route)\n132:     }\n133: \n134:     private func showToast(message: String): Unit {\n135:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n136:     }\n137: \n138:     private func clearLoginError(): Unit {\n139:         this.loginErrorMessage = \"\"\n140:     }\n141: \n142:     private func performLogin(): Unit {\n143:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n144:             this.clearLoginError()\n145:             this.navigateTo(loginStore.successRoute())\n146:             return\n147:         }\n148: \n149:         this.loginErrorMessage = loginStore.invalidLoginMessage\n150:         this.showToast(loginStore.invalidLoginMessage)\n151:     }\n152: \n153:     private func performLogout(): Unit {\n154:         profileStore.logout(Global.abilityContext)\n155:         this.loginEmail = \"\"\n156:         this.loginPassword = \"\"\n157:         this.clearLoginError()\n158:         this.onboardingPageIndex = 0\n159:         this.homeSearchQuery = \"\"\n160:         this.homeSelectedFilter = \"\"\n161:         this.historySearchQuery = \"\"\n162:         this.historyTabIndex = 0\n163:         this.routeBackStack.clear()\n164:         this.navigateTo(profileStore.logoutRoute())\n165:     }\n166: \n167:     private func routeSummary(route: String): String {\n168:         match (route) {\n169:             case \"home_screen\" => \"Home now renders repository-backed discovery content, local search/filter controls, and restaurant selection before detail routing.\"\n170:             case \"history\" => \"History now preserves search plus tab-local content, reuses favourite restaurants, and saves the selected restaurant before navigation.\"\n171:             case \"cart\" => \"Cart now renders snapshot-backed items, a local note editor, a local coupon field, delivery details, and bill totals without adding new checkout persistence flows.\"\n172:             case \"restaurant_details\" => \"Restaurant detail now reads the selected restaurant, preserves local section expansion and like state, keeps menu quantity controls local to the route, and shows the cart action only when selected quantities are non-zero.\"\n173:             case _ => \"\"\n174:         }\n175:     }\n176: \n177:     private func homeHour(): Int64 {\n178:         return 9\n179:     }\n180: \n181:     private func goToProfile(): Unit {\n182:         this.navigateTo(routePath(RouteId.Profile))\n183:     }\n184: \n185:     private func goToRestaurantDetail(): Unit {\n186:         this.detailRecommendedExpanded = true\n187:         this.detailNonVegExpanded = true\n188:         this.detailVegExpanded = true\n189:         this.detailLiked = detailStore.session().isRestaurantLiked(detailStore.selectedRestaurant())\n190:         this.detailMutationRevision = 0\n191:         this.navigateTo(routePath(RouteId.RestaurantDetails))\n192:     }\n193: \n194:     private func detailState(): DetailPageState {\n195:         return detailStore.loadDetailState(\n196:             this.detailRecommendedExpanded,\n197:             this.detailNonVegExpanded,\n198:             this.detailVegExpanded\n199:         )\n200:     }\n201: \n202:     private func selectHomeRestaurant(restaurant: RestaurantData): Unit {\n203:         homeStore.selectRestaurant(restaurant, { =>\n204:             this.goToRestaurantDetail()\n205:         })\n206:     }\n207: \n208:     private func selectHistoryRestaurant(restaurant: RestaurantData): Unit {\n209:         historyStore.selectRestaurant(restaurant, { =>\n210:             this.goToRestaurantDetail()\n211:         })\n212:     }\n213: \n214:     @Builder\n215:     private func buildOnboardingRoute() {\n216:         renderOnboardingRoute(\n217:             this.onboardingPageIndex,\n218:             this.onboardingController,\n219:             { index: Int32 =>\n220:                 this.onboardingPageIndex = Int64(index)\n221:             },\n222:             { =>\n223:                 if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n224:                     this.navigateTo(routePath(RouteId.Login))\n225:                 } else {\n226:                     this.onboardingController.showNext()\n227:                 }\n228:             }\n229:         )\n230:     }\n231: \n232:     @Builder\n233:     private func buildLoginRoute() {\n234:         renderLoginRoute(\n235:             this.loginEmail,\n236:             this.loginPassword,\n237:             this.loginErrorMessage,\n238:             { value: String =>\n239:                 this.loginEmail = value\n240:                 this.clearLoginError()\n241:             },\n242:             { value: String =>\n243:                 this.loginPassword = value\n244:                 this.clearLoginError()\n245:             },\n246:             { => this.showToast(loginStore.comingSoonMessage) },\n247:             { => this.performLogin() },\n248:             { => this.showToast(loginStore.comingSoonMessage) },\n249:             { => this.showToast(loginStore.comingSoonMessage) },\n250:             { => this.showToast(loginStore.comingSoonMessage) },\n251:             { => this.clearLoginError() }\n252:         )\n253:     }\n254: \n255:     @Builder\n256:     private func buildProfileRoute() {\n257:         renderProfileRoute(\n258:             profileStore.userName,\n259:             profileStore.userEmail,\n260:             { => this.navigateTo(profileStore.backRoute()) },\n261:             { => this.showToast(profileStore.placeholderActionMessage) },\n262:             { => this.showToast(profileStore.placeholderActionMessage) },\n263:             { => this.performLogout() }\n264:         )\n265:     }\n266: \n267:     @Builder\n268:     private func buildHomeRoute() {\n269:         renderHomeRoute(\n270:             homeStore.buildFilteredState(this.homeSearchQuery, this.homeSelectedFilter),\n271:             this.homeHour(),\n272:             this.homeSearchQuery,\n273:             this.homeSelectedFilter,\n274:             { value: String =>\n275:                 this.homeSearchQuery = value\n276:             },\n277:             { value: String =>\n278:                 this.homeSelectedFilter = homeStore.toggleFilter(this.homeSelectedFilter, value)\n279:             },\n280:             { => this.goToProfile() },\n281:             { restaurant: RestaurantData =>\n282:                 this.selectHomeRestaurant(restaurant)\n283:             }\n284:         )\n285:     }\n286: \n287:     @Builder\n288:     private func buildHistoryRoute() {\n289:         renderHistoryRoute(\n290:             historyStore.buildVisibleState(this.historySearchQuery),\n291:             this.historyTabIndex,\n292:             this.historySearchQuery,\n293:             { value: String =>\n294:                 this.historySearchQuery = value\n295:             },\n296:             { value: Int64 =>\n297:                 this.historyTabIndex = value\n298:             },\n299:             { restaurant: RestaurantData =>\n300:                 this.selectHistoryRestaurant(restaurant)\n301:             }\n302:         )\n303:     }\n304: \n305:     @Builder\n306:     private func buildCartRoute() {\n307:         renderCartRoute(\n308:             cartStore.loadCartState(),\n309:             this.cartNote,\n310:             this.cartCoupon,\n311:             { value: String =>\n312:                 this.cartNote = value\n313:             },\n314:             { value: String =>\n315:                 this.cartCoupon = value\n316:             },\n317:             { item: CartSnapshotItemData =>\n318:                 cartStore.decrementQuantity(item)\n319:                 this.cartMutationRevision += 1\n320:             },\n321:             { item: CartSnapshotItemData =>\n322:                 cartStore.incrementQuantity(item)\n323:                 this.cartMutationRevision += 1\n324:             },\n325:             { =>\n326:                 this.navigateBack()\n327:             }\n328:         )\n329:     }\n330: \n331:     @Builder\n332:     private func buildDetailRoute() {\n333:         renderDetailRoute(\n334:             this.detailState(),\n335:             { =>\n336:                 this.navigateBack()\n337:             },\n338:             { =>\n339:                 let restaurant = detailStore.selectedRestaurant()\n340:                 this.detailLiked = detailStore.toggleLiked(restaurant, this.detailLiked)\n341:             },\n342:             { =>\n343:                 this.showToast(loginStore.comingSoonMessage)\n344:             },\n345:             { =>\n346:                 this.detailRecommendedExpanded = !this.detailRecommendedExpanded\n347:             },\n348:             { =>\n349:                 this.detailNonVegExpanded = !this.detailNonVegExpanded\n350:             },\n351:             { =>\n352:                 this.detailVegExpanded = !this.detailVegExpanded\n353:             },\n354:             { item: DetailMenuItemData =>\n355:                 detailStore.incrementQuantity(item)\n356:                 this.detailMutationRevision += 1\n357:             },\n358:             { item: DetailMenuItemData =>\n359:                 detailStore.decrementQuantity(item)\n360:                 this.detailMutationRevision += 1\n\n(Showing lines 1-360 of 434. Use offset=361 to continue.)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\nimport kit.ArkUI.*\nimport ohos.base.ResourceStr\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos.arkui.state_macro_manage.Component\nimport ohos.arkui.state_macro_manage.Entry\nimport ohos.arkui.state_macro_manage.State\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.{CartSnapshotItemData, DetailMenuItemData, DetailPageState, RestaurantData}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.{cartStore, renderCartRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.{detailStore, renderDetailRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history.{historyStore, renderHistoryRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home.{homeStore, renderHomeRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.{loginStore, renderLoginRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.{onboardingStore, renderOnboardingRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{profileStore, renderProfileRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangji