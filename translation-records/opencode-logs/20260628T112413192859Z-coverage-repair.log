 }\n34: \n35:     public func itemTotal(items: ArrayList<CartSnapshotItemData>): Float64 {\n36:         var total: Float64 = 0.0\n37:         for (item in items) {\n38:             var remaining = item.quantity\n39:             while (remaining > 0) {\n40:                 total += item.menuItem.price\n41:                 remaining -= 1\n42:             }\n43:         }\n44:         return total\n45:     }\n46: \n47:     public func incrementQuantity(item: CartSnapshotItemData): Unit {\n48:         sessionRepository.incrementMenuItemQuantity(item.menuItem.dish)\n49:     }\n50: \n51:     public func decrementQuantity(item: CartSnapshotItemData): Unit {\n52:         sessionRepository.decrementMenuItemQuantity(item.menuItem.dish)\n53:     }\n54: \n55:     public func formatPrice(price: Float64): String {\n56:         return \"$${price}\"\n57:     }\n58: \n59:     public func formatEta(minutes: Int64): String {\n60:         return formatMinutesDuration(minutes)\n61:     }\n62: \n63:     public func taxAmount(itemTotal: Float64): Float64 {\n64:         return itemTotal * 0.18\n65:     }\n66: \n67:     public func grandTotal(itemTotal: Float64): Float64 {\n68:         return itemTotal + taxAmount(itemTotal)\n69:     }\n70: \n71:     public func deliveryLocation(): String {\n72:         return \"Guwahati\"\n73:     }\n74:     public func session(): SessionRepository {\n75:         return sessionRepository\n76:     }\n77: }\n\n(End of file - total 77 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.homeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.formatMinutesDuration\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\npublic let cartStore = CartStore()\n\npublic