 Color.Gray })\n42: }\n43: \n44: @Builder\n45: public func renderOnboardingRoute(\n46:     pageIndex: Int64,\n47:     controller: SwiperController,\n48:     onIndexChanged: (Int32) -> Unit,\n49:     onNext: () -> Unit\n50: ) {\n51:     Column(space: 24) {\n52:         Swiper(controller: controller) {\n53:             buildOnboardingCard(\n54:                 onboardingStore.slideAt(0).title,\n55:                 onboardingStore.slideAt(0).description,\n56:                 onboardingStore.slideAt(0).mediaName\n57:             )\n58:             buildOnboardingCard(\n59:                 onboardingStore.slideAt(1).title,\n60:                 onboardingStore.slideAt(1).description,\n61:                 onboardingStore.slideAt(1).mediaName\n62:             )\n63:             buildOnboardingCard(\n64:                 onboardingStore.slideAt(2).title,\n65:                 onboardingStore.slideAt(2).description,\n66:                 onboardingStore.slideAt(2).mediaName\n67:             )\n68:         }\n69:         .indicator(false)\n70:         .onChange({ index: Int32 =>\n71:             onIndexChanged(index)\n72:         })\n73:         .width(100.percent)\n74:         .height(78.percent)\n75: \n76:         Row {\n77:             Row(space: 12) {\n78:                 buildOnboardingIndicator(pageIndex == 0)\n79:                 buildOnboardingIndicator(pageIndex == 1)\n80:                 buildOnboardingIndicator(pageIndex == 2)\n81:             }\n82:             Button(\">\")\n83:                 .onClick({ _ =>\n84:                     onNext()\n85:                 })\n86:         }\n87:         .width(90.percent)\n88:         .justifyContent(FlexAlign.SpaceBetween)\n89:         .alignItems(VerticalAlign.Center)\n90:         .margin(bottom: 12)\n91:     }\n92:     .width(100.percent)\n93:     .height(100.percent)\n94:     .backgroundColor(colorDarkGreen)\n95:     .alignItems(HorizontalAlign.Center)\n96:     .justifyContent(FlexAlign.SpaceBetween)\n97: }\n\n(End of file - total 97 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n\n@Builder\nfunc buildOnboardingCard(title: String, description: String, mediaName: String) {\n    Column(space: 18) {\n        Image(\n            match (mediaName) {\n                case \"chinese_bowl\" => mediaChineseBowl\n                case \"rider\" => mediaRider\n                case _ => mediaClock\n            }\n        )\n            .width(72.percent)\n            .height(280)\n        Text(title)\n            .fontSize(30)","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\onboarding\\onboarding_page.cj","time":{"start":1782387556221,"end":1782387556230}},"id":"prt_efe93be2e001Z8GPqb0GEqMBP5","sessionID":"ses_1016ce029ffemCaBB5i2jTaXCt","messageID":"msg_efe939350001AArH6COicZlGMn"}}
{"type":"tool_use","timestamp":1782387556423,"sessionID":"ses_1016ce029ffemCaBB5i2jTaXCt","part":{"type":"tool","tool":"read","callID":"call_S3Zr56fwNiZw6fsMYB1nqKq8","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase03_onboarding_login_profile_test.cj","limit":220},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase03_onboarding_login_profile_test.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry\n2: \n3: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, routePath}\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.LoginStore\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.OnboardingStore\n6: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.ProfileStore\n7: import std.unittest.*\n8: import std.unittest.testmacro.*\n9: \n10: @Test\n11: public class Phase03OnboardingLoginProfileTest {\n12:     @TestCase\n13:     public func onboardingStorePreservesThreePageProgression(): Unit {\n14:         let store = OnboardingStore()\n15:         @Assert(store.pageCount(), 3)\n16:         @Assert(store.slideAt(0).title, \"Choose your favourite food\")\n17:         @Assert(store.isLastPage(0), false)\n18:         @Assert(store.nextIndex(0), 1)\n19:         @Assert(store.isLastPage(2), true)\n20:         @Assert(store.nextIndex(2), 2)\n21:     }\n22: \n23:     @TestCase\n24:     public func loginStoreAcceptsOnlySourceCredentials(): Unit {\n25:         let store = LoginStore()\n26:         @Assert(store.isValidCredentials(\"abcxyz@gmail.com\", \"abcdef\"), true)\n27:         @Assert(store.isValidCredentials(\"abcxyz@gmail.com\", \"bad\"), false)\n28:         @Assert(store.isValidCredentials(\"other@example.com\", \"abcdef\"), false)\n29:         @Assert(store.successRoute(), routePath(RouteId.Home))\n30:     }\n31: \n32:     @TestCase\n33:     public func profileStoreRoutesBackAndLogoutToSourceDestinations(): Unit {\n34:         let store = ProfileStore()\n35:         @Assert(store.backRoute(), routePath(RouteId.History))\n36:         @Assert(store.logoutRoute(), routePath(RouteId.Onboarding))\n37:         @Assert(store.userName, \"Andrew Howard\")\n38:         @Assert(store.userEmail, \"andrewhoward@gmail.com\")\n39:     }\n40: }\n\n(End of file - total 40 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, routePath}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.LoginStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.OnboardingStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.ProfileStore\nimport std.unittest.*\nimport std.unittest.testmacro.*\n\n@Test\npublic class Phase03OnboardingLoginProfileTest {\n    @TestCase\n    public func onboardingStorePreservesThreePageProgression(): Unit {\n        let store = OnboardingStore()\n        @Assert(store.pageCount(), 3)\n        @Assert(store.slideAt(0).title, \"Choose your favourite food\")\n        @Assert(store.isLastPage(0), false)\n        @Assert(store.nextIndex(0), 1)\n        @Assert(store.isLastPage(2), true)\n        @Assert(store.nextIndex(2), 2)","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\test\\cangjie\\phase03_onboarding_login_profile_test.cj","time":{"start":1782387556383,"end":1782387556421}},"id":"prt_efe93c01a001gUjQYtWNCwdvQD","sessionID":"ses_1016ce029ffemCaBB5i2jTaXCt","messageID":"msg_efe939350001AArH6COicZlGMn"}}
{"type":"tool_use","timestamp":1782387556425,"sessionID":"ses_1016ce029ffemCaBB5i2jTaXCt","part":{"type":"tool","tool":"read","callID":"call_YXgehrLuiZGJjjz6jvaFJnia","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj","limit":280},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n2: \n3: import kit.ArkUI.*\n4: import ohos.arkui.state_macro_manage.Builder\n5: import ohos.arkui.state_macro_manage.Component\n6: import ohos.arkui.state_macro_manage.Entry\n7: import ohos.arkui.state_macro_manage.State\n8: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n9: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.{loginStore, renderLoginRoute}\n10: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.{onboardingStore, renderOnboardingRoute}\n11: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{profileStore, renderProfileRoute}\n12: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.runtime.{Global, bootstrapStartRoute}\n13: \n14: @Entry\n15: @Component\n16: class FoodikeBootstrap {\n17:     @State\n18:     var currentRoute: String = bootstrapStartRoute\n19: \n20:     @State\n21:     var isShellAtTop: Bool = true\n22: \n23:     @State\n24:     var onboardingPageIndex: Int64 = 0\n25: \n26:     @State\n27:     var loginEmail: String = \"\"\n28: \n29:     @State\n30:     var loginPassword: String = \"\"\n31: \n32:     @State\n33:     var loginErrorMessage: String = \"\"\n34: \n35:     private var onboardingController: SwiperController = SwiperController()\n36: \n37:     private func applyShellState(shellState: ShellRouteState): Unit {\n38:         this.currentRoute = shellState.currentRoute\n39:         this.isShellAtTop = shellState.isAtTop\n40:     }\n41: \n42:     private func shellState(): ShellRouteState {\n43:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n44:     }\n45: \n46:     private func applyShellCommand(command: ShellCommand): Unit {\n47:         let shellState = this.shellState()\n48:         shellState.applyCommand(command)\n49:         this.applyShellState(shellState)\n50:     }\n51: \n52:     private func navigateTo(route: String): Unit {\n53:         let shellState = this.shellState()\n54:         shellState.currentRoute = route\n55:         shellState.isAtTop = true\n56:         this.applyShellState(shellState)\n57:     }\n58: \n59:     private func showBottomShell(route: String): Bool {\n60:         let shellState = this.shellState()\n61:         shellState.currentRoute = route\n62:         return shellState.showBottomShell()\n63:     }\n64: \n65:     private func routeTitle(route: String): String {\n66:         match (route) {\n67:             case \"onboarding\" => \"Onboarding\"\n68:             case \"login_screen\" => \"Login\"\n69:             case \"home_screen\" => \"Home\"\n70:             case \"history\" => \"History\"\n71:             case \"cart\" => \"Cart\"\n72:             case \"profile\" => \"Profile\"\n73:             case \"restaurant_details\" => \"Restaurant Detail\"\n74:             case _ => \"Unknown Route\"\n75:         }\n76:     }\n77: \n78:     private func showToast(message: String): Unit {\n79:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n80:     }\n81: \n82:     private func clearLoginError(): Unit {\n83:         this.loginErrorMessage = \"\"\n84:     }\n85: \n86:     private func performLogin(): Unit {\n87:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n88:             this.clearLoginError()\n89:             this.navigateTo(loginStore.successRoute())\n90:             return\n91:         }\n92: \n93:         this.loginErrorMessage = loginStore.invalidLoginMessage\n94:         this.showToast(loginStore.invalidLoginMessage)\n95:     }\n96: \n97:     private func performLogout(): Unit {\n98:         profileStore.logout(Global.abilityContext)\n99:         this.loginEmail = \"\"\n100:         this.loginPassword = \"\"\n101:         this.clearLoginError()\n102:         this.onboardingPageIndex = 0\n103:         this.navigateTo(profileStore.logoutRoute())\n104:     }\n105: \n106:     private func routeSummary(route: String): String {\n107:         match (route) {\n108:             case \"home_screen\" => \"Home remains the shared shell placeholder from phase 02 while onboarding, login, and profile now run as dedicated phase-03 routes.\"\n109:             case \"history\" => \"History remains available as a shell route so profile still has a source-consistent back destination.\"\n110:             case \"cart\" => \"Cart continues to be a shell-owned placeholder route until later phases land the real content.\"\n111:             case \"restaurant_details\" => \"Restaurant detail remains in the route contract but keeps its placeholder body until later phases.\"\n112:             case _ => \"\"\n113:         }\n114:     }\n115: \n116:     @Builder\n117:     private func buildOnboardingRoute() {\n118:         renderOnboardingRoute(\n119:             this.onboardingPageIndex,\n120:             this.onboardingController,\n121:             { index: Int32 =>\n122:                 this.onboardingPageIndex = Int64(index)\n123:             },\n124:             { =>\n125:                 if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n126:                     this.navigateTo(routePath(RouteId.Login))\n127:                 } else {\n128:                     this.onboardingController.showNext()\n129:                 }\n130:             }\n131:         )\n132:     }\n133: \n134:     @Builder\n135:     private func buildLoginRoute() {\n136:         renderLoginRoute(\n137:             this.loginEmail,\n138:             this.loginPassword,\n139:             this.loginErrorMessage,\n140:             { value: String =>\n141:                 this.loginEmail = value\n142:                 this.clearLoginError()\n143:             },\n144:             { value: String =>\n145:                 this.loginPassword = value\n146:                 this.clearLoginError()\n147:             },\n148:             { => this.showToast(loginStore.comingSoonMessage) },\n149:             { => this.performLogin() },\n150:             { => this.showToast(loginStore.comingSoonMessage) },\n151:             { => this.showToast(loginStore.comingSoonMessage) },\n152:             { => this.showToast(loginStore.comingSoonMessage) },\n153:             { => this.clearLoginError() }\n154:         )\n155:     }\n156: \n157:     @Builder\n158:     private func buildProfileRoute() {\n159:         renderProfileRoute(\n160:             profileStore.userName,\n161:             profileStore.userEmail,\n162:             { => this.navigateTo(profileStore.backRoute()) },\n163:             { => this.showToast(profileStore.placeholderActionMessage) },\n164:             { => this.showToast(profileStore.placeholderActionMessage) },\n165:             { => this.performLogout() }\n166:         )\n167:     }\n168: \n169:     @Builder\n170:     private func buildPlaceholderRoute() {\n171:         Column(space: 18) {\n172:             Text(\"Foodike\")\n173:                 .fontSize(42)\n174:                 .fontWeight(FontWeight.Bold)\n175:             Text(this.routeTitle(this.currentRoute))\n176:                 .fontSize(28)\n177:             Text(this.routeSummary(this.currentRoute))\n178:                 .fontSize(16)\n179:                 .textAlign(TextAlign.Center)\n180:                 .width(86.percent)\n181: \n182:             if (this.currentRoute == routePath(RouteId.Home) || this.currentRoute == routePath(RouteId.History)) {\n183:                 Button(if (this.isShellAtTop) { \"Simulate Scrolled Content\" } else { \"Return To Top\" })\n184:                     .onClick({ _ =>\n185:                         let shellState = this.shellState()\n186:                         shellState.setTopState(!shellState.isAtTop)\n187:                         this.applyShellState(shellState)\n188:                     })\n189:             }\n190: \n191:             Button(\"Primary Route Action\")\n192:                 .onClick({ _ =>\n193:                     this.applyShellCommand(ShellCommand.PrimaryAction)\n194:                 })\n195: \n196:             if (this.showBottomShell(this.currentRoute)) {\n197:                 Row(space: 12) {\n198:                     Button(\"Home Tab\")\n199:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HomeTab) })\n200:                     Button(\"Cart\")\n201:                         .onClick({ _ => this.applyShellCommand(ShellCommand.CartAction) })\n202:                     Button(\"History Tab\")\n203:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HistoryTab) })\n204:                 }\n205:             }\n206:         }\n207:         .width(100.percent)\n208:         .height(100.percent)\n209:         .justifyContent(FlexAlign.Center)\n210:         .alignItems(HorizontalAlign.Center)\n211:         .padding(top: 24, right: 24, bottom: 24, left: 24)\n212:     }\n213: \n214:     func build() {\n215:         if (this.currentRoute == routePath(RouteId.Onboarding)) {\n216:             this.buildOnboardingRoute()\n217:         } else if (this.currentRoute == routePath(RouteId.Login)) {\n218:             this.buildLoginRoute()\n219:         } else if (this.currentRoute == routePath(RouteId.Profile)) {\n220:             this.buildProfileRoute()\n221:         } else {\n222:             this.buildPlaceholderRoute()\n223:         }\n224:     }\n225: }\n\n(End of file - total 225 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\nim