out.Column\n32: import androidx.compose.foundation.layout.fillMaxSize\n33: import androidx.compose.foundation.layout.padding\n34: import androidx.compose.material.MaterialTheme\n35: import androidx.compose.material.Surface\n36: import androidx.compose.runtime.Composable\n37: import androidx.compose.runtime.rememberCoroutineScope\n38: import androidx.compose.ui.Alignment\n39: import androidx.compose.ui.Modifier\n40: import androidx.compose.ui.graphics.toArgb\n41: import androidx.compose.ui.platform.LocalContext\n42: import androidx.compose.ui.unit.dp\n43: import androidx.navigation.NavHostController\n44: import com.example.foodike.presentation.onboarding.components.BottomSection\n45: import com.example.foodike.presentation.onboarding.components.OnboardingPage\n46: import com.example.foodike.presentation.onboarding.util.OnBoardingItem\n47: import com.example.foodike.presentation.util.Screen\n48: import com.google.accompanist.pager.ExperimentalPagerApi\n49: import com.google.accompanist.pager.HorizontalPager\n50: import com.google.accompanist.pager.rememberPagerState\n51: import kotlinx.coroutines.launch\n52: \n53: @OptIn(ExperimentalPagerApi::class)\n54: @Composable\n55: fun OnBoarding(\n56:     navController: NavHostController,\n57: ) {\n58:     Surface(\n59:         modifier = Modifier.fillMaxSize(),\n60:         color = MaterialTheme.colors.primary\n61:     ) {\n62:         Column(\n63:             modifier = Modifier.fillMaxSize(),\n64:             verticalArrangement = Arrangement.Center,\n65:             horizontalAlignment = Alignment.CenterHorizontally\n66:         ) {\n67:             val context = LocalContext.current as Activity\n68:             context.window.statusBarColor = MaterialTheme.colors.primary.toArgb()\n69:             context.window.navigationBarColor = MaterialTheme.colors.primary.toArgb()\n70: \n71:             val scope = rememberCoroutineScope()\n72: \n73:             val items = OnBoardingItem.get()\n74: \n75:             val pagerState = rememberPagerState()\n76: \n77:             HorizontalPager(\n78:                 count = items.size,\n79:                 modifier = Modifier\n80:                     .fillMaxSize()\n81:                     .weight(0.8f),\n82:                 state = pagerState,\n83:             ) { page ->\n84:                 OnboardingPage(item = items[page])\n85:             }\n86:             Column(\n87:                 modifier = Modifier\n88:                     .padding(0.dp, 0.dp, 0.dp, 16.dp)\n89:                     .fillMaxSize()\n90:                     .weight(0.2f),\n91:                 verticalArrangement = Arrangement.Bottom,\n92:                 horizontalAlignment = Alignment.CenterHorizontally\n93:             ) {\n94:                 BottomSection(size = items.size, index = pagerState.currentPage) {\n95:                     if (pagerState.currentPage + 1 < items.size) {\n96:                         scope.launch {\n97:                             pagerState.scrollToPage(pagerState.currentPage + 1)\n98:                         }\n99: \n100:                     } else {\n101:                         navController.navigate(Screen.LoginScreen.route)\n102:                     }\n103:                 }\n104:             }\n105: \n106:         }\n107:     }\n108: \n109: }\n110: \n111: \n112: \n113: \n\n(End of file - total 113 lines)\n</content>","metadata":{"preview":"/**\n *\n *\tMIT License\n *\n *\tCopyright (c) 2026 Gautam Hazarika\n *\n *\tPermission is hereby granted, free of charge, to any person obtaining a copy\n *\tof this software and associated documentation files (the \"Software\"), to deal\n *\tin the Software without restriction, including without limitation the rights\n *\tto use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n *\tcopies of the Software, and to permit persons to whom the Software is\n *\tfurnished to do so, subject to the following conditions:\n *\n *\tThe above copyright notice and this permission notice shall be 