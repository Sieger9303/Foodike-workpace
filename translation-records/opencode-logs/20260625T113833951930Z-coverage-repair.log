{"type":"tool_use","timestamp":1782387555893,"sessionID":"ses_1016ce029ffemCaBB5i2jTaXCt","part":{"type":"tool","tool":"read","callID":"call_LIO1DvfIwslSV5V7CZKA1WRz","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\onboarding\\onboarding_store.cj","limit":220},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\onboarding\\onboarding_store.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding\n2: \n3: import std.collection.ArrayList\n4: \n5: public class OnboardingSlide {\n6:     public let title: String\n7:     public let description: String\n8:     public let mediaName: String\n9: \n10:     public init(title: String, description: String, mediaName: String) {\n11:         this.title = title\n12:         this.description = description\n13:         this.mediaName = mediaName\n14:     }\n15: }\n16: \n17: public let onboardingStore = OnboardingStore()\n18: \n19: public class OnboardingStore {\n20:     private let slidesData = ArrayList<OnboardingSlide>([\n21:         OnboardingSlide(\n22:             \"Choose your favourite food\",\n23:             \"Choose from a range of restaurants and hotels near you\",\n24:             \"chinese_bowl\"\n25:         ),\n26:         OnboardingSlide(\n27:             \"Vaccinated delivery partners\",\n28:             \"Vaccinated delivery partners ensure the health and security of the customer\",\n29:             \"rider\"\n30:         ),\n31:         OnboardingSlide(\n32:             \"Expect Delivery in 20 minutes\",\n33:             \"Fast and easy to track delivery to ease the experience of the customer\",\n34:             \"clock\"\n35:         )\n36:     ])\n37: \n38:     public init() {}\n39: \n40:     public func slides(): ArrayList<OnboardingSlide> {\n41:         return slidesData\n42:     }\n43: \n44:     public func pageCount(): Int64 {\n45:         return slidesData.size\n46:     }\n47: \n48:     public func slideAt(index: Int64): OnboardingSlide {\n49:         return slidesData[index]\n50:     }\n51: \n52:     public func isLastPage(index: Int64): Bool {\n53:         return index >= pageCount() - 1\n54:     }\n55: \n56:     public func nextIndex(index: Int64): Int64 {\n57:         if (isLastPage(index)) {\n58:             return index\n59:         }\n60: \n61:         return index + 1\n62:     }\n63: }\n\n(End of file - total 63 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding\n\nimport std.collection.ArrayList\n\npublic class OnboardingSlide {\n    public let title: String\n    public let description: String\n    public let mediaName: String\n\n    public init(title: String, description: String, mediaName: String) {\n        this.title = title\n        this.description = description\n        this.mediaName = mediaName\n    }\n}\n\npublic let onboardingStore = OnboardingStore()\n\npublic class OnboardingStore {\n    private let slidesData = ArrayList<OnboardingSlide>([","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\onboarding\\onboarding_store.cj","time":{"start":1782387555885,"end":1782387555892}},"id":"prt_efe93bddf001dxfsALlQzhbFW4","sessionID":"ses_1016ce029ffemCaBB5i2jTaXCt","messageID":"msg_efe939350001AArH6COicZlGMn"}}
