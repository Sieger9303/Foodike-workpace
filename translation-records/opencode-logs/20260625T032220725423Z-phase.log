eatures/startup/startup_store.cj\",\n181:       \"kind\": \"feature-store\",\n182:       \"sourceRefs\": [\n183:         \"app/src/main/java/com/example/foodike/presentation/common/SplashViewModel.kt\"\n184:       ],\n185:       \"topLevelDefinitions\": [\n186:         \"StartupState\",\n187:         \"resolveStartRoute\"\n188:       ],\n189:       \"translationGuidelines\": [\n190:         \"Preserve the source startup contract: route is resolved before the shell becomes interactive.\"\n191:       ]\n192:     },\n193:     {\n194:       \"path\": \"entry/src/main/cangjie/ohos_app_cangjie_entry/features/login/login_store.cj\",\n195:       \"kind\": \"feature-store\",\n196:       \"sourceRefs\": [\n197:         \"app/src/main/java/com/example/foodike/presentation/login/LoginViewModel.kt\",\n198:         \"app/src/main/java/com/example/foodike/presentation/login/LoginEvent.kt\",\n199:         \"app/src/main/java/com/example/foodike/presentation/login/UiEvent.kt\"\n200:       ],\n201:       \"topLevelDefinitions\": [\n202:         \"LoginState\",\n203:         \"LoginCommand\",\n204:         \"LoginUiEvent\",\n205:         \"handleLoginCommand\"\n206:       ],\n207:       \"translationGuidelines\": [\n208:         \"Keep field state, validation, persisted login mutation, and snackbar/error emission separate from page widgets.\"\n209:       ]\n210:     },\n211:     {\n212:       \"path\": \"entry/src/main/cangjie/ohos_app_cangjie_entry/features/home/home_store.cj\",\n213:       \"kind\": \"feature-store\",\n214:       \"sourceRefs\": [\n215:         \"app/src/main/java/com/example/foodike/presentation/home/HomeViewModel.kt\",\n216:         \"app/src/main/java/com/example/foodike/presentation/home/HomeScreenState.kt\",\n217:         \"app/src/main/java/com/example/foodike/presentation/home/HomeScreenEvent.kt\"\n218:       ],\n219:       \"topLevelDefinitions\": [\n220:         \"HomeState\",\n221:         \"loadHomeContent\",\n222:         \"selectRestaurant\"\n223:      