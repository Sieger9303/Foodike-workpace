toJSValue(context: JSContext): JSValue\n217: }\n218: \n219: /**\n220:  * UIAbility is an application component that has the UI.\n221:  * The UIAbility module, inherited from Ability, provides lifecycle callbacks such as component creation, destruction,\n222:  * and foreground/background switching.\n223:  */\n224: @!APILevel[\n225:     since: \"22\",\n226:     syscap: \"SystemCapability.Ability.AbilityRuntime.AbilityCore\"\n227: ]\n228: public open class UIAbility <: Ability {\n229:     /**\n230:      * Context of the UIAbility.\n231:      *\n232:      * @returns { UIAbilityContext } Returns the context of the UIAbility.\n233:      */\n234:     @!APILevel[\n235:         since: \"22\",\n236:         syscap: \"SystemCapability.Ability.AbilityRuntime.AbilityCore\"\n237:     ]\n238:     public mut prop context: UIAbilityContext\n239: \n240:     /**\n241:      * Parameters for starting the UIAbility.\n242:      *\n243:      * @returns { Want } Returns the parameters for starting the UIAbility.\n244:      */\n245:     @!APILevel[\n246:         since: \"22\",\n247:         syscap: \"SystemCapability.Ability.AbilityRuntime.AbilityCore\"\n248:     ]\n249:     public mut prop launchWant: Want\n250: \n251:     /**\n252:      * Latest Want received through onCreate or onNewWant when the UIAbility is started for multiple times.\n253:      *\n254:      * @returns { Want } Returns the latest Want received through onCreate or onNewWant when the UIAbility is started\n255:      * for multiple times.\n256:      */\n257:     @!APILevel[\n258:         since: \"22\",\n259:         syscap: \"SystemCapability.Ability.AbilityRuntime.AbilityCore\"\n260:     ]\n261:     public mut prop lastRequestWant: Want\n262: \n263:     /**\n264:      * Called to initialize the service logic when a UIAbility instance in the completely closed state is created.\n265:      * In other words, a UIAbility instance enters this lifecycle callback from a cold start. This API returns the\n266:      * result synchronously and does not support asynchronous callback.\n267:      *\n268:      * @param { Want } want - Want information, including the ability name and bundle name.\n269:      * @param { LaunchParam } launchParam - Parameters for starting the UIAbility, and the reason for\n270:      * the last abnormal exit.\n271:      */\n272:     @!APILevel[\n273:         since: \"22\",\n274:         syscap: \"SystemCapability.Ability.AbilityRuntime.AbilityCore\"\n275:     ]\n276:     public open func onCreate(want: Want, launchParam: LaunchParam): Unit\n277: \n278:     /**\n279:      * Called when a WindowStage is created for this UIAbility.\n280:      *\n281:      * @param { WindowStage } windowStage - WindowStage information.\n282:      */\n283:     @!APILevel[\n284:         since: \"22\",\n285:         syscap: \"SystemCapability.Ability.AbilityRuntime.AbilityCore\"\n286:     ]\n287:     public open func onWindowStageCreate(windowStage: WindowStage): Unit\n288: \n289:     /**\n290:      * Called when the WindowStage is destroyed for this UIAbility.\n291:      */\n292:     @!APILevel[\n293:         since: \"22\",\n294:         syscap: \"SystemCapability.Ability.AbilityRuntime.AbilityCore\"\n295:     ]\n296:     public open func onWindowStageDestroy(): Unit\n297: \n298:     /**\n299:      * Called to clear resources when this UIAbility is destroyed.\n300:      * This API returns the result synchronously or uses a promise to return the result.\n301:      * After the onDestroy() lifecycle callback is executed, the application may exit. Consequently,\n302:      * the asynchronous function (for example, asynchronously writing data to the database) in onDestroy() may fail to\n303:      * be executed. You can use the asynchronous lifecycle to ensure that the subsequent lifecycle continues only after\n304:      * the asynchronous function in onDestroy() finishes the execution.\n305:      */\n306:     @!APILevel[\n307:         since: \"22\",\n308:         syscap: \"SystemCapability.Ability.AbilityRuntime.AbilityCore\"\n309:     ]\n310:     public open func onDestroy(): Unit\n311: \n312:     /**\n313:      * Triggered when the application transitions from the background to the foreground.\n314:      * It is called between onWillForeground and onDidForeground.\n315:      * It can be used to request system resources required, for example, requesting location services when the\n316:      * application transitions to the foreground.\n317:      * \n318:      * **NOTE**:\n319:      * This API returns the result synchronously and does not support asynchronous callback.\n320:      */\n321:     @!APILevel[\n322:         since: \"22\",\n323:         syscap: \"SystemCapability.Ability.AbilityRuntime.AbilityCore\"\n324:     ]\n325:     public open func onForeground(): Unit\n326: \n327:     /**\n328:      * Triggered when the application transitions from the background to the foreground.\n329:      * It is called between onWillForeground and onDidForeground.\n330:      * It can be used to request system resources required, for example, requesting location services when the\n331:      * application transitions to the foreground.\n332:      * \n333:      * **NOTE**:\n334:      * This API returns the result synchronously and does not support asynchronous callback.\n335:      */\n336:     @!APILevel[\n337:         since: \"22\",\n338:         syscap: \"SystemCapability.Ability.AbilityRuntime.AbilityCore\"\n339:     ]\n340:     public open func onBackground(): Unit\n341: \n342:     /**\n343:      * Called when a UIAbility instance that has undergone the following states is started again:\n344:      * started in the foreground, running in the foreground, and switched to the background.\n345:      *\n346:      * The triggering of the onNewWant lifecycle of a UIAbility instance indicates that this launch is a hot launch.\n347:      * Note that a hot launch does not necessarily trigger the onNewWant lifecycle.\n348:      *\n349:      * @param { Want } want - Want information