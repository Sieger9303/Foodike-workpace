utePath(RouteId.Home) || this.currentRoute == routePath(RouteId.History)) {\n+                    Button(if (this.isShellAtTop) { \"Simulate Scrolled Content\" } else { \"Return To Top\" })\n+                        .onClick({ evt =>\n+                            this.isShellAtTop = !this.isShellAtTop\n+                        })\n+                        .margin(top: 12)\n+                    Text(if (this.isShellAtTop) { \"Shell chrome is visible because the shared top-level list is at the first item.\" } else { \"Shell chrome is hidden because the shared top-level list has moved away from the first item.\" })\n+                        .fontSize(14)\n+                        .margin(top: 8)\n+                }\n+\n                 Text(\"Route picker\")\n                     .fontSize(18)\n                     .margin(top: 24)\n \n@@ -139,9 +145,9 @@\n                         Button(\"History Tab\")\n                             .onClick({ evt => this.navigateTo(routePath(RouteId.History)) })\n                             .margin(left: 12)\n                     }.margin(top: 12)\n-                    Text(\"The shell-owned bottom bar and cart action appear only on home and history routes, matching the source route contract for this phase.\")\n+                    Text(\"The shell-owned bottom bar and cart action appear only on home and history routes while the shared top-level list remains at the first item, matching the source route contract for this phase.\")\n                         .fontSize(14)\n                         .margin(top: 8)\n                 }\n             }.width(100.percent)\n","additions":18,"deletions":12},{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase02_startup_navigation_test.cj","relativePath":"Foodike-Harmony/entry/src/test/cangjie/phase02_startup_navigation_test.cj","type":"add","patch":"Index: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase02_startup_navigation_test.cj\n