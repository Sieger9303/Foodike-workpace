s' in target:\n        pid='phase-01-project-skeleton-resources'\n    if pid:\n        for sp in refs:\n            matches.append((sp,pid,'file'))\nfor a in plan.get('assets',[]):\n    for sp in a.get('sourcePaths',[]) or []:\n        matches.append((sp,'phase-01-project-skeleton-resources','asset'))\nfor t in plan.get('tests',[]):\n    pid=t.get('ownerPhase','')\n    for sp in t.get('sourcePaths',[]) or []:\n        matches.append((sp,pid,'test'))\n\ndef path_match(src,pat):\n    if '*' in pat:\n        return fnmatch.fnmatch(src, pat)\n    return src==pat\n\ndef heur(src, feature_name):\n    s=src.replace('\\\\','/').lower(); f=(feature_name or '').lower()\n    if s.startswith('app/src/main/res/') or s=='app/src/main/androidmanifest.xml' or s.startswith('app/src/main/assets') or s.startswith('readme') or s.endswith('contributing.md') or '/ui/theme/' in s:\n        return 'phase-01-project-skeleton-resources','resource-doc'\n    if s in {'build.gradle.kts','settings.gradle.kts','gradle.properties'} or s.startswith('gradle/') or s.endswith('libs.versions.toml') or s.endswith('proguard-rules.pro') or s.endswith('app/build.gradle.kts'):\n        return 'phase-01-project-skeleton-resources','build-config'\n    if '/presentation/onboarding/' in s:\n        return 'phase-03-onboarding-login','onboarding-prefix'\n    if '/presentation/login/' in s:\n        return 'phase-03-onboarding-login','login-prefix'\n    if '/presentation/home/' in s or s.endswith('/presentation/components/searchbar.kt') or s.endswith('/presentation/components/restaurantcard.kt'):\n        return 'phase-04-home-history','home-prefix'\n    if '/presentation/history/' in s:\n        return 'phase-04-home-history','history-prefix'\n    if '/presentation/details/' in s or '/presentation/cart/' in s:\n        return 'phase-05-detail-cart','detail-cart-prefix'\n    if '/presentation/profile/' in s or s.startswith('app/src/test/') or s.startswith('app/src/androidtest/'):\n        return 'phase-06-profile-capabilities-verification','profile-test-prefix'\n    if s.endswith('/presentation/mainactivity.kt') or '/presentation/common/' in s or '/presentation/util/' in s or '/data/repository/' in s or '/domain/repository/' in s or s.endswith('/di/appmodule.kt') or s.endswith('/foodikeapp.kt') or s.endswith('/data/data_source/fakedata.kt'):\n        return 'phase-02-startup-session-navigation','startup-shared-data'\n    if '/domain/model/' in s:\n        if s.endswith('/restaurant.kt') or s.endswith('/advertisement.kt') or s.endswith('/fooditem.kt'):\n            return 'phase-04-home-history','home-domain-model'\n        if s.endswith('/menuitem.kt') or s.endswith('/cartitem.kt'):\n            return 'phase-05-detail-cart','detail-cart-model'\n        return 'phase-02-startup-session-navigation','shared-domain-model'\n    if 'profile' in f or 'logout' in f or 'instrumented test' in f or 'unit test' in f:\n        return 'phase-06-profile-capabilities-verification','feature-name'\n    return '',''\nupdates=[]; unresolved=[]\nfor e in matrix['entries']:\n    if e.get('status')=='not-applicable' or e.get('plannedPhase'):\n        continue\n    fid=e.get('featureId',''); src=e.get('sourcePath',''); feature_name=e.get('featureName',''); phase=''; reason=''\n    if fid in explicit:\n        phase=explicit[fid]; reason='featureId'\n    else:\n        for pat,pid,kind in matches:\n            if path_match(src,pat):\n                phase=pid; reason=kind; break\n    if not phase:\n        phase,reason=heur(src,feature_name)\n    if not phase:\n        unresolved.append({'featureId':fid,'sourcePath':src,'featureName':feature_name})\n        continue\n    setv={'plannedPhase':phase}\n    if '/ui/theme/' in src.replace('\\\\','/').lower():\n        note='Assigned to phase 01 by best-fit semantic ownership: source path is theme/resource scope, while the generated permission label appears to be a static-analysis false positive.'\n        existing=(e.get('notes') or '').strip()\n        setv['notes']= existing + (' ' if existing else '') + note if note not in existing else existing\n    updates.append({'featureId':fid,'set':setv})\nif unresolved:\n    raise SystemExit('Unresolved rows: ' + json.dumps(unresolved[:20], ensure_ascii=False))\npayload={'updates':updates}\ntemp.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding='utf-8')\nprint(str(temp))\nprint('updates', len(updates))\"; if ($?) { & 'C:\\Users\\Sieger\\AppData\\Local\\Programs\\Python\\Python312\\python.exe' 'D:\\X2Cangjie\\X2Cangjie\\scripts\\shared\\source_coverage\\patch_authority.py' '--kind' 'matrix' '--authority' 'D:\\workspace\\Foodike\\translation-inputs\\source-coverage-matrix.json' '--patch' 'C:\\Users\\Sieger\\AppData\\Local\\Temp\\opencode\\foodike_backfill_round1_matrix_patch.json' '--markdown' 'D:\\workspace\\Foodike\\translation-inputs\\source-coverage-matrix.md' '--plan-json' 'D:\\workspace\\Foodike\\plan.json' }","description":"Create and apply matrix plannedPhase patch","workdir":"D:\\workspace\\Foodike","timeout":120000},"output":"C:\\Users\\Sieger\\AppData\\Local\\Temp\\opencode\\foodike_backfill_round1_matrix_patch.json\r\nupdates 248\r\nPatched matrix authority.\r\nUpdated entries: 248\r\nAdded entries: 0\r\nTouched ids: app-src-main-java-com-example-foodike-data-data-source-f-f170137f2d-001-file-document-storage-saf-mediastore-or, app-src-main-java-com-example-foodike-data-data-source-f-8d9b6c748e-002-image-viewing-bitmap-exif-handling-zoom, app-src-main-java-com-example-foodike-data-data-source-f-5dbff38a8a-003-intent-uri-bundle-deeplink-or-cross-scre, app-src-main-java-com-example-foodike-data-data-source-f-d03fbb20a2-004-navigation-surface-menu-drawer-toolbar-o, app-src-main-java-com-example-foodike-data-data-source-f-552e89ac77-005-runtime-permission-request-permission-re, app-src-main-java-com-example-foodike-presentation-detai-fe74e39178-001-image-viewing-bitmap-exif-handling-zoom, app-src-main-java-com-example-foodike-presentation-det