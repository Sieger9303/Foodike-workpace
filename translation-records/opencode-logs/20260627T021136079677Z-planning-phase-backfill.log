activity.kt') or '/presentation/common/' in s or '/presentation/util/' in s or '/data/repository/' in s or '/domain/repository/' in s or s.endswith('/di/appmodule.kt') or s.endswith('/foodikeapp.kt') or s.endswith('/data/data_source/fakedata.kt'):\n        return 'phase-02-startup-session-navigation','startup-shared-data'\n    if '/domain/model/' in s:\n        if s.endswith('/restaurant.kt') or s.endswith('/advertisement.kt') or s.endswith('/fooditem.kt'):\n            return 'phase-04-home-history','home-domain-model'\n        if s.endswith('/menuitem.kt') or s.endswith('/cartitem.kt'):\n            return 'phase-05-detail-cart','detail-cart-model'\n        return 'phase-02-startup-session-navigation','shared-domain-model'\n    if 'profile' in f or 'logout' in f or 'instrumented test' in f or 'unit test' in f:\n        return 'phase-06-profile-capabilities-verification','feature-name'\n    return '',''\n\nunmapped=[]; assigned=collections.Counter(); reasons=collections.Counter(); samples=[]\nfor e in matrix['entries']:\n    if e.get('status')=='not-applicable' or e.get('plannedPhase'): continue\n    fid=e.get('featureId',''); src=e.get('sourcePath',''); phase=''; reason=''\n    if fid in explicit:\n        phase=explicit[fid]; reason='featureId'\n    else:\n        for pat,pid,kind in group_matches:\n            if path_match(src,pat):\n                phase=pid; reason=kind; break\n    if not phase:\n        phase,reason=heur(src,e.get('featureName',''))\n    if not phase:\n        unmapped.append((fid,src,e.get('featureName','')))\n    else:\n        assigned[phase]+=1; reasons[reason]+=1; samples.append((fid,src,phase,reason))\nprint('assigned_total', sum(assigned.values()))\nprint('assigned_by_phase')\nfor k,v in assigned.items(): print(k,v)\nprint('reasons')\nfor k,v in reasons.items(): print(k,v)\nprint('unmapped', len(unmapped))\nfor row in unmapped[:40]: print('UNMAPPED\\t%s\\t%s\\t%s' % row)\n\"","description":"Preview semantic plannedPhase assignments","