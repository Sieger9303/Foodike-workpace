28D39)\n38:     }\n39: }\n40: \n41: @Builder\n42: func buildHistoryRecordCard(record: HistoryRecordData) {\n43:     Column(space: 10) {\n44:         Row {\n45:             Column(space: 4) {\n46:                 Text(record.restaurantName)\n47:                     .fontWeight(FontWeight.Bold)\n48:                 Text(record.place)\n49:                     .fontSize(14)\n50:                     .fontColor(Color.Gray)\n51:                 Text(record.timestampText)\n52:                     .fontSize(14)\n53:                     .fontColor(Color.Gray)\n54:             }\n55:             .layoutWeight(1)\n56:             Text(record.totalText)\n57:                 .fontSize(16)\n58:         }\n59: \n60:         Divider().width(100.percent)\n61: \n62:         Row(space: 10) {\n63:             Image(if (record.isVeg) { mediaIcVeg } else { mediaIcNonVeg })\n64:                 .width(16)\n65:                 .height(16)\n66:             Text(record.itemSummary)\n67:                 .layoutWeight(1)\n68:                 .fontSize(14)\n69:             Button(record.actionText)\n70:         }\n71:         .alignItems(VerticalAlign.Center)\n72: \n73:         if (record.deliveryRating > 0) {\n74:             Row {\n75:                 Column(space: 4) {\n76:                     Text(\"Your rating for delivery\")\n77:                         .fontSize(14)\n78:                         .fontColor(Color.Gray)\n79:                     Text(\"Your rating for food\")\n80:                         .fontSize(14)\n81:                         .fontColor(Color.Gray)\n82:                 }\n83:                 .layoutWeight(1)\n84:                 Column(space: 4) {\n85:                     Text(\"* ${record.deliveryRating}\")\n86:                     Text(\"* ${record.foodRating}\")\n87:                 }\n88:                 buildHistoryStatusRow(record.statusText)\n89:             }\n90:             .alignItems(VerticalAlign.Center)\n91:         } else {\n92:             Row {\n93:                 Text(record.actionText)\n94:                     .fontSize(16)\n95:                     .fontWeight(FontWeight.Bold)\n96:                     .fontColor(0xFF228D39)\n97:                 Blank().layoutWeight(1)\n98:                 buildHistoryStatusRow(record.statusText)\n99:             }\n100:             .alignItems(VerticalAlign.Center)\n101:         }\n102:     }\n103:     .width(100.percent)\n104:     .padding(top: 14, right: 14, bottom: 14, left: 14)\n105:     .backgroundColor(Color.White)\n106:     .borderRadius(16)\n107: }\n108: \n109: @Builder\n110: func buildHistoryRecords(records: ArrayList<HistoryRecordData>) {\n111:     Column(space: 10) {\n112:         ForEach(records, itemGeneratorFunc: { record: HistoryRecordData, _: Int64 =>\n113:             buildHistoryRecordCard(record)\n114:         })\n115:     }\n116:     .width(100.percent)\n117: }\n118: \n119: @Builder\n120: func buildHistoryFavourites(favourites: ArrayList<RestaurantData>, onSelectRestaurant: (RestaurantData) -> Unit) {\n121:     if (favourites.size > 0) {\n122:         Column(space: 10) {\n123:             ForEach(favourites, itemGeneratorFunc: { restaurant: RestaurantData, _: Int64 =>\n124:                 renderRestaurantCard(restaurant, { =>\n125:                     onSelectRestaurant(restaurant)\n126:                 })\n127:             })\n128:         }\n129:         .width(100.percent)\n130:     } else {\n131:         Row {\n132:             Text(\"Empty\")\n133:                 .fontSize(16)\n134:         }\n135:         .width(100.percent)\n136:         .justifyContent(FlexAlign.Center)\n137:     }\n138: }\n139: \n140: @Builder\n141: public func renderHistoryRoute(\n142:     state: HistoryPageState,\n143:     selectedTab: Int64,\n144:     query: String,\n145:     onQueryChange: (String) -> Unit,\n146:     onTabSelect: (Int64) -> Unit,\n147:     onSelectRestaurant: (RestaurantData) -> Unit\n148: ) {\n149:     Scroll(Scroller()) {\n150:         Column(space: 14) {\n151:             renderSearchBar(query, onQueryChange)\n152:             buildHistoryTabs(selectedTab, onTabSelect)\n153:             if (selectedTab == 0) {\n154:                 buildHistoryRecords(state.records)\n155:             } else {\n156:                 buildHistoryFavourites(state.favourites, onSelectRestaurant)\n157:             }\n158:         }\n159:         .width(100.percent)\n160:         .padding(top: 16, right: 16, bottom: 24, left: 16)\n161:     }\n162:     .scrollable(ScrollDirection.Vertical)\n163:     .scrollBar(BarState.Off)\n164:     .width(100.percent)\n165:     .height(100.percent)\n166:     .backgroundColor(Color.White)\n167: }\n\n(End of file - total 167 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{mediaIcNonVeg, mediaIcVeg}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.widgets.{renderRestaurantCard, renderSearchBar}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\n\n@Builder\nfunc buildHistoryTabs(selectedTab: Int64, onTabSelect: (Int64) -> Unit) {\n    Row(space: 18) {\n        Text(historyStore.tabLabel(0))\n            .fontSize(18)\n            .fontWeight(if (selectedTab == 0) { FontWeight.Bold } else { FontWeight.Regular })\n            .onClick({ _ =>\n                onTabSelect(0)\n            })\n        Text(historyStore.tabLabel(1))\n            .fontSize(18)","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_page.cj","time":{"start":1782402337800,"end":1782402337807}},"id":"prt_eff754bc40016FUPpa3aJQ8f6z","sessionID":"ses_1008b4e19ffekRdAT5Lxgyqh5H","messageID":"msg_eff75218900104osGyUgJroaXC"}}
