blems.extend(\n776:         _validate_bool(\n777:             facts.get(\"sourceBehaviorMapped\"),\n778:             path=f\"{COVERAGE_FACTS_KEY}.sourceBehaviorMapped\",\n779:         )\n780:     )\n781:     problems.extend(\n782:         _validate_bool(\n783:             facts.get(\"targetBehaviorImplemented\"),\n784:             path=f\"{COVERAGE_FACTS_KEY}.targetBehaviorImplemented\",\n785:         )\n786:     )\n787: \n788:     simplification = _dict_value(facts.get(\"activeSimplification\"))\n789:     if not simplification:\n790:         problems.append(f\"{COVERAGE_FACTS_KEY}.activeSimplification must be an object\")\n791:     else:\n792:         problems.extend(\n793:             _validate_bool(\n794:                 simplification.get(\"used\"),\n795:                 path=f\"{COVERAGE_FACTS_KEY}.activeSimplification.used\",\n796:             )\n797:         )\n798:         problems.extend(\n799:             _validate_list(\n800:                 simplification.get(\"preservedBehaviors\"),\n801:                 path=f\"{COVERAGE_FACTS_KEY}.activeSimplification.preservedBehaviors\",\n802:             )\n803:         )\n804:         problems.extend(\n805:             _validate_list(\n806:                 simplification.get(\"omittedBehaviors\"),\n807:                 path=f\"{COVERAGE_FACTS_KEY}.activeSimplification.omittedBehaviors\",\n808:             )\n809:         )\n810:         if strict and simplification.get(\"used\"):\n811:             if not _is_non_empty_text(simplification.get(\"reason\")):\n812:                 problems.append(f\"{COVERAGE_FACTS_KEY}.activeSimplification.reason is required when used\")\n813:             if not _is_non_empty_list(simplification.get(\"preservedBehaviors\")):\n814:                 problems.append(\n815:                     f\"{COVERAGE_FACTS_KEY}.activeSimplification.preservedBehaviors is required when used\"\n816:                 )\n817:             if not _is_non_empty_list(simplification.get(\"omittedBehaviors\")):