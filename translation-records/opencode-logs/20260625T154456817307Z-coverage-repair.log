758: \n759: \n760: COVERAGE_CLOSURE_TO_STATUS = {\n761:     \"open\": \"planned\",\n762:     \"implemented\": \"implemented\",\n763:     \"simplified\": \"implemented-simplified\",\n764:     \"platform-replaced\": \"platform-replaced\",\n765:     \"deferred\": \"deferred\",\n766:     \"not-applicable\": \"not-applicable\",\n767: }\n768: \n769: \n770: def effective_matrix_status(entry: dict[str, Any]) -> str:\n771:     \"\"\"Return gate status, allowing agent-authored coverage facts to supersede stale status.\"\"\"\n772: \n773:     facts = coverage_facts(entry)\n774:     status = COVERAGE_CLOSURE_TO_STATUS.get(str(facts.get(\"closureKind\") or \"\").strip().lower())\n775:     if status and facts.get(\"factsSource\") == \"agent\":\n776:         return status\n777:     raw_status = str(entry.get(\"status\") or \"\").strip().lower()\n778:     return raw_status if raw_status else \"empty\"\n779: \n780: \n781: def parity_matches_status(entry: dict[str, Any], status: str) -> bool:\n782:     parity = parity_level(entry)\n783:     if status == \"implemented\":\n784:         return parity in IMPLEMENTED_PARITY_LEVELS\n785:     if status == \"implemented-simplified\":\n786:         return parity in SIMPLIFIED_PARITY_LEVELS\n787:     if status == \"platform-replaced\":\n788:         return parity in PLATFORM_REPLACED_PARITY_LEVELS\n789:     if status == \"deferred\":\n790:         return parity == \"deferred\"\n791:     if status == \"not-applicable\":\n792:         return parity == \"not-applicable\"\n793:     return parity in {\"\", \"unverified\"}\n794: \n795: \n796: def repeated_signature_groups(\n797:     signature_entries: dict[str, list[dict[str, Any]]],\n798:     *,\n799:     min_count: int,\n800:     max_samples: int,\n801: ) -> list[dict[str, Any]]:\n802:     return [\n803:         {\"signature\": signature, \"count\": len(entries), \"entries\": sample_matrix_entries(entries, max_samples=5)}\n804:         for signature, entries in sorted(signature_entries.items(), key=lambda item: (-len(item[1]), item[0]))\n805:         if signature and len(entries) >= min_count\n806:     ][:max_samples]\n807: \n808: \n809: def repeated_group_severity(\n810:     count: int,\n811:     ratio_value: float,\n812:     *,\n813:     medium_count: int,\n814:     medium_ratio: float,\n815:     high_count: int,\n816:     high_ratio: float,\n817: ) -> str:\n818:     if count >= high_count or (count >= medium_count and ratio_value >= high_ratio):\n819:         return \"high\"\n820:     if count >= medium_count or (count >= max(5, medium_count // 2) and ratio_value >= medium_ratio):\n821:         return \"medium\"\n822:     return \"\"\n823: \n824: \n825: def has_specific_simplified_reason(entry: dict[str, Any]) -> bool:\n826:     \"\"\"Return whether a simplified implementation has a concrete explanation.\"\"\"\n827: \n828:     facts = coverage_facts(entry)\n829:     simplification = facts.get(\"activeSimplification\") if isinstance(facts.get(\"activeSimplification\"), dict) else {}\n830:     if simplification.get(\"used\") and has_text(simplification.get(\"reason\")):\n831:         return bool(\n832:             has_text_or_list(simplification.get(\"preservedBehaviors\"))\n833:             or has_text_or_list(simplification.get(\"omittedBehaviors\"))\n834:         )\n835:     text = combined_text(entry.get(\"notes\"), entry.get(\"targetFallback\"), entry.get(\"tests\"))\n836:     if len(text) < 40:\n837:         return False\n838:     return any(keyword in text for keyword in SIMPLIFIED_REASON_KEYWORDS)\n839: \n\n(Showing lines 720-839 of 1949. Use offset=840 to continue.)\n</content>","metadata":{"preview":"\ndef has_source_behavior_evidence(entry: dict[str, Any]) -> bool:\n    facts = coverage_facts(entry)\n    if facts.get(\"sourceBehaviorMapped\") is True:\n        return True\n    return any(\n        has_text_or_list(entry.get(field))\n        for field in (\"sourceBehavior\", \"sourceEvidence\", \"featurePoint\")\n    )\n\n\ndef has_target_behavior_