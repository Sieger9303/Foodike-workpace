{"type":"tool_use","timestamp":1782368265618,"sessionID":"ses_10293461bffeeWYRBGoTh3K6fq","part":{"type":"tool","tool":"read","callID":"call_YXDv4ugz0tuGW66J9QUZQwaH","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj"},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n2: \n3: import kit.ArkUI.*\n4: import kit.LocalizationKit.*\n5: import ohos.arkui.state_macro_manage.Builder\n6: import ohos.arkui.state_macro_manage.Component\n7: import ohos.arkui.state_macro_manage.Entry\n8: import ohos.arkui.state_macro_manage.State\n9: import ohos_app_cangjie_entry.Global\n10: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.loginStore\n11: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.onboardingStore\n12: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.profileStore\n13: \n14: @Entry\n15: @Component\n16: class FoodikeBootstrap {\n17:     @State\n18:     var currentRoute: String = bootstrapStartRoute\n19: \n20:     @State\n21:     var isShellAtTop: Bool = true\n22: \n23:     @State\n24:     var onboardingPageIndex: Int64 = 0\n25: \n26:     @State\n27:     var loginEmail: String = \"\"\n28: \n29:     @State\n30:     var loginPassword: String = \"\"\n31: \n32:     private var onboardingController: SwiperController = SwiperController()\n33: \n34:     private func applyShellState(shellState: ShellRouteState): Unit {\n35:         this.currentRoute = shellState.currentRoute\n36:         this.isShellAtTop = shellState.isAtTop\n37:     }\n38: \n39:     private func shellState(): ShellRouteState {\n40:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n41:     }\n42: \n43:     private func applyShellCommand(command: ShellCommand): Unit {\n44:         let shellState = this.shellState()\n45:         shellState.applyCommand(command)\n46:         this.applyShellState(shellState)\n47:     }\n48: \n49:     private func navigateTo(route: String): Unit {\n50:         let shellState = this.shellState()\n51:         shellState.currentRoute = route\n52:         shellState.isAtTop = true\n53:         this.applyShellState(shellState)\n54:     }\n55: \n56:     private func showBottomShell(route: String): Bool {\n57:         let shellState = this.shellState()\n58:         shellState.currentRoute = route\n59:         return shellState.showBottomShell()\n60:     }\n61: \n62:     private func routeTitle(route: String): String {\n63:         match (route) {\n64:             case \"onboarding\" => \"Onboarding\"\n65:             case \"login_screen\" => \"Login\"\n66:             case \"home_screen\" => \"Home\"\n67:             case \"history\" => \"History\"\n68:             case \"cart\" => \"Cart\"\n69:             case \"profile\" => \"Profile\"\n70:             case \"restaurant_details\" => \"Restaurant Detail\"\n71:             case _ => \"Unknown Route\"\n72:         }\n73:     }\n74: \n75:     private func showToast(message: String): Unit {\n76:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n77:     }\n78: \n79:     private func performLogin(): Unit {\n80:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n81:             this.navigateTo(loginStore.successRoute())\n82:             return\n83:         }\n84: \n85:         this.showToast(loginStore.invalidLoginMessage)\n86:     }\n87: \n88:     private func performLogout(): Unit {\n89:         profileStore.logout(Global.abilityContext)\n90:         this.loginEmail = \"\"\n91:         this.loginPassword = \"\"\n92:         this.onboardingPageIndex = 0\n93:         this.navigateTo(profileStore.logoutRoute())\n94:     }\n95: \n96:     private func routeSummary(route: String): String {\n97:         match (route) {\n98:             case \"home_screen\" => \"Home remains the shared shell placeholder from phase 02 while onboarding, login, and profile now run as dedicated phase-03 routes.\"\n99:             case \"history\" => \"History remains available as a shell route so profile still has a source-consistent back destination.\"\n100:             case \"cart\" => \"Cart continues to be a shell-owned placeholder route until later phases land the real content.\"\n101:             case \"restaurant_details\" => \"Restaurant detail remains in the route contract but keeps its placeholder body until later phases.\"\n102:             case _ => \"\"\n103:         }\n104:     }\n105: \n106:     @Builder\n107:     private func buildTopBar(title: ResourceStr, backLabel: ResourceStr, onBack: () -> Unit) {\n108:         Row {\n109:             Button(backLabel)\n110:                 .onClick({ _ => onBack() })\n111:             Text(title)\n112:                 .fontSize(28)\n113:                 .fontWeight(FontWeight.Bold)\n114:                 .margin(left: 16)\n115:         }\n116:         .width(100.percent)\n117:         .justifyContent(FlexAlign.Start)\n118:         .alignItems(VerticalAlign.Center)\n119:     }\n120: \n121:     @Builder\n122:     private func buildOnboardingCard(title: String, description: String, mediaName: String) {\n123:         Column(space: 18) {\n124:             Image(\n125:                 match (mediaName) {\n126:                     case \"chinese_bowl\" => @r(app.media.chinese_bowl)\n127:                     case \"rider\" => @r(app.media.rider)\n128:                     case _ => @r(app.media.clock)\n129:                 }\n130:             )\n131:                 .width(72.percent)\n132:                 .height(280)\n133:             Text(title)\n134:                 .fontSize(30)\n135:                 .fontColor(Color.White)\n136:                 .fontWeight(FontWeight.Bold)\n137:                 .textAlign(TextAlign.Center)\n138:             Text(description)\n139:                 .fontSize(17)\n140:                 .fontColor(Color.White)\n141:                 .textAlign(TextAlign.Center)\n142:                 .width(86.percent)\n143:         }\n144:         .width(100.percent)\n145:         .height(100.percent)\n146:         .justifyContent(FlexAlign.Center)\n147:         .alignItems(HorizontalAlign.Center)\n148:     }\n149: \n150:     @Builder\n151:     private func buildOnboardingRoute() {\n152:         Column(space: 24) {\n153:             Swiper(controller: this.onboardingController) {\n154:                 this.buildOnboardingCard(\n155:                     onboardingStore.slideAt(0).title,\n156:                     onboardingStore.slideAt(0).description,\n157:                     onboardingStore.slideAt(0).mediaName\n158:                 )\n159:                 this.buildOnboardingCard(\n160:                     onboardingStore.slideAt(1).title,\n161:                     onboardingStore.slideAt(1).description,\n162:                     onboardingStore.slideAt(1).mediaName\n163:                 )\n164:                 this.buildOnboardingCard(\n165:                     onboardingStore.slideAt(2).title,\n166:                     onboardingStore.slideAt(2).description,\n167:                     onboardingStore.slideAt(2).mediaName\n168:                 )\n169:             }\n170:             .indicator(true)\n171:             .onChange({ index: Int32 =>\n172:                 this.onboardingPageIndex = Int64(index)\n173:             })\n174:             .width(100.percent)\n175:             .height(78.percent)\n176: \n177:             Row {\n178:                 Text(\"${this.onboardingPageIndex + 1}/${onboardingStore.pageCount()}\")\n179:                     .fontSize(16)\n180:                     .fontColor(Color.White)\n181:                 Button(if (onboardingStore.isLastPage(this.onboardingPageIndex)) { \"Login\" } else { \"Next\" })\n182:                     .onClick({ _ =>\n183:                         if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n184:                             this.navigateTo(routePath(RouteId.Login))\n185:                         } else {\n186:                             this.onboardingController.showNext()\n187:                         }\n188:                     })\n189:             }\n190:             .width(90.percent)\n191:             .justifyContent(FlexAlign.SpaceBetween)\n192:             .alignItems(VerticalAlign.Center)\n193:             .margin(bottom: 12)\n194:         }\n195:         .width(100.percent)\n196:         .height(100.percent)\n197:         .backgroundColor(@r(app.color.DarkGreen))\n198:         .alignItems(HorizontalAlign.Center)\n199:         .justifyContent(FlexAlign.SpaceBetween)\n200:     }\n201: \n202:     @Builder\n203:     private func buildLoginRoute() {\n204:         Column(space: 16) {\n205:             Text(@r(app.string.welcome_back))\n206:                 .fontSize(32)\n207:                 .fontWeight(FontWeight.Bold)\n208: \n209:             TextInput(text: this.loginEmail, placeholder: loginStore.emailHint)\n210:                 .width(90.percent)\n211:                 .height(52)\n212:                 .fontSize(16)\n213:                 .placeholderColor(Color.Gray)\n214:                 .onChange({ value: String =>\n215:                     this.loginEmail = value\n216:                 })\n217: \n218:             TextInput(text: this.loginPassword, placeholder: loginStore.passwordHint)\n219:                 .width(90.percent)\n220:                 .height(52)\n221:                 .fontSize(16)\n222:                 .placeholderColor(Color.Gray)\n223:                 .enterKeyType(EnterKeyType.Done)\n224:                 .onChange({ value: String =>\n225:                     this.loginPassword = value\n226:                 })\n227:                 .onSubmit({ _ =>\n228:                     this.performLogin()\n229:                 })