verlayOffset(x: 0.0, y: 20.0))\n38:                     // 加载jpg格式图片\n39:                     Image(@r(app.media.startIcon_jpg))\n40:                     .width(110)\n41:                     .height(110)\n42:                     .margin(15)\n43:                     .overlay(value: \"jpg\", align: Alignment.Bottom, offset: OverlayOffset(x: 0.0, y: 20.0))\n44:                 }\n45:             }\n46:             .height(320)\n47:             .width(360)\n48:             .padding(right: 10, top: 10)\n49:     }\n50: }\n51: ```\n52: \n53: ![image1](figures/image1.gif)\n54: \n55: ### 示例2（为图片添加事件）\n56: \n57: 为图片添加onClick和onFinish事件。\n58: \n59: <!-- run -->\n60: \n61: ```cangjie\n62: package ohos_app_cangjie_entry\n63: import kit.ArkUI.*\n64: import ohos.arkui.state_macro_manage.*\n65: import ohos.i18n.*\n66: import ohos.resource.*\n67: \n68: @Entry\n69: @Component\n70: class EntryView {\n71:     let imageOne: AppResource= @r(app.media.startIcon)\n72:     let imageTwo = @r(app.media.background)\n73:     let imageThree = @r(app.media.svg_move)\n74:     @State var src: AppResource = this.imageOne\n75:     @State var src2: AppResource = this.imageThree\n76: \n77:     func build() {\n78:         Column(){\n79:             // 为图片添加点击事件，点击完成后加载特定图片\n80:             Image(this.src)\n\n(Showing lines 1-80 of 101. Use offset=81 to continue.)\n</content>","metadata":{"preview":"### 示例1（加载基本类型图片）\n\n加载png、gif、svg和jpg等基本类型的图片。\n\n<!-- run -->\n\n```cangjie\npackage ohos_app_cangjie_entry\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.*\nimport ohos.i18n.*\nimport ohos.resource.*\n\n@Entry\n@Component\nclass EntryView {\n    func build() {\n        Flex(direction: FlexDirection.Column, alignItems: ItemAlign.Start) {\n                Row() {\n                    // 加载png格式图片","truncated":true,"loaded":[]},"title":".agents\\skills\\cangjie-harmonyos-doc-search\\harmonyos-6.1-8k\\API\\arkui-cj\\cj-image-video-image\\Image\\示例代码\\示例1加载基本类型图片_2more_79ca0322.md","time":{"start":17