to onboarding\")\n35:         }\n36:     }\n37: \n38:     public override func onWindowStageCreate(windowStage: WindowStage): Unit {\n39:         Hilog.info(0x0000, \"Foodike\", \"Loading Foodike bootstrap content\")\n40:         Global._abilityContext = Some(this.context)\n41:         Global._windowStage = Some(windowStage)\n42:         windowStage.loadContent(\"FoodikeBootstrap\")\n43:     }\n44: }\n45: \n46: public class Global {\n47:     public static var _abilityContext: Option<UIAbilityContext> = None\n48:     public static var _windowStage: Option<WindowStage> = None\n49: \n50:     public static prop abilityContext: UIAbilityContext {\n51:         get() {\n52:             match (_abilityContext) {\n53:                 case Some(context) => context\n54:                 case None => throw Exception(\"Global.abilityContext is not set\")\n55:             }\n56:         }\n57:     }\n58: \n59:     public static prop windowStage: WindowStage {\n60:         get() {\n61:             match (_windowStage) {\n62:                 case Some(stage) => stage\n63:                 case None => throw Exception(\"Global.windowStage is not set\")\n64:             }\n65:         }\n66:     }\n67: }\n\n(End of file - total 67 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry\n\nimport kit.AbilityKit.LaunchParam\nimport kit.AbilityKit.LaunchReason\nimport kit.AbilityKit.UIAbility\nimport kit.AbilityKit.UIAbilityContext\nimport kit.AbilityKit.Want\nimport kit.ArkUI.WindowStage\nimport kit.PerformanceAnalysisKit.Hilog\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.bootstrapStartRoute\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.LoginPreferencesService\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.startup.startupStore\n\nclass EntryAbility <: UIAbility {\n    public init() {\n        super()\n        registerSelf()\n    }\n\n    public override func onCreate(want: Want, launchParam: LaunchParam): Unit {","trunca