op: Bool = true\n27: \n28:     @State\n29:     var onboardingPageIndex: Int64 = 0\n30: \n31:     @State\n32:     var loginEmail: String = \"\"\n33: \n34:     @State\n35:     var loginPassword: String = \"\"\n36: \n37:     @State\n38:     var loginErrorMessage: String = \"\"\n39: \n40:     @State\n41:     var homeSearchQuery: String = \"\"\n42: \n43:     @State\n44:     var homeSelectedFilter: String = \"\"\n45: \n46:     @State\n47:     var historySearchQuery: String = \"\"\n48: \n49:     @State\n50:     var historyTabIndex: Int64 = 0\n51: \n52:     @State\n53:     var previousRoute: String = \"home_screen\"\n54: \n55:     @State\n56:     var cartNote: String = \"\"\n57: \n58:     @State\n59:     var cartCoupon: String = \"\"\n60: \n61:     @State\n62:     var detailRecommendedExpanded: Bool = true\n63: \n64:     @State\n65:     var detailNonVegExpanded: Bool = true\n66: \n67:     @State\n68:     var detailVegExpanded: Bool = true\n69: \n70:     @State\n71:     var detailLiked: Bool = false\n72: \n73:     private var onboardingController: SwiperController = SwiperController()\n74: \n75:     private func applyShellState(shellState: ShellRouteState): Unit {\n76:         this.currentRoute = shellState.currentRoute\n77:         this.isShellAtTop = shellState.isAtTop\n78:     }\n79: \n80:     private func shellState(): ShellRouteState {\n81:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n82:     }\n83: \n84:     private func applyShellCommand(command: ShellCommand): Unit {\n85:         let shellState = this.shellState()\n86:         shellState.applyCommand(command)\n87:         this.applyShellState(shellState)\n88:     }\n89: \n90:     private func navigateTo(route: String): Unit {\n91:         let shellState = this.shellState()\n92:         this.previousRoute = shellState.currentRoute\n93:         shellState.currentRoute = route\n94:         shellState.isAtTop = true\n95:         this.applyShellState(shellState)\n96:     }\n97: \n98:     private func navigateBack(): Unit {\n99:         let targetRoute = this.previousRoute\n100:         this.previousRoute = this.currentRoute\n101:         this.navigateTo(targetRoute)\n102:     }\n103: \n104:     private func showBottomShell(route: String): Bool {\n105:         let shellState = this.shellState()\n106:         shellState.currentRoute = route\n107:         return shellState.showBottomShell()\n108:     }\n109: \n110:     private func routeTitle(route: String): String {\n111:         match (route) {\n112:             case \"onboarding\" => \"Onboarding\"\n113:             case \"login_screen\" => \"Login\"\n114:             case \"home_screen\" => \"Home\"\n115:             case \"history\" => \"History\"\n116:             case \"cart\" => \"Cart\"\n117:             case \"profile\" => \"Profile\"\n118:             case \"restaurant_details\" => \"Restaurant Detail\"\n119:             case _ => \"Unknown Route\"\n120:         }\n121:     }\n122: \n123:     private func showToast(message: String): Unit {\n124:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n125:     }\n126: \n127:     private func clearLoginError(): Unit {\n128:         this.loginErrorMessage = \"\"\n129:     }\n130: \n131:     private func performLogin(): Unit {\n132:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n133:             this.clearLoginError()\n134:             this.navigateTo(loginStore.successRoute())\n135:             return\n136:         }\n137: \n138:         this.loginErrorMessage = loginStore.invalidLoginMessage\n139:         this.showToast(loginStore.invalidLoginMessage)\n140:     }\n141: \n142:     private func performLogout(): Unit {\n143:         profileStore.logout(Global.abilityContext)\n144:         this.loginEmail = \"\"\n145:         this.loginPassword = \"\"\n146:         this.clearLoginError()\n147:         this.onboardingPageIndex = 0\n148:         this.homeSearchQuery = \"\"\n149:         this.homeSelectedFilter = \"\"\n150:         this.historySearchQuery = \"\"\n151:         this.historyTabIndex = 0\n152:         this.navigateTo(profileStore.logoutRoute())\n153:     }\n154: \n155:     private func routeSummary(route: String): String {\n156:         match (route) {\n157:             case \"home_screen\" => \"Home now renders repository-backed discovery content, local search/filter controls, and restaurant selection before detail routing.\"\n158:             case \"history\" => \"History now preserves search plus tab-local content, reuses favourite restaurants, and saves the selected restaurant before navigation.\"\n159:             case \"cart\" => \"Cart now renders snapshot-backed items, a local note editor, a local coupon field, delivery details, and bill totals without adding new checkout persistence flows.\"\n160:             case \"restaurant_details\" => \"Restaurant detail now reads the selected restaurant, preserves local section expansion and like state, keeps menu quantity controls local to the route, and shows the cart action only when selected quantities are non-zero.\"\n161:             case _ => \"\"\n162:         }\n163:     }\n164: \n165:     private func homeHour(): Int64 {\n166:         return 9\n167:     }\n168: \n169:     private func goToProfile(): Unit {\n170:         this.navigateTo(routePath(RouteId.Profile))\n171:     }\n172: \n173:     private func goToRestaurantDetail(): Unit {\n174:         this.detailRecommendedExpanded = true\n175:         this.detailNonVegExpanded = true\n176:         this.detailVegExpanded = true\n177:         this.detailLiked = detailStore.session().isRestaurantLiked(detailStore.selectedRestaurant())\n178:         this.navigateTo(routePath(RouteId.RestaurantDetails))\n179:     }\n180: \n181:     private func detailState(): DetailPageState {\n182:         return detailStore.loadDetailState(\n183:             this.detailRecommendedExpanded,\n184:             this.detailNonVegExpanded,\n185:             this.detailVegExpanded\n186:         )\n187:     }\n188: \n189:     private func selectHomeRestaurant(restaurant: RestaurantData): Unit {\n190:         homeStore.selectRestaurant(restaurant, { =>\n191:             this.goToRestaurantDetail()\n192:         })\n193:     }\n194: \n195:     private func selectHistoryRestaurant(restaurant: RestaurantData): Unit {\n196:         historyStore.selectRestaurant(restaurant, { =>\n197:             this.goToRestaurantDetail()\n198:         })\n199:     }\n200: \n201:     @Builder\n202:     private func buildOnboardingRoute() {\n203:         renderOnboardingRoute(\n204:             this.onboardingPageIndex,\n205:             this.onboardingController,\n206:             { index: Int32 =>\n207:                 this.onboardingPageIndex = Int64(index)\n208:             },\n209:             { =>\n210:                 if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n211:                     this.navigateTo(routePath(RouteId.Login))\n212:                 } else {\n213:                     this.onboardingController.showNext()\n214:                 }\n215:             }\n216:         )\n217:     }\n218: \n219:     @Builder\n220:     private func buildLoginRoute() {\n221:         renderLoginRoute(\n222:             this.loginEmail,\n223:             this.loginPassword,\n224:             this.loginErrorMessage,\n225:             { value: String =>\n226:                 this.loginEmail = value\n227:                 this.clearLoginError()\n228:             },\n229:             { value: String =>\n230:                 this.loginPassword = value\n231:                 this.clearLoginError()\n232:             },\n233:             { => this.showToast(loginStore.comingSoonMessage) },\n234:             { => this.performLogin() },\n235:             { => this.showToast(loginStore.comingSoonMessage) },\n236:             { => this.showToast(loginStore.comingSoonMessage) },\n237:             { => this.showToast(loginStore.comingSoonMessage) },\n238:             { => this.clearLoginError() }\n239:         )\n240:     }\n241: \n242:     @Builder\n243:     private func buildProfileRoute() {\n244:         renderProfileRoute(\n245:             profileStore.userName,\n246:             profileStore.userEmail,\n247:             { => this.navigateTo(profileStore.backRoute()) },\n248:             { => this.showToast(profileStore.placeholderActionMessage) },\n249:             { => this.showToast(profileStore.placeholderActionMessage) },\n250:             { => this.performLogout() }\n251:         )\n252:     }\n253: \n254:     @Builder\n255:     private func buildHomeRoute() {\n256:         renderHomeRoute(\n257:             homeStore.loadHomeState(),\n258:             this.homeHour(),\n259:             this.homeSearchQuery,\n260:             this.homeSelectedFilter,\n261:             { value: String =>\n262:                 this.homeSearchQuery = value\n263:             },\n264:             { value: String =>\n265:                 this.homeSelectedFilter = homeStore.toggleFilter(this.homeSelectedFilter, value)\n266:             },\n267:             { => this.goToProfile() },\n268:             { restaurant: RestaurantData =>\n269:                 this.selectHomeRestaurant(restaurant)\n270:             }\n271:         )\n272:     }\n273: \n274:     @Builder\n275:     private func buildHistoryRoute() {\n276:         renderHistoryRoute(\n277:             historyStore.loadHistoryState(),\n278:             this.historyTabIndex,\n279:             this.historySearchQuery,\n280:             { value: String =>\n281:                 this.historySearchQuery = value\n282:             },\n283:             { value: Int64 =>\n284:                 this.historyTabIndex = value\n285:             },\n286:             { restaurant: RestaurantData =>\n287:                 this.selectHistoryRestaurant(restaurant)\n288:             }\n289:         )\n290:     }\n291: \n292:     @Builder\n293:     private func buildCartRoute() {\n294:         renderCartRoute(\n295:             cartStore.loadCartState(),\n296:             this.cartNote,\n297:             this.cartCoupon,\n298:             { value: String =>\n299:                 this.cartNote = value\n300:             },\n301:             { value: String =>\n302:                 this.cartCoupon = value\n303:             },\n304:             { =>\n305:                 this.navigateBack()\n306:             }\n307:         )\n308:     }\n309: \n310:     @Builder\n311:     private func buildDetailRoute() {\n312:         renderDetailRoute(\n313:             this.detailState(),\n314:             { =>\n315:                 this.navigateBack()\n316:             },\n317:             { =>\n318:                 let restaurant = detailStore.selectedRestaurant()\n319:                 this.detailLiked = detailStore.toggleLiked(restaurant, this.detailLiked)\n320:             },\n321:             { =>\n322:                 this.showToast(\"Share coming soon\")\n323:             },\n324:             { =>\n325:                 this.detailRecommendedExpanded = !this.detailRecommendedExpanded\n326:             },\n327:             { =>\n328:                 this.detailNonVegExpanded = !this.detailNonVegExpanded\n329:             },\n330:             { =>\n331:                 this.detailVegExpanded = !this.detailVegExpanded\n332:             },\n333:             { item: DetailMenuItemData =>\n334:                 detailStore.incrementQuantity(item)\n335:             },\n336:             { item: DetailMenuItemData =>\n337:                 detailStore.decrementQuantity(item)\n338:             },\n339:             { =>\n340:                 this.navigateTo(routePath(RouteId.Cart))\n341:             }\n342:         )\n343:     }\n344: \n345:     @Builder\n346:     private func buildPlaceholderRoute() {\n347:         Column(space: 18) {\n348:             Text(\"Foodike\")\n349:                 .fontSize(42)\n350:                 .fontWeight(FontWeight.Bold)\n351:             Text(this.routeTitle(this.currentRoute))\n352:                 .fontSize(28)\n353:             Text(this.routeSummary(this.currentRoute))\n354:                 .fontSize(16)\n355:                 .textAlign(TextAlign.Center)\n356:                 .width(86.percent)\n357: \n358:             if (this.currentRoute == routePath(RouteId.Home) || this.currentRoute == routePath(RouteId.History)) {\n359:                 Button(if (this.isShellAtTop) { \"Simulate Scrolled Content\" } else { \"Return To Top\" })\n360:                     .onClick({ _ =>\n361:                         let shellState = this.shellState()\n362:                         shellState.setTopState(!shellState.isAtTop)\n363:                         this.applyShellState(shellState)\n364:                     })\n365:             }\n366: \n367:             Button(\"Primary Route Action\")\n368:                 .onClick({ _ =>\n369:                     this.applyShellCommand(ShellCommand.PrimaryAction)\n370:                 })\n371: \n372:             if (this.showBottomShell(this.currentRoute)) {\n373:                 Row(space: 12) {\n374:                     Button(\"Home Tab\")\n375:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HomeTab) })\n376:                     Button(\"Cart\")\n377:                         .onClick({ _ => this.applyShellCommand(ShellCommand.CartAction) })\n378:                     Button(\"History Tab\")\n379:                         .onClick({ _ => this.applyShellCommand(ShellCommand.HistoryTab) })\n380:                 }\n381:             }\n382:         }\n383:         .width(100.percent)\n384:         .height(100.percent)\n385:         .justifyContent(FlexAlign.Center)\n386:         .alignItems(HorizontalAlign.Center)\n387:         .padding(top: 24, right: 24, bottom: 24, left: 24)\n388:     }\n389: \n390:     func build() {\n391:         if (this.currentRoute == routePath(RouteId.Onboarding)) {\n392:             this.buildOnboardingRoute()\n393:         } else if (this.currentRoute == routePath(RouteId.Login)) {\n394:             this.buildLoginRoute()\n395:         } else if (this.currentRoute == routePath(RouteId.Home)) {\n396:             this.buildHomeRoute()\n397:         } else if (this.currentRoute == routePath(RouteId.History)) {\n398:             this.buildHistoryRoute()\n399:         } else if (this.currentRoute == routePath(RouteId.Cart)) {\n400:             this.buildCartRoute()\n401:         } else if (this.currentRoute == routePath(RouteId.RestaurantDetails)) {\n402:             this.buildDetailRoute()\n403:         } else if (this.currentRoute == routePath(RouteId.Profile)) {\n404:             this.buildProfileRoute()\n405:         } else {\n406:             this.buildPlaceholderRoute()\n407:         }\n408:     }\n409: }\n\n(End of file - total 409 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos.arkui.state_macro_manage.Component\nimport ohos.arkui.state_macro_manage.Entry\nimport ohos.arkui.state_macro_manage.State\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.{DetailMenuItemData, DetailPageState, RestaurantData}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.cart.{cartStore, renderCartRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.detail.{detailStore, renderDetailRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history.{historyStore, renderHistoryRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home.{homeStore, renderHomeRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.{loginStore, renderLoginRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.{onboardingStore, renderOnboardingRoute}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.p