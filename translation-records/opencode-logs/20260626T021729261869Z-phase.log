Unit,\n50:     onSectionClick: () -> Unit,\n51:     onLogout: () -> Unit\n52: ) {\n53:     Column(space: 18) {\n54:         buildProfileTopBar(onBack)\n55: \n56:         Row {\n57:             Column(space: 6) {\n58:                 Text(userName)\n59:                     .fontSize(28)\n60:                     .fontWeight(FontWeight.Bold)\n61:                 Text(userEmail)\n62:                     .fontSize(15)\n63:                     .fontColor(Color.Gray)\n64:             }\n65:             .layoutWeight(1)\n66: \n67:             Column(space: 8) {\n68:                 Image(mediaProfile)\n69:                     .width(96)\n70:                     .height(96)\n71:                     .borderRadius(48)\n72:                 Text(stringEdit)\n73:                     .fontSize(15)\n74:                     .fontColor(colorDarkGreen)\n75:                     .fontWeight(FontWeight.Bold)\n76:                     .onClick({ _ =>\n77:                         onEdit()\n78:                     })\n79:             }\n80:             .alignItems(HorizontalAlign.Center)\n81:         }\n82:         .width(100.percent)\n83:         .alignItems(VerticalAlign.Center)\n84: \n85:         Divider()\n86:             .width(100.percent)\n87: \n88:         Column {\n89:             buildProfileSection(stringSavedAddresses, stringAddEditSavedAddresses, true, onSectionClick)\n90:             buildProfileSection(stringPaymentsAndRefunds, stringRefundsInformation, true, onSectionClick)\n91:             buildProfileSection(stringOnlineOrderingHelp, stringOrderingInformation, true, onSectionClick)\n92:             buildProfileSection(stringAbout, stringAboutTheApp, false, onSectionClick)\n93:         }\n94:         .width(100.percent)\n95: \n96:         Blank()\n97:             .layoutWeight(1)\n98: \n99:         Button(stringLogOut)\n100:             .width(220)\n101:             .height(50)\n102:             .onClick({ _ =>\n103:                 onLogout()\n104:             })\n105:     }\n106:     .width(100.percent)\n107:     .height(100.percent)\n108:     .padding(top: 18, right: 24, bottom: 24, left: 24)\n109:     .backgroundColor(Color.White)\n110: }\n\n(End of file - total 110 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile\n\nimport kit.ArkUI.*\nimport ohos.arkui.state_macro_manage.Builder\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.*\n\n@Builder\nfunc buildProfileTopBar(onBack: () -> Unit) {\n    Row {\n        Button(\"<\")\n            .onClick({ _ =>\n                onBack()\n            })\n        Text(stringProfileTitle)\n            .fontSize(28)\n            .fontWeight(FontWeight.Bold)\n            .margin(left: 16)\n    }\n    .width(100.percent)\n    .justifyContent(FlexAlign.Start)","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\profile\\profile_page.cj","time":{"start":1782440445118,"end":1782440445127}},"id":"prt_f01bac47b001UOfxmZgvABHPPC","sessionID":"ses_0fe4831ceffeOChODcUYsOMwFi","messageID":"msg_f01b9c11b0014Be8yygKGoNP4V"}}
