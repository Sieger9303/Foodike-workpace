ommon/SplashViewModel.kt\",\n38:         \"app/src/main/java/com/example/foodike/presentation/MainActivity.kt\"\n39:       ],\n40:       \"topLevelDefinitions\": [\n41:         \"startup state store\",\n42:         \"start destination resolver\"\n43:       ],\n44:       \"translationGuidelines\": [\n45:         \"Startup logic should read persisted session state and decide onboarding vs home before normal route rendering.\"\n46:       ]\n47:     },\n48:     {\n49:       \"targetPath\": \"entry/src/main/cangjie/ohos_app_cangjie_entry/data/session\",\n50:       \"sourceReferences\": [\n51:         \"app/src/main/java/com/example/foodike/data/repository/LoginRepositoryImpl.kt\",\n52:         \"app/src/main/java/com/example/foodike/data/repository/UserDataRepositoryImpl.kt\",\n53:         \"app/src/main/java/com/example/foodike/domain/repository/LoginRepository.kt\",\n54:         \"app/src/main/java/com/example/foodike/domain/repository/UserDataRepository.kt\"\n55:       ],\n56:       \"topLevelDefinitions\": [\n57:         \"session persistence service\",\n58:         \"selected restaurant store\",\n59:         \"liked restaurant stream\",\n60:         \"cart item stream\"\n61:       ],\n62:       \"translationGuidelines\": [\n63:         \"Keep persistent login state separate from fake catalogue content.\",\n64:         \"Expose stream-like update surfaces so UI refresh remains immediate after mutations.\"\n65:       ]\n66:     },\n67:     {\n68:       \"targetPath\": \"entry/src/main/cangjie/ohos_app_cangjie_entry/data/content\",\n69:       \"sourceReferences\": [\n70:         \"app/src/main/java/com/example/foodike/data/data_source/FakeData.kt\",\n71:         \"app/src/main/java/com/example/foodike/data/repository/HomeRepositoryImpl.kt\"\n72:       ],\n73:       \"topLevelDefinitions\": [\n74:         \"fake catalogue data\",\n75:         \"ads/food/restaurant repository implementations\",\n76:         \"search and lookup helpers\"\n77:       ],\n78:       \"transla