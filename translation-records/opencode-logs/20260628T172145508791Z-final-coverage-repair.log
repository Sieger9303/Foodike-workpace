sert(routeService.placeholderActionMessage(), \"Coming soon!\")\n28:         @Assert(routeService.editActionMessage(), \"Coming soon!\")\n29:         @Assert(routeService.sectionActionMessage(ProfileSection.SavedAddresses), \"Coming soon!\")\n30:         @Assert(routeService.sectionActionMessage(ProfileSection.PaymentsAndRefunds), \"Coming soon!\")\n31:         @Assert(routeService.sectionActionMessage(ProfileSection.OnlineOrderingHelp), \"Coming soon!\")\n32:         @Assert(routeService.sectionActionMessage(ProfileSection.About), \"Coming soon!\")\n33:     }\n34: \n35:     @TestCase\n36:     public func profileStorePreservesLogoutRoute(): Unit {\n37:         let store = ProfileStore()\n38:         @Assert(store.logoutRoute(), routePath(RouteId.Onboarding))\n39:     }\n40: \n41:     @TestCase\n42:     public func profileStorePreservesBackAndLogoutRoutes(): Unit {\n43:         let store = ProfileStore()\n44:         let routeService = ProfileRouteService()\n45:         let backStack = ArrayList<String>([])\n46:         backStack.add(routePath(RouteId.Home))\n47:         @Assert(store.logoutRoute(), routePath(RouteId.Onboarding))\n48:         @Assert(routeService.resolveBackRoute(routePath(RouteId.Profile), backStack), routePath(RouteId.Home))\n49:         @Assert(routeService.canNavigateBack(routePath(RouteId.Profile), backStack), true)\n50:     }\n51: \n52:     @TestCase\n53:     public func profileLogoutTransitionResetsRouteStateAndReturnsOnboarding(): Unit {\n54:         let store = ProfileStore()\n55:         let routeService = ProfileRouteService()\n56:         let transition = routeService.buildLogoutTransition(store.logoutRoute())\n57:         @Assert(transition.nextRoute, routePath(RouteId.Onboarding))\n58:         @Assert(transition.resetState.loginEmail, \"\")\n59:         @Assert(transition.resetState.loginPassword, \"\")\n60:         @Assert(transition.resetState.onboardingPageIndex, 0)\n61:         @Assert(transition.resetState.homeSearchQuery, \"\")\n62:         @Assert(transition.resetState.homeSelectedFilter, \"\")\n63:         @Assert(transition.resetState.historySearchQuery, \"\")\n64:         @Assert(transition.resetState.historyTabIndex, 0)\n65:     }\n66: \n67:     @TestCase\n68:     public func profileBackRouteUsesTheNavigationStackWhenPresent(): Unit {\n69:         let routeService = ProfileRouteService()\n70:         let backStack = ArrayList<String>([])\n71:         backStack.add(routePath(RouteId.Home))\n72:         backStack.add(routePath(RouteId.History))\n73:         @Assert(routeService.resolveBackRoute(routePath(RouteId.Profile), backStack), routePath(RouteId.History))\n74:         @Assert(routeService.canNavigateBack(routePath(RouteId.Profile), backStack), true)\n75:         let emptyBackStack = ArrayList<String>([])\n76:         @Assert(routeService.resolveBackRoute(routePath(RouteId.Profile), emptyBackStack), routePath(RouteId.Profile))\n77:         @Assert(routeService.canNavigateBack(routePath(RouteId.Profile), emptyBackStack), false)\n78:     }\n79: \n80:     @TestCase\n\n(Showing lines 1-80 of 90. Use offset=81 to continue.)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, resolveStartRoute, routePath}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.{ProfileAction, ProfileRouteService, ProfileSection, ProfileStore}\nimport std.collection.ArrayList\nimport std.unittest.*\nimport std.unittest.testmacro.*\n\n@Test\npublic class Phase06ProfileCapabilitiesVerificationTest {\n    @TestCase\n    public func profileStorePreservesStaticIdentityAndPlaceholderActions(): Unit {\n        let store = ProfileStore()\n        @Assert(store.userName, \"Andrew Howard\")\n        @Assert(store.userEmail, \"andrewhoward@gmail.com\")\n        @Assert(store.profileSectionCount(), 4)\n        @Assert(store.actionFeedbackMessage(ProfileAction.Edit), \"Coming soon!\")\n        @Assert(store.sectionFeedbackMessage(ProfileSection.SavedAddresses), \"Coming soon!\")\n        @Assert(store.sectionFeedbackMessage(ProfileSection.PaymentsAndRefunds), \"Coming soon!\")\n        @Assert(store.sectionFeedbackMessage(ProfileSection.OnlineOrderingHelp), \"Coming soon!\")","truncated":true,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\test\\cangjie\\phase06_profile_capabilities_verification_test.cj","time":{"start":1782667436902,"end":1782667436929}},"id":"prt_f0f426361001aporGtl3hGJUeC","sessionID":"ses_0f0bf9916ffe8SCaEB5IJMFOY2","messageID":"msg_f0f4241bb001U9iaBsiHACDIpG"}}
