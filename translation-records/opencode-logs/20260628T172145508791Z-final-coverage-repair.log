.resetState = resetState\n40:     }\n41: }\n42: \n43: public class ProfileRouteService {\n44:     public init() {}\n45: \n46:     public func placeholderActionMessage(): String {\n47:         return \"Coming soon!\"\n48:     }\n49: \n50:     public func resolveBackRoute(currentRoute: String, routeBackStack: ArrayList<String>): String {\n51:         if (routeBackStack.size == 0) {\n52:             return currentRoute\n53:         }\n54: \n55:         return routeBackStack[routeBackStack.size - 1]\n56:     }\n57: \n58:     public func canNavigateBack(currentRoute: String, routeBackStack: ArrayList<String>): Bool {\n59:         return resolveBackRoute(currentRoute, routeBackStack) != currentRoute\n60:     }\n61: \n62:     public func resetAfterLogout(): ProfileRouteState {\n63:         return ProfileRouteState(\n64:             \"\",\n65:             \"\",\n66:             0,\n67:             \"\",\n68:             \"\",\n69:             \"\",\n70:             0\n71:         )\n72:     }\n73: \n74:     public func buildLogoutTransition(logoutRoute: String): ProfileLogoutTransition {\n75:         return ProfileLogoutTransition(logoutRoute, resetAfterLogout())\n76:     }\n77: \n78:     public func editActionMessage(): String {\n79:         return placeholderActionMessage()\n80:     }\n81: \n82:     public func sectionActionMessage(section: ProfileSection): String {\n83:         return placeholderActionMessage()\n84:     }\n85: }\n86: \n87: public let profileRouteService = ProfileRouteService()\n\n(End of file - total 87 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile\n\nimport std.collection.ArrayList\n\npublic class ProfileRouteState {\n    public var loginEmail: String\n    public var loginPassword: String\n    public var onboardingPageIndex: Int64\n    public var homeSearchQuery: String\n    public var homeSelectedFilter: String\n    public var historySearchQuery: String\n    public var historyTabIndex: