ence\": \"path=app/build.gradle.kts; category=kotlin-source; importance=critical; featurePoint=Screen lifecycle, entry point initialization, resume/pause refresh, or teardown behavior.\",\n3794:       \"status\": \"platform-replaced\",\n3795:       \"plannedPhase\": \"phase-01-project-skeleton-resources\",\n3796:       \"sourceBehavior\": \"app/build.gradle.kts provides the splashscreen and Compose entry build features that support source app startup initialization.\",\n3797:       \"targetBehavior\": \"HarmonyOS replaces Android splash and Compose entry wiring with EntryAbility startup resolution, the shared bootstrapStartRoute runtime variable, a focused startup launch service, FoodikeBootstrap page loading, and the registered main_pages launcher page.\",\n3798:       \"verificationEvidence\": [\n3799:         \"Phase 01 build gate PASS: translation-inputs/build-reports/phase-01-project-skeleton-resources/build-report.md\",\n3800:         \"Manual source/target review confirmed app_ability.cj and startup_launch_service.cj resolve startup state into bootstrapStartRoute before the registered FoodikeBootstrap page loads through main_pages.json.\"\n3801:       ],\n3802:       \"parityLevel\": \"platform-replaced\",\n3803:       \"targetEndpoints\": [\n3804:         \"entry/src/main/cangjie/app_ability.cj\",\n3805:         \"entry/src/main/cangjie/ohos_app_cangjie_entry/features/startup/startup_launch_service.cj\",\n3806:         \"entry/src/main/cangjie/ohos_app_cangjie_entry/features/startup/startup_store.cj\",\n3807:         \"entry/src/main/cangjie/ohos_app_cangjie_entry/runtime/app_runtime.cj\",\n3808:         \"entry/src/main/resources/base/profile/main_pages.json\",\n3809:         \"entry/src/main/module.json5\"\n3810:       ],\n3811:       \"tests\": [],\n3812:       \"notes\": \"The entry lifecycle is preserved through HarmonyOS UIAbility hooks and registered page loading instead of Android composeOptions/buildFeatures wiring.\",\n3813:       \"deferredReason\