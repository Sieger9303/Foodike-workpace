ions":26,"deletions":0},{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\login\\login_store.cj","relativePath":"Foodike-Harmony/entry/src/main/cangjie/ohos_app_cangjie_entry/features/login/login_store.cj","type":"add","patch":"Index: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\login\\login_store.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\login\\login_store.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\login\\login_store.cj\n@@ -0,0 +1,37 @@\n+package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login\n+\n+import kit.AbilityKit.UIAbilityContext\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, routePath}\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.LoginPreferencesService\n+\n+public let loginStore = LoginStore()\n+\n+public class LoginStore {\n+    private let validEmail: String = \"abcxyz@gmail.com\"\n+    private let validPassword: String = \"abcdef\"\n+    private let preferencesService: LoginPreferencesService = LoginPreferencesService()\n+\n+    public var emailHint: String = \"Enter email or phone number\"\n+    public var passwordHint: String = \"Password\"\n+    public var invalidLoginMessage: String = \"Please enter correct email and password\"\n+    public var comingSoonMessage: String = \"Coming soon!\"\n+\n+    public init() {}\n+\n+    public func isValidCredentials(email: String, password: String): Bool {\n+        return email == validEmail && password == validPassword\n+    }\n+\n+    public func login(context: UIAbilityContext, email: String, password: String): Bool {\n+        if (!isValidCredentials(email, password)) {\n+            return false\n+        }\n+\n+        preferencesService.login(context)\n+        return true\n+    }\n+\n+    public func successRoute(): String {\n+        return routePath(RouteId.Home)\n+    }\n+}\n","additions":37,"deletions":0},{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\onboarding\\onboarding_store.cj","relativePath":"Foodike-Harmony/entry/src/main/cangjie/ohos_app_cangjie_entry/features/onboarding/onboarding_store.cj","type":"add","patch":"Index: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\onboarding\\onboarding_store.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\onboarding\\onboarding_store.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\onboarding\\onboarding_store.cj\n@@ -0,0 +1,63 @@\n+package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding\n+\n+import std.collection.ArrayList\n+\n+public class OnboardingSlide {\n+    public let title: String\n+    public let description: String\n+    public let mediaName: String\n+\n+    public init(title: String, description: String, mediaName: String) {\n+        this.title = title\n+        this.description = description\n+        this.mediaName = mediaName\n+    }\n+}\n+\n+public let onboardingStore = OnboardingStore()\n+\n+public class OnboardingStore {\n+    private let slidesData = ArrayList<OnboardingSlide>([\n+        OnboardingSlide(\n+            \"Choose your favourite food\",\n+            \"Choose from a range of restaurants and hotels near you\",\n+            \"chinese_bowl\"\n+        ),\n+        OnboardingSlide(\n+            \"Vaccinated delivery partners\",\n+            \"Vaccinated delivery partners ensure the health and security of the customer\",\n+            \"rider\"\n+        ),\n+        OnboardingSlide(\n+            \"Expect Delivery in 20 minutes\",\n+            \"Fast and easy to track delivery to ease the experience of the customer\",\n+            \"clock\"\n+        )\n+    ])\n+\n+    public init() {}\n+\n+    public func slides(): ArrayList<OnboardingSlide> {\n+        return slidesData\n+    }\n+\n+    public func pageCount(): Int64 {\n+        return slidesData.size\n+    }\n+\n+    public func slideAt(index: Int64): OnboardingSlide {\n+        return slidesData[index]\n+    }\n+\n+    public func isLastPage(index: Int64): Bool {\n+        return index >= pageCount() - 1\n+    }\n+\n+    public func nextIndex(index: Int64): Int64 {\n+        if (isLastPage(index)) {\n+            return index\n+        }\n+\n+        return index + 1\n+    }\n+}\n","additions":63,"deletions":0},{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\profile\\profile_store.cj","relativePath":"Foodike-Harmony/entry/src/main/cangjie/ohos_app_cangjie_entry/features/profile/profile_store.cj","type":"add","patch":"Index: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\profile\\profile_store.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\profile\\profile_store.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\profile\\profile_store.cj\n@@ -0,0 +1,30 @@\n+package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile\n+\n+import kit.AbilityKit.UIAbilityContext\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, routePath}\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.LoginPreferencesService\n+\n+public let profileStore = ProfileStore()\n+\n+public class ProfileStore {\n+    private let preferencesService: LoginPreferencesService