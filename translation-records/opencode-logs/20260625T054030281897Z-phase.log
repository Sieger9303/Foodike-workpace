{"type":"tool_use","timestamp":1782367863594,"sessionID":"ses_102b4b020ffezHsYsEmnxMB0zX","part":{"type":"tool","tool":"read","callID":"call_kNjdaVWYXeaWoUpHFkpiA4lR","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj","limit":500},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n2: \n3: import kit.ArkUI.*\n4: import kit.LocalizationKit.*\n5: import ohos.arkui.state_macro_manage.Component\n6: import ohos.arkui.state_macro_manage.Entry\n7: import ohos.arkui.state_macro_manage.State\n8: import ohos_app_cangjie_entry.Global\n9: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.loginStore\n10: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.onboardingStore\n11: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.profileStore\n12: \n13: @Entry\n14: @Component\n15: class FoodikeBootstrap {\n16:     @State\n17:     var currentRoute: String = bootstrapStartRoute\n18: \n19:     @State\n20:     var isShellAtTop: Bool = true\n21: \n22:     @State\n23:     var onboardingPageIndex: Int64 = 0\n24: \n25:     @State\n26:     var loginEmail: String = \"\"\n27: \n28:     @State\n29:     var loginPassword: String = \"\"\n30: \n31:     private var onboardingController: SwiperController = SwiperController()\n32: \n33:     private func applyShellState(shellState: ShellRouteState): Unit {\n34:         this.currentRoute = shellState.currentRoute\n35:         this.isShellAtTop = shellState.isAtTop\n36:     }\n37: \n38:     private func shellState(): ShellRouteState {\n39:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n40:     }\n41: \n42:     private func applyShellCommand(command: ShellCommand): Unit {\n43:         let shellState = this.shellState()\n44:         shellState.applyCommand(command)\n45:         this.applyShellState(shellState)\n46:     }\n47: \n48:     private func navigateTo(route: String): Unit {\n49:         let shellState = this.shellState()\n50:         shellState.currentRoute = route\n51:         shellState.isAtTop = true\n52:         this.applyShellState(shellState)\n53:     }\n54: \n55:     private func showBottomShell(route: String): Bool {\n56:         let shellState = this.shellState()\n57:         shellState.currentRoute = route\n58:         return shellState.showBottomShell()\n59:     }\n60: \n61:     private func routeTitle(route: String): String {\n62:         match (route) {\n63:             case \"onboarding\" => \"Onboarding\"\n64:             case \"login_screen\" => \"Login\"\n65:             case \"home_screen\" => \"Home\"\n66:             case \"history\" => \"History\"\n67:             case \"cart\" => \"Cart\"\n68:             case \"profile\" => \"Profile\"\n69:             case \"restaurant_details\" => \"Restaurant Detail\"\n70:             case _ => \"Unknown Route\"\n71:         }\n72:     }\n73: \n74:     private func showToast(message: String): Unit {\n75:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n76:     }\n77: \n78:     private func performLogin(): Unit {\n79:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n80:             this.navigateTo(loginStore.successRoute())\n81:             return\n82:         }\n83: \n84:         this.showToast(loginStore.invalidLoginMessage)\n85:     }\n86: \n87:     private func performLogout(): Unit {\n88:         profileStore.logout(Global.abilityContext)\n89:         this.loginEmail = \"\"\n90:         this.loginPassword = \"\"\n91:         this.onboardingPageIndex = 0\n92:         this.navigateTo(profileStore.logoutRoute())\n93:     }\n94: \n95:     private func routeSummary(route: String): String {\n96:         match (route) {\n97:             case \"home_screen\" => \"Home remains the shared shell placeholder from phase 02 while onboarding, login, and profile now run as dedicated phase-03 routes.\"\n98:             case \"history\" => \"History remains available as a shell route so profile still has a source-consistent back destination.\"\n99:             case \"cart\" => \"Cart continues to be a shell-owned placeholder route until later phases land the real content.\"\n100:             case \"restaurant_details\" => \"Restaurant detail remains in the route contract but keeps its placeholder body until later phases.\"\n101:             case _ => \"\"\n102:         }\n103:     }\n104: \n105:     @Builder\n106:     private func buildTopBar(title: String, backLabel: String, onBack: () -> Unit) {\n107:         Row {\n108:             Button(backLabel)\n109:                 .onClick({ _ => onBack() })\n110:             Text(title)\n111:                 .fontSize(28)\n112:                 .fontWeight(FontWeight.Bold)\n113:                 .margin(left: 16)\n114:         }\n115:         .width(100.percent)\n116:         .justifyContent(FlexAlign.Start)\n117:         .alignItems(VerticalAlign.Center)\n118:     }\n119: \n120:     @Builder\n121:     private func buildOnboardingCard(title: String, description: String, mediaName: String) {\n122:         Column(space: 18) {\n123:             Image(\n124:                 match (mediaName) {\n125:                     case \"chinese_bowl\" => @r(app.media.chinese_bowl)\n126:                     case \"rider\" => @r(app.media.rider)\n127:                     case _ => @r(app.media.clock)\n128:                 }\n129:             )\n130:                 .width(72.percent)\n131:                 .height(280)\n132:             Text(title)\n133:                 .fontSize(30)\n134:                 .fontColor(Color.White)\n135:                 .fontWeight(FontWeight.Bold)\n136:                 .textAlign(TextAlign.Center)\n137:             Text(description)\n138:                 .fontSize(17)\n139:                 .fontColor(Color.White)\n140:                 .textAlign(TextAlign.Center)\n141:                 .width(86.percent)\n142:         }\n143:         .width(100.percent)\n144:         .height(100.percent)\n145:         .justifyContent(FlexAlign.Center)\n146:         .alignItems(HorizontalAlign.Center)\n147:     }\n148: \n149:     @Builder\n150:     private func buildOnboardingRoute() {\n151:         Column(space: 24) {\n152:             Swiper(controller: this.onboardingController) {\n153:                 this.buildOnboardingCard(\n154:                     onboardingStore.slideAt(0).title,\n155:                     onboardingStore.slideAt(0).description,\n156:                     onboardingStore.slideAt(0).mediaName\n157:                 )\n158:                 this.buildOnboardingCard(\n159:                     onboardingStore.slideAt(1).title,\n160:                     onboardingStore.slideAt(1).description,\n161:                     onboardingStore.slideAt(1).mediaName\n162:                 )\n163:                 this.buildOnboardingCard(\n164:                     onboardingStore.slideAt(2).title,\n165:                     onboardingStore.slideAt(2).description,\n166:                     onboardingStore.slideAt(2).mediaName\n167:                 )\n168:             }\n169:             .indicator(true)\n170:             .onChange({ index: Int32 =>\n171:                 this.onboardingPageIndex = Int64(index)\n172:             })\n173:             .width(100.percent)\n174:             .height(78.percent)\n175: \n176:             Row {\n177:                 Text(\"${this.onboardingPageIndex + 1}/${onboardingStore.pageCount()}\")\n178:                     .fontSize(16)\n179:                     .fontColor(Color.White)\n180:                 Button(if (onboardingStore.isLastPage(this.onboardingPageIndex)) { \"Login\" } else { \"Next\" })\n181:                     .onClick({ _ =>\n182:                         if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n183:                             this.navigateTo(routePath(RouteId.Login))\n184:                         } else {\n185:                             this.onboardingController.showNext()\n186:                         }\n187:                     })\n188:             }\n189:             .width(90.percent)\n190:             .justifyContent(FlexAlign.SpaceBetween)\n191:             .alignItems(VerticalAlign.Center)\n192:             .margin(bottom: 12)\n193:         }\n194:         .width(100.percent)\n195:         .height(100.percent)\n196:         .backgroundColor(@r(app.color.DarkGreen))\n197:         .alignItems(HorizontalAlign.Center)\n198:         .justifyContent(FlexAlign.SpaceBetween)\n199:     }\n200: \n201:     @Builder\n202:     private func buildLoginRoute() {\n203:         Column(space: 16) {\n204:             Text(@r(app.string.welcome_back))\n205:                 .fontSize(32)\n206:                 .fontWeight(FontWeight.Bold)\n207: \n208:             TextInput(text: this.loginEmail, placeholder: loginStore.emailHint)\n209:                 .width(90.percent)\n210:                 .height(52)\n211:                 .fontSize(16)\n212:                 .placeholderColor(Color.Gray)\n213:                 .onChange({ value: String =>\n214:                     this.loginEmail = value\n215:                 })\n216: \n217:             TextInput(text: this.loginPassword, placeholder: loginStore.passwordHint)\n218:                 .width(90.percent)\n219:                 .height(52)\n220:                 .fontSize(16)\n221:                 .placeholderColor(Color.Gray)\n222:                 .enterKeyType(EnterKeyType.Done)\n223:                 .onChange({ value: String =>\n224:                     this.loginPassword = value\n225:                 })\n226:                 .onSubmit({ _ =>\n227:                     this.performLogin()\n228:                 })\n229: \n230:             Text(@r(app.string.forg