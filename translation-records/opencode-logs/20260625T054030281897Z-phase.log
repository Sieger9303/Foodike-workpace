_details\" => \"Restaurant detail remains part of the route host even before full content arrives in later phases.\"\n-            case _ => \"No summary available.\"\n-        }\n-    }\n-\n-    private func primaryActionLabel(route: String): String {\n-        match (route) {\n-            case \"onboarding\" => \"Continue to Login\"\n-            case \"login_screen\" => \"Enter Home\"\n-            case \"home_screen\" => \"Open Restaurant Detail\"\n-            case \"history\" => \"Open Profile\"\n-            case \"cart\" => \"Return Home\"\n-            case \"profile\" => \"Log Out to Onboarding\"\n-            case \"restaurant_details\" => \"Back to Home\"\n-            case _ => \"Go Home\"\n-        }\n-    }\n-\n-    private func runPrimaryAction(): Unit {\n-        this.applyShellCommand(ShellCommand.PrimaryAction)\n-    }\n-\n-    func build() {\n-        Row {\n-            Column {\n-                Text(\"Foodike\")\n-                    .fontSize(42)\n-                Text(\"Startup route host\")\n-                    .fontSize(18)\n-                Text(this.routeTitle(this.currentRoute))\n-                    .fontSize(26)\n-                    .margin(top: 18)\n-                Text(this.routeSummary(this.currentRoute))\n-                    .fontSize(16)\n-                    .margin(top: 8)\n-\n-                Text(\"Current route: ${this.currentRoute}\")\n-                    .fontSize(14)\n-                    .margin(top: 12)\n-\n-                if (this.currentRoute == routePath(RouteId.Onboarding)) {\n-                    Text(\"The source activity composes navigation only after startup picks a first destination. This route represents the logged-out path.\")\n-                        .fontSize(14)\n-                        .margin(top: 18)\n-                }\n-\n-                if (this.currentRoute == routePath(RouteId.Login)) {\n-                    Text(\"Login remains a dedicated destination inside the shared route host, just as `SetupNavigation` keeps it in the source destination graph.\")\n-                        .fontSize(14)\n-                        .margin(top: 18)\n-                }\n-\n-                if (this.currentRoute == routePath(RouteId.Home) || this.currentRoute == routePath(RouteId.History)) {\n-                    Text(\"The shared shell reacts to both the active route and the top-of-list state before showing bottom-bar commands.\")\n-                        .fontSize(14)\n-                        .margin(top: 18)\n-                    Button(if (this.isShellAtTop) { \"Simulate Scrolled Content\" } else { \"Return To Top\" })\n-                        .onClick({ evt =>\n-                            let shellState = this.shellState()\n-                            shellState.setTopState(!shellState.isAtTop)\n-                            this.applyShellState(shellState)\n-                        })\n-                        .margin(top: 12)\n-                    Text(if (this.isShellAtTop) { \"Shell chrome is visible because the shared top-level list is at the first item.\" } else { \"Shell chrome is hidden because the shared top-level list has moved away from the first item.\" })\n-                        .fontSize(14)\n-                        .margin(top: 8)\n-                }\n-\n-                if (this.currentRoute == routePath(RouteId.Cart)) {\n-                    Text(\"Cart is not a bottom-bar destination in the source graph. It is opened from the shell-owned cart action.\")\n-                        .fontSize(14)\n-                        .margin(top: 18)\n-                }\n-\n-                if (this.currentRoute == routePath(RouteId.Profile)) {\n-                    Text(\"Profile remains a first-class route so later logout work can clear back to onboarding through the same host.\")\n-                        .fontSize(14)\n-                        .margin(top: 18)\n-                }\n-\n-                if (this.currentRoute == routePath(RouteId.RestaurantDetails)) {\n-                    Text(\"Restaurant detail already participates in the route host, preserving the source destination contract before feature content lands in phase 05.\")\n-                        .fontSize(14)\n-                        .margin(top: 18)\n-                }\n-\n-                Button(this.primaryActionLabel(this.currentRoute))\n-                    .onClick({ evt =>\n-                        this.runPrimaryAction()\n-                    })\n-                    .margin(top: 20)\n-\n-                if (this.showBottomShell(this.currentRoute)) {\n-                    Text(\"Bottom shell commands\")\n-                        .fontSize(18)\n-                        .margin(top: 28)\n-                    Row {\n-                        Button(\"Home Tab\")\n-                            .onClick({ evt => this.applyShellCommand(ShellCommand.HomeTab) })\n-                        Button(\"Cart\")\n-                            .onClick({ evt => this.applyShellCommand(ShellCommand.CartAction) })\n-                            .margin(left: 12)\n-                        Button(\"History Tab\")\n-                            .onClick({ evt => this.applyShellCommand(ShellCommand.HistoryTab) })\n-                            .margin(left: 12)\n-                    }.margin(top: 12)\n-                    Text(\"The shell-owned bottom bar and cart action appear only on home and history routes while the shared top-level list remains at the first item, matching the source route contract for this phase.\")\n-                        .fontSize(14)\n-                        .margin(top: 8)\n-                } else {\n-                    Text(\"Bottom shell chrome is inactive for this route, matching the source scaffold contract.\")\n-                        .fontSize(14)\n-                        .margin(top: 24)\n-                }\n-            }.width(100.percent)\n-        }.height(100.percent)\n-    }\n-}\n","additions":0,"deletions":183},{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj","relativePath":"Foodike-Harmony/entry/src/main/cangjie/ohos_app_cangjie_entry/app/bootstrap_page.cj","type":"add","patch":"Index: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\app\\bootstrap_page.cj\n@@ -0,0 +1,439 @@\n+package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n+\n+import kit.ArkUI.*\n+import kit.LocalizationKit.*\n+import ohos.arkui.state_macro_manage.Component\n+import ohos.arkui.state_macro_manage.Entry\n+import ohos.arkui.state_macro_manage.State\n+import ohos_app_cangjie_entry.Global\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.loginStore\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.onboardingStore\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.profileStore\n+\n+@Entry\n+@Component\n+class FoodikeBootstrap {\n+    @State\n+    var currentRoute: String = bootstrapStartRoute\n+\n+    @State\n+    var isShellAtTop: Bool = true\n+\n+    @State\n+    var onboardingPageIndex: Int64 = 0\n+\n+    @State\n+    var loginEmail: String = \"\"\n+\n+    @State\n+    var loginPassword: String = \"\"\n+\n+    private var onboardingController: SwiperController = SwiperController()\n+\n+    private func applyShellState(shellState: ShellRouteState): Unit {\n+        this.currentRoute = shellState.currentRoute\n+        this.isShellAtTop = shellState.isAtTop\n+    }\n+\n+    private func shellState(): ShellRouteState {\n+        ShellRouteState(this.currentRoute, this.isShellAtTop)\n+    }\n+\n+    private func applyShellCommand(command: ShellCommand): Unit {\n+        let shellState = this.shellState()\n+        shellState.applyCommand(command)\n+        this.applyShellState(shellState)\n+    }\n+\n+    private func navigateTo(route: String): Unit {\n+        let shellState = this.shellState()\n+        shellState.currentRoute = route\n+        shellState.isAtTop = true\n+        this.applyShellState(shellState)\n+    }\n+\n+    private func showBottomShell(route: String): Bool {\n+        let shellState = this.shellState()\n+        shellState.currentRoute = route\n+        return shellState.showBottomShell()\n+    }\n+\n+    private func routeTitle(route: String): String {\n+        match (route) {\n+            case \"onboarding\" => \"Onboarding\"\n+            case \"login_screen\" => \"Login\"\n+            case \"home_screen\" => \"Home\"\n+            case \"history\" => \"History\"\n+            case \"cart\" => \"Cart\"\n+            case \"profile\" => \"Profile\"\n+            case \"restaurant_details\" => \"Restaurant Detail\"\n+            case _ => \"Unknown Route\"\n+        }\n+    }\n+\n+    private func showToast(message: String): Unit {\n+        getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n+    }\n+\n+    private func performLogin(): Unit {\n+        if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n+            this.navigateTo(loginStore.successRoute())\n+            return\n+        }\n+\n+        this.showToast(loginStore.invalidLoginMessage)\n+    }\n+\n+    private func performLogout(): Unit {\n+        profileStore.logout(Global.abilityContext)\n+        this.loginEmail = \"\"\n+        this.loginPassword = \"\"\n+        this.onboardingPageIndex = 0\n+        this.navigateTo(profileStore.logoutRoute())\n+    }\n+\n+    private func routeSummary(route: String): String {\n+        match (route) {\n+            case \"home_screen\" => \"Home remains the shared shell placeholder from phase 02 while onboarding, login, and profile now run as dedicated phase-03 routes.\"\n+            case \"history\" => \"History remains available as a shell route so profile still has a source-consistent back destination.\"\n+            case \"cart\" => \"Cart continues to be a shell-owned placeholder route until later phases land the real content.\"\n+            case \"restaurant_details\" => \"Restaurant detail remains in the route contract but keeps its placeholder body until later phases.\"\n+            case _ => \"\"\n+        }\n+    }\n+\n+    @Builder\n+    private func buildTopBar(title: String, backLabel: String, onBack: () -> Unit) {\n+        Row {\n+            Button(backLabel)\n+                .onClick({ _ => onBack() })\n+            Text(title)\n+                .fontSize(28)\n+                .fontWeight(FontWeight.Bold)\n+                .margin(left: 16)\n+        }\n+        .width(100.percent)\n+        .justifyContent(FlexAlign.Start)\n+        .alignItems(VerticalAlign.Center)\n+    }\n+\n+    @Builder\n+    private func buildOnboardingCard(title: String, description: String, mediaName: String) {\n+        Column(space: 18) {\n+            Image(\n+                match (mediaName) {\n+                    case \"chinese_bowl\" => @r(app.media.chinese_bowl)\n+                    case \"rider\" => @r(app.media.rider)\n+                    case _ => @r(app.media.clock)\n+                }\n+            )\n+                .width(72.percent)\n+                .height(280)\n+            Text(title)\n+                .fontSize(30)\n+                .fontColor(Color.White)\n+                .fontWeight(FontWeight.Bold)\n+                .textAlign(TextAlign.Center)\n+            Text(description)\n+                .fontSize(17)\n+                .fontColor(Color.White)\n+                .textAlign(TextAlign.Center)\n+                .width(86.percent)\n+        }\n+        .width(100.percent)\n+        .height(100.percent)\n+        .justifyContent(FlexAlign.Center)\n+        .alignItems(HorizontalAlign.Center)\n+    }\n+\n+    @Builder\n+    private func buildOnboardingRoute() {\n+        Column(space: 24) {\n+            Swiper(controller: this.onboardingController) {\n+                this.buildOnboardingCard(\n+                    onboardingStore.slideAt(0).title,\n+                    onboardingStore.slideAt(0).description,\n+                    onboardingStore.slideAt(0).mediaName\n+                )\n+                this.buildOnboardingCard(\n+                    onboardingStore.slideAt(1).title,\n+                    onboardingStore.slideAt(1).description,\n+                    onboardingStore.slideAt(1).mediaName\n+                )\n+                this.buildOnboardingCard(\n+                    onboardingStore.slideAt(2).title,\n+                    onboardingStore.slideAt(2).description,\n+                    onboardingStore.slideAt(2).mediaName\n+                )\n+            }\n+            .indicator(true)\n+            .onChange({ index: Int32 =>\n+                this.onboardingPageIndex = Int64(index)\n+            })\n+            .width(100.percent)\n+            .height(78.percent)\n+\n+            Row {\n+                Text(\"${this.onboardingPageIndex + 1}/${onboardingStore.pageCount()}\")\n+                    .fontSize(16)\n+                    .fontColor(Color.White)\n+                Button(if (onboardingStore.isLastPage(this.onboardingPageIndex)) { \"Login\" } else { \"Next\" })\n+                    .onClick({ _ =>\n+                        if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n+                            this.navigateTo(routePath(RouteId.Login))\n+                        } else {\n+                            this.onboardingController.showNext()\n+                        }\n+                    })\n+            }\n+            .width(90.percent)\n+            .justifyContent(FlexAlign.SpaceBetween)\n+            .alignItems(VerticalAlign.Center)\n+            .margin(bottom: 12)\n+        }\n+        .width(100.percent)\n+        .height(100.percent)\n+        .backgroundColor(@r(app.color.DarkGreen))\n+        .alignItems(HorizontalAlign.Center)\n+        .justifyContent(FlexAlign.SpaceBetween)\n+    }\n+\n+    @Builder\n+    private func buildLoginRoute() {\n+        Column(space: 16) {\n+            Text(@r(app.string.welcome_back))\n+                .fontSize(32)\n+                .fontWeight(FontWeight.Bold)\n+\n+            TextInput(text: this.loginEmail, placeholder: loginStore.emailHint)\n+                .width(90.percent)\n+                .height(52)\n+                .fontSize(16)\n+                .placeholderColor(Color.Gray)\n+                .onChange({ value: String =>\n+                    this.loginEmail = value\n+                })\n+\n+            TextInput(text: this.loginPassword, placeholder: loginStore.passwordHint)\n+                .width(90.percent)\n+                .height(52)\n+                .fontSize(16)\n+                .placeholderColor(Color.Gray)\n+                .enterKeyType(EnterKeyType.Done)\n+                .onChange({ value: String =>\n+                    this.loginPassword = value\n+                })\n+                .onSubmit({ _ =>\n+                    this.performLogin()\n+                })\n+\n+            Text(@r(app.string.forgot_password))\n+                .fontSize(14)\n+                .fontColor(Color.Gray)\n+                .width(90.percent)\n+                .textAlign(TextAlign.End)\n+                .onClick({ _ =>\n+                    this.showToast(loginStore.comingSoonMessage)\n+                })\n+\n+            Button(@r(app.string.login))\n+                .width(220)\n+                .height(50)\n+                .onClick({ _ =>\n+                    this.performLogin()\n+                })\n+\n+            Row {\n+                Text(@r(app.string.or_sign_in_with))\n+                    .fontSize(16)\n+                    .fontColor(Color.Gray)\n+            }\n+            .margin(top: 8)\n+\n+            Row(space: 20) {\n+                Image(@r(app.media.goog_icon))\n+                    .width(48)\n+                    .height(48)\n+                    .onClick({ _ =>\n+                        this.showToast(loginStore.comingSoonMessage)\n+                    })\n+                Image(@r(app.media.fb_icon))\n+                    .width(48)\n+                    .height(48)\n+                    .onClick({ _ =>\n+                        this.showToast(loginStore.comingSoonMessage)\n+                    })\n+            }\n+\n+            Text(@r(app.string.new_to_foodike))\n+                .fontSize(15)\n+                .fontColor(Color.Gray)\n+                .margin(top: 8)\n+                .onClick({ _ =>\n+                    this.showToast(loginStore.comingSoonMessage)\n+                })\n+        }\n+        .width(100.percent)\n+        .height(100.percent)\n+        .padding({ left: 24, right: 24, top: 24, bottom: 24 })\n+        .justifyContent(FlexAlign.Center)\n+        .alignItems(HorizontalAlign.Center)\n+        .backgroundColor(Color.White)\n+    }\n+\n+    @Builder\n+    private func buildProfileSectionCard(title: ResourceStr, subtitle: ResourceStr, dividerVisible: Bool) {\n+        Column(space: 8) {\n+            Text(title)\n+                .fontSize(21)\n+                .fontWeight(FontWeight.Medium)\n+            Text(subtitle)\n+                .fontSize(15)\n+                .fontColor(Color.Gray)\n+            if (dividerVisible) {\n+                Divider()\n+                    .width(100.percent)\n+            }\n+        }\n+        .width(100.percent)\n+        .padding({ top: 10, bottom: 10 })\n+        .onClick({ _ =>\n+            this.showToast(profileStore.placeholderActionMessage)\n+        })\n+    }\n+\n+    @Builder\n+    private func buildProfileRoute() {\n+        Column(space: 18) {\n+            this.buildTopBar(@r(app.string.profile_title), @r(app.string.back), { =>\n+                this.navigateTo(profileStore.backRoute())\n+            })\n+\n+            Row {\n+                Column(space: 6) {\n+                    Text(profileStore.userName)\n+                        .fontSize(28)\n+                        .fontWeight(FontWeight.Bold)\n+                    Text(profileStore.userEmail)\n+                        .fontSize(15)\n+                        .fontColor(Color.Gray)\n+                }\n+                .layoutWeight(1.0)\n+\n+                Column(space: 8) {\n+                    Image(@r(app.media.ic_profile))\n+                        .width(96)\n+                        .height(96)\n+                    Text(@r(app.string.edit))\n+                        .fontSize(15)\n+                        .fontColor(@r(app.color.DarkGreen))\n+                        .fontWeight(FontWeight.Bold)\n+                        .onClick({ _ =>\n+                            this.showToast(profileStore.placeholderActionMessage)\n+                        })\n+                }\n+                .alignItems(HorizontalAlign.Center)\n+            }\n+            .width(100.percent)\n+            .alignItems(VerticalAlign.Center)\n+\n+            Divider()\n+                .width(100.percent)\n+\n+            Column {\n+                this.buildProfileSectionCard(\n+                    @r(app.string.saved_addresses),\n+                    @r(app.string.add_edit_and_delete_saved_addresses),\n+                    true\n+                )\n+                this.buildProfileSectionCard(\n+                    @r(app.string.payments_and_refunds),\n+                    @r(app.string.information_about_refunds_and_payments),\n+                    true\n+                )\n+                this.buildProfileSectionCard(\n+                    @r(app.string.online_ordering_help),\n+                    @r(app.string.information_about_ordering_food),\n+                    true\n+                )\n+                this.buildProfileSectionCard(\n+                    @r(app.string.about),\n+                    @r(app.string.about_the_app),\n+                    false\n+                )\n+            }\n+            .width(100.percent)\n+\n+            Blank()\n+                .layoutWeight(1.0)\n+\n+            Button(@r(app.string.log_out))\n+                .width(220)\n+                .height(50)\n+                .onClick({ _ =>\n+                    this.performLogout()\n+                })\n+        }\n+        .width(100.percent)\n+        .height(100.percent)\n+        .padding({ left: 24, right: 24, top: 18, bottom: 24 })\n+        .backgroundColor(Color.White)\n+    }\n+\n+    @Builder\n+    private func buildPlaceholderRoute() {\n+        Column(space: 18) {\n+            Text(\"Foodike\")\n+                .fontSize(42)\n+                .fontWeight(FontWeight.Bold)\n+            Text(this.routeTitle(this.currentRoute))\n+                .fontSize(28)\n+            Text(this.routeSummary(this.currentRoute))\n+                .fontSize(16)\n+                .textAlign(TextAlign.Center)\n+                .width(86.percent)\n+\n+            if (this.currentRoute == routePath(RouteId.Home) || this.currentRoute == routePath(RouteId.History)) {\n+                Button(if (this.isShellAtTop) { \"Simulate Scrolled Content\" } else { \"Return To Top\" })\n+                    .onClick({ _ =>\n+                        let shellState = this.shellState()\n+                        shellState.setTopState(!shellState.isAtTop)\n+                        this.applyShellState(shellState)\n+                    })\n+            }\n+\n+            Button(\"Primary Route Action\")\n+                .onClick({ _ =>\n+                    this.applyShellCommand(ShellCommand.PrimaryAction)\n+                })\n+\n+            if (this.showBottomShell(this.currentRoute)) {\n+                Row(space: 12) {\n+                    Button(\"Home Tab\")\n+                        .onClick({ _ => this.applyShellCommand(ShellCommand.HomeTab) })\n+                    Button(\"Cart\")\n+                        .onClick({ _ => this.applyShellCommand(ShellCommand.CartAction) })\n+                    Button(\"History Tab\")\n+                        .onClick({ _ => this.applyShellCommand(ShellCommand.HistoryTab) })\n+                }\n+            }\n+        }\n+        .width(100.percent)\n+        .height(100.percent)\n+        .justifyContent(FlexAlign.Center)\n+        .alignItems(HorizontalAlign.Center)\n+        .padding({ left: 24, right: 24, top: 24, bottom: 24 })\n+    }\n+\n+    func build() {\n+        if (this.currentRoute == routePath(RouteId.Onboarding)) {\n+            this.buildOnboardingRoute()\n+        } else if (this.currentRoute == routePath(RouteId.Login)) {\n+            this.buildLoginRoute()\n+        } else if (this.currentRoute == routePath(RouteId.Profile)) {\n+            this.buildProfileRoute()\n+        } else {\n+            this.buildPlaceholderRoute()\n+        }\n+    }\n+}\n","additions":439,"deletions":0},{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\element\\string.json","relativePath":"Foodike-Harmony/entry/src/main/resources/base/element/string.json","type":"update","patch":"Index: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\element\\string.json\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\element\\string.json\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\element\\string.json\n@@ -14,7 +14,75 @@\n     },\n     {\n       \"name\": \"module_desc\",\n       \"value\": \"Foodike HarmonyOS entry module\"\n+    },\n+    {\n+      \"name\": \"welcome_back\",\n+      \"value\": \"Welcome back!\"\n+    },\n+    {\n+      \"name\": \"forgot_password\",\n+      \"value\": \"forgot password?\"\n+    },\n+    {\n+      \"name\": \"login\",\n+      \"value\": \"Login\"\n+    },\n+    {\n+      \"name\": \"or_sign_in_with\",\n+      \"value\": \"or sign in with\"\n+    },\n+    {\n+      \"name\": \"new_to_foodike\",\n+      \"value\": \"New to Foodike? Sign up\"\n+    },\n+    {\n+      \"name\": \"log_out\",\n+      \"value\": \"Log Out\"\n+    },\n+    {\n+      \"name\": \"saved_addresses\",\n+      \"value\": \"Saved Addresses\"\n+    },\n+    {\n+      \"name\": \"add_edit_and_delete_saved_addresses\",\n+      \"value\": \"Add, edit and delete saved addresses\"\n+    },\n+    {\n+      \"name\": \"payments_and_refunds\",\n+      \"value\": \"Payments & Refunds\"\n+    },\n+    {\n+      \"name\": \"information_about_refunds_and_payments\",\n+      \"value\": \"Information about refunds and payments\"\n+    },\n+    {\n+      \"name\": \"online_ordering_help\",\n+      \"value\": \"Online Ordering Help\"\n+    },\n+    {\n+      \"name\": \"information_about_ordering_food\",\n+      \"value\": \"Information about ordering food\"\n+    },\n+    {\n+      \"name\": \"about\",\n+      \"value\": \"About\"\n+    },\n+    {\n+      \"name\": \"about_the_app\",\n+      \"value\": \"About the app\"\n+    },\n+    {\n+      \"name\": \"back\",\n+      \"value\": \"Back\"\n+    },\n+    {\n+      \"name\": \"edit\",\n+      \"value\": \"Edit\"\n+    },\n+    {\n+      \"name\": \"profile_title\",\n+      \"value\": \"Profile\"\n     }\n   ]\n }\n","additions":68,"deletions":0},{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\chinese_bowl.svg","relativePath":"Foodike-Harmony/entry/src/main/resources/base/media/chinese_bowl.svg","type":"add","patch":"Index: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\chinese_bowl.svg\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\chinese_bowl.svg\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\chinese_bowl.svg\n@@ -0,0 +1,10 @@\n+<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 240 240\">\n+  <rect width=\"240\" height=\"240\" rx=\"36\" fill=\"#1f7a34\"/>\n+  <path d=\"M45 118c0 41 33 74 75 74s75-33 75-74H45z\" fill=\"#ffffff\"/>\n+  <path d=\"M62 118h116\" stroke=\"#c1f0c9\" stroke-width=\"10\" stroke-linecap=\"round\"/>\n+  <path d=\"M92 78c0-17 14-31 31-31\" stroke=\"#f7f4d4\" stroke-width=\"8\" fill=\"none\" stroke-linecap=\"round\"/>\n+  <path d=\"M131 70c4-11 15-18 27-18\" stroke=\"#f7f4d4\" stroke-width=\"8\" fill=\"none\" stroke-linecap=\"round\"/>\n+  <circle cx=\"95\" cy=\"116\" r=\"8\" fill=\"#59d173\"/>\n+  <circle cx=\"122\" cy=\"106\" r=\"8\" fill=\"#59d173\"/>\n+  <circle cx=\"148\" cy=\"116\" r=\"8\" fill=\"#59d173\"/>\n+</svg>\n","additions":10,"deletions":0},{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\rider.svg","relativePath":"Foodike-Harmony/entry/src/main/resources/base/media/rider.svg","type":"add","patch":"Index: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\rider.svg\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\rider.svg\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\rider.svg\n@@ -0,0 +1,9 @@\n+<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 240 240\">\n+  <rect width=\"240\" height=\"240\" rx=\"36\" fill=\"#59d173\"/>\n+  <circle cx=\"76\" cy=\"173\" r=\"23\" fill=\"#2d2d2d\"/>\n+  <circle cx=\"174\" cy=\"173\" r=\"23\" fill=\"#2d2d2d\"/>\n+  <path d=\"M68 166l28-56h52l18 56\" stroke=\"#ffffff\" stroke-width=\"10\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n+  <rect x=\"101\" y=\"85\" width=\"55\" height=\"28\" rx=\"8\" fill=\"#ffffff\"/>\n+  <circle cx=\"119\" cy=\"62\" r=\"18\" fill=\"#f4c9a8\"/>\n+  <path d=\"M112 80l-20 28\" stroke=\"#f4c9a8\" stroke-width=\"10\" stroke-linecap=\"round\"/>\n+</svg>\n","additions":9,"deletions":0},{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\clock.svg","relativePath":"Foodike-Harmony/entry/src/main/resources/base/media/clock.svg","type":"add","patch":"Index: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\clock.svg\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\clock.svg\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\clock.svg\n@@ -0,0 +1,7 @@\n+<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 240 240\">\n+  <rect width=\"240\" height=\"240\" rx=\"36\" fill=\"#0d5a22\"/>\n+  <circle cx=\"120\" cy=\"120\" r=\"72\" fill=\"#ffffff\"/>\n+  <circle cx=\"120\" cy=\"120\" r=\"58\" fill=\"#e9f7ec\"/>\n+  <path d=\"M120 88v38l28 16\" stroke=\"#1f7a34\" stroke-width=\"10\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n+  <circle cx=\"120\" cy=\"120\" r=\"7\" fill=\"#1f7a34\"/>\n+</svg>\n","additions":7,"deletions":0},{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\goog_icon.svg","relativePath":"Foodike-Harmony/entry/src/main/resources/base/media/goog_icon.svg","type":"add","patch":"Index: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\goog_icon.svg\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\goog_icon.svg\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\goog_icon.svg\n@@ -0,0 +1,7 @@\n+<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 120 120\">\n+  <rect width=\"120\" height=\"120\" rx=\"24\" fill=\"#ffffff\"/>\n+  <path d=\"M100 61c0-4-1-8-2-12H60v23h22c-2 11-12 19-22 19-13 0-24-11-24-25s11-25 24-25c6 0 12 3 16 7l16-16C84 23 73 18 60 18 35 18 15 38 15 63s20 45 45 45c23 0 43-17 43-47z\" fill=\"#4285f4\"/>\n+  <path d=\"M15 63c0 25 20 45 45 45 22 0 41-15 44-36H82c-2 11-12 19-22 19-13 0-24-11-24-25H15z\" fill=\"#34a853\" opacity=\"0.9\"/>\n+  <path d=\"M35 38l19 14c2-6 8-11 16-11 6 0 12 3 16 7l16-16C84 23 73 18 60 18 42 18 25 28 18 45z\" fill=\"#ea4335\"/>\n+  <path d=\"M18 45c-2 5-3 11-3 18h21c0-4 1-8 3-11z\" fill=\"#fbbc05\"/>\n+</svg>\n","additions":7,"deletions":0},{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\fb_icon.svg","relativePath":"Foodike-Harmony/entry/src/main/resources/base/media/fb_icon.svg","type":"add","patch":"Index: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\fb_icon.svg\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\fb_icon.svg\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\fb_icon.svg\n@@ -0,0 +1,4 @@\n+<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 120 120\">\n+  <rect width=\"120\" height=\"120\" rx=\"24\" fill=\"#1877f2\"/>\n+  <path d=\"M69 101V67h11l3-14H69V45c0-4 2-8 8-8h7V25c-1 0-6-1-12-1-12 0-20 7-20 21v8H42v14h10v34h17z\" fill=\"#ffffff\"/>\n+</svg>\n","additions":4,"deletions":0},{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\ic_profile.svg","relativePath":"Foodike-Harmony/entry/src/main/resources/base/media/ic_profile.svg","type":"add","patch":"Index: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\ic_profile.svg\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\ic_profile.svg\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\resources\\base\\media\\ic_profile.svg\n@@ -0,0 +1,5 @@\n+<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 160 160\">\n+  <circle cx=\"80\" cy=\"80\" r=\"80\" fill=\"#e4e6e7\"/>\n+  <circle cx=\"80\" cy=\"60\" r=\"28\" fill=\"#aeb4b7\"/>\n+  <path d=\"M30 136c10-28 28-42 50-42s40 14 50 42\" fill=\"#aeb4b7\"/>\n+</svg>\n","additions":5,"deletions":0},{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase03_onboarding_login_profile_test.cj","relativePath":"Foodike-Harmony/entry/src/test/cangjie/phase03_onboarding_login_profile_test.cj","type":"add","patch":"Index: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase03_onboarding_login_profile_test.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase03_onboarding_login_profile_test.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase03_onboarding_login_profile_test.cj\n@@ -0,0 +1,40 @@\n+package ohos_app_cangjie_entry\n+\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, routePath}\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.LoginStore\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.OnboardingStore\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.ProfileStore\n+import std.unittest.*\n+import std.unittest.testmacro.*\n+\n+@Test\n+public class Phase03OnboardingLoginProfileTest {\n+    @TestCase\n+    public func onboardingStorePreservesThreePageProgression(): Unit {\n+        let store = OnboardingStore()\n+        @Assert(store.pageCount(), 3)\n+        @Assert(store.slideAt(0).title, \"Choose your favourite food\")\n+        @Assert(store.isLastPage(0), false)\n+        @Assert(store.nextIndex(0), 1)\n+        @Assert(store.isLastPage(2), true)\n+        @Assert(store.nextIndex(2), 2)\n+    }\n+\n+    @TestCase\n+    public func loginStoreAcceptsOnlySourceCredentials(): Unit {\n+        let store = LoginStore()\n+        @Assert(store.isValidCredentials(\"abcxyz@gmail.com\", \"abcdef\"), true)\n+        @Assert(store.isValidCredentials(\"abcxyz@gmail.com\", \"bad\"), false)\n+        @Assert(store.isValidCredentials(\"other@example.com\", \"abcdef\"), false)\n+        @Assert(store.successRoute(), routePath(RouteId.Home))\n+    }\n+\n+    @TestCase\n+    public func profileStoreRoutesBackAndLogoutToSourceDestinations(): Unit {\n+        let store = ProfileStore()\n+        @Assert(store.backRoute(), routePath(RouteId.History))\n+        @Assert(store.logoutRoute(), routePath(RouteId.Onboarding))\n+        @Assert(store.userName, \"Andrew Howard\")\n+        @Assert(store.userEmail, \"andrewhoward@gmail.com\")\n+    }\n+}\n","additions":40,"deletions":0}],"diagnostics":{},"truncated":false},"title":"Success. Updated the following files:\nM Foodike-Harmony/entry/src/main/cangjie/ohos_app_cangjie_entry/data/session/login_preferences_service.cj\nM Foodike-Harmony/entry/src/main/cangjie/app_ability.cj\nA Foodike-Harmony/entry/src/main/cangjie/ohos_app_cangjie_entry/features/login/login_store.cj\nA Foodike-Harmony/entry/src/main/cangjie/ohos_app_cangjie_entry/features/onboarding/onboarding_store.cj\nA Foodike-Harmony/entry/src/main/cangjie/ohos_app_cangjie_entry/features/profile/profile_store.cj\nD Foodike-Harmony/entry/src/main/cangjie/ohos_app_cangjie_entry/app/bootstrap_page.cj\nA Foodike-Harmony/entry/src/main/cangjie/ohos_app_cangjie_entry/app/bootstrap_page.cj\nM Foodike-Harmony/entry/src/main/resources/base/element/string.json\nA Foodike-Harmony/entry/src/main/resources/base/media/chinese_bowl.svg\nA Foodike-Harmony/entry/src/main/resources/base/media/rider.svg\nA Foodike-Harmony/entry/src/main/resources/base/media/clock.svg\nA Foodike-Harmony/entry/src/main/resources/base/media/goog_icon.svg\nA Foodike-Harmony/entry/src/main/resources/base/media/fb_icon.svg\nA Foodike-Harmony/en