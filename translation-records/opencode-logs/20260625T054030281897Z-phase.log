rofile_test.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase03_onboarding_login_profile_test.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\test\\cangjie\\phase03_onboarding_login_profile_test.cj\n@@ -0,0 +1,40 @@\n+package ohos_app_cangjie_entry\n+\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.app.{RouteId, routePath}\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.login.LoginStore\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.onboarding.OnboardingStore\n+import ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.profile.ProfileStore\n+import std.unittest.*\n+import std.unittest.testmacro.*\n+\n+@Test\n+public class Phase03OnboardingLoginProfileTest {\n+    @TestCase\n+    public func onboardingStorePreservesThreePageProgression(): Unit {\n+        let store = OnboardingStore()\n+        @Assert(store.pageCount(), 3)\n+        @Assert(store.slideAt(0).title, \"Choose your favourite food\")\n+        @Assert(store.isLastPage(0), false)\n+        @Assert(store.nextIndex(0), 1)\n+        @Assert(store.isLastPage(2), true)\n+        @Assert(store.nextIndex(2), 2)\n+    }\n+\n+    @TestCase\n+    public func loginStoreAcceptsOnlySourceCredentials(): Unit {\n+        let store = LoginStore()\n+        @Assert(store.isValidCredentials(\"abcxyz@gmail.com\", \"abcdef\"), true)\n+        @Assert(store.isValidCredentials(\"abcxyz@gmail.com\", \"bad\"), false)\n+        @Assert(store.isValidCredentials(\"other@example.com\", \"abcdef\"), false)\n+        @Assert(store.successRoute(), routePath(RouteId.Home))\n+    }\n+\n+    @TestCase\n+    public func profileStoreRoutesBackAndLogoutToSourceDestinations(): Unit {\n+        let store = ProfileStore()\n+        @Assert(store.backRoute(), routePath(RouteId.History))\n+        @Assert(store.logoutRoute(), routePath(RouteId.Onboarding))\n+        @Assert(store.userName, \"Andrew Howard\")\n+        @Assert(store.userEmail, \"andrewhoward@gmail.com\")\n+    }\n+}\n\n","files":[{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\data\\session\\login_preferences_service.cj","relativePath":"Foodike-Harmony/entry/src/main/cangjie/ohos_app_cangjie_entry/data/session/login_preferences_service.cj","type":"update","patch":"Index: D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\data\\session\\login_preferences_service.cj\n===================================================================\n--- D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\data\\session\\login_preferences_service.cj\n+++ D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\data\\session\\login_preferences_service.cj\n@@ -26,12 +26,24 @@\n             case _ => false\n         }\n     }\n \n-    public func toggleLoginState(context: UIAbilityContext): Bool {\n+    public func writeLoginState(context: UIAbilityContext, isLoggedIn: Bool): Bool {\n         let preferences = Preferences.getPreferences(context, preferenceFileName())\n-        let nextState = nextLoginState(readLoginState(context))\n-        preferences.put(preferenceKey(), PreferencesValueType.BoolData(nextState))\n+        preferences.put(preferenceKey(), PreferencesValueType.BoolData(isLoggedIn))\n         preferences.flush()\n-        return nextState\n+        return isLoggedIn\n     }\n+\n+    public func toggleLoginState(context: UIAbilityContext): Bool {\n+        let nextState = nextLoginState(readLoginState(context))\n+        return writeLoginState(context, nextState)\n+    }\n+\n+    public func login(context: UIAbilityContext): Bool {\n+        return writeLoginState(context, true)\n+    }\n+\n+    public func logout(context: UIAbilityContext): Bool {\n+        return writeLoginState(context, false)\n+    }\n }\n","additions":