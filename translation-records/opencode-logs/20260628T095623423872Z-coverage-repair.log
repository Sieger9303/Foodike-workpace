ize(14)\n35:                 .fontColor(Color.Gray)\n36:             Text(\"Guwahati\")\n37:                 .fontSize(16)\n38:                 .fontWeight(FontWeight.Medium)\n39:         }\n40:     }\n41:     .width(100.percent)\n42:     .justifyContent(FlexAlign.SpaceBetween)\n43:     .alignItems(VerticalAlign.Center)\n44: }\n45: \n46: @Builder\n47: func buildHomeGreeting(hour: Int64) {\n48:     Column(space: 2) {\n49:         Text(homeStore.greetingForHour(hour))\n50:             .fontSize(28)\n51:             .fontWeight(FontWeight.Regular)\n52:         Text(\"Andrew\")\n53:             .fontSize(28)\n54:             .fontWeight(FontWeight.Regular)\n55:     }\n56:     .width(100.percent)\n57: }\n58: \n59: @Builder\n60: func buildHomeSectionTitle(title: ResourceStr) {\n61:     Text(title)\n62:         .fontSize(20)\n63:         .fontWeight(FontWeight.Regular)\n64:         .width(100.percent)\n65: }\n66: \n67: @Builder\n68: func buildHomeAdCards(advertisements: ArrayList<AdvertisementData>) {\n69:     Scroll(Scroller()) {\n70:         Row(space: 12) {\n71:             ForEach(advertisements, itemGeneratorFunc: { advertisement: AdvertisementData, _: Int64 =>\n72:                 Row(space: 12) {\n73:                     Column(space: 8) {\n74:                         Text(advertisement.title)\n75:                             .fontSize(22)\n76:                             .fontWeight(FontWeight.Bold)\n77:                         Text(advertisement.subtitle)\n78:                             .fontSize(13)\n79:                     }\n80:                     .layoutWeight(1)\n81:                     Image(homeMedia(advertisement.mediaName))\n82:                         .width(92)\n83:                         .height(92)\n84:                 }\n85:                 .width(260)\n86:                 .padding(top: 16, right: 16, bottom: 16, left: 16)\n87:                 .backgroundColor(0xFFF4F4F4)\n88:                 .borderRadius(20)\n89:             })\n90:         }\n91:     }\n92:     .scrollable(ScrollDirection.Horizontal)\n93:     .scrollBar(BarState.Off)\n94:     .width(100.percent)\n95:     .height(140)\n96: }\n97: \n98: @Builder\n99: func buildRecommendedCategories(categories: ArrayList<FoodCategoryData>) {\n100:     Scroll(Scroller()) {\n101:         Row(space: 16) {\n102:             ForEach(categories, itemGeneratorFunc: { category: FoodCategoryData, _: Int64 =>\n103:                 Column(space: 8) {\n104:                     Image(restaurantMedia(category.mediaName))\n105:                         .width(80)\n106:                         .height(80)\n107:                         .borderRadius(40)\n108:                     Text(category.name)\n109:                         .fontSize(14)\n110:                 }\n111:                 .alignItems(HorizontalAlign.Center)\n112:             })\n113:         }\n114:     }\n115:     .scrollable(ScrollDirection.Horizontal)\n116:     .scrollBar(BarState.Off)\n117:     .width(100.percent)\n118:     .height(120)\n119: }\n120: \n121: @Builder\n122: func buildFavouriteStrip(favourites: ArrayList<RestaurantData>, onSelectRestaurant: (RestaurantData) -> Unit) {\n123:     if (favourites.size > 0) {\n124:         Column(space: 10) {\n125:             buildHomeSectionTitle(stringOrderFromFavourites)\n126:             Scroll(Scroller()) {\n127:                 Row(space: 12) {\n128:                     ForEach(favourites, itemGeneratorFunc: { restaurant: RestaurantData, _: Int64 =>\n129:                         Column(space: 8) {\n130:                             Image(restaurantMedia(restaurant.mediaName))\n131:                                 .width(98)\n132:                                 .height(128)\n133:                                 .borderRadius(12)\n134:                             Text(restaurant.name)\n135:                                 .fontSize(14)\n136:                         }\n137:                         .width(110)\n138:                         .alignItems(HorizontalAlign.Center)\n139:                         .onClick({ _ =>\n140:                             onSelectRestaurant(restaurant)\n141:                         })\n142:                     })\n143:                 }\n144:             }\n145:             .scrollable(ScrollDirection.Horizontal)\n146:             .scrollBar(BarState.Off)\n147:             .width(100.percent)\n148:             .height(170)\n149:         }\n150:     }\n151: }\n152: \n153: @Builder\n154: func buildFilterRow(selectedFilter: String, onToggleFilter: (String) -> Unit) {\n155:     Scroll(Scroller()) {\n156:         Row(space: 8) {\n157:             ForEach(homeStore.filtersList(), itemGeneratorFunc: { filterName: String, _: Int64 =>\n158:                 Text(filterName)\n159:                     .fontSize(14)\n160:                     .fontColor(if (selectedFilter == filterName) { Color.White } else { Color.Black })\n161:                     .padding(top: 8, right: 12, bottom: 8, left: 12)\n162:                     .backgroundColor(if (selectedFilter == filterName) { 0xFF228D39 } else { Color.White })\n163:                     .borderRadius(16)\n164:                     .border(width: 1.px, color: 0x55000000)\n165:                     .onClick({ _ =>\n166:                         onToggleFilter(filterName)\n167:                     })\n168:             })\n169:         }\n170:     }\n171:     .scrollable(ScrollDirection.Horizontal)\n172:     .scrollBar(BarState.Off)\n173:     .width(100.percent)\n174:     .height(48)\n175: }\n176: \n177: @Builder\n178: func buildRestaurantList(restaurants: ArrayList<RestaurantData>, onSelectRestaurant: (RestaurantData) -> Unit) {\n179:     Column(space: 10) {\n180:         ForEach(restaurants, itemGeneratorFunc: { restaurant: RestaurantData, _: Int64 =>\n181:             renderRestaurantCard(restaurant, { =>\n182:                 onSelectRestaurant(restaurant)\n183:             })\n184:         })\n185:     }\n186:     .width(100.percent)\n187: }\n188: \n189: @Builder\n190: func buildHomeFooter() {\n191:     Row(space: 6) {\n192:         Text(stringWith)\n193:             .fontSize(24)\n194:             .fontColor(Color.Gray)\n195:         Text(stringLove)\n196:             .fontSize(24)\n197:             .fontColor(Color.Red)\n198:         Text(stringFromCreator)\n199:             .fontSize(24)\n200:             .fontColor(Color.Gray)\n201:     }\n202:     .width(100.percent)\n203:     .justifyContent(FlexAlign.Center)\n204: }\n205: \n206: @Builder\n207: public func renderHomeRoute(\n208:     state: HomePageState,\n209:     hour: Int64,\n210:     query: String,\n211:     selectedFilter: String,\n212:     onQueryChange: (String) -> Unit,\n213:     onToggleFilter: (String) -> Unit,\n214:     onProfileClick: () -> Unit,\n215:     onSelectRestaurant: (RestaurantData) -> Unit\n216: ) {\n217:     Scroll(Scroller()) {\n218:         Column(space: 18) {\n219:             buildHomeTopSection(onProfileClick)\n220:             buildHomeGreeting(hour)\n221:             renderSearchBar(query, onQueryChange)\n222:             buildHomeAdCards(state.advertisements)\n223:             buildHomeSectionTitle(stringRecommendedForYou)\n224:             buildRecommendedCategories(state.categories)\n225:             buildFavouriteStrip(state.favourites, onSelectRestaurant)\n226:             buildFilterRow(selectedFilter, onToggleFilter)\n227:             buildHomeSectionTitle(stringAllAroundYou)\n228:             buildRestaurantList(state.restaurants, onSelectRestaurant)\n229:             buildHomeFooter()\n230:         }\n231:         .width(100.percent)\n232:         .padding(top: 12, right: 16, bottom: 24, left: 16)\n233:     }\n234:     .scrollable(ScrollDirection.Vertical)\n235:     .scrollBar(BarState.Off)\n236:     .width(100.percent)\n237:     .height(100.percent)\n238:     .backgroundColor(Color.White)\n239: }\n\n(End of file - total 239 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.featu