State {\n40:         return HomePageState(\n41:             loadAdvertisements(),\n42:             loadRecommendedCategories(),\n43:             loadFavouriteRestaurants(),\n44:             loadRestaurantCatalog()\n45:         )\n46:     }\n47: \n48:     public func buildVisibleState(query: String): HomePageState {\n49:         let state = loadHomeState()\n50:         if (query == \"\") {\n51:             return state\n52:         }\n53:         return HomePageState(\n54:             state.advertisements,\n55:             state.categories,\n56:             filterRestaurants(state.favourites, query),\n57:             filterRestaurants(state.restaurants, query)\n58:         )\n59:     }\n60: \n61:     public func buildFilteredState(query: String, selectedFilter: String): HomePageState {\n62:         let state = buildVisibleState(query)\n63:         if (selectedFilter == \"\") {\n64:             return state\n65:         }\n66:         return HomePageState(\n67:             state.advertisements,\n68:             state.categories,\n69:             filterByTag(state.favourites, selectedFilter),\n70:             filterByTag(state.restaurants, selectedFilter)\n71:         )\n72:     }\n73: \n74:     public func filtersList(): ArrayList<String> {\n75:         return filters\n76:     }\n77: \n78:     public func toggleFilter(currentFilter: String, tappedFilter: String): String {\n79:         if (currentFilter == tappedFilter) {\n80:             return \"\"\n81:         }\n82:         return tappedFilter\n83:     }\n84: \n85:     public func greetingForHour(hour: Int64): String {\n86:         if (hour >= 0 && hour <= 11) {\n87:             return \"Good Morning!\"\n88:         }\n89:         if (hour >= 12 && hour <= 15) {\n90:             return \"Good Afternoon!\"\n91:         }\n92:         return \"Good Evening!\"\n93:     }\n94: \n95:     public func selectRestaurant(restaurant: RestaurantData, onNavigate: () -> Unit): Unit {\n96:         sessionRepository.setSelectedRestaurant(restaurant)\n97:         onNavigate()\n98:     }\n99: \n100:     private func filterRestaurants(restaurants: ArrayList<RestaurantData>, query: String): ArrayList<RestaurantData> {\n101:         let filtered = ArrayList<RestaurantData>([])\n102:         for (restaurant in restaurants) {\n103:             if (matchesQuery(restaurant, query)) {\n104:                 filtered.add(restaurant)\n105:             }\n106:         }\n107:         return filtered\n108:     }\n109: \n110:     public func filterByTag(restaurants: ArrayList<RestaurantData>, tag: String): ArrayList<RestaurantData> {\n111:         let filtered = ArrayList<RestaurantData>([])\n112:         for (restaurant in restaurants) {\n113:             if (matchesTag(restaurant, tag)) {\n114:                 filtered.add(restaurant)\n115:             }\n116:         }\n117:         return filtered\n118:     }\n119: \n120:     private func matchesQuery(restaurant: RestaurantData, query: String): Bool {\n121:         return containsIgnoreCase(restaurant.name, query)\n122:             || containsIgnoreCase(restaurant.variety, query)\n123:             || containsIgnoreCase(restaurant.place, query)\n124:     }\n125: \n126:     public func matchesTag(restaurant: RestaurantData, tag: String): Bool {\n127:         match (tag) {\n128:             case \"Fast Delivery\" => restaurant.etaMinutes <= 30\n129:             case \"50% Discount\" => restaurant.averagePrice <= 2.5\n130:             case \"Great deals\" => restaurant.rating >= 4.5\n131:             case \"Non-Veg\" => !containsIgnoreCase(restaurant.variety, \"Vegetarian\")\n132:             case _ => true\n133:         }\n134:     }\n135: \n136:     public func containsIgnoreCase(source: String, query: String): Bool {\n137:         let normalizedSource = source.toLower()\n138:         let normalizedQuery = query.toLower()\n139:         let sourceLength = normalizedSource.size\n140:         let queryLength = normalizedQuery.size\n141:         if (queryLength == 0) {\n142:             return true\n143:         }\n144:         if (queryLength > sourceLength) {\n145:             return false\n146:         }\n147:         var start: Int64 = 0\n148:         while (start + queryLength <= sourceLength) {\n149:             if (normalizedSource[start..(start + queryLength)] == normalizedQuery) {\n150:                 return true\n151:             }\n152:             start += 1\n153:         }\n154:         return false\n155:     }\n156: \n157:     public func session(): SessionRepository {\n158:         return sessionRepository\n159:     }\n160: }\n\n(End of file - total 160 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.content.homeContentRepository\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\nimport std.unicode.*\n\npublic let homeStore = HomeStore()\n\npublic class HomeStore {\n    private let contentRepository = homeContentRepository\n    private let sessionRepository = sessionRepository\n    private let filters = ArrayList<String>([\n        \"Fast Delivery\",\n        \"50% Discount\",\n        \"Great deals\",\n        \"Non-Veg\"\n    ])\n","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\home\\home_store.cj","time":{"start":1782640654980,"end":1782640654986}},"id":"prt_f0da9ba72002vF3O6D670ugZBZ","sessionID":"ses_0f2575765ffenKx6OV3TM4M7aL","messageID":"msg_f0da96f3c00158VSjmiDzqLH4m"}}
