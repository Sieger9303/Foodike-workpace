targetFallback\",\n150:     \"futureCompletionPath\",\n151:     \"notes\",\n152: }\n153: PLATFORM_UPDATE_FIELDS = PLATFORM_LIST_FIELDS | PLATFORM_TEXT_FIELDS | PLATFORM_OBJECT_FIELDS\n154: PLATFORM_ADD_FIELDS = PLATFORM_UPDATE_FIELDS | {\n155:     \"capabilityId\",\n156:     \"capabilityName\",\n157:     \"importance\",\n158:     \"sourcePaths\",\n159:     \"sourceEvidence\",\n160:     \"sourceEvidenceSummary\",\n161:     \"requiredTargetCapabilitySearch\",\n162:     \"targetStrategyHint\",\n163:     \"minimumParity\",\n164:     \"requiredTests\",\n165:     \"allowedDeferredReasons\",\n166: }\n167: PLATFORM_ADD_REQUIRED_FIELDS = {\"capabilityId\", \"capabilityName\", \"importance\", \"sourceEvidenceSummary\"}\n168: \n169: \n170: class PatchError(ValueError):\n171:     \"\"\"Raised for user-facing patch validation errors.\"\"\"\n172: \n173: \n174: @dataclass(frozen=True)\n175: class PatchContext:\n176:     target_project: Path | None = None\n177:     legal_phases: frozenset[str] | None = None\n178:     allow_missing_endpoints: bool = False\n179:     allow_unknown_phase: bool = False\n180: \n181: \n182: def parse_args() -> argparse.Namespace:\n183:     parser = argparse.ArgumentParser(\n184:         description=(\n185:             \"Apply a strict JSON patch payload to source-coverage-matrix.json or \"\n186:             \"platform-capability-check.json and optionally sync the Markdown view.\"\n187:         ),\n188:         formatter_class=HelpFormatter,\n189:     )\n190:     parser.add_argument(\n191:         \"--kind\",\n192:         choices=(\"auto\", \"matrix\", \"platform\"),\n193:         default=\"auto\",\n194:         help=\"Authority type. auto infers from the authority filename.\",\n195:     )\n196:     parser.add_argument(\"--authority\", required=True, help=\"Authority JSON path to patch.\")\n197:     parser.add_argument(\n198:         \"--patch\",\n199:         default=\"\",\n200:         help=\"Strict JSON patch payload. Omit with --validate-only to just validate the authority.\",\n201:     )\n202:     parser.add_argument(\"--validate-only\", action=\"store_true\", help=\"Validate the authority without applying a patch.\")\n203:     parser.add_argument(\"--dry-run\", action=\"store_true\", help=\"Validate and summarize without writing files.\")\n204:     parser.add_argument(\n205:         \"--markdown\",\n206:         default=\"\",\n207:         help=\"Markdown mirror path. Defaults to the authority path with .md suffix.\",\n208:     )\n209:     parser.add_argument(\"--no-markdown\", action=\"store_true\", help=\"Do not sync the Markdown mirror.\")\n210:     parser.add_argument(\"--summary-json\", default=\"\", help=\"Optional path for a machine-readable patch summary.\")\n211:     parser.add_argument(\n212:         \"--max-markdown-files\",\n213:         type=int,\n214:         default=250,\n215:         help=\"Maximum rows rendered in the Markdown mirror.\",\n216:     )\n217:     parser.add_argument(\n218:         \"--target-project\",\n219:         default=\"\",\n220:         help=(\n221:             \"Optional target project root. When set, targetEndpoints touched by this patch must point \"\n222:             \"to existing target files, with optional ::symbol checks.\"\n223:         ),\n224:     )\n225:     parser.add_argument(\n226:         \"--plan-json\",\n227:         default=\"\",\n228:         help=\"Optional strict plan.json. When set, plannedPhase values touched by this patch must exist in phases[].\",\n229:     )\n230:     parser.add_argument(\n231:         \"--allow-missing-endpoints\",\n232:         action=\"store_true\",\n233:         help=\"Skip targetEndpoints filesystem/symbol validation even when --target-project is set.\",\n234:     )\n235:     parser.add_argument(\n236:         \"--allow-unknown-phase\",\n237:         action=\"store_true\",\n238:         help=\"Skip plannedPhase validation even when --plan-json is set.\",\n239:     )\n240:     return parser.parse_args()\n241: \n242: \n243: def 