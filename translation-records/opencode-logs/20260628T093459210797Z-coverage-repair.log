ute: String = bootstrapStartRoute\n25: \n26:     @State\n27:     var isShellAtTop: Bool = true\n28: \n29:     @State\n30:     var onboardingPageIndex: Int64 = 0\n31: \n32:     @State\n33:     var loginEmail: String = \"\"\n34: \n35:     @State\n36:     var loginPassword: String = \"\"\n37: \n38:     @State\n39:     var loginErrorMessage: String = \"\"\n40: \n41:     @State\n42:     var homeSearchQuery: String = \"\"\n43: \n44:     @State\n45:     var homeSelectedFilter: String = \"\"\n46: \n47:     @State\n48:     var historySearchQuery: String = \"\"\n49: \n50:     @State\n51:     var historyTabIndex: Int64 = 0\n52: \n53:     @State\n54:     var previousRoute: String = \"home_screen\"\n55: \n56:     @State\n57:     var cartNote: String = \"\"\n58: \n59:     @State\n60:     var cartCoupon: String = \"\"\n61: \n62:     @State\n63:     var cartMutationRevision: Int64 = 0\n64: \n65:     @State\n66:     var detailRecommendedExpanded: Bool = true\n67: \n68:     @State\n69:     var detailNonVegExpanded: Bool = true\n70: \n71:     @State\n72:     var detailVegExpanded: Bool = true\n73: \n74:     @State\n75:     var detailLiked: Bool = false\n76: \n77:     @State\n78:     var detailMutationRevision: Int64 = 0\n79: \n80:     private var onboardingController: SwiperController = SwiperController()\n81: \n82:     private func applyShellState(shellState: ShellRouteState): Unit {\n83:         this.currentRoute = shellState.currentRoute\n84:         this.isShellAtTop = shellState.isAtTop\n85:     }\n86: \n87:     private func shellState(): ShellRouteState {\n88:         ShellRouteState(this.currentRoute, this.isShellAtTop)\n89:     }\n90: \n91:     private func applyShellCommand(command: ShellCommand): Unit {\n92:         let shellState = this.shellState()\n93:         shellState.applyCommand(command)\n94:         this.applyShellState(shellState)\n95:     }\n96: \n97:     private func navigateTo(route: String): Unit {\n98:         let shellState = this.shellState()\n99:         this.previousRoute = shellState.currentRoute\n100:         shellState.currentRoute = route\n101:         shellState.isAtTop = true\n102:         this.applyShellState(shellState)\n103:     }\n104: \n105:     private func navigateBack(): Unit {\n106:         let targetRoute = this.previousRoute\n107:         this.previousRoute = this.currentRoute\n108:         this.navigateTo(targetRoute)\n109:     }\n110: \n111:     private func showBottomShell(route: String): Bool {\n112:         let shellState = this.shellState()\n113:         shellState.currentRoute = route\n114:         return shellState.showBottomShell()\n115:     }\n116: \n117:     private func routeTitle(route: String): ResourceStr {\n118:         routeLabelByPath(route)\n119:     }\n120: \n121:     private func showToast(message: String): Unit {\n122:         getUIContext().getPromptAction().showToast(ShowToastOptions(message: message))\n123:     }\n124: \n125:     private func clearLoginError(): Unit {\n126:         this.loginErrorMessage = \"\"\n127:     }\n128: \n129:     private func performLogin(): Unit {\n130:         if (loginStore.login(Global.abilityContext, this.loginEmail, this.loginPassword)) {\n131:             this.clearLoginError()\n132:             this.navigateTo(loginStore.successRoute())\n133:             return\n134:         }\n135: \n136:         this.loginErrorMessage = loginStore.invalidLoginMessage\n137:         this.showToast(loginStore.invalidLoginMessage)\n138:     }\n139: \n140:     private func performLogout(): Unit {\n141:         profileStore.logout(Global.abilityContext)\n142:         this.loginEmail = \"\"\n143:         this.loginPassword = \"\"\n144:         this.clearLoginError()\n145:         this.onboardingPageIndex = 0\n146:         this.homeSearchQuery = \"\"\n147:         this.homeSelectedFilter = \"\"\n148:         this.historySearchQuery = \"\"\n149:         this.historyTabIndex = 0\n150:         this.navigateTo(profileStore.logoutRoute())\n151:     }\n152: \n153:     private func routeSummary(route: String): String {\n154:         match (route) {\n155:             case \"home_screen\" => \"Home now renders repository-backed discovery content, local search/filter controls, and restaurant selection before detail routing.\"\n156:             case \"history\" => \"History now preserves search plus tab-local content, reuses favourite restaurants, and saves the selected restaurant before navigation.\"\n157:             case \"cart\" => \"Cart now renders snapshot-backed items, a local note editor, a local coupon field, delivery details, and bill totals without adding new checkout persistence flows.\"\n158:             case \"restaurant_details\" => \"Restaurant detail now reads the selected restaurant, preserves local section expansion and like state, keeps menu quantity controls local to the route, and shows the cart action only when selected quantities are non-zero.\"\n159:             case _ => \"\"\n160:         }\n161:     }\n162: \n163:     private func homeHour(): Int64 {\n164:         return 9\n165:     }\n166: \n167:     private func goToProfile(): Unit {\n168:         this.navigateTo(routePath(RouteId.Profile))\n169:     }\n170: \n171:     private func goToRestaurantDetail(): Unit {\n172:         this.detailRecommendedExpanded = true\n173:         this.detailNonVegExpanded = true\n174:         this.detailVegExpanded = true\n175:         this.detailLiked = detailStore.session().isRestaurantLiked(detailStore.selectedRestaurant())\n176:         this.detailMutationRevision = 0\n177:         this.navigateTo(routePath(RouteId.RestaurantDetails))\n178:     }\n179: \n180:     private func detailState(): DetailPageState {\n181:         return detailStore.loadDetailState(\n182:             this.detailRecommendedExpanded,\n183:             this.detailNonVegExpanded,\n184:             this.detailVegExpanded\n185:         )\n186:     }\n187: \n188:     private func selectHomeRestaurant(restaurant: RestaurantData): Unit {\n189:         homeStore.selectRestaurant(restaurant, { =>\n190:             this.goToRestaurantDetail()\n191:         })\n192:     }\n193: \n194:     private func selectHistoryRestaurant(restaurant: RestaurantData): Unit {\n195:         historyStore.selectRestaurant(restaurant, { =>\n196:             this.goToRestaurantDetail()\n197:         })\n198:     }\n199: \n200:     @Builder\n201:     private func buildOnboardingRoute() {\n202:         renderOnboardingRoute(\n203:             this.onboardingPageIndex,\n204:             this.onboardingController,\n205:             { index: Int32 =>\n206:                 this.onboardingPageIndex = Int64(index)\n207:             },\n208:             { =>\n209:                 if (onboardingStore.isLastPage(this.onboardingPageIndex)) {\n210:                     this.navigateTo(routePath(RouteId.Login))\n211:                 } else {\n212:                     this.onboardingController.showNext()\n213:                 }\n214:             }\n215:         )\n216:     }\n217: \n218:     @Builder\n219:     private func buildLoginRoute() {\n220:         renderLoginRoute(\n221:             this.loginEmail,\n222:             this.loginPassword,\n223:             this.loginErrorMessage,\n224:             { value: String =>\n225:                 this.loginEmail = value\n226:                 this.clearLoginError()\n227:             },\n228:             { value: String =>\n229:                 this.loginPassword = value\n230:                 this.clearLoginError()\n231:             },\n232:             { => this.showToast(loginStore.comingSoonMessage) },\n233:             { => this.performLogin() },\n234:             { => this.showToast(loginStore.comingSoonMessage) },\n235:             { => this.showToast(loginStore.comingSoonMessage) },\n236:             { => this.showToast(loginStore.comingSoonMessage) },\n237:             { => this.clearLoginError() }\n238:         )\n239:     }\n240: \n241:     @Builder\n242:     private func buildProfileRoute() {\n243:         renderProfileRoute(\n244:             profileStore.userName,\n245:             profileStore.userEmail,\n246:             { => this.navigateTo(profileStore.backRoute()) },\n247:             { => this.showToast(profileStore.placeholderActionMessage) },\n248:             { => this.showToast(profileStore.placeholderActionMessage) },\n249:             { => this.performLogout() }\n250:         )\n251:     }\n252: \n253:     @Builder\n254:     private func buildHomeRoute() {\n255:         renderHomeRoute(\n256:             homeStore.buildFilteredState(this.homeSearchQuery, this.homeSelectedFilter),\n257:             this.homeHour(),\n258:             this.homeSearchQuery,\n259:             this.homeSelectedFilter,\n260:             { value: String =>\n261:                 this.homeSearchQuery = value\n262:             },\n263:             { value: String =>\n264:                 this.homeSelectedFilter = homeStore.toggleFilter(this.homeSelectedFilter, value)\n265:             },\n266:             { => this.goToProfile() },\n267:             { restaurant: RestaurantData =>\n268:                 this.selectHomeRestaurant(restaurant)\n269:             }\n270:         )\n271:     }\n272: \n273:     @Builder\n274:     private func buildHistoryRoute() {\n275:         renderHistoryRoute(\n276:             historyStore.buildVisibleState(this.historySearchQuery),\n277:             this.historyTabIndex,\n278:             this.historySearchQuery,\n279:             { value: String =>\n280:                 this.historySearchQuery = value\n281:             },\n282:             { value: Int64 =>\n283:                 this.historyTabIndex = value\n284:             },\n285:             { restaurant: RestaurantData =>\n286:                 this.selectHistoryRestaurant(restaurant)\n287:             }\n288:         )\n289:     }\n290: \n291:     @Builder\n292:     private func buildCartRoute() {\n293:         renderCartRoute(\n294:             cartStore.loadCartState(),\n295:         