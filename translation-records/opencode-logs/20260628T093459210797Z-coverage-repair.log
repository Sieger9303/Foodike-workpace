{"type":"tool_use","timestamp":1782639335737,"sessionID":"ses_0f26aef26ffePG2GvaQeSuibPl","part":{"type":"tool","tool":"read","callID":"call_2Vh3qIyZ8vIiq6sZoxnqrDTd","state":{"status":"completed","input":{"filePath":"D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_store.cj","limit":320,"offset":1},"output":"<path>D:\\workspace\\Foodike\\Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_store.cj</path>\n<type>file</type>\n<content>\n1: package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history\n2: \n3: import ohos.base.ResourceStr\n4: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{stringFavourite, stringHistory}\n5: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\n6: import ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\n7: import std.collection.ArrayList\n8: import std.unicode.*\n9: \n10: public let historyStore = HistoryStore()\n11: \n12: public class HistoryStore {\n13:     private let sessionRepository = sessionRepository\n14:     private let orderHistory = ArrayList<HistoryRecordData>([\n15:         HistoryRecordData(\"Fish n Rolls\", \"Tezpur\", \"13 Aug 2022, 11:12 PM\", \"$7.90\", \"Chinese Shawarma\\nCombo (1)\", false, 5, 5, \"Delivered\", \"Reorder\"),\n16:         HistoryRecordData(\"Fish n Rolls\", \"Tezpur\", \"13 Aug 2022, 11:12 PM\", \"$7.90\", \"Chinese Shawarma\\nCombo (1)\", false, 0, 0, \"Delivered\", \"Rate Order\")\n17:     ])\n18: \n19:     public init() {}\n20: \n21:     public func loadHistoryState(): HistoryPageState {\n22:         return HistoryPageState(sessionRepository.getLikedRestaurants(), orderHistory)\n23:     }\n24: \n25:     public func buildVisibleState(query: String): HistoryPageState {\n26:         let state = loadHistoryState()\n27:         if (query == \"\") {\n28:             return state\n29:         }\n30:         return HistoryPageState(filterFavourites(state.favourites, query), state.records)\n31:     }\n32: \n33:     public func tabLabel(index: Int64): ResourceStr {\n34:         if (index == 0) {\n35:             return stringHistory\n36:         }\n37:         return stringFavourite\n38:     }\n39: \n40:     public func tabLabelText(index: Int64): String {\n41:         if (index == 0) {\n42:             return \"History\"\n43:         }\n44:         return \"Favourites\"\n45:     }\n46: \n47:     public func selectRestaurant(restaurant: RestaurantData, onNavigate: () -> Unit): Unit {\n48:         sessionRepository.setSelectedRestaurant(restaurant)\n49:         onNavigate()\n50:     }\n51: \n52:     private func filterFavourites(favourites: ArrayList<RestaurantData>, query: String): ArrayList<RestaurantData> {\n53:         let filtered = ArrayList<RestaurantData>([])\n54:         for (restaurant in favourites) {\n55:             if (matchesQuery(restaurant, query)) {\n56:                 filtered.add(restaurant)\n57:             }\n58:         }\n59:         return filtered\n60:     }\n61: \n62:     private func matchesQuery(restaurant: RestaurantData, query: String): Bool {\n63:         return containsIgnoreCase(restaurant.name, query)\n64:             || containsIgnoreCase(restaurant.variety, query)\n65:             || containsIgnoreCase(restaurant.place, query)\n66:     }\n67: \n68:     public func containsIgnoreCase(source: String, query: String): Bool {\n69:         let normalizedSource = source.toLower()\n70:         let normalizedQuery = query.toLower()\n71:         let sourceLength = normalizedSource.size\n72:         let queryLength = normalizedQuery.size\n73:         if (queryLength == 0) {\n74:             return true\n75:         }\n76:         if (queryLength > sourceLength) {\n77:             return false\n78:         }\n79:         var start: Int64 = 0\n80:         while (start + queryLength <= sourceLength) {\n81:             if (normalizedSource[start..(start + queryLength)] == normalizedQuery) {\n82:                 return true\n83:             }\n84:             start += 1\n85:         }\n86:         return false\n87:     }\n88: \n89:     public func session(): SessionRepository {\n90:         return sessionRepository\n91:     }\n92: }\n\n(End of file - total 92 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history\n\nimport ohos.base.ResourceStr\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{stringFavourite, stringHistory}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.data.session.{SessionRepository, sessionRepository}\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.domain.*\nimport std.collection.ArrayList\nimport std.unicode.*\n\npublic let historyStore = HistoryStore()\n\npublic class HistoryStore {\n    private let sessionRepository = sessionRepository\n    private let orderHistory = ArrayList<HistoryRecordData>([\n        HistoryRecordData(\"Fish n Rolls\", \"Tezpur\", \"13 Aug 2022, 11:12 PM\", \"$7.90\", \"Chinese Shawarma\\nCombo (1)\", false, 5, 5, \"Delivered\", \"Reorder\"),\n        HistoryRecordData(\"Fish n Rolls\", \"Tezpur\", \"13 Aug 2022, 11:12 PM\", \"$7.90\", \"Chinese Shawarma\\nCombo (1)\", false, 0, 0, \"Delivered\", \"Rate Order\")\n    ])\n\n    public init() {}\n","truncated":false,"loaded":[]},"title":"Foodike-Harmony\\entry\\src\\main\\cangjie\\ohos_app_cangjie_entry\\features\\history\\history_store.cj","time":{"start":1782639335721,"end":1782639335737}},"id":"prt_f0d9599280017TIJUjlSjoBPZ4","sessionID":"ses_0f26aef26ffePG2GvaQeSuibPl","messageID":"msg_f0d9557ac0015wS0jcGyLwBBwX"}}
