ble-state-viewmodel-flow-livedata\",\n71:         \"app-src-main-java-com-example-foodike-presentation-histo-0df0da2994-003-screen-lifecycle-entry-point-initializat\"\n72:       ],\n73:       \"resourceInputs\": [],\n74:       \"platformCapabilityIds\": [],\n75:       \"expectedTargetDomains\": [\n76:         \"ohos_app_cangjie_entry/app/bootstrap_page.cj\",\n77:         \"ohos_app_cangjie_entry/features/home/home_store.cj\",\n78:         \"ohos_app_cangjie_entry/common/widgets/search_bar.cj\",\n79:         \"ohos_app_cangjie_entry/features/history/history_store.cj\",\n80:         \"ohos_app_cangjie_entry/features/home/home_page.cj\"\n81:       ],\n82:       \"requiredBehaviors\": [\n83:         \"`buildHomeRoute` refreshes the repository-backed home state on each route render so the feed sections reflect current liked/search/filter state whenever the route is entered or updated.\",\n84:         \"`FoodikeBootstrap` stores home query/filter route state and `HomeStore.buildFilteredState(...)` rebuilds ads, categories, favourites, and restaurants from current repositories on each render.\",\n85:         \"`HomeStore` mirrors the state aggregation without any permission flow.\",\n86:         \"`buildHomeRoute` recomputes `HomeStore.buildFilteredState(...)` from repository data when the home route renders, preserving entry-time feed loading.\",\n87:         \"`HomeStore.loadHomeState()` and `buildFilteredState(...)` aggregate repository-backed ads, categories, restaurants, and liked restaurants into the current home route state.\",\n88:         \"`renderSearchBar` and `usesLocalSearchState()` keep only route-local query state without any preference persistence.\",\n89:         \"`renderSearchBar` feeds route-level query state into `HomeStore.buildFilteredState(...)` and `HistoryStore.buildVisibleState(...)`, enabling immediate home/history filtering from the shared search surface.\",\n90:         \"`buildHistoryRoute` reloads `HistoryStore.buildVisibleState(...)` on each route render so the current liked-restaurant state is reflected whenever the page is entered or updated.\",\n91:         \"`HistoryStore` plus `FoodikeBootstrap` route state expose observable search/tab state and reload the repository-backed favourites list on each rebuild.\",\n92:         \"`bootstrap_page.cj` keeps `homeSelectedFilter` in route state, and `buildFilterRow` re-renders selected styling while `HomeStore.buildFilteredState(...)` applies the active chip to visible lists.\",\n93:         \"`FoodikeBootstrap::buildHistoryRoute` binds current query/tab state and recomputes `HistoryStore.buildVisibleState(...)` whenever the history route is shown.\"\n94:       ],\n95:       \"acceptanceEvidence\": [\n96:         \"Replace broad endpoints with precise target functions, types, resources, or tests before closing the group.\"\n97:       ],\n98:       \"riskHints\": [\n99:         \"current evidence uses broad shell/root/whole-file endpoints\"\n100:       ],\n101:       \"matrixRows\": [\n102:         {\n103:           \"kind\": \"source-feature\",\n104:           \"featureId\": \"app-src-main-java-com-example-foodike-presentation-home-ef0657c4ea-005-screen-lifecycle-entry-point-initializat\",\n105:           \"featureName\": \"Screen lifecycle, entry point initialization, resume/pause refresh, or teardown behavior.\",\n106:           \"sourcePath\": \"app/src/main/java/com/example/foodike/presentation/home/HomeScreen.kt\",\n107:           \"importance\": \"critical\",\n108:           \"plannedPhase\": \"phase-04-home-history\",\n109:           \"status\": \"implemented\",\n110:           \"parityLevel\": \"equivalent\",\n111:           \"verdict\": \"complete\",\n112:           \"reasons\": [\n113:             \"implemented with behavior, parity, endpoint, and verification evidence\"\n114:           ],\n115:           \"targetEndpoints\": [\n116:             \"entry/src/main/cangjie/ohos_app_cangjie_entry/app/bootstrap_page.cj::buildHomeRoute\",\n117:        