\"george\")\n36:         @Assert(state.restaurants.size, 1)\n37:         @Assert(state.restaurants[0].name, \"George Street\")\n38:     }\n39: \n40:     @TestCase\n41:     public func homeStoreSelectionSavesRestaurantBeforeNavigation(): Unit {\n42:         let store = HomeStore()\n43:         let restaurant = store.loadHomeState().restaurants[0]\n44:         let events = ArrayList<String>([])\n45:         store.selectRestaurant(restaurant, { =>\n46:             events.add(store.session().getSelectedRestaurantName())\n47:             events.add(\"navigate\")\n48:         })\n49:         @Assert(events[0], restaurant.name)\n50:         @Assert(events[1], \"navigate\")\n51:     }\n52: \n53:     @TestCase\n54:     public func homeStoreKeepsSourceLocalFilterToggleSemantics(): Unit {\n55:         let store = HomeStore()\n56:         @Assert(store.toggleFilter(\"\", \"Fast Delivery\"), \"Fast Delivery\")\n57:         @Assert(store.toggleFilter(\"Fast Delivery\", \"Fast Delivery\"), \"\")\n58:         @Assert(store.toggleFilter(\"Fast Delivery\", \"Non-Veg\"), \"Non-Veg\")\n59:     }\n60: \n61:     @TestCase\n62:     public func homeStoreAppliesChipFilterToVisibleRestaurantLists(): Unit {\n63:         let store = HomeStore()\n64:         let state = store.buildFilteredState(\"\", \"Fast Delivery\")\n65:         @Assert(state.restaurants.size > 0, true)\n66:         @Assert(store.matchesTag(state.restaurants[0], \"Fast Delivery\"), true)\n67:     }\n68: \n69:     @TestCase\n70:     public func homeStorePreservesGreetingBuckets(): Unit {\n71:         let store = HomeStore()\n72:         @Assert(store.greetingForHour(9), \"Good Morning!\")\n73:         @Assert(store.greetingForHour(14), \"Good Afternoon!\")\n74:         @Assert(store.greetingForHour(19), \"Good Evening!\")\n75:     }\n76: \n77:     @TestCase\n78:     public func restaurantCardCustomerInfoMatchesSourceThresholdOrdering(): Unit {\n79:         @Assert(getCustomerInfo(51), \"50+\")\n80:         @Assert(getCustomerInfo(800), \"50+\")\n81:         @Assert(getCustomerInfo(12), \"1000+\")\n82:     }\n83: \n84:     @TestCase\n85:     public func historyStoreSelectionSavesRestaurantBeforeNavigation(): Unit {\n86:         let store = HistoryStore()\n87:         let restaurant = store.loadHistoryState().favourites[1]\n88:         let events = ArrayList<String>([])\n89:         store.selectRestaurant(restaurant, { =>\n90:             events.add(store.session().getSelectedRestaurantName())\n91:             events.add(\"navigate\")\n92:         })\n93:         @Assert(events[0], restaurant.name)\n94:         @Assert(events[1], \"navigate\")\n95:     }\n96: \n97:     @TestCase\n98:     public func historyStoreExposesSourceTabOrdering(): Unit {\n99:         let store = HistoryStore()\n100:         @Assert(store.tabLabelText(0), \"History\")\n101:         @Assert(store.tabLabelText(1), \"Favourites\")\n102:     }\n103: \n104:     @TestCase\n105:     public func historyStoreFiltersFavouriteRestaurantsFromSearchQuery(): Unit {\n106:         let store = HistoryStore()\n107:         let state = store.buildVisibleState(\"Mission\")\n108:         @Assert(state.favourites.size, 2)\n109:         @Assert(state.favourites[0].place, \"Mission Charali\")\n110:         @Assert(state.favourites[1].place, \"Mission Charali\")\n111:     }\n112: \n113:     @TestCase\n114:     public func historyStoreSearchIsCaseInsensitiveForLikedRestaurants(): Unit {\n115:         let store = HistoryStore()\n116:         let state = store.buildVisibleState(\"mission\")\n117:         @Assert(state.favourites.size, 2)\n118:         @Assert(state.favourites[0].place, \"Mission Charali\")\n119:     }\n120: }\n\n(End of file - total 120 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry_test\n\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.home.HomeStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.features.history.HistoryStore\nimport ohos_app_cangjie_entry.ohos_app_cangjie_ent