:         case RouteId.RestaurantDetails => stringRestaurant\n45:     }\n46: }\n47: \n48: public func routeLabelByPath(route: String): ResourceStr {\n49:     match (route) {\n50:         case \"onboarding\" => routeLabel(RouteId.Onboarding)\n51:         case \"login_screen\" => routeLabel(RouteId.Login)\n52:         case \"home_screen\" => routeLabel(RouteId.Home)\n53:         case \"history\" => routeLabel(RouteId.History)\n54:         case \"cart\" => routeLabel(RouteId.Cart)\n55:         case \"profile\" => routeLabel(RouteId.Profile)\n56:         case \"restaurant_details\" => routeLabel(RouteId.RestaurantDetails)\n57:         case _ => route\n58:     }\n59: }\n60: \n61: public func routeWithArgs(route: RouteId, args: ArrayList<String>): String {\n62:     var composedRoute = routePath(route)\n63:     for (arg in args) {\n64:         composedRoute = composedRoute + \"/\" + arg\n65:     }\n66:     return composedRoute\n67: }\n68: \n69: public func primaryActionTarget(route: String): String {\n70:     match (route) {\n71:         case \"onboarding\" => routePath(RouteId.Login)\n72:         case \"login_screen\" => routePath(RouteId.Home)\n73:         case \"home_screen\" => routePath(RouteId.RestaurantDetails)\n74:         case \"history\" => routePath(RouteId.Profile)\n75:         case \"cart\" => routePath(RouteId.Home)\n76:         case \"profile\" => routePath(RouteId.Onboarding)\n77:         case \"restaurant_details\" => routePath(RouteId.Home)\n78:         case _ => routePath(RouteId.Home)\n79:     }\n80: }\n81: \n82: public func primaryActionLabel(route: String): ResourceStr {\n83:     routeLabelByPath(primaryActionTarget(route))\n84: }\n\n(End of file - total 84 lines)\n</content>","metadata":{"preview":"package ohos_app_cangjie_entry.ohos_app_cangjie_entry.app\n\nimport ohos.base.ResourceStr\nimport ohos_app_cangjie_entry.ohos_app_cangjie_entry.common.{stringAppName, stringCart, stringHistory, stringHome, stringLogin, stringProfileTitle, stringRestaurant}